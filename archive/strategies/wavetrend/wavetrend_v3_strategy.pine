// ─── Strategy inputs (generated) ─────────────────────────────────────────────
g_strat       = "Strategy"
tradeDirInput = input.string("Both", "Trade Direction",
     options=["Both", "Long Only", "Short Only"], group=g_strat,
     tooltip="Filter entries by direction. Useful for asymmetric instruments.")
confirmClose  = input.bool(true,  "Entries on Confirmed Bar Only", group=g_strat,
     tooltip="Only trigger entries on closed bars. Prevents repainting in live trading.")
cooldownBars  = input.int(0,     "Cooldown Bars After Exit", minval=0, group=g_strat,
     tooltip="Block new entries for N bars after a position closes. Set 0 to disable.")
allowSignalReversal = input.bool(true, "Allow Same-Bar Signal Reversal", group=g_strat,
     tooltip="Allow a new opposite entry on the same bar when the current position also has an indicator exit. Same-direction conflicts are still resolved by context score.")
indicatorExitExecMode = input.string("1H Only", "Execute Indicator Exits",
     options=["All TF", "1H Only", "Off"], group=g_strat,
     tooltip="Controls whether indicator-managed exits are executed with strategy.close. test42 showed them useful on 1H but net-negative on 15m, 4H, and Daily.")
indicatorExitNeedsTargetOrStructure = input.bool(false, "Indicator Exits Need Target/Structure", group=g_strat,
     tooltip="Experimental. Only execute WT/GB/Opp/Time closes after the structural target was touched or opposite structure invalidates the trade. test49 showed this can worsen 1H Aggressive because indicator exits also act as damage control.")
oneHourExecutionMode = input.string("Bracket SL/TP", "1H Execution Mode",
     options=["Bracket SL/TP", "Stop + Signal Exit"], group=g_strat,
     tooltip="Concept test from test57/test58. Stop + Signal Exit keeps the protective stop but removes the fixed TP limit on 1H. test58 rejected it as a default because full-stop losses grew faster than signal-exit winners. 15m and 4H always keep bracket SL/TP.")
enableBE      = input.bool(true, "Break-Even Stop", group=g_strat,
     tooltip="Move SL to entry price once the trade is N×R in profit.")
beATRInput    = input.float(1.0,  "Break-Even Trigger (R×)", minval=0.1, step=0.1, group=g_strat,
     tooltip="R-multiple of the initial stop distance that triggers the break-even move. 1.0 = move SL to entry once 1R in profit.")

var int _lastExitBar = na
_justClosed = strategy.closedtrades > 0 and strategy.closedtrades.exit_bar_index(strategy.closedtrades - 1) == bar_index
if _justClosed
    _lastExitBar := bar_index
_inCooldown = cooldownBars > 0 and not na(_lastExitBar) and (bar_index - _lastExitBar) < cooldownBars
_canEntry   = not _inCooldown and (not confirmClose or barstate.isconfirmed)

// ─── Strategy execution (generated, directional fixed SL/TP) ─────────────────
_canLong  = tradeDirInput != "Short Only"
_canShort = tradeDirInput != "Long Only"

var float _longSL = na
var float _longTP = na
var float _shortSL = na
var float _shortTP = na
var float _longHighExec = na
var float _longLowExec = na
var float _shortLowExec = na
var float _shortHighExec = na
var float _longRiskExec = na
var float _shortRiskExec = na
var float _longTargetExec = na
var float _shortTargetExec = na
var float _longEntryScoreExec = na
var float _shortEntryScoreExec = na
var float _longTargetRoomRExec = na
var float _shortTargetRoomRExec = na
var float _longTargetRoomATRExec = na
var float _shortTargetRoomATRExec = na
var float _longFavPivotExec = na
var float _shortFavPivotExec = na
var float _longAdvPivotExec = na
var float _shortAdvPivotExec = na
var int _longEntryBarExec = na
var int _shortEntryBarExec = na
var int _longTargetBarExec = na
var int _shortTargetBarExec = na
var int _longFavPivotBarExec = na
var int _shortFavPivotBarExec = na
var int _longAdvPivotBarExec = na
var int _shortAdvPivotBarExec = na
var bool _longTargetHitExec = false
var bool _shortTargetHitExec = false
var bool _longBETriggered = false
var bool _shortBETriggered = false
var string _longFamilyExec = ''
var string _shortFamilyExec = ''
var string _longEntryStructExec = ''
var string _shortEntryStructExec = ''
var string _pendingLongFamilyExec = ''
var string _pendingShortFamilyExec = ''
var string _pendingLongStructExec = ''
var string _pendingShortStructExec = ''
var float _pendingLongScoreExec = na
var float _pendingShortScoreExec = na
var float _pendingLongTargetRoomRExec = na
var float _pendingShortTargetRoomRExec = na
var float _pendingLongTargetRoomATRExec = na
var float _pendingShortTargetRoomATRExec = na

_newLongExec = strategy.position_size > 0 and strategy.position_size[1] <= 0
_newShortExec = strategy.position_size < 0 and strategy.position_size[1] >= 0
_flatExec = strategy.position_size == 0

if strategy.closedtrades > _loggedClosedTrades
    for _ct = _loggedClosedTrades to strategy.closedtrades - 1
        _entryId = strategy.closedtrades.entry_id(_ct)
        _exitId = strategy.closedtrades.exit_id(_ct)
        _entryPx = strategy.closedtrades.entry_price(_ct)
        _exitPx = strategy.closedtrades.exit_price(_ct)
        _profit = strategy.closedtrades.profit(_ct)
        _barsHeldReal = strategy.closedtrades.exit_bar_index(_ct) - strategy.closedtrades.entry_bar_index(_ct)
        _realLong = _entryId == 'Long'
        _realDirVal = _realLong ? 'LONG' : 'SHORT'
        _realFam = _realLong ? _longFamilyExec : _shortFamilyExec
        _realRisk = _realLong ? _longRiskExec : _shortRiskExec
        _realR = not na(_realRisk) and _realRisk > 0 ? (_realLong ? (_exitPx - _entryPx) / _realRisk : (_entryPx - _exitPx) / _realRisk) : na
        _realHigh = _realLong ? math.max(nz(_longHighExec, high), high) : math.max(nz(_shortHighExec, high), high)
        _realLow = _realLong ? math.min(nz(_longLowExec, low), low) : math.min(nz(_shortLowExec, low), low)
        _realMfeR = not na(_realRisk) and _realRisk > 0 ? (_realLong ? (_realHigh - _entryPx) / _realRisk : (_entryPx - _realLow) / _realRisk) : na
        _realMaeR = not na(_realRisk) and _realRisk > 0 ? (_realLong ? (_entryPx - _realLow) / _realRisk : (_realHigh - _entryPx) / _realRisk) : na
        _realCapturePct = not na(_realMfeR) and _realMfeR > 0 ? _realR / _realMfeR * 100 : na
        _realTarget = _realLong ? _longTargetExec : _shortTargetExec
        _realTargetRoomR = _realLong ? _longTargetRoomRExec : _shortTargetRoomRExec
        _realTargetRoomATR = _realLong ? _longTargetRoomATRExec : _shortTargetRoomATRExec
        _realTargetTouchedByRange = not na(_realTarget) and (_realLong ? _realHigh >= _realTarget : _realLow <= _realTarget)
        _realTargetHit = (_realLong ? _longTargetHitExec : _shortTargetHitExec) or _realTargetTouchedByRange
        _realTargetBar = _realLong ? _longTargetBarExec : _shortTargetBarExec
        _realBarsToTarget = _realTargetHit ? (not na(_realTargetBar) ? _realTargetBar - strategy.closedtrades.entry_bar_index(_ct) : strategy.closedtrades.exit_bar_index(_ct) - strategy.closedtrades.entry_bar_index(_ct)) : na
        _realEntryScore = _realLong ? _longEntryScoreExec : _shortEntryScoreExec
        _realEntryStruct = _realLong ? _longEntryStructExec : _shortEntryStructExec
        _realFavPivot = _realLong ? _longFavPivotExec : _shortFavPivotExec
        _realAdvPivot = _realLong ? _longAdvPivotExec : _shortAdvPivotExec
        _realFavPivotR = not na(_realRisk) and _realRisk > 0 and not na(_realFavPivot) ? (_realLong ? (_realFavPivot - _entryPx) / _realRisk : (_entryPx - _realFavPivot) / _realRisk) : na
        _realAdvPivotR = not na(_realRisk) and _realRisk > 0 and not na(_realAdvPivot) ? (_realLong ? (_entryPx - _realAdvPivot) / _realRisk : (_realAdvPivot - _entryPx) / _realRisk) : na
        _realFavPivotBar = _realLong ? _longFavPivotBarExec : _shortFavPivotBarExec
        _realAdvPivotBar = _realLong ? _longAdvPivotBarExec : _shortAdvPivotBarExec
        _realBarsToFavPivot = not na(_realFavPivotBar) ? _realFavPivotBar - strategy.closedtrades.entry_bar_index(_ct) : na
        _realBarsToAdvPivot = not na(_realAdvPivotBar) ? _realAdvPivotBar - strategy.closedtrades.entry_bar_index(_ct) : na
        array.push(_realDir, _realDirVal)
        array.push(_realFamily, _realFam)
        array.push(_realExit, _exitId)
        array.push(_realProfit, _profit)
        array.push(_realExitR, _realR)
        array.push(_realBars, _barsHeldReal)
        if debugMode
            log.info(str.format('WT3 REAL EXIT | dir={0} | family={1} | exit={2} | trade={3} | barsHeld={4} | pnl={5} | R={6} | entry={7} | exitPx={8} | profile={9} | tf={10} | chartSec={11} | executionMode={12} | MFE={13} | MAE={14} | capturePct={15} | targetPx={16} | targetRoomR={17} | targetRoomATR={18} | targetHit={19} | barsToTarget={20} | favPivotPx={21} | favPivotR={22} | barsToFavPivot={23} | advPivotPx={24} | advPivotR={25} | barsToAdvPivot={26} | entryScore={27} | entryStruct={28}',
                 _realDirVal, _realFam, _exitId, str.tostring(_ct), str.tostring(_barsHeldReal),
                 str.tostring(_profit, '#.##'), str.tostring(_realR, '#.##'),
                 str.tostring(_entryPx, format.mintick), str.tostring(_exitPx, format.mintick), profileMode,
                 timeframe.period, str.tostring(_chartSec), oneHourExecutionMode,
                 str.tostring(_realMfeR, '#.##'), str.tostring(_realMaeR, '#.##'), str.tostring(_realCapturePct, '#.#'),
                 str.tostring(_realTarget, format.mintick), str.tostring(_realTargetRoomR, '#.##'), str.tostring(_realTargetRoomATR, '#.##'),
                 str.tostring(_realTargetHit), str.tostring(_realBarsToTarget),
                 str.tostring(_realFavPivot, format.mintick), str.tostring(_realFavPivotR, '#.##'), str.tostring(_realBarsToFavPivot),
                 str.tostring(_realAdvPivot, format.mintick), str.tostring(_realAdvPivotR, '#.##'), str.tostring(_realBarsToAdvPivot),
                 str.tostring(_realEntryScore, '#.#'), _realEntryStruct))
    _loggedClosedTrades := strategy.closedtrades

if _newLongExec
    _longHighExec := high
    _longLowExec := low
    _longFamilyExec := _pendingLongFamilyExec
    _longEntryStructExec := _pendingLongStructExec
    _longEntryScoreExec := _pendingLongScoreExec
    _longTargetRoomRExec := _pendingLongTargetRoomRExec
    _longTargetRoomATRExec := _pendingLongTargetRoomATRExec
    _longFavPivotExec := na
    _longAdvPivotExec := na
    _longFavPivotBarExec := na
    _longAdvPivotBarExec := na
    _pendingLongFamilyExec := ''
    _pendingLongStructExec := ''
    _pendingLongScoreExec := na
    _pendingLongTargetRoomRExec := na
    _pendingLongTargetRoomATRExec := na
    _longRiskExec := math.max(strategy.position_avg_price - _longSL, syminfo.mintick)
    _longTargetExec := _longTP
    _longEntryBarExec := bar_index
    _longTargetHitExec := not na(_longTargetExec) and high >= _longTargetExec
    _longTargetBarExec := _longTargetHitExec ? bar_index : na
if _newShortExec
    _shortLowExec := low
    _shortHighExec := high
    _shortFamilyExec := _pendingShortFamilyExec
    _shortEntryStructExec := _pendingShortStructExec
    _shortEntryScoreExec := _pendingShortScoreExec
    _shortTargetRoomRExec := _pendingShortTargetRoomRExec
    _shortTargetRoomATRExec := _pendingShortTargetRoomATRExec
    _shortFavPivotExec := na
    _shortAdvPivotExec := na
    _shortFavPivotBarExec := na
    _shortAdvPivotBarExec := na
    _pendingShortFamilyExec := ''
    _pendingShortStructExec := ''
    _pendingShortScoreExec := na
    _pendingShortTargetRoomRExec := na
    _pendingShortTargetRoomATRExec := na
    _shortRiskExec := math.max(_shortSL - strategy.position_avg_price, syminfo.mintick)
    _shortTargetExec := _shortTP
    _shortEntryBarExec := bar_index
    _shortTargetHitExec := not na(_shortTargetExec) and low <= _shortTargetExec
    _shortTargetBarExec := _shortTargetHitExec ? bar_index : na
if _flatExec
    _longHighExec := na
    _longLowExec := na
    _shortLowExec := na
    _shortHighExec := na
    _longRiskExec := na
    _shortRiskExec := na
    _longTargetExec := na
    _shortTargetExec := na
    _longEntryScoreExec := na
    _shortEntryScoreExec := na
    _longTargetRoomRExec := na
    _shortTargetRoomRExec := na
    _longTargetRoomATRExec := na
    _shortTargetRoomATRExec := na
    _longFavPivotExec := na
    _shortFavPivotExec := na
    _longAdvPivotExec := na
    _shortAdvPivotExec := na
    _longEntryBarExec := na
    _shortEntryBarExec := na
    _longTargetBarExec := na
    _shortTargetBarExec := na
    _longFavPivotBarExec := na
    _shortFavPivotBarExec := na
    _longAdvPivotBarExec := na
    _shortAdvPivotBarExec := na
    _longTargetHitExec := false
    _shortTargetHitExec := false
    _longBETriggered := false
    _shortBETriggered := false
    _longFamilyExec := ''
    _shortFamilyExec := ''
    _longEntryStructExec := ''
    _shortEntryStructExec := ''

_longBarsExec = strategy.position_size > 0 and not na(_longEntryBarExec) ? bar_index - _longEntryBarExec : 0
_shortBarsExec = strategy.position_size < 0 and not na(_shortEntryBarExec) ? bar_index - _shortEntryBarExec : 0
_longHighNowExec = strategy.position_size > 0 ? math.max(nz(_longHighExec, high), high) : na
_shortLowNowExec = strategy.position_size < 0 ? math.min(nz(_shortLowExec, low), low) : na
_longLowNowExec = strategy.position_size > 0 ? math.min(nz(_longLowExec, low), low) : na
_shortHighNowExec = strategy.position_size < 0 ? math.max(nz(_shortHighExec, high), high) : na
_longMfeExecR = strategy.position_size > 0 and not na(_longRiskExec) and _longRiskExec > 0 and not na(_longHighNowExec) ? (_longHighNowExec - strategy.position_avg_price) / _longRiskExec : 0.0
_shortMfeExecR = strategy.position_size < 0 and not na(_shortRiskExec) and _shortRiskExec > 0 and not na(_shortLowNowExec) ? (strategy.position_avg_price - _shortLowNowExec) / _shortRiskExec : 0.0
_longCurrentExecR = strategy.position_size > 0 and not na(_longRiskExec) and _longRiskExec > 0 ? (close - strategy.position_avg_price) / _longRiskExec : 0.0
_shortCurrentExecR = strategy.position_size < 0 and not na(_shortRiskExec) and _shortRiskExec > 0 ? (strategy.position_avg_price - close) / _shortRiskExec : 0.0
_longExecEarlyFail = useLowerTfEarlyFailure and _chartSec <= 3600 and strategy.position_size > 0 and (_longFamilyExec == 'rr' or _longFamilyExec == 'er') and _longBarsExec >= lowerTfEarlyFailureBars and _longMfeExecR < lowerTfEarlyFailureMfeR and _longCurrentExecR <= 0
_shortExecEarlyFail = useLowerTfEarlyFailure and _chartSec <= 3600 and strategy.position_size < 0 and (_shortFamilyExec == 'rr' or _shortFamilyExec == 'er') and _shortBarsExec >= lowerTfEarlyFailureBars and _shortMfeExecR < lowerTfEarlyFailureMfeR and _shortCurrentExecR <= 0
_longExecOneHourPBFail = useOneHourPullbackFailure and _chartSec == 3600 and strategy.position_size > 0 and _longFamilyExec == 'pb' and _longBarsExec >= oneHourPullbackFailureBars and _longMfeExecR < oneHourPullbackFailureMfeR and _longCurrentExecR <= 0
_shortExecOneHourPBFail = useOneHourPullbackFailure and _chartSec == 3600 and strategy.position_size < 0 and _shortFamilyExec == 'pb' and _shortBarsExec >= oneHourPullbackFailureBars and _shortMfeExecR < oneHourPullbackFailureMfeR and _shortCurrentExecR <= 0
_longExecProtectR = _longFamilyExec == 'pb' ? pbMfeProtectR : _longFamilyExec == 'er' ? erMfeProtectR : mfeProtectR
_shortExecProtectR = _shortFamilyExec == 'pb' ? pbMfeProtectR : _shortFamilyExec == 'er' ? erMfeProtectR : mfeProtectR
_longExecGivebackR = math.max(givebackFloorR, _longMfeExecR * _givebackKeepPct)
_shortExecGivebackR = math.max(givebackFloorR, _shortMfeExecR * _givebackKeepPct)
_execConfirmedGivebackTfOk = confirmedGivebackTFMode == 'All TF' or (confirmedGivebackTFMode == '4H Only' and _chartSec == 14400) or (confirmedGivebackTFMode == '15m + 4H' and (_chartSec == 900 or _chartSec == 14400))
_longExecTargetTouched = strategy.position_size > 0 and not na(_longTP) and high >= _longTP
_shortExecTargetTouched = strategy.position_size < 0 and not na(_shortTP) and low <= _shortTP
_longExecStructureInvalid = strategy.position_size > 0 and (structureShortOk or (lhDetected and llDetected))
_shortExecStructureInvalid = strategy.position_size < 0 and (structureLongOk or (hhDetected and hlDetected))
_longExecConfirmedPivot = confirmedGivebackUsePivot and strategy.position_size > 0 and _plFound and (bar_index - structPivLen) >= nz(_longEntryBarExec, bar_index) and low[structPivLen] <= strategy.position_avg_price + _longExecGivebackR * _longRiskExec
_shortExecConfirmedPivot = confirmedGivebackUsePivot and strategy.position_size < 0 and _phFound and (bar_index - structPivLen) >= nz(_shortEntryBarExec, bar_index) and high[structPivLen] >= strategy.position_avg_price - _shortExecGivebackR * _shortRiskExec
_longExecConfirmedGiveback = useConfirmedGivebackExit and _execConfirmedGivebackTfOk and strategy.position_size > 0 and _longMfeExecR >= _longExecProtectR and _longCurrentExecR <= _longExecGivebackR and not _longExecTargetTouched and (_longExecConfirmedPivot or (confirmedGivebackUseStructure and _longExecStructureInvalid))
_shortExecConfirmedGiveback = useConfirmedGivebackExit and _execConfirmedGivebackTfOk and strategy.position_size < 0 and _shortMfeExecR >= _shortExecProtectR and _shortCurrentExecR <= _shortExecGivebackR and not _shortExecTargetTouched and (_shortExecConfirmedPivot or (confirmedGivebackUseStructure and _shortExecStructureInvalid))
_longExecOpposite = strategy.position_size > 0 and (shortRRSignal or shortPBSignal or shortERSignal) and _oppShortScore >= oppositeExitMinScore
_shortExecOpposite = strategy.position_size < 0 and (longRRSignal or longPBSignal or longERSignal) and _oppLongScore >= oppositeExitMinScore
_longExecGivebackSignal = strategy.position_size > 0 and _longMfeExecR >= _longExecProtectR and _longCurrentExecR <= _longExecGivebackR
_shortExecGivebackSignal = strategy.position_size < 0 and _shortMfeExecR >= _shortExecProtectR and _shortCurrentExecR <= _shortExecGivebackR
_longExecFamilyWT = strategy.position_size > 0 and _wtCrossDown and ((_longFamilyExec == 'rr' and (_longMfeExecR >= mfeProtectR or wtOsc > 0)) or ((_longFamilyExec == 'pb' or _longFamilyExec == 'er') and (_longMfeExecR >= _longExecProtectR or wtOsc < 0)))
_shortExecFamilyWT = strategy.position_size < 0 and _wtCrossUp and ((_shortFamilyExec == 'rr' and (_shortMfeExecR >= mfeProtectR or wtOsc < 0)) or ((_shortFamilyExec == 'pb' or _shortFamilyExec == 'er') and (_shortMfeExecR >= _shortExecProtectR or wtOsc > 0)))
_longExecTimeFail = strategy.position_size > 0 and _longBarsExec >= maxBarsInTradeA and _longCurrentExecR < minProfitR
_shortExecTimeFail = strategy.position_size < 0 and _shortBarsExec >= maxBarsInTradeA and _shortCurrentExecR < minProfitR
_longExecFollowThr = strategy.position_size > 0 and _longBarsExec == followThroughBarsA and not na(_longHighNowExec) and _longHighNowExec < strategy.position_avg_price + followThroughATR * atrVal
_shortExecFollowThr = strategy.position_size < 0 and _shortBarsExec == followThroughBarsA and not na(_shortLowNowExec) and _shortLowNowExec > strategy.position_avg_price - followThroughATR * atrVal
_longExecMgmtSignal = (useExitOpposite and _longExecOpposite) or (useExitGiveback and _longExecGivebackSignal) or _longExecConfirmedGiveback or (useExitFamilyWT and _longExecFamilyWT) or _longExecEarlyFail or _longExecOneHourPBFail or (useExitTimeFail and _longExecTimeFail) or (useExitFollowThr and _longExecFollowThr)
_shortExecMgmtSignal = (useExitOpposite and _shortExecOpposite) or (useExitGiveback and _shortExecGivebackSignal) or _shortExecConfirmedGiveback or (useExitFamilyWT and _shortExecFamilyWT) or _shortExecEarlyFail or _shortExecOneHourPBFail or (useExitTimeFail and _shortExecTimeFail) or (useExitFollowThr and _shortExecFollowThr)
_oneHourStopSignalMode = _chartSec == 3600 and oneHourExecutionMode == "Stop + Signal Exit"
_longExecLimit = _oneHourStopSignalMode ? na : _longTP
_shortExecLimit = _oneHourStopSignalMode ? na : _shortTP

if strategy.position_size > 0
    _longHighExec := _longHighNowExec
    _longLowExec := _longLowNowExec
    if na(_longFavPivotExec) and _phFound and (bar_index - structPivLen) >= nz(_longEntryBarExec, bar_index)
        _longFavPivotExec := high[structPivLen]
        _longFavPivotBarExec := bar_index - structPivLen
    if na(_longAdvPivotExec) and _plFound and (bar_index - structPivLen) >= nz(_longEntryBarExec, bar_index)
        _longAdvPivotExec := low[structPivLen]
        _longAdvPivotBarExec := bar_index - structPivLen
    if not _longTargetHitExec and not na(_longTargetExec) and high >= _longTargetExec
        _longTargetHitExec := true
        _longTargetBarExec := bar_index
    if enableBE and not na(_longRiskExec) and high >= strategy.position_avg_price + beATRInput * _longRiskExec
        _longBETriggered := true
    _longBEStop = _longBETriggered ? strategy.position_avg_price : _longSL
    _longGivebackStop = useExitGiveback and useStrategyGivebackStop and _longMfeExecR >= _longExecProtectR ? strategy.position_avg_price + _longExecGivebackR * _longRiskExec : _longSL
    strategy.exit("Long Exit", "Long", stop=math.max(_longBEStop, _longGivebackStop), limit=_longExecLimit)
if strategy.position_size < 0
    _shortLowExec := _shortLowNowExec
    _shortHighExec := _shortHighNowExec
    if na(_shortFavPivotExec) and _plFound and (bar_index - structPivLen) >= nz(_shortEntryBarExec, bar_index)
        _shortFavPivotExec := low[structPivLen]
        _shortFavPivotBarExec := bar_index - structPivLen
    if na(_shortAdvPivotExec) and _phFound and (bar_index - structPivLen) >= nz(_shortEntryBarExec, bar_index)
        _shortAdvPivotExec := high[structPivLen]
        _shortAdvPivotBarExec := bar_index - structPivLen
    if not _shortTargetHitExec and not na(_shortTargetExec) and low <= _shortTargetExec
        _shortTargetHitExec := true
        _shortTargetBarExec := bar_index
    if enableBE and not na(_shortRiskExec) and low <= strategy.position_avg_price - beATRInput * _shortRiskExec
        _shortBETriggered := true
    _shortBEStop = _shortBETriggered ? strategy.position_avg_price : _shortSL
    _shortGivebackStop = useExitGiveback and useStrategyGivebackStop and _shortMfeExecR >= _shortExecProtectR ? strategy.position_avg_price - _shortExecGivebackR * _shortRiskExec : _shortSL
    strategy.exit("Short Exit", "Short", stop=math.min(_shortBEStop, _shortGivebackStop), limit=_shortExecLimit)

// ─── Strategy-managed exits (real position state, same exit families) ─────────
_execIndicatorExit = indicatorExitExecMode == "All TF" or (indicatorExitExecMode == "1H Only" and _chartSec == 3600)
_longExecExitAllowed = not indicatorExitNeedsTargetOrStructure or _longExecTargetTouched or _longExecStructureInvalid
_shortExecExitAllowed = not indicatorExitNeedsTargetOrStructure or _shortExecTargetTouched or _shortExecStructureInvalid
_longExecExitSignal = (_execIndicatorExit and ((_longExecMgmtSignal and _longExecExitAllowed) or _longExecOneHourPBFail)) or _longExecConfirmedGiveback
_shortExecExitSignal = (_execIndicatorExit and ((_shortExecMgmtSignal and _shortExecExitAllowed) or _shortExecOneHourPBFail)) or _shortExecConfirmedGiveback

if strategy.position_size > 0 and _longExecExitSignal
    strategy.close("Long",  comment=_longExecConfirmedGiveback ? "Confirmed MFE Exit" : _longExecOneHourPBFail ? "1H PB Fail Exit" : "Indicator Exit")
if strategy.position_size < 0 and _shortExecExitSignal
    strategy.close("Short", comment=_shortExecConfirmedGiveback ? "Confirmed MFE Exit" : _shortExecOneHourPBFail ? "1H PB Fail Exit" : "Indicator Exit")

_canOpenLongNow = strategy.position_size == 0 or (allowSignalReversal and strategy.position_size < 0 and _shortExecExitSignal)
_canOpenShortNow = strategy.position_size == 0 or (allowSignalReversal and strategy.position_size > 0 and _longExecExitSignal)

if longEntrySignal and _canLong and _canEntry and _canOpenLongNow
    _longSL := longStop
    _longTP := longEntryTakeProfit
    _pendingLongFamilyExec := longRRSignal ? 'rr' : longPBSignal ? 'pb' : 'er'
    _pendingLongStructExec := 'hh=' + str.tostring(hhDetected) + ',hl=' + str.tostring(hlDetected) + ',lh=' + str.tostring(lhDetected) + ',ll=' + str.tostring(llDetected) + ',longStruct=' + str.tostring(structureLongOk) + ',shortStruct=' + str.tostring(structureShortOk) + ',structurePhase=' + _playbookStructure + ',playbook=' + _longPlaybook + ',wtBullDiv=' + str.tostring(wtBullDiv) + ',wtBearDiv=' + str.tostring(wtBearDiv) + ',highConfirmBars=' + str.tostring(barsSinceHighPivotConfirm) + ',lowConfirmBars=' + str.tostring(barsSinceLowPivotConfirm) + ',highActualBars=' + str.tostring(barsSinceHighPivotActual) + ',lowActualBars=' + str.tostring(barsSinceLowPivotActual) + ',rangePos=' + str.tostring(setupRangePos, '#.##') + ',target=' + str.tostring(longEntryTakeProfit, format.mintick) + ',stop=' + str.tostring(longStop, format.mintick)
    _pendingLongScoreExec := longRRSignal ? longContextScoreRR : longPBSignal ? longContextScorePB : earlyLongContextScore
    _pendingLongTargetRoomRExec := longTargetRoomR
    _pendingLongTargetRoomATRExec := longTargetRoomATR
    strategy.entry("Long", strategy.long)

if shortEntrySignal and _canShort and _canEntry and _canOpenShortNow
    _shortSL := shortStop
    _shortTP := shortEntryTakeProfit
    _pendingShortFamilyExec := shortRRSignal ? 'rr' : shortPBSignal ? 'pb' : 'er'
    _pendingShortStructExec := 'hh=' + str.tostring(hhDetected) + ',hl=' + str.tostring(hlDetected) + ',lh=' + str.tostring(lhDetected) + ',ll=' + str.tostring(llDetected) + ',longStruct=' + str.tostring(structureLongOk) + ',shortStruct=' + str.tostring(structureShortOk) + ',structurePhase=' + _playbookStructure + ',playbook=' + _shortPlaybook + ',wtBullDiv=' + str.tostring(wtBullDiv) + ',wtBearDiv=' + str.tostring(wtBearDiv) + ',highConfirmBars=' + str.tostring(barsSinceHighPivotConfirm) + ',lowConfirmBars=' + str.tostring(barsSinceLowPivotConfirm) + ',highActualBars=' + str.tostring(barsSinceHighPivotActual) + ',lowActualBars=' + str.tostring(barsSinceLowPivotActual) + ',rangePos=' + str.tostring(setupRangePos, '#.##') + ',target=' + str.tostring(shortEntryTakeProfit, format.mintick) + ',stop=' + str.tostring(shortStop, format.mintick)
    _pendingShortScoreExec := shortRRSignal ? shortContextScoreRR : shortPBSignal ? shortContextScorePB : earlyShortContextScore
    _pendingShortTargetRoomRExec := shortTargetRoomR
    _pendingShortTargetRoomATRExec := shortTargetRoomATR
    strategy.entry("Short", strategy.short)
