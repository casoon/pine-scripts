string i_invalidMode = input.string("High/Low", "Structure Invalidation", options=["High/Low", "Close"], group="Break Confirmation", tooltip="High/Low: wick through anchorA invalidates. Close: only close through anchorA invalidates (less sensitive to spikes).")

// === GROUP: WAVE TARGETS (STEP 2) ===
bool i_showTargets = input.bool(true, "Show Fib Targets", group="Wave Targets", tooltip="After confirmed pullback, project Fibonacci extension targets")

bool i_target100 = input.bool(true, "Target 1.000", group="Wave Targets", inline="tgt1")
bool i_target127 = input.bool(true, "Target 1.272", group="Wave Targets", inline="tgt1")
bool i_target162 = input.bool(true, "Target 1.618", group="Wave Targets", inline="tgt1")
bool i_target200 = input.bool(true, "Target 2.000", group="Wave Targets", inline="tgt1")

