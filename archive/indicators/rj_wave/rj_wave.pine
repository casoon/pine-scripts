// === GROUP: SEED / INITIALIZATION ===
int i_seedLookback = input.int(300, "Seed Lookback Bars", minval=50, maxval=1000, group="Seed / Initialization", tooltip="How many bars back to search for initial anchor point. Larger = more history, but may include old/irrelevant structure.")

string i_seedMode = input.string("Auto", "Seed Mode", options=["Auto", "Lowest Low", "Highest High"], group="Seed / Initialization", tooltip="Auto: picks the earlier extreme. Lowest Low: start from lowest point. Highest High: start from highest point.")

float i_minImpulsePercent = input.float(3.0, "Min Impulse %", minval=0.5, maxval=20.0, step=0.5, group="Seed / Initialization", tooltip="Minimum impulse size (A to B) as percentage to 'arm' the structure. Prevents starting on noise.")

// === GROUP: PIVOT DETECTION ===
int i_pivotLeftBars = input.int(5, "Left Bars", minval=1, maxval=50, group="Pivot Detection", tooltip="Number of bars to the left for pivot confirmation. Higher = fewer but more significant pivots.")

int i_pivotRightBars = input.int(5, "Right Bars", minval=1, maxval=50, group="Pivot Detection", tooltip="Number of bars to the right for pivot confirmation. This creates a delay of N bars.")

// === GROUP: FIBONACCI VALIDATION ===
float i_fibTolerance = input.float(1.0, "Fib Tolerance %", minval=0.1, maxval=5.0, step=0.1, group="Fibonacci Validation", tooltip="Tolerance for Fibonacci level matching. ±1% means 0.618 matches 0.612 to 0.624")

bool i_useFib236 = input.bool(true, "Use 0.236", group="Fibonacci Validation", inline="fib1")
bool i_useFib382 = input.bool(true, "Use 0.382", group="Fibonacci Validation", inline="fib1")
bool i_useFib500 = input.bool(true, "Use 0.500", group="Fibonacci Validation", inline="fib1")

bool i_useFib618 = input.bool(true, "Use 0.618", group="Fibonacci Validation", inline="fib2")
bool i_useFib786 = input.bool(true, "Use 0.786", group="Fibonacci Validation", inline="fib2")
bool i_useFib886 = input.bool(true, "Use 0.886", group="Fibonacci Validation", inline="fib2")

bool i_useFib100 = input.bool(true, "Use 1.000", group="Fibonacci Validation", inline="fib3", tooltip="Extension levels for deep pullbacks")
bool i_useFib127 = input.bool(true, "Use 1.272", group="Fibonacci Validation", inline="fib3")
bool i_useFib162 = input.bool(true, "Use 1.618", group="Fibonacci Validation", inline="fib3")
