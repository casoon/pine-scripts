//@version=6
// ============================================================================
// RJ-Wave Fibonacci Validator [WavesUnchained]
// Version: 1.0.0
// Author: WavesUnchained
// Build: 2025-12-20 16:35:54
// ============================================================================
// Validates wave structure using Fibonacci retracements. Only commits waves
// when pullbacks hit valid Fib levels with a break confirmation.
//
// Features:
//   ✓ Tracks impulse waves (AnchorA → AnchorB)
//   ✓ Monitors up to 3 concurrent pullback candidates
//   ✓ Validates pullback against Fibonacci levels (configurable tolerance)
//   ✓ Requires break of AnchorB before committing a wave
//   ✓ Projects price targets after each committed wave
//
// ============================================================================

indicator("RJ-Wave Fibonacci Validator [WavesUnchained]", shorttitle="RJ-Wave", overlay=true,
     max_lines_count=500, max_labels_count=500, max_boxes_count=100)

