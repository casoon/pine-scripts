//@version=6
// ============================================================================
// Commodity FlowTrend [WavesUnchained]
// Version: 1.0
// Author: WavesUnchained
// Build: 2026-06-18 00:00:00
// ============================================================================
// MFI + CCI composite oscillator tuned for commodity markets. Combines
// money-flow momentum (MFI) with cycle-sensitive trend context (CCI) to
// identify flow regimes: expansion, accumulation, distribution, and reversal.
//
// Features:
//   ✓ Manual MFI with pluggable smoothing (EMA, SMA, RMA, WMA)
//   ✓ CCI confirmation layer (normalized to MFI scale for visual alignment)
//   ✓ 4-state flow background: bull/bear expansion vs. accumulation/distribution
//   ✓ 4-state color-coded MFI histogram
//   ✓ Extreme-zone reversal signals with optional CCI gating
//   ✓ Midline confirmation dots (MFI crosses 50 with aligned CCI)
//   ✓ Alert conditions for all signal types
//
// ============================================================================

indicator("Commodity FlowTrend [WavesUnchained]", "CFT", overlay=false, max_labels_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

g_base = "1 · Base"
src    = input.source(hlc3, "Source",         group=g_base)
mfiLen = input.int(14,      "MFI Length",     minval=1, group=g_base)
cciLen = input.int(20,      "CCI Length",     minval=1, group=g_base)
sigLen = input.int(5,       "Signal Length",  minval=1, group=g_base)

g_smooth = "2 · Smoothing"
smoothType = input.string("EMA", "Type", options=["EMA", "SMA", "RMA", "WMA"], group=g_smooth)

g_levels = "3 · Levels"
mfiOB  = input.float(80, "MFI Overbought", group=g_levels)
mfiOS  = input.float(20, "MFI Oversold",   group=g_levels)
mfiMid = input.float(50, "MFI Midline",    group=g_levels)

g_filter = "4 · Signal Filters"
useCCIConfirm   = input.bool(true, "Require CCI Confirmation",   group=g_filter)
useExtremeOnly  = input.bool(true, "Only Signal From OB/OS Zone", group=g_filter)
lookbackExtreme = input.int(8,     "OB/OS Lookback",             minval=1, group=g_filter)

g_col = "5 · Colors"
colBull = input.color(#26a69a, "Bull", group=g_col)
colBear = input.color(#ef5350, "Bear", group=g_col)

g_display = "6 · Display"
showBg      = input.bool(true,  "Show Flow Background",    group=g_display)
showHist    = input.bool(true,  "Show MFI Histogram",      group=g_display)
showCCI     = input.bool(true,  "Show CCI Normalized",     group=g_display)
showSignals = input.bool(true,  "Show Signals",            group=g_display)

// ─────────────────────────────────────────────────────────────────────────────
// SMOOTHING
// ─────────────────────────────────────────────────────────────────────────────

f_smooth(series float x, simple int len, simple string mode) =>
    switch mode
        "SMA" => ta.sma(x, len)
        "RMA" => ta.rma(x, len)
        "WMA" => ta.wma(x, len)
        =>       ta.ema(x, len)

// ─────────────────────────────────────────────────────────────────────────────
// MFI
// ─────────────────────────────────────────────────────────────────────────────

rawMoneyFlow  = src * volume
positiveFlow  = src > src[1] ? rawMoneyFlow : 0.0
negativeFlow  = src < src[1] ? rawMoneyFlow : 0.0
positiveSum   = math.sum(positiveFlow, mfiLen)
negativeSum   = math.sum(negativeFlow, mfiLen)

mfiRaw = negativeSum == 0.0 ? 100.0 :
         positiveSum == 0.0 ? 0.0   :
         100.0 - (100.0 / (1.0 + positiveSum / negativeSum))

mfi       = f_smooth(mfiRaw, sigLen, smoothType)
mfiSignal = f_smooth(mfi,    sigLen, smoothType)
hist      = mfi - mfiSignal

// ─────────────────────────────────────────────────────────────────────────────
// CCI (normalized to 0–100 for visual alignment with MFI)
// ─────────────────────────────────────────────────────────────────────────────

cciRaw  = ta.cci(src, cciLen)
cci     = f_smooth(cciRaw, sigLen, smoothType)
cciNorm = math.max(math.min(50.0 + cci / 4.0, 100.0), 0.0)

// ─────────────────────────────────────────────────────────────────────────────
// FLOW STATE
// ─────────────────────────────────────────────────────────────────────────────

mfiBull    = mfi > mfiMid
mfiBear    = mfi < mfiMid
mfiRising  = mfi > mfi[1]
mfiFalling = mfi < mfi[1]
cciBullish = cci > 0.0
cciBearish = cci < 0.0

bullExpansion    = mfiBull  and cciBullish and mfiRising
bearExpansion    = mfiBear  and cciBearish and mfiFalling
bullAccumulation = not mfiBull and mfiRising  and cci > cci[1]
bearDistribution = not mfiBear and mfiFalling and cci < cci[1]

// ─────────────────────────────────────────────────────────────────────────────
// SIGNALS
// ─────────────────────────────────────────────────────────────────────────────

wasOversold   = ta.lowest(mfi,  lookbackExtreme) <= mfiOS
wasOverbought = ta.highest(mfi, lookbackExtreme) >= mfiOB

bullCross = ta.crossover(mfi,  mfiSignal)
bearCross = ta.crossunder(mfi, mfiSignal)

bullConfirm = not useCCIConfirm or cciBullish or cci > cci[1]
bearConfirm = not useCCIConfirm or cciBearish or cci < cci[1]

bullSignal = bullCross and bullConfirm and (not useExtremeOnly or wasOversold)
bearSignal = bearCross and bearConfirm and (not useExtremeOnly or wasOverbought)

bullMidConfirm = ta.crossover(mfi,  mfiMid) and cciBullish
bearMidConfirm = ta.crossunder(mfi, mfiMid) and cciBearish

// ─────────────────────────────────────────────────────────────────────────────
// COLORS
// ─────────────────────────────────────────────────────────────────────────────

mfiLineColor = color.from_gradient(mfi, mfiOS, mfiOB, colBull, colBear)
sigColor     = color.new(color.white, 40)

// 4-state histogram
histRising = hist >= hist[1]
histColor  = hist >= 0.0
     ? (histRising     ? colBull                     : color.new(colBull, 55))
     : (not histRising ? colBear                     : color.new(colBear, 55))

bgColor =
     bullExpansion    ? color.new(colBull, 84) :
     bullAccumulation ? color.new(colBull, 91) :
     bearExpansion    ? color.new(colBear, 84) :
     bearDistribution ? color.new(colBear, 91) :
     na

// ─────────────────────────────────────────────────────────────────────────────
// HLINES
// ─────────────────────────────────────────────────────────────────────────────

hline(100,   "100",        color=color.new(color.gray, 80))
hline(mfiOB, "Overbought", color=color.new(colBear, 45), linestyle=hline.style_dashed)
hline(mfiMid,"Midline",    color=color.new(color.gray, 50), linestyle=hline.style_dotted)
hline(mfiOS, "Oversold",   color=color.new(colBull, 45), linestyle=hline.style_dashed)
hline(0,     "0",          color=color.new(color.gray, 80))

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────

bgcolor(showBg ? bgColor : na, title="Flow Background")

// Histogram centered on midline
plot(showHist ? hist + mfiMid : na, "MFI Histogram",
     style=plot.style_columns, color=histColor)

// CCI normalized (behind MFI line)
plot(showCCI ? cciNorm : na, "CCI Normalized",
     color=color.new(color.orange, 15), linewidth=1)

// MFI lines
pSig = plot(mfiSignal, "MFI Signal", color=sigColor,       linewidth=1)
pMFI = plot(mfi,       "MFI",        color=mfiLineColor,   linewidth=2)

// Fill between MFI and signal
fill(pMFI, pSig,
     color=mfi >= mfiSignal ? color.new(colBull, 88) : color.new(colBear, 88),
     title="MFI Fill")

// ─────────────────────────────────────────────────────────────────────────────
// SIGNAL MARKERS
// ─────────────────────────────────────────────────────────────────────────────

plotshape(showSignals and bullSignal, "Bull Signal",
     style=shape.triangleup, location=location.bottom,
     color=colBull, size=size.small,
     text="MFI↑", textcolor=colBull)

plotshape(showSignals and bearSignal, "Bear Signal",
     style=shape.triangledown, location=location.top,
     color=colBear, size=size.small,
     text="MFI↓", textcolor=colBear)

// Midline confirmation dots — placed on the MFI line
plotshape(showSignals and bullMidConfirm ? mfi : na, "Bull Mid Confirm",
     style=shape.circle, location=location.absolute,
     color=color.new(colBull, 0), size=size.tiny)

plotshape(showSignals and bearMidConfirm ? mfi : na, "Bear Mid Confirm",
     style=shape.circle, location=location.absolute,
     color=color.new(colBear, 0), size=size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────

alertcondition(bullSignal,     "CFT Bull Signal",           "Commodity FlowTrend bullish signal")
alertcondition(bearSignal,     "CFT Bear Signal",           "Commodity FlowTrend bearish signal")
alertcondition(bullMidConfirm, "CFT Bull Midline Confirm",  "MFI crossed above midline with bullish CCI")
alertcondition(bearMidConfirm, "CFT Bear Midline Confirm",  "MFI crossed below midline with bearish CCI")
