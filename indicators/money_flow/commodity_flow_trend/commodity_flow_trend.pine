//@version=6
// ============================================================================
// Commodity FlowTrend [WavesUnchained]
// Version: 1.0
// Author: WavesUnchained
// Build: 2026-06-18 00:00:00
// ============================================================================
// MFI + CCI composite oscillator tuned for commodity markets. Combines
// money-flow momentum (MFI) with cycle-sensitive trend context (CCI) to
// identify flow regimes: expansion, accumulation, distribution, and reversal.
//
// Features:
//   ✓ Manual MFI with pluggable smoothing (EMA, SMA, RMA, WMA)
//   ✓ CCI confirmation layer (normalized to MFI scale for visual alignment)
//   ✓ 4-state flow background: bull/bear expansion vs. accumulation/distribution
//   ✓ 4-state color-coded MFI histogram
//   ✓ Extreme-zone reversal signals with optional CCI gating
//   ✓ Midline confirmation dots (MFI crosses 50 with aligned CCI)
//   ✓ Alert conditions for all signal types
//
// ============================================================================

indicator("Commodity FlowTrend [WavesUnchained]", "CFT", overlay=false, max_labels_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

g_base = "1 · Base"
src    = input.source(hlc3, "Source",         group=g_base)
mfiLen = input.int(14,      "MFI Length",     minval=1, group=g_base)
cciLen = input.int(20,      "CCI Length",     minval=1, group=g_base)
sigLen = input.int(5,       "Signal Length",  minval=1, group=g_base)

g_smooth = "2 · Smoothing"
smoothType = input.string("EMA", "Type",
     options=["EMA", "SMA", "RMA", "WMA", "SuperSmoother", "T3", "KAMA", "JMA Approx"],
     group=g_smooth)
jmaPhase = input.int(50,    "  JMA Phase", minval=-100, maxval=100,             group=g_smooth)
jmaPower = input.float(2.0, "  JMA Power", minval=1.0,  maxval=4.0, step=0.25, group=g_smooth)

g_levels = "3 · Levels"
mfiOB  = input.float(80, "MFI Overbought", group=g_levels)
mfiOS  = input.float(20, "MFI Oversold",   group=g_levels)
mfiMid = input.float(50, "MFI Midline",    group=g_levels)

g_filter = "4 · Signal Filters"
triggerMode     = input.string("MFI Lead", "Trigger Mode", options=["MFI Lead", "CCI Lead"], group=g_filter,
     tooltip="MFI Lead: MFI cross triggers, CCI confirms (slower, volume-aware). CCI Lead: CCI zero-cross triggers, MFI direction confirms (faster, earlier entries).")
useCCIConfirm   = input.bool(true, "Require CCI Confirmation",   group=g_filter)
useExtremeOnly  = input.bool(true, "Only Signal From OB/OS Zone", group=g_filter)
lookbackExtreme = input.int(8,     "OB/OS Lookback",             minval=1, group=g_filter)
useRegimeFilter = input.bool(true, "Regime Signal Filter",        group=g_filter)

g_col = "5 · Colors"
colBull = input.color(#26a69a, "Bull", group=g_col)
colBear = input.color(#ef5350, "Bear", group=g_col)

g_display = "6 · Display"
showBg      = input.bool(false, "Show Flow Background",    group=g_display)
showHist    = input.bool(true,  "Show MFI Histogram",      group=g_display)
showCCI     = input.bool(true,  "Show CCI Normalized",     group=g_display)
showSignals  = input.bool(true,  "Show Signals",            group=g_display)
showCCITurn = input.bool(true,  "Show CCI Turn Markers",   group=g_display,
     tooltip="Small diamonds when CCI turns from an extreme zone (±100) — fires before the MFI cross. Bull turn = CCI was below -100 and now reversing up. Bear turn = CCI was above +100 and now reversing down.")

// ─────────────────────────────────────────────────────────────────────────────
// SMOOTHING
// ─────────────────────────────────────────────────────────────────────────────

f_supersmoother(series float x, simple int len) =>
    float a1 = math.exp(-1.414 * math.pi / len)
    float b1 = 2.0 * a1 * math.cos(1.414 * math.pi / len)
    float c2 = b1
    float c3 = -(a1 * a1)
    float c1 = 1.0 - c2 - c3
    var float ss = na
    ss := c1 * (x + nz(x[1])) / 2.0 + c2 * nz(ss[1]) + c3 * nz(ss[2])
    ss

f_t3(series float x, simple int len) =>
    float b  = 0.7
    float e1 = ta.ema(x, len)
    float e2 = ta.ema(e1, len)
    float e3 = ta.ema(e2, len)
    float e4 = ta.ema(e3, len)
    float e5 = ta.ema(e4, len)
    float e6 = ta.ema(e5, len)
    float c1 = -(b * b * b)
    float c2 =  3.0 * b * b + 3.0 * b * b * b
    float c3 = -6.0 * b * b - 3.0 * b - 3.0 * b * b * b
    float c4 =  1.0 + 3.0 * b + b * b * b + 3.0 * b * b
    c1 * e6 + c2 * e5 + c3 * e4 + c4 * e3

f_kama(series float x, simple int len) =>
    float change   = math.abs(x - x[len])
    float vol      = math.sum(math.abs(x - x[1]), len)
    float er       = vol != 0.0 ? change / vol : 0.0
    float sc       = math.pow(er * (2.0 / 3.0 - 2.0 / 31.0) + 2.0 / 31.0, 2)
    var float kama = na
    kama := nz(kama[1], x) + sc * (x - nz(kama[1], x))
    kama

f_jma(series float x, simple int len, simple int phase, simple float power) =>
    var float jma = na
    var float e0  = na
    var float e1  = na
    var float e2  = na
    float phaseRatio = phase < -100 ? 0.5 : phase > 100 ? 2.5 : phase / 100.0 + 1.5
    float beta       = 0.45 * (len - 1) / (0.45 * (len - 1) + 2.0)
    float alpha      = math.pow(beta, power)
    e0  := (1.0 - alpha) * x + alpha * nz(e0[1], x)
    e1  := (x - e0) * (1.0 - beta) + beta * nz(e1[1], 0.0)
    e2  := (e0 + phaseRatio * e1 - nz(jma[1], x)) * math.pow(1.0 - alpha, 2.0) + math.pow(alpha, 2.0) * nz(e2[1], 0.0)
    jma := nz(jma[1], x) + e2
    jma

f_smooth(series float x, simple int len, simple string mode) =>
    switch mode
        "SMA"           => ta.sma(x, len)
        "RMA"           => ta.rma(x, len)
        "WMA"           => ta.wma(x, len)
        "SuperSmoother" => f_supersmoother(x, len)
        "T3"            => f_t3(x, len)
        "KAMA"          => f_kama(x, len)
        "JMA Approx"    => f_jma(x, len, jmaPhase, jmaPower)
        =>                 ta.ema(x, len)

// ─────────────────────────────────────────────────────────────────────────────
// MFI
// ─────────────────────────────────────────────────────────────────────────────

rawMoneyFlow  = src * volume
positiveFlow  = src > src[1] ? rawMoneyFlow : 0.0
negativeFlow  = src < src[1] ? rawMoneyFlow : 0.0
positiveSum   = math.sum(positiveFlow, mfiLen)
negativeSum   = math.sum(negativeFlow, mfiLen)

mfiRaw = negativeSum == 0.0 ? 100.0 :
         positiveSum == 0.0 ? 0.0   :
         100.0 - (100.0 / (1.0 + positiveSum / negativeSum))

mfi       = f_smooth(mfiRaw, sigLen, smoothType)
mfiSignal = f_smooth(mfi,    sigLen, smoothType)
hist      = mfi - mfiSignal
mfiTrend  = ta.ema(mfiRaw, mfiLen * 2)

// ─────────────────────────────────────────────────────────────────────────────
// CCI (normalized to 0–100 for visual alignment with MFI)
// ─────────────────────────────────────────────────────────────────────────────

cciRaw  = ta.cci(src, cciLen)
cci     = f_smooth(cciRaw, sigLen, smoothType)
cciNorm = math.max(math.min(50.0 + cci / 4.0, 100.0), 0.0)

// ─────────────────────────────────────────────────────────────────────────────
// FLOW STATE
// ─────────────────────────────────────────────────────────────────────────────

mfiBull    = mfi > mfiMid
mfiBear    = mfi < mfiMid
mfiRising  = mfi > mfi[1]
mfiFalling = mfi < mfi[1]
cciBullish = cci > 0.0
cciBearish = cci < 0.0

bullExpansion    = mfiBull  and cciBullish and mfiRising
bearExpansion    = mfiBear  and cciBearish and mfiFalling
bullAccumulation = not mfiBull and mfiRising  and cci > cci[1]
bearDistribution = not mfiBear and mfiFalling and cci < cci[1]

// ─────────────────────────────────────────────────────────────────────────────
// SIGNALS
// ─────────────────────────────────────────────────────────────────────────────

wasOversold   = ta.lowest(mfi,  lookbackExtreme) <= mfiOS
wasOverbought = ta.highest(mfi, lookbackExtreme) >= mfiOB

bullCross = ta.crossover(mfi,  mfiSignal)
bearCross = ta.crossunder(mfi, mfiSignal)

bullConfirm = not useCCIConfirm or cciBullish or cci > cci[1]
bearConfirm = not useCCIConfirm or cciBearish or cci < cci[1]

regimeBull = not useRegimeFilter or mfi > mfiTrend
regimeBear = not useRegimeFilter or mfi < mfiTrend

// MFI Lead: MFI cross triggers, CCI confirms
bool _bullMFI = bullCross and bullConfirm and (not useExtremeOnly or wasOversold)  and regimeBull
bool _bearMFI = bearCross and bearConfirm and (not useExtremeOnly or wasOverbought) and regimeBear

// CCI Lead: CCI zero-cross triggers, MFI direction (above/below midline) confirms
bool cciCrossUp   = ta.crossover(cci, 0.0)
bool cciCrossDown = ta.crossunder(cci, 0.0)
bool cciWasOS     = ta.lowest(cci,  lookbackExtreme) <= -100.0
bool cciWasOB     = ta.highest(cci, lookbackExtreme) >=  100.0
bool _bullCCI = cciCrossUp   and (not useExtremeOnly or cciWasOS) and mfiBull and regimeBull
bool _bearCCI = cciCrossDown and (not useExtremeOnly or cciWasOB) and mfiBear and regimeBear

bool bullSignal = triggerMode == "CCI Lead" ? _bullCCI : _bullMFI
bool bearSignal = triggerMode == "CCI Lead" ? _bearCCI : _bearMFI

bullMidConfirm = ta.crossover(mfi,  mfiMid) and cciBullish
bearMidConfirm = ta.crossunder(mfi, mfiMid) and cciBearish

// CCI turn from extreme: local inflection while still in OB/OS zone → early warning
bool cciTurningUp   = cci > cci[1] and cci[1] <= cci[2] and cci[1] < -100.0
bool cciTurningDown = cci < cci[1] and cci[1] >= cci[2] and cci[1] >  100.0

// ─────────────────────────────────────────────────────────────────────────────
// COLORS
// ─────────────────────────────────────────────────────────────────────────────

mfiLineColor = color.from_gradient(mfi, mfiOS, mfiOB, colBull, colBear)
sigColor     = mfi >= mfiSignal ? color.new(colBull, 30) : color.new(colBear, 30)

// 4-state histogram
histRising = hist >= hist[1]
histColor  = hist >= 0.0
     ? (histRising     ? color.new(colBull, 20) : color.new(colBull, 60))
     : (not histRising ? color.new(colBear, 20) : color.new(colBear, 60))

bgColor =
     bullExpansion    ? color.new(colBull, 84) :
     bullAccumulation ? color.new(colBull, 91) :
     bearExpansion    ? color.new(colBear, 84) :
     bearDistribution ? color.new(colBear, 91) :
     na

// ─────────────────────────────────────────────────────────────────────────────
// HLINES
// ─────────────────────────────────────────────────────────────────────────────

hline(100,   "100",        color=color.new(color.gray, 80))
hline(mfiOB, "Overbought", color=color.new(colBear, 45), linestyle=hline.style_dashed)
hline(mfiMid,"Midline",    color=color.new(color.gray, 50), linestyle=hline.style_dotted)
hline(mfiOS, "Oversold",   color=color.new(colBull, 45), linestyle=hline.style_dashed)
hline(0,     "0",          color=color.new(color.gray, 80))

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────

bgcolor(showBg ? bgColor : na, title="Flow Background")

// Histogram centered on midline
plot(showHist ? hist + mfiMid : na, "MFI Histogram",
     style=plot.style_columns, color=histColor)

// CCI normalized (behind MFI line)
plot(showCCI ? cciNorm : na, "CCI Normalized",
     color=color.new(color.orange, 15), linewidth=1)

// MFI lines
pSig = plot(mfiSignal, "MFI Signal", color=sigColor,       linewidth=1)
pMFI = plot(mfi,       "MFI",        color=mfiLineColor,   linewidth=2)

// Fill between MFI and signal
fill(pMFI, pSig,
     color=mfi >= mfiSignal ? color.new(colBull, 88) : color.new(colBear, 88),
     title="MFI Fill")

// ─────────────────────────────────────────────────────────────────────────────
// SIGNAL MARKERS
// ─────────────────────────────────────────────────────────────────────────────

plotshape(showSignals and bullSignal ? mfi - 6.0 : na, "Bull Signal",
     style=shape.triangleup, location=location.absolute,
     color=colBull, size=size.tiny)

plotshape(showSignals and bearSignal ? mfi + 6.0 : na, "Bear Signal",
     style=shape.triangledown, location=location.absolute,
     color=colBear, size=size.tiny)

// Midline confirmation dots — placed on the MFI line
plotshape(showSignals and bullMidConfirm ? mfi : na, "Bull Mid Confirm",
     style=shape.circle, location=location.absolute,
     color=color.new(colBull, 0), size=size.tiny)

plotshape(showSignals and bearMidConfirm ? mfi : na, "Bear Mid Confirm",
     style=shape.circle, location=location.absolute,
     color=color.new(colBear, 0), size=size.tiny)

// CCI turn markers — small diamonds on the CCI line, fires before MFI cross
plotshape(showCCITurn and cciTurningUp   ? cciNorm : na, "CCI Bull Turn",
     style=shape.diamond, location=location.absolute,
     color=color.new(colBull, 20), size=size.tiny)
plotshape(showCCITurn and cciTurningDown ? cciNorm : na, "CCI Bear Turn",
     style=shape.diamond, location=location.absolute,
     color=color.new(colBear, 20), size=size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────

alertcondition(bullSignal,     "CFT Bull Signal",           "Commodity FlowTrend bullish signal")
alertcondition(bearSignal,     "CFT Bear Signal",           "Commodity FlowTrend bearish signal")
alertcondition(bullMidConfirm, "CFT Bull Midline Confirm",  "MFI crossed above midline with bullish CCI")
alertcondition(bearMidConfirm, "CFT Bear Midline Confirm",  "MFI crossed below midline with bearish CCI")
