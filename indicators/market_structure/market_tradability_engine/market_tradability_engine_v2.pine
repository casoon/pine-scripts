int adxLength =
     preset == "Very Fast" ? 8 :
     preset == "Fast"      ? 10 :
     preset == "Balanced"  ? 14 :
     preset == "Calm"      ? 18 :
     preset == "Position"  ? 21 :
     customAdxLength

int rankLength =
     preset == "Very Fast" ? 80 :
     preset == "Fast"      ? 110 :
     preset == "Balanced"  ? 150 :
     preset == "Calm"      ? 220 :
     preset == "Position"  ? 350 :
     customRankLength

// Reactivity resolves how readily a state change triggers - independent of
// Preset above, which only resolves lookback lengths. "Early" loosens every
// threshold and shortens every confirmation/duration bar count so states
// change on softer, faster evidence; "Conservative" tightens both.

float structureThreshold =
     reactivity == "Early"        ? 42.0 :
     reactivity == "Balanced"     ? 55.0 :
     reactivity == "Conservative" ? 65.0 :
     customStructureThreshold

float energyLowThreshold =
     reactivity == "Early"        ? 42.0 :
     reactivity == "Balanced"     ? 35.0 :
     reactivity == "Conservative" ? 28.0 :
     customEnergyLowThreshold

float energyVeryLowThreshold =
     reactivity == "Early"        ? 28.0 :
     reactivity == "Balanced"     ? 22.0 :
     reactivity == "Conservative" ? 16.0 :
     customEnergyVeryLowThreshold

float energyHighThreshold =
     reactivity == "Early"        ? 48.0 :
     reactivity == "Balanced"     ? 60.0 :
     reactivity == "Conservative" ? 70.0 :
     customEnergyHighThreshold

float acceptanceNeutralBand =
     reactivity == "Early"        ? 12.0 :
     reactivity == "Balanced"     ? 18.0 :
     reactivity == "Conservative" ? 24.0 :
     customAcceptanceNeutralBand

float acceptancePressureThreshold =
     reactivity == "Early"        ? 16.0 :
     reactivity == "Balanced"     ? 24.0 :
     reactivity == "Conservative" ? 32.0 :
