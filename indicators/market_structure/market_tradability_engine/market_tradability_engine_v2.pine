     preset == "Very Fast" ? 10 :
     preset == "Fast"      ? 14 :
     preset == "Balanced"  ? 20 :
     preset == "Calm"      ? 30 :
     preset == "Position"  ? 45 :
     customQualityLength

int rangeLength =
     preset == "Very Fast" ? 16 :
     preset == "Fast"      ? 22 :
     preset == "Balanced"  ? 30 :
     preset == "Calm"      ? 45 :
     preset == "Position"  ? 70 :
     customRangeLength

int baselineLength =
     preset == "Very Fast" ? 18 :
     preset == "Fast"      ? 25 :
     preset == "Balanced"  ? 34 :
     preset == "Calm"      ? 50 :
     preset == "Position"  ? 80 :
     customBaselineLength

int atrLength =
     preset == "Very Fast" ? 10 :
     preset == "Fast"      ? 12 :
     preset == "Balanced"  ? 14 :
     preset == "Calm"      ? 18 :
     preset == "Position"  ? 21 :
