//@version=6
// ============================================================================
// Liquidity Hunter [WavesUnchained]
// Version: 3.4.0
// Author: WavesUnchained
// Build: 2026-07-07 00:00:00
// ============================================================================
// Focused premium liquidity tool.
//
// Features:
//   ✓ Ranks equal highs/lows by quality score (touches, age, ATR distance)
//   ✓ Separates true sweeps (wick-reject) from breakout acceptance
//   ✓ Wick-quality + close-position stop hunt detection (not just red candle + volume)
//   ✓ Reclaim scoring with structural (micro-BOS) and regime/premium-discount bonuses
//   ✓ Fair Value Gaps (3-candle imbalance) as magnet zones
//   ✓ Optional level-flip: broken levels re-tracked as opposite-side zones
//   ✓ Event priority on chart: one marker per bar (Exhaustion > Hunt > Reclaim > Sweep > Breakout)
//   ✓ Reduces chart clutter to the few levels that matter
//   ✓ Session-aware scoring and tighter alerts
//   ✓ Momentum Hybrid: qualifies sweeps/hunts with WaveTrend + MFI extremes (Exhaustion Events)
//
// ============================================================================

indicator("Liquidity Hunter [WavesUnchained]", "Liquidity Hunter", overlay=true,
     max_boxes_count=100, max_lines_count=150, max_labels_count=150)

// ============================================================================
// INPUTS
// ============================================================================

var g1 = "Liquidity Levels"
enableLevels       = input.bool(true,  "Show Liquidity Levels",         group=g1)
pivotLen           = input.int(8,      "Pivot Length",                   group=g1, minval=3, maxval=30)
eqToleranceAtr     = input.float(0.12, "Equal Level Tolerance (ATR)",    group=g1, minval=0.02, maxval=1.0, step=0.01)
minTouches         = input.int(2,      "Minimum Touches",                group=g1, minval=2, maxval=5)
maxTrackedLevels   = input.int(30,     "Max Tracked Levels / Side",      group=g1, minval=10, maxval=60)
maxLevelAge        = input.int(400,    "Max Level Age (bars)",           group=g1, minval=50, maxval=1500)
maxLevelDistance   = input.float(8.0,  "Max Level Distance (ATR)",       group=g1, minval=1.0, maxval=20.0, step=0.5)

var g2 = "Premium Events"
enableSweeps       = input.bool(true,  "Show Sweep Markers",             group=g2)
enableReclaims     = input.bool(true,  "Show Reclaim Labels",            group=g2)
minSweepAtr        = input.float(0.05, "Minimum Sweep Depth (ATR)",      group=g2, minval=0.0, maxval=1.0, step=0.01)
reclaimBars        = input.int(3,      "Reclaim Window (bars)",          group=g2, minval=1, maxval=10)
minCloseBackAtr    = input.float(0.10, "Minimum Close-Back Distance (ATR)", group=g2, minval=0.02, maxval=1.5, step=0.01)
minVolumeRatio     = input.float(1.2,  "Minimum Volume Ratio",           group=g2, minval=0.5, maxval=5.0, step=0.1)
maxEventsDisplay   = input.int(6,      "Max Premium Events",             group=g2, minval=1, maxval=20)

var g_hunt = "Stop Hunts"
enableStopHunts    = input.bool(true,  "Detect Stop Hunts",              group=g_hunt,
     tooltip="Same-bar sweep: wick through known level + volume spike + wick/close-position reversal — premium signal")
huntVolMultiplier  = input.float(1.5,  "Volume Spike Multiplier",        group=g_hunt, minval=1.0, maxval=5.0, step=0.1)
huntWickRatioMin   = input.float(0.45, "Min Rejection Wick Ratio",       group=g_hunt, minval=0.2, maxval=0.8, step=0.05,
     tooltip="Rejection wick length as a share of the bar's full range (independent of the level price). Higher = stricter rejection candle shape required.")
huntClosePosMax    = input.float(0.45, "Max Close Position in Bar",      group=g_hunt, minval=0.2, maxval=0.8, step=0.05,
     tooltip="Where the close sits within the bar's range (0 = at the low, 1 = at the high). Lower = closer to the opposite extreme required.")
maxHuntsDisplay    = input.int(8,      "Max Hunts to Show",              group=g_hunt, minval=1, maxval=30)

var g_gaps = "Fair Value Gaps"
enableGaps         = input.bool(true,  "Show Fair Value Gaps",           group=g_gaps,
     tooltip="3-candle imbalance (low > high[2] / high < low[2]) — act as magnets, price tends to return to fill them")
maxGapsDisplay     = input.int(5,      "Max FVGs to Display",            group=g_gaps, minval=1, maxval=20)
minGapSizePct      = input.float(0.05, "Min FVG Size %",                 group=g_gaps, minval=0.0, maxval=5.0, step=0.05) / 100
showGapLabels      = input.bool(true,  "Show FVG Labels",                group=g_gaps,
     tooltip="Off keeps the FVG zone as a plain box without a text label — less clutter when several gaps are open at once")

var g_ctx = "Regime Context"
enableRegimeContext = input.bool(false, "Enable Regime / Premium-Discount Context", group=g_ctx,
     tooltip="Adds range-vs-trend regime and premium/discount range location as a score bonus to reclaim events (and to the dashboard). Informational quality layer only — never gates or blocks a signal.")
regimeLookback     = input.int(50,     "Regime Lookback (bars)",         group=g_ctx, minval=20, maxval=200)
erTrendThreshold   = input.float(0.35, "Trend Efficiency Threshold",     group=g_ctx, minval=0.10, maxval=0.90, step=0.05)
contextBonusMax    = input.float(12.0, "Max Context Bonus (score pts)",  group=g_ctx, minval=0.0, maxval=25.0, step=1.0)

var g_flip = "Level Lifecycle"
enableLevelFlip    = input.bool(false, "Flip Broken Levels into Opposite Zone", group=g_flip,
     tooltip="When a level breaks with a full close-through acceptance (not a sweep-reject), keep tracking it on the opposite side (old resistance -> candidate support, and vice versa) instead of discarding it.")

var g3 = "Context"
useSessionFilter   = input.bool(false, "Use Active Session Filter",      group=g3)
activeSession      = input.session("0700-1700", "Active Session",        group=g3)
alertDistanceAtr   = input.float(1.0,  "Alert Distance (ATR)",           group=g3, minval=0.25, maxval=5.0, step=0.25)
eventMemoryBars    = input.int(30,     "Recent Event Memory (bars)",     group=g3, minval=5, maxval=100)

var g_mom = "Momentum Hybrid"
enableExhaustion = input.bool(false, "Show WT Exhaustion Context", group=g_mom,
     tooltip="Qualifies sweep and stop-hunt events with WaveTrend extremes. When a sweep fires at an oscillator extreme, the probability of a genuine reversal rises — marked as an Exhaustion Event.")
lhWtExtThr   = input.float(53.0, "WT Extreme Threshold", minval=30, maxval=80, step=1, group=g_mom,
     tooltip="Absolute WaveTrend level considered extreme. BSL sweep above +threshold = bearish exhaustion. SSL sweep below -threshold = bullish exhaustion.")
lhMfiLen     = input.int(14,     "MFI Length",           minval=5, maxval=50, group=g_mom)
exhaustColor = input.color(color.new(#e91e63, 20), "Exhaustion Color", group=g_mom)

var g4 = "Display"
showDashboard      = input.bool(true,  "Show Dashboard",                 group=g4)
showBackground     = input.bool(true,  "Highlight Armed Levels",         group=g4)
showSecondary      = input.bool(true,  "Show Secondary Levels",          group=g4)
extendBars         = input.int(15,     "Forward Extend Bars",            group=g4, minval=5, maxval=50)
debugMode          = input.bool(false, "Debug: Show Level Counts",       group=g4,
     tooltip="Adds a dashboard row showing how many levels are tracked and how many pass the active filter — use to diagnose why no lines appear")

var g5 = "Styling"
bslColor           = input.color(color.new(color.red, 10),    "BSL Color",        group=g5)
sslColor           = input.color(color.new(color.lime, 10),   "SSL Color",        group=g5)
sweepColor         = input.color(color.new(color.orange, 0),  "Sweep Color",      group=g5)
bearReclaimColor   = input.color(color.new(color.red, 0),     "Bearish Reclaim",  group=g5)
bullReclaimColor   = input.color(color.new(color.green, 0),   "Bullish Reclaim",  group=g5)
stopHuntColor      = input.color(color.new(color.yellow, 20), "Stop Hunt",        group=g5)
gapBullColor       = input.color(color.new(color.teal, 80),   "Gap Bullish",      group=g5)
gapBearColor       = input.color(color.new(color.orange, 80), "Gap Bearish",      group=g5)

// ============================================================================
// TYPES
// ============================================================================

type LiquidityLevel
    float price
    int   pivotBar
    int   lastTouchBar
    int   touches
    bool  swept
    int   sweepBar
    bool  reclaimed
    int   reclaimDir
    float lastScore

type LiquidityEvent
    int   eventBar
    float eventPrice
    int   direction
    float score
    float levelPrice
    float volumeRatio

type GapLevel
    int   gapBar
    float gapHigh
    float gapLow
    float gapSize
    int   direction

type StopHunt
    int   huntBar
    float huntPrice
    int   direction
    float volumeRatio
    float levelPrice

type ExhaustionEvent
    int   evtBar
    float evtPrice
    int   direction
    float wtOsc

// ============================================================================
// COMMON
// ============================================================================

atr14        = ta.atr(14)
avgVol       = ta.sma(volume, 20)
volRatio     = avgVol > 0 ? volume / avgVol : 1.0
inSession    = not useSessionFilter or not na(time(timeframe.period, activeSession))
toleranceAbs = math.max(atr14 * eqToleranceAtr, syminfo.mintick * 2.0)
sweepAbs     = atr14 * minSweepAtr
closeBackAbs = atr14 * minCloseBackAtr

barRange       = math.max(high - low, syminfo.mintick)
upperWickRatio = (high - math.max(open, close)) / barRange
lowerWickRatio = (math.min(open, close) - low) / barRange
closePosition  = (close - low) / barRange

// Regime Context (#9): range-vs-trend regime + premium/discount range location.
// Informational quality layer — feeds a bounded score bonus, never a gate.
rangeHigh       = ta.highest(high, regimeLookback)
rangeLow        = ta.lowest(low, regimeLookback)
rangeMid        = (rangeHigh + rangeLow) / 2
inPremiumZone   = close > rangeMid
netChangeAbs    = math.abs(close - close[regimeLookback])
sumChangeAbs    = math.sum(math.abs(close - close[1]), regimeLookback)
efficiencyRatio = sumChangeAbs > 0 ? netChangeAbs / sumChangeAbs : 0.0
isTrending      = efficiencyRatio >= erTrendThreshold
trendUp         = close > close[regimeLookback]
string regimeLabel = "Range"
if isTrending
    regimeLabel := trendUp ? "Trend Up" : "Trend Down"

// Momentum Hybrid (#8): WaveTrend + MFI for exhaustion event qualification
_lhWtEsa     = ta.ema(hlc3, 10)
_lhWtD       = ta.ema(math.abs(hlc3 - _lhWtEsa), 10)
_lhWtCi      = (hlc3 - _lhWtEsa) / (0.015 * math.max(_lhWtD, syminfo.mintick))
lhWtOsc      = ta.ema(_lhWtCi, 21)
_lhMfiTyp    = (high + low + close) / 3
_lhMfiRaw    = _lhMfiTyp * volume
_lhMfiPosSum = math.sum(_lhMfiTyp > _lhMfiTyp[1] ? _lhMfiRaw : 0.0, lhMfiLen)
_lhMfiNegSum = math.sum(_lhMfiTyp < _lhMfiTyp[1] ? _lhMfiRaw : 0.0, lhMfiLen)
lhMfi        = _lhMfiNegSum == 0 ? 100.0 : 100.0 - 100.0 / (1.0 + _lhMfiPosSum / _lhMfiNegSum)

f_level_score(_touches, _ageBars, _distAtr) =>
    touchScore  = math.min(_touches, 5) * 20.0
    agePenalty  = math.min(_ageBars / maxLevelAge, 1.0) * 18.0
    distPenalty = math.min(_distAtr, maxLevelDistance) * 7.0
    math.max(0.0, touchScore + 18.0 - agePenalty - distPenalty)

f_context_bonus(_isBearish, _inPremium, _isTrending, _trendUp, _maxBonus) =>
    // Range/trend regime + premium-discount location as bounded evidence —
    // never a gate. Bearish reclaims score higher from premium / range-reject /
    // downtrend-aligned; bullish reclaims mirror from discount / uptrend-aligned.
    bonus = 0.0
    if _isBearish and _inPremium
        bonus += _maxBonus * 0.5
    if not _isBearish and not _inPremium
        bonus += _maxBonus * 0.5
    if not _isTrending
        bonus += _maxBonus * 0.5
    else if _isBearish and not _trendUp
        bonus += _maxBonus * 0.5
    else if not _isBearish and _trendUp
        bonus += _maxBonus * 0.5
    math.min(_maxBonus, bonus)

f_event_score(_touches, _wickAtr, _closeBackAtr, _volRatio, _sessionBoost, _wtOsc, _mfi, _isBearish, _useMomentum, _structBonus, _ctxBonus) =>
    touchScore = math.min(_touches, 5) * 12.0
    wickScore  = math.min(_wickAtr, 1.5) * 18.0
    closeScore = math.min(_closeBackAtr, 1.5) * 24.0
    volScore   = math.max(0.0, math.min(_volRatio, 3.0) - 1.0) * 12.0

    // Optional WaveTrend and MFI exhaustion bonuses — momentum is a quality
    // layer only; it never gates the event and is disabled unless the user
    // opts in via the Momentum Hybrid toggle.
    wtBonus = 0.0
    mfiBonus = 0.0
    if _useMomentum
        if _isBearish and _wtOsc > lhWtExtThr
            wtBonus := 10.0
        else if not _isBearish and _wtOsc < -lhWtExtThr
            wtBonus := 10.0
        if _isBearish and _mfi > 80.0
            mfiBonus := 10.0
        else if not _isBearish and _mfi < 20.0
            mfiBonus := 10.0

    math.min(100.0, touchScore + wickScore + closeScore + volScore + _sessionBoost + wtBonus + mfiBonus + _structBonus + _ctxBonus)

// ============================================================================
// LEVEL REGISTRY
// ============================================================================

var array<LiquidityLevel> bslLevels    = array.new<LiquidityLevel>()
var array<LiquidityLevel> sslLevels    = array.new<LiquidityLevel>()
var array<LiquidityEvent> recentEvents = array.new<LiquidityEvent>()

pivotHigh = ta.pivothigh(high, pivotLen, pivotLen)
pivotLow  = ta.pivotlow(low,  pivotLen, pivotLen)

if not na(pivotHigh)
    pivotBar = bar_index - pivotLen
    found = false
    for lvl in bslLevels
        if math.abs(lvl.price - pivotHigh) <= toleranceAbs
            lvl.touches      += 1
            lvl.lastTouchBar := pivotBar
            lvl.price        := (lvl.price * (lvl.touches - 1) + pivotHigh) / lvl.touches
            found            := true
            break
    if not found
        array.push(bslLevels, LiquidityLevel.new(pivotHigh, pivotBar, pivotBar, 1, false, na, false, 0, 0.0))
    if array.size(bslLevels) > maxTrackedLevels
        array.shift(bslLevels)

if not na(pivotLow)
    pivotBar = bar_index - pivotLen
    found = false
    for lvl in sslLevels
        if math.abs(lvl.price - pivotLow) <= toleranceAbs
            lvl.touches      += 1
            lvl.lastTouchBar := pivotBar
            lvl.price        := (lvl.price * (lvl.touches - 1) + pivotLow) / lvl.touches
            found            := true
            break
    if not found
        array.push(sslLevels, LiquidityLevel.new(pivotLow, pivotBar, pivotBar, 1, false, na, false, 0, 0.0))
    if array.size(sslLevels) > maxTrackedLevels
        array.shift(sslLevels)

if atr14 > 0 and array.size(bslLevels) > 0
    for i = array.size(bslLevels) - 1 to 0
        lvl = array.get(bslLevels, i)
        if bar_index - lvl.lastTouchBar > maxLevelAge or math.abs(close - lvl.price) / atr14 > maxLevelDistance
            array.remove(bslLevels, i)

if atr14 > 0 and array.size(sslLevels) > 0
    for i = array.size(sslLevels) - 1 to 0
        lvl = array.get(sslLevels, i)
        if bar_index - lvl.lastTouchBar > maxLevelAge or math.abs(close - lvl.price) / atr14 > maxLevelDistance
            array.remove(sslLevels, i)

// ============================================================================
// FAIR VALUE GAP DETECTION (3-candle imbalance)
// ============================================================================

var array<GapLevel> gapLevels = array.new<GapLevel>()

if low > high[2]
    gapSz = low - high[2]
    if gapSz / close >= minGapSizePct
        array.unshift(gapLevels, GapLevel.new(bar_index - 1, low, high[2], gapSz, 1))
        if array.size(gapLevels) > maxGapsDisplay * 3
            array.pop(gapLevels)

if high < low[2]
    gapSz = low[2] - high
    if gapSz / close >= minGapSizePct
        array.unshift(gapLevels, GapLevel.new(bar_index - 1, low[2], high, gapSz, -1))
        if array.size(gapLevels) > maxGapsDisplay * 3
            array.pop(gapLevels)

for gap in gapLevels
    if gap.gapSize > 0
        if gap.direction == 1 and low <= gap.gapLow
            gap.gapSize := 0
        else if gap.direction == -1 and high >= gap.gapHigh
            gap.gapSize := 0

f_unfilled_gaps() =>
    result = array.new<GapLevel>()
    count  = 0
    for gap in gapLevels
        if gap.gapSize > 0 and count < maxGapsDisplay
            array.push(result, gap)
            count += 1
    result

curGaps = f_unfilled_gaps()

// ============================================================================
// SWEEP / RECLAIM ENGINE + STOP HUNT DETECTION
// ============================================================================

bslSweep           = false
sslSweep           = false
bslBreakout        = false
sslBreakout        = false
bearishReclaim     = false
bullishReclaim     = false
bearishReclaimScore = 0.0
bullishReclaimScore = 0.0
bslHunt            = false
sslHunt            = false

var array<StopHunt> stopHunts = array.new<StopHunt>()

for lvl in bslLevels
    if lvl.touches >= minTouches
        wickAtr      = atr14 > 0 ? math.max(0.0, high - lvl.price) / atr14 : 0.0
        closeBackAtr = atr14 > 0 ? math.max(0.0, lvl.price - close) / atr14 : 0.0
        touched      = high >= lvl.price + sweepAbs
        if not lvl.swept and touched
            lvl.swept    := true
            lvl.sweepBar := bar_index
            // A close that already sits beyond the level by the sweep threshold
            // is acceptance (breakout), not a sweep-and-reject — keep them apart.
            isBreakout = close >= lvl.price + sweepAbs
            if isBreakout
                bslBreakout := true
                if enableLevelFlip
                    // touches := minTouches so the flipped zone is immediately
                    // eligible for scoring/sweep/reclaim — the breakout itself
                    // is treated as equivalent evidence to reaching minTouches,
                    // instead of requiring a fresh multi-touch confirmation that
                    // may never happen right after price already broke away.
                    array.push(sslLevels, LiquidityLevel.new(lvl.price, bar_index, bar_index, minTouches, false, na, false, 0, 0.0))
                    if array.size(sslLevels) > maxTrackedLevels
                        array.shift(sslLevels)
            else
                bslSweep := true
                if enableStopHunts and upperWickRatio >= huntWickRatioMin and closePosition <= huntClosePosMax and volRatio >= huntVolMultiplier
                    bslHunt := true
                    array.unshift(stopHunts, StopHunt.new(bar_index, high, -1, volRatio, lvl.price))
                    if array.size(stopHunts) > maxHuntsDisplay
                        array.pop(stopHunts)
        canReclaim = lvl.swept and not lvl.reclaimed and bar_index <= lvl.sweepBar + reclaimBars
        if canReclaim and close <= lvl.price - closeBackAbs and volRatio >= minVolumeRatio and high >= lvl.price
            lvl.reclaimed    := true
            lvl.reclaimDir   := -1
            bearishReclaim   := true
            sessionBoost     = inSession ? 10.0 : 0.0
            structBonus      = close < low[1] ? 10.0 : 0.0
            ctxBonus         = enableRegimeContext ? f_context_bonus(true, inPremiumZone, isTrending, trendUp, contextBonusMax) : 0.0
            eventScore       = f_event_score(lvl.touches, wickAtr, closeBackAtr, volRatio, sessionBoost, lhWtOsc, lhMfi, true, enableExhaustion, structBonus, ctxBonus)
            bearishReclaimScore := math.max(bearishReclaimScore, eventScore)
            array.unshift(recentEvents, LiquidityEvent.new(bar_index, high, -1, eventScore, lvl.price, volRatio))
            if array.size(recentEvents) > maxEventsDisplay
                array.pop(recentEvents)

for lvl in sslLevels
    if lvl.touches >= minTouches
        wickAtr      = atr14 > 0 ? math.max(0.0, lvl.price - low) / atr14 : 0.0
        closeBackAtr = atr14 > 0 ? math.max(0.0, close - lvl.price) / atr14 : 0.0
        touched      = low <= lvl.price - sweepAbs
        if not lvl.swept and touched
            lvl.swept    := true
            lvl.sweepBar := bar_index
            isBreakout = close <= lvl.price - sweepAbs
            if isBreakout
                sslBreakout := true
                if enableLevelFlip
                    array.push(bslLevels, LiquidityLevel.new(lvl.price, bar_index, bar_index, minTouches, false, na, false, 0, 0.0))
                    if array.size(bslLevels) > maxTrackedLevels
                        array.shift(bslLevels)
            else
                sslSweep := true
                if enableStopHunts and lowerWickRatio >= huntWickRatioMin and (1.0 - closePosition) <= huntClosePosMax and volRatio >= huntVolMultiplier
                    sslHunt := true
                    array.unshift(stopHunts, StopHunt.new(bar_index, low, 1, volRatio, lvl.price))
                    if array.size(stopHunts) > maxHuntsDisplay
                        array.pop(stopHunts)
        canReclaim = lvl.swept and not lvl.reclaimed and bar_index <= lvl.sweepBar + reclaimBars
        if canReclaim and close >= lvl.price + closeBackAbs and volRatio >= minVolumeRatio and low <= lvl.price
            lvl.reclaimed    := true
            lvl.reclaimDir   := 1
            bullishReclaim   := true
            sessionBoost     = inSession ? 10.0 : 0.0
            structBonus      = close > high[1] ? 10.0 : 0.0
            ctxBonus         = enableRegimeContext ? f_context_bonus(false, inPremiumZone, isTrending, trendUp, contextBonusMax) : 0.0
            eventScore       = f_event_score(lvl.touches, wickAtr, closeBackAtr, volRatio, sessionBoost, lhWtOsc, lhMfi, false, enableExhaustion, structBonus, ctxBonus)
            bullishReclaimScore := math.max(bullishReclaimScore, eventScore)
            array.unshift(recentEvents, LiquidityEvent.new(bar_index, low, 1, eventScore, lvl.price, volRatio))
            if array.size(recentEvents) > maxEventsDisplay
                array.pop(recentEvents)

if array.size(recentEvents) > 0
    for i = array.size(recentEvents) - 1 to 0
        evt = array.get(recentEvents, i)
        if bar_index - evt.eventBar > eventMemoryBars
            array.remove(recentEvents, i)

// Exhaustion context: WT at an extreme near a sweep/hunt. This is diagnostic
// context only; the liquidity event path remains sweep/reclaim-driven.
exhaustionBear = enableExhaustion and (bslSweep or bslHunt) and lhWtOsc >  lhWtExtThr
exhaustionBull = enableExhaustion and (sslSweep or sslHunt) and lhWtOsc < -lhWtExtThr

var array<ExhaustionEvent> exhaustionEvents = array.new<ExhaustionEvent>()
if exhaustionBear
    array.unshift(exhaustionEvents, ExhaustionEvent.new(bar_index, high, -1, lhWtOsc))
    if array.size(exhaustionEvents) > maxEventsDisplay
        array.pop(exhaustionEvents)
if exhaustionBull
    array.unshift(exhaustionEvents, ExhaustionEvent.new(bar_index, low, 1, lhWtOsc))
    if array.size(exhaustionEvents) > maxEventsDisplay
        array.pop(exhaustionEvents)

// ============================================================================
// ACTIVE LEVEL SCORING
// ============================================================================

primaryBslPrice   = float(na)
primaryBslScore   = 0.0
primaryBslTouches = 0
secondaryBslPrice   = float(na)
secondaryBslScore   = 0.0
secondaryBslTouches = 0

primarySslPrice   = float(na)
primarySslScore   = 0.0
primarySslTouches = 0
secondarySslPrice   = float(na)
secondarySslScore   = 0.0
secondarySslTouches = 0

activeBslCount = 0
activeSslCount = 0

for lvl in bslLevels
    if lvl.touches >= minTouches and not lvl.swept and not lvl.reclaimed and lvl.price > close and atr14 > 0
        ageBars      = bar_index - lvl.lastTouchBar
        distAtr      = (lvl.price - close) / atr14
        score        = f_level_score(lvl.touches, ageBars, distAtr)
        lvl.lastScore := score
        activeBslCount += 1
        if score > primaryBslScore
            secondaryBslPrice   := primaryBslPrice
            secondaryBslScore   := primaryBslScore
            secondaryBslTouches := primaryBslTouches
            primaryBslPrice     := lvl.price
            primaryBslScore     := score
            primaryBslTouches   := lvl.touches
        else if score > secondaryBslScore
            secondaryBslPrice   := lvl.price
            secondaryBslScore   := score
            secondaryBslTouches := lvl.touches

for lvl in sslLevels
    if lvl.touches >= minTouches and not lvl.swept and not lvl.reclaimed and lvl.price < close and atr14 > 0
        ageBars      = bar_index - lvl.lastTouchBar
        distAtr      = (close - lvl.price) / atr14
        score        = f_level_score(lvl.touches, ageBars, distAtr)
        lvl.lastScore := score
        activeSslCount += 1
        if score > primarySslScore
            secondarySslPrice   := primarySslPrice
            secondarySslScore   := primarySslScore
            secondarySslTouches := primarySslTouches
            primarySslPrice     := lvl.price
            primarySslScore     := score
            primarySslTouches   := lvl.touches
        else if score > secondarySslScore
            secondarySslPrice   := lvl.price
            secondarySslScore   := score
            secondarySslTouches := lvl.touches

nearPrimaryBsl = not na(primaryBslPrice) and atr14 > 0 and (primaryBslPrice - close) / atr14 <= alertDistanceAtr
nearPrimarySsl = not na(primarySslPrice) and atr14 > 0 and (close - primarySslPrice) / atr14 <= alertDistanceAtr

recentBullScore = 0.0
recentBearScore = 0.0
for evt in recentEvents
    if evt.direction == 1
        recentBullScore := math.max(recentBullScore, evt.score)
    if evt.direction == -1
        recentBearScore := math.max(recentBearScore, evt.score)

// ============================================================================
// VISUALS
// ============================================================================

color armedBgColor = na
if showBackground
    if nearPrimaryBsl and primaryBslScore >= primarySslScore
        armedBgColor := color.new(bslColor, 90)
    else if nearPrimarySsl and primarySslScore > primaryBslScore
        armedBgColor := color.new(sslColor, 90)
bgcolor(armedBgColor, title="Armed Liquidity")

// Event priority: Exhaustion > Hunt > Reclaim > Sweep > Breakout — resolved
// globally across both sides, not per-direction, so a bar never shows a
// low-priority marker on one side while a higher-priority event fires on the
// other (e.g. a plain SSL sweep marker next to a BSL hunt on the same bar).
// Hunt, Reclaim and Exhaustion are premium events — they get a proper label
// with a hover tooltip (drawn further below, at barstate.islast) instead of a
// bare plotshape marker, and each one's label suppresses the lower-priority
// ones on the same bar regardless of direction (see the "superseded" checks
// below). Sweep/Breakout stay as minimal, unlabeled markers — ambient
// context, not a premium event.
bearSweepShow      = enableSweeps and bslSweep
bearBreakoutShow   = enableSweeps and bslBreakout
bearHuntShow       = enableStopHunts and bslHunt
bearReclaimShow    = enableReclaims and bearishReclaim
bullSweepShow      = enableSweeps and sslSweep
bullBreakoutShow   = enableSweeps and sslBreakout
bullHuntShow       = enableStopHunts and sslHunt
bullReclaimShow    = enableReclaims and bullishReclaim

bearPriority = exhaustionBear ? 5 : bearHuntShow ? 4 : bearReclaimShow ? 3 : bearSweepShow ? 2 : bearBreakoutShow ? 1 : 0
bullPriority = exhaustionBull ? 5 : bullHuntShow ? 4 : bullReclaimShow ? 3 : bullSweepShow ? 2 : bullBreakoutShow ? 1 : 0

// Global winner for this bar; ties go to the bear side (arbitrary but
// deterministic) so exactly one side's marker can ever render per bar.
barPriority     = math.max(bearPriority, bullPriority)
bearIsBarWinner = bearPriority == barPriority
bullIsBarWinner = bullPriority == barPriority and not bearIsBarWinner

plotshape(bearIsBarWinner and bearPriority == 2, "BSL Sweep", shape.triangledown,
     location.abovebar, sweepColor, size=size.tiny)
plotshape(bullIsBarWinner and bullPriority == 2, "SSL Sweep", shape.triangleup,
     location.belowbar, sweepColor, size=size.tiny)

plotshape(bearIsBarWinner and bearPriority == 1, "BSL Breakout", shape.circle,
     location.abovebar, color.new(bslColor, 60), size=size.tiny)
plotshape(bullIsBarWinner and bullPriority == 1, "SSL Breakout", shape.circle,
     location.belowbar, color.new(sslColor, 60), size=size.tiny)

var array<box>   drawBoxes  = array.new_box()
var array<line>  drawLines  = array.new_line()
var array<label> drawLabels = array.new_label()

if barstate.islast
    for bx in drawBoxes
        box.delete(bx)
    array.clear(drawBoxes)
    for ln in drawLines
        line.delete(ln)
    array.clear(drawLines)
    for lb in drawLabels
        label.delete(lb)
    array.clear(drawLabels)

    // --- Unfilled Fair Value Gaps ---
    if enableGaps and array.size(curGaps) > 0
        for i = 0 to array.size(curGaps) - 1
            gap    = array.get(curGaps, i)
            gapCol = gap.direction == 1 ? gapBullColor : gapBearColor
            pct    = gap.gapSize / close * 100
            array.push(drawBoxes, box.new(gap.gapBar, gap.gapHigh, bar_index + extendBars, gap.gapLow,
                 border_color=gapCol, bgcolor=gapCol, border_width=1,
                 border_style=line.style_dashed))
            if showGapLabels
                array.push(drawLabels, label.new(gap.gapBar,
                     gap.direction == 1 ? gap.gapLow : gap.gapHigh,
                     str.format("FVG {0}  {1}%", gap.direction == 1 ? "UP" : "DN", str.tostring(pct, "#.##")),
                     color=gapCol, textcolor=color.white,
                     style=gap.direction == 1 ? label.style_label_up : label.style_label_down,
                     size=size.small,
                     tooltip=str.format("{0} Fair Value Gap\nRange: {1} - {2}\nSize: {3}%\nUnfilled since bar {4}",
                         gap.direction == 1 ? "Bullish" : "Bearish",
                         str.tostring(gap.gapLow, format.mintick),
                         str.tostring(gap.gapHigh, format.mintick),
                         str.tostring(pct, "#.##"),
                         str.tostring(bar_index - gap.gapBar))))

    // --- BSL/SSL Levels ---
    if enableLevels
        if not na(primaryBslPrice)
            bslDistTxt = atr14 > 0 ? str.tostring((primaryBslPrice - close) / atr14, "#.##") : "n/a"
            array.push(drawLines, line.new(bar_index - 60, primaryBslPrice, bar_index + extendBars, primaryBslPrice,
                 color=bslColor, width=3))
            array.push(drawLabels, label.new(bar_index + extendBars, primaryBslPrice,
                 str.format("BSL {0}x · {1} · {2} ATR", primaryBslTouches, str.tostring(primaryBslScore, "#"), bslDistTxt),
                 style=label.style_label_left, color=bslColor, textcolor=color.white, size=size.small,
                 tooltip=str.format("Buy-Side Liquidity (primary)\nPrice: {0}\nTouches: {1}\nScore: {2}\nDistance: {3} ATR",
                     str.tostring(primaryBslPrice, format.mintick),
                     str.tostring(primaryBslTouches),
                     str.tostring(primaryBslScore, "#.#"),
                     bslDistTxt)))
        if showSecondary and not na(secondaryBslPrice)
            secBslDistTxt = atr14 > 0 ? str.tostring((secondaryBslPrice - close) / atr14, "#.##") : "n/a"
            array.push(drawLines, line.new(bar_index - 40, secondaryBslPrice, bar_index + extendBars, secondaryBslPrice,
                 color=color.new(bslColor, 45), style=line.style_dashed, width=1))
            array.push(drawLabels, label.new(bar_index + extendBars, secondaryBslPrice,
                 str.format("BSL 2 · {0} · {1} ATR", str.tostring(secondaryBslScore, "#"), secBslDistTxt),
                 style=label.style_label_left, color=color.new(bslColor, 35), textcolor=color.white, size=size.tiny,
                 tooltip=str.format("Buy-Side Liquidity (secondary)\nPrice: {0}\nTouches: {1}\nScore: {2}\nDistance: {3} ATR",
                     str.tostring(secondaryBslPrice, format.mintick),
                     str.tostring(secondaryBslTouches),
                     str.tostring(secondaryBslScore, "#.#"),
                     secBslDistTxt)))

        if not na(primarySslPrice)
            sslDistTxt = atr14 > 0 ? str.tostring((close - primarySslPrice) / atr14, "#.##") : "n/a"
            array.push(drawLines, line.new(bar_index - 60, primarySslPrice, bar_index + extendBars, primarySslPrice,
                 color=sslColor, width=3))
            array.push(drawLabels, label.new(bar_index + extendBars, primarySslPrice,
                 str.format("SSL {0}x · {1} · {2} ATR", primarySslTouches, str.tostring(primarySslScore, "#"), sslDistTxt),
                 style=label.style_label_left, color=sslColor, textcolor=color.white, size=size.small,
                 tooltip=str.format("Sell-Side Liquidity (primary)\nPrice: {0}\nTouches: {1}\nScore: {2}\nDistance: {3} ATR",
                     str.tostring(primarySslPrice, format.mintick),
                     str.tostring(primarySslTouches),
                     str.tostring(primarySslScore, "#.#"),
                     sslDistTxt)))
        if showSecondary and not na(secondarySslPrice)
            secSslDistTxt = atr14 > 0 ? str.tostring((close - secondarySslPrice) / atr14, "#.##") : "n/a"
            array.push(drawLines, line.new(bar_index - 40, secondarySslPrice, bar_index + extendBars, secondarySslPrice,
                 color=color.new(sslColor, 45), style=line.style_dashed, width=1))
            array.push(drawLabels, label.new(bar_index + extendBars, secondarySslPrice,
                 str.format("SSL 2 · {0} · {1} ATR", str.tostring(secondarySslScore, "#"), secSslDistTxt),
                 style=label.style_label_left, color=color.new(sslColor, 35), textcolor=color.white, size=size.tiny,
                 tooltip=str.format("Sell-Side Liquidity (secondary)\nPrice: {0}\nTouches: {1}\nScore: {2}\nDistance: {3} ATR",
                     str.tostring(secondarySslPrice, format.mintick),
                     str.tostring(secondarySslTouches),
                     str.tostring(secondarySslScore, "#.#"),
                     secSslDistTxt)))

        if enableReclaims and array.size(recentEvents) > 0
            for i = 0 to array.size(recentEvents) - 1
                evt = array.get(recentEvents, i)
                // A stop hunt or exhaustion event on the same bar (either
                // direction) already gets its own (higher-priority) label —
                // don't also show a lower-priority Reclaim label for that bar.
                supersededByHunt = false
                for hunt in stopHunts
                    if hunt.huntBar == evt.eventBar
                        supersededByHunt := true
                supersededByExhaustion = false
                for ex in exhaustionEvents
                    if ex.evtBar == evt.eventBar
                        supersededByExhaustion := true
                if not supersededByHunt and not supersededByExhaustion
                    evtCol  = evt.direction == 1 ? bullReclaimColor : bearReclaimColor
                    evtStyl = evt.direction == 1 ? label.style_label_up : label.style_label_down
                    array.push(drawLabels, label.new(evt.eventBar, evt.eventPrice, str.format("R {0}", str.tostring(evt.score, "#")),
                         style=evtStyl, color=evtCol, textcolor=color.white, size=size.small,
                         tooltip=str.format("{0} Reclaim\nSwept the {1} level, then closed back through it — the sweep got rejected.\nLevel: {2}\nScore: {3} / 100\nVolume: x{4}",
                             evt.direction == 1 ? "Bullish" : "Bearish",
                             evt.direction == 1 ? "SSL" : "BSL",
                             str.tostring(evt.levelPrice, format.mintick),
                             str.tostring(evt.score, "#"),
                             str.tostring(evt.volumeRatio, "#.##"))))

    // --- Stop Hunt Labels ---
    if enableStopHunts and array.size(stopHunts) > 0
        for i = 0 to array.size(stopHunts) - 1
            hunt = array.get(stopHunts, i)
            if bar_index - hunt.huntBar <= 500
                supersededByExhaustion = false
                for ex in exhaustionEvents
                    if ex.evtBar == hunt.huntBar
                        supersededByExhaustion := true
                if not supersededByExhaustion
                    array.push(drawLabels, label.new(hunt.huntBar, hunt.huntPrice, str.format("H x{0}", str.tostring(hunt.volumeRatio, "#.#")),
                         color=stopHuntColor, textcolor=color.black,
                         style=hunt.direction == -1 ? label.style_label_down : label.style_label_up,
                         size=size.small,
                         tooltip=str.format("{0} Stop Hunt\nWick pierced the level with a rejection candle (wick ratio + close position) and a volume spike.\nLevel: {1}\nVolume spike: x{2}",
                             hunt.direction == -1 ? "Bearish" : "Bullish",
                             str.tostring(hunt.levelPrice, format.mintick),
                             str.tostring(hunt.volumeRatio, "#.##"))))

    // --- Exhaustion Labels ---
    if enableExhaustion and array.size(exhaustionEvents) > 0
        for i = 0 to array.size(exhaustionEvents) - 1
            ex = array.get(exhaustionEvents, i)
            if bar_index - ex.evtBar <= 500
                array.push(drawLabels, label.new(ex.evtBar, ex.evtPrice, str.format("EX WT {0}", str.tostring(ex.wtOsc, "#")),
                     color=exhaustColor, textcolor=color.white,
                     style=ex.direction == -1 ? label.style_label_down : label.style_label_up,
                     size=size.small,
                     tooltip=str.format("{0} Exhaustion\nA sweep/hunt fired while WaveTrend was at an extreme — momentum is stretched, raising reversal odds.\nWT: {1}  (threshold {2})",
                         ex.direction == -1 ? "Bearish" : "Bullish",
                         str.tostring(ex.wtOsc, "#.#"),
                         str.tostring(lhWtExtThr, "#"))))

// ============================================================================
// DASHBOARD
// ============================================================================

if showDashboard and barstate.islast
    dashRows = 7 + (enableRegimeContext ? 1 : 0) + (debugMode ? 1 : 0) + (enableExhaustion ? 3 : 0)
    var table dash = table.new(position.top_right, 3, dashRows,
         bgcolor=color.new(color.white, 5),
         border_color=color.new(color.gray, 60),
         border_width=1,
         frame_color=color.new(color.gray, 40),
         frame_width=1)

    muted  = color.new(color.gray, 20)
    headBg = color.new(color.gray, 90)

    // Directional bias is a dashboard-only summary. It is NOT an aggregator in
    // the signal path — sweeps, reclaims, hunts and alerts never read it.
    biasValue = 0
    biasValue += bullishReclaim ? 2 : 0
    biasValue -= bearishReclaim ? 2 : 0
    biasValue += recentBullScore >= 65 ? 1 : 0
    biasValue -= recentBearScore >= 65 ? 1 : 0
    biasValue += primarySslScore > primaryBslScore and nearPrimarySsl ? 1 : 0
    biasValue -= primaryBslScore > primarySslScore and nearPrimaryBsl ? 1 : 0
    biasText  = biasValue >= 2 ? "Bullish" : biasValue <= -2 ? "Bearish" : "Neutral"
    biasColor = biasValue >= 2 ? bullReclaimColor : biasValue <= -2 ? bearReclaimColor : color.new(color.gray, 50)

    r = 0
    table.cell(dash, 0, r, "Liquidity Hunter", text_color=muted, bgcolor=headBg, text_size=size.small)
    table.cell(dash, 1, r, "Value",            text_color=muted, bgcolor=headBg, text_size=size.small)
    table.cell(dash, 2, r, "State",            text_color=muted, bgcolor=headBg, text_size=size.small)

    r += 1
    table.cell(dash, 0, r, "Bias",    text_color=muted,         text_size=size.small)
    table.cell(dash, 1, r, biasText,  text_color=color.white, bgcolor=biasColor, text_size=size.small)
    table.cell(dash, 2, r, str.tostring(biasValue), text_color=color.white, bgcolor=biasColor, text_size=size.small)

    bslDist = not na(primaryBslPrice) and atr14 > 0 ? (primaryBslPrice - close) / atr14 : na
    r += 1
    table.cell(dash, 0, r, "Primary BSL", text_color=muted, text_size=size.small)
    table.cell(dash, 1, r, not na(primaryBslPrice) ? str.tostring(primaryBslPrice, format.mintick) : "---",
         text_color=not na(primaryBslPrice) ? bslColor : muted, text_size=size.small)
    table.cell(dash, 2, r, not na(bslDist) ? str.format("S {0} | {1} ATR", str.tostring(primaryBslScore, "#"), str.tostring(bslDist, "#.#")) : "---",
         text_color=not na(primaryBslPrice) ? color.white : muted, text_size=size.tiny)

    sslDist = not na(primarySslPrice) and atr14 > 0 ? (close - primarySslPrice) / atr14 : na
    r += 1
    table.cell(dash, 0, r, "Primary SSL", text_color=muted, text_size=size.small)
    table.cell(dash, 1, r, not na(primarySslPrice) ? str.tostring(primarySslPrice, format.mintick) : "---",
         text_color=not na(primarySslPrice) ? sslColor : muted, text_size=size.small)
    table.cell(dash, 2, r, not na(sslDist) ? str.format("S {0} | {1} ATR", str.tostring(primarySslScore, "#"), str.tostring(sslDist, "#.#")) : "---",
         text_color=not na(primarySslPrice) ? color.white : muted, text_size=size.tiny)

    lastEventText  = "---"
    lastEventColor = muted
    if array.size(recentEvents) > 0
        evt           = array.get(recentEvents, 0)
        lastEventText := str.format("{0} {1}", evt.direction == 1 ? "Bull" : "Bear", str.tostring(evt.score, "#"))
        lastEventColor := evt.direction == 1 ? bullReclaimColor : bearReclaimColor

    r += 1
    table.cell(dash, 0, r, "Last Event",   text_color=muted, text_size=size.small)
    table.cell(dash, 1, r, lastEventText,  text_color=color.white, bgcolor=color.new(lastEventColor, 15), text_size=size.small)
    table.cell(dash, 2, r, str.format("Bull {0} | Bear {1}", str.tostring(recentBullScore, "#"), str.tostring(recentBearScore, "#")),
         text_color=muted, text_size=size.tiny)

    string liqStateText  = "Idle"
    color  liqStateColor = color.new(color.gray, 60)
    if bslBreakout or sslBreakout
        liqStateText  := "Breakout Accepted"
        liqStateColor := bslBreakout ? bslColor : sslColor
    else if bearishReclaim
        liqStateText  := "Bearish Reclaim Active"
        liqStateColor := bearReclaimColor
    else if bullishReclaim
        liqStateText  := "Bullish Reclaim Active"
        liqStateColor := bullReclaimColor
    else if bslSweep or bslHunt
        liqStateText  := "BSL Swept"
        liqStateColor := bslColor
    else if sslSweep or sslHunt
        liqStateText  := "SSL Swept"
        liqStateColor := sslColor
    else if nearPrimaryBsl
        liqStateText  := "Approaching BSL"
        liqStateColor := color.new(bslColor, 40)
    else if nearPrimarySsl
        liqStateText  := "Approaching SSL"
        liqStateColor := color.new(sslColor, 40)

    r += 1
    table.cell(dash, 0, r, "State",       text_color=muted, text_size=size.small)
    table.cell(dash, 1, r, liqStateText,  text_color=color.white, bgcolor=color.new(liqStateColor, 20), text_size=size.small)
    table.cell(dash, 2, r, inSession ? "Session On" : "Session Off", text_color=muted, text_size=size.small)

    if enableRegimeContext
        r += 1
        zoneText  = inPremiumZone ? "Premium" : "Discount"
        zoneColor = inPremiumZone ? bearReclaimColor : bullReclaimColor
        table.cell(dash, 0, r, "Regime",    text_color=muted, text_size=size.small)
        table.cell(dash, 1, r, regimeLabel, text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)
        table.cell(dash, 2, r, zoneText,    text_color=color.white, bgcolor=color.new(zoneColor, 20), text_size=size.small)

    gapCount  = array.size(curGaps)
    huntCount = array.size(stopHunts)
    r += 1
    table.cell(dash, 0, r, "FVG / Hunts",           text_color=muted, text_size=size.small)
    table.cell(dash, 1, r, str.format("{0} open", gapCount),
         text_color=gapCount > 0 ? color.new(color.teal, 0) : muted, text_size=size.small)
    table.cell(dash, 2, r, str.format("{0} hunts", huntCount),
         text_color=huntCount > 0 ? stopHuntColor : muted, text_size=size.small)

    if debugMode
        bslTracked = array.size(bslLevels)
        sslTracked = array.size(sslLevels)
        r += 1
        table.cell(dash, 0, r, "Debug",
             text_color=color.new(color.orange, 20), bgcolor=headBg, text_size=size.tiny)
        table.cell(dash, 1, r,
             str.format("BSL {0} tracked / {1} active", bslTracked, activeBslCount),
             text_color=activeBslCount > 0 ? bslColor : muted, text_size=size.tiny)
        table.cell(dash, 2, r,
             str.format("SSL {0} tracked / {1} active", sslTracked, activeSslCount),
             text_color=activeSslCount > 0 ? sslColor : muted, text_size=size.tiny)

    if enableExhaustion
        r += 1
        table.cell(dash, 0, r, "", bgcolor=color.new(color.gray, 80))
        table.cell(dash, 1, r, "", bgcolor=color.new(color.gray, 80))
        table.cell(dash, 2, r, "", bgcolor=color.new(color.gray, 80))

        string wtStateText  = "Neutral"
        color  wtStateColor = color.new(color.gray, 60)
        if math.abs(lhWtOsc) > lhWtExtThr
            wtStateText  := lhWtOsc > 0 ? "Extreme ↑" : "Extreme ↓"
            wtStateColor := exhaustColor
        else if lhWtOsc > 20
            wtStateText  := "Bull"
            wtStateColor := bullReclaimColor
        else if lhWtOsc < -20
            wtStateText  := "Bear"
            wtStateColor := bearReclaimColor
        exText  = exhaustionBear ? "EX BEAR" : exhaustionBull ? "EX BULL" : "—"
        exColor = exhaustionBear or exhaustionBull ? exhaustColor : color.new(color.gray, 60)

        r += 1
        table.cell(dash, 0, r, "WT State", text_color=muted,        text_size=size.small)
        table.cell(dash, 1, r, wtStateText, text_color=color.white, bgcolor=color.new(wtStateColor, 20), text_size=size.small)
        table.cell(dash, 2, r, str.format("MFI {0}", str.tostring(lhMfi, "#")), text_color=muted, text_size=size.small)

        r += 1
        table.cell(dash, 0, r, "Exhaustion", text_color=muted,     text_size=size.small)
        table.cell(dash, 1, r, exText,       text_color=color.white, bgcolor=color.new(exColor, 20), text_size=size.small)
        table.cell(dash, 2, r, str.format("WT {0}", str.tostring(lhWtOsc, "#.#")), text_color=muted, text_size=size.small)

// ============================================================================
// ALERTS
// ============================================================================

bool alertsOnBarClose = input.bool(true, "Alerts only on bar close (confirmed)", group="Alerts")
bool alertOk = not alertsOnBarClose or barstate.isconfirmed
alertcondition(alertOk and (nearPrimaryBsl and not nearPrimaryBsl[1]),
     "Primary BSL Near", "LQH · PRIMARY BSL NEAR · {{ticker}} {{interval}}")
alertcondition(alertOk and (nearPrimarySsl and not nearPrimarySsl[1]),
     "Primary SSL Near", "LQH · PRIMARY SSL NEAR · {{ticker}} {{interval}}")
alertcondition(alertOk and (bslSweep), "BSL Swept", "LQH · BUY-SIDE SWEEP · {{ticker}} {{interval}}")
alertcondition(alertOk and (sslSweep), "SSL Swept", "LQH · SELL-SIDE SWEEP · {{ticker}} {{interval}}")
alertcondition(alertOk and (bslBreakout), "BSL Breakout", "LQH · BUY-SIDE BREAKOUT · {{ticker}} {{interval}}")
alertcondition(alertOk and (sslBreakout), "SSL Breakout", "LQH · SELL-SIDE BREAKOUT · {{ticker}} {{interval}}")
alertcondition(alertOk and (bslHunt), "BSL Stop Hunt", "LQH · BUY-SIDE STOP HUNT · {{ticker}} {{interval}}")
alertcondition(alertOk and (sslHunt), "SSL Stop Hunt", "LQH · SELL-SIDE STOP HUNT · {{ticker}} {{interval}}")
alertcondition(alertOk and (bearishReclaim), "Bearish Reclaim", "LQH · BEARISH RECLAIM SHORT · {{ticker}} {{interval}}")
alertcondition(alertOk and (bullishReclaim), "Bullish Reclaim", "LQH · BULLISH RECLAIM LONG · {{ticker}} {{interval}}")
alertcondition(alertOk and (bearishReclaim and bearishReclaimScore >= 65),
     "Premium Bearish Reclaim", "LQH · PREMIUM BEARISH RECLAIM SHORT · {{ticker}} {{interval}}")
alertcondition(alertOk and (exhaustionBear), "WT Exhaustion Context Bear", "LQH · BUY-SIDE SWEEP WT EXHAUSTION SHORT · {{ticker}} {{interval}}")
alertcondition(alertOk and (exhaustionBull), "WT Exhaustion Context Bull", "LQH · SELL-SIDE SWEEP WT EXHAUSTION LONG · {{ticker}} {{interval}}")
alertcondition(alertOk and (bullishReclaim and bullishReclaimScore >= 65),
     "Premium Bullish Reclaim", "LQH · PREMIUM BULLISH RECLAIM LONG · {{ticker}} {{interval}}")
