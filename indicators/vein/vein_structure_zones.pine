//@version=6
// ============================================================================
// Vein Structure & Zones 4H [WavesUnchained]
// Version: 0.1
// Author: WavesUnchained
// ============================================================================
// Combined structural event detection and automatic zone management.
// Merges structure_events and levels_zones into a single overlay.
//
// Features:
//   ✓ Micro/Major swing detection with quality grading
//   ✓ BOS (Micro/Major) with quality
//   ✓ Spring / Upthrust with quality
//   ✓ Climax sequence state machine (CLX→TST→BOS)
//   ✓ Rejection candles
//   ✓ Auto S/R zones from Swings, Springs, BOS Flips, Climax
//   ✓ Zone lifecycle: Fresh → Tested → Confirmed → Broken → Flipped
//   ✓ Priority-based zone rendering
//   ✓ Light / Debug / Research display modes
//
// ============================================================================
indicator("Vein: Structure & Zones 4H [WavesUnchained]", "Vein S&Z", overlay=true, max_labels_count=500, max_lines_count=200, max_boxes_count=50)

// ============================================================================
// MODULE: inputs — structure
// ============================================================================

var gSwing = "Swing / Pivot"
int leftBars       = input.int(3, "Micro Pivot Left Bars", minval=1, maxval=20, group=gSwing)
int rightBars      = input.int(3, "Micro Pivot Right Bars", minval=1, maxval=20, group=gSwing)
int majorLeftBars  = input.int(7, "Major Pivot Left Bars", minval=3, maxval=30, group=gSwing, tooltip="Longer pivots = more significant structure")
int majorRightBars = input.int(7, "Major Pivot Right Bars", minval=3, maxval=30, group=gSwing)

var gStructure = "Structure"
float bosBuffer = input.float(0.0, "BOS Buffer (points)", minval=0.0, step=0.001, group=gStructure)

var gWyckoff = "Wyckoff Heuristics"
float minWickRatio     = input.float(0.35, "Min Wick Ratio for Spring/Upthrust", minval=0.1, maxval=0.8, step=0.05, group=gWyckoff)
float minCandleATR     = input.float(0.5, "Min Candle Range / ATR", minval=0.1, step=0.1, group=gWyckoff)
float climaxRangeATR   = input.float(1.8, "Climax: Min Range / ATR", minval=1.0, step=0.1, group=gWyckoff)
float climaxVolFactor  = input.float(1.8, "Climax: Min Volume / Avg", minval=1.0, step=0.1, group=gWyckoff)
float testRangeFactor  = input.float(0.6, "Test: Max Range vs Climax", minval=0.1, maxval=1.0, step=0.1, group=gWyckoff)
float testVolFactor    = input.float(0.7, "Test: Max Volume vs Climax", minval=0.1, maxval=1.0, step=0.1, group=gWyckoff)
int   testLookback     = input.int(10, "Test: Lookback Bars", minval=3, maxval=30, group=gWyckoff)
float rejWickRatio     = input.float(0.5, "Rejection: Min Wick Ratio", minval=0.2, maxval=0.8, step=0.05, group=gWyckoff)
float rejBodyMax       = input.float(0.3, "Rejection: Max Body/Range", minval=0.1, maxval=0.6, step=0.05, group=gWyckoff)

var gQuality = "Event Quality"
float strongWickRatio  = input.float(0.55, "Strong: Min Wick Ratio", minval=0.3, maxval=0.8, step=0.05, group=gQuality)
float strongCandleATR  = input.float(0.8, "Strong: Min Candle / ATR", minval=0.3, step=0.1, group=gQuality)
float strongVolFactor  = input.float(1.3, "Strong: Min Volume / Avg", minval=1.0, step=0.1, group=gQuality)
float strongSweepATR   = input.float(0.15, "Strong: Min Sweep Depth (ATR)", minval=0.0, step=0.05, group=gQuality)

// ============================================================================
// MODULE: inputs — zones
// ============================================================================

var gZones = "Zone Generation"
bool showSwingZones   = input.bool(true, "Major Swing Zones", group=gZones)
bool showSpringZones  = input.bool(true, "Spring / Upthrust Zones", group=gZones)
bool showBOSFlips     = input.bool(true, "BOS Flip Zones", group=gZones)
bool showClimaxZones  = input.bool(true, "Climax Zones", group=gZones)
float zoneWidthATR    = input.float(0.3, "Zone Width (ATR multiple)", minval=0.1, maxval=1.0, step=0.05, group=gZones)
int   maxZones        = input.int(8, "Max Visible Zones", minval=2, maxval=20, group=gZones)
int   zoneExpireBars  = input.int(200, "Zone Expire After (bars)", minval=50, maxval=500, group=gZones)
bool  showBrokenZones = input.bool(false, "Show Broken Zones", group=gZones)

// ============================================================================
// MODULE: inputs — display
// ============================================================================

var gVolume = "Volume"
int volAvgLen = input.int(20, "Volume Average Length", minval=5, group=gVolume)

var gATR = "ATR"
int atrLen = input.int(14, "ATR Length", minval=1, group=gATR)

var gAssess = "Zone Assessment"
float maxAssessDistATR = input.float(3.0, "Max Assessment Distance (ATR)", minval=1.0, step=0.5, group=gAssess)
int   approachBars     = input.int(5, "Approach Lookback Bars", minval=2, maxval=15, group=gAssess)
bool  showAssessTable  = input.bool(false, "Show Assessment Table", group=gAssess, tooltip="Assessment table (top left) — off by default")
bool  showAssessLabels = input.bool(true, "Show Assessment Labels on Zones", group=gAssess)

var gDisplay = "Display"
string displayMode  = input.string("Light", "Display Mode", options=["Light", "Debug", "Research"], group=gDisplay)
bool showSwings     = input.bool(true, "Show Swing Labels", group=gDisplay)
bool showBOS        = input.bool(true, "Show BOS Labels", group=gDisplay)
bool showFakeBreaks = input.bool(true, "Show Fake Break Labels", group=gDisplay)
bool showSpringUT   = input.bool(true, "Show Spring / Upthrust Labels", group=gDisplay)
bool showClimax     = input.bool(true, "Show Climax Labels", group=gDisplay)
bool showTest       = input.bool(true, "Show Test Labels", group=gDisplay)
bool showRejection  = input.bool(true, "Show Rejection Labels", group=gDisplay)
bool showZoneLabels = input.bool(true, "Show Zone Labels", group=gDisplay)
color supportColor  = input.color(color.new(#00e676, 0), "Support Zone Color", group=gDisplay)
color resistColor   = input.color(color.new(#ff1744, 0), "Resistance Zone Color", group=gDisplay)
color flipColor     = input.color(color.new(#ffab00, 0), "Flip Zone Color", group=gDisplay)

// ============================================================================
// MODULE: base calculations
// ============================================================================

float atrValue = ta.atr(atrLen)
float avgVol   = ta.sma(volume, volAvgLen)
float relVol   = avgVol > 0 ? volume / avgVol : 1.0
float candleRange = high - low
float bodySize    = math.abs(close - open)
float bodyToRange = candleRange > 0 ? bodySize / candleRange : 0.0
float upperWick   = high - math.max(open, close)
float lowerWick   = math.min(open, close) - low
float upperWickRatio = candleRange > 0 ? upperWick / candleRange : 0.0
float lowerWickRatio = candleRange > 0 ? lowerWick / candleRange : 0.0
float candleATR = atrValue > 0 ? candleRange / atrValue : 0.0

// Assessment context indicators
float ema20 = ta.ema(close, 20)
float ema50 = ta.ema(close, 50)
float rsi14 = ta.rsi(close, 14)
float mfi14 = ta.mfi(hlc3, 14)
float priceChange10 = math.abs(close - close[10])
float pathLength10  = math.sum(math.abs(close - close[1]), 10)
float effRatio      = pathLength10 > 0 ? priceChange10 / pathLength10 : 0.0
bool  isTrendUp     = ema20 > ema50 and effRatio > 0.35
bool  isTrendDown   = ema20 < ema50 and effRatio > 0.35
bool  isRange       = effRatio <= 0.35

// ============================================================================
// MODULE: swing detection — micro + major
// ============================================================================

float pivotHi = ta.pivothigh(high, leftBars, rightBars)
float pivotLo = ta.pivotlow(low, leftBars, rightBars)
bool isSwingHigh = not na(pivotHi)
bool isSwingLow  = not na(pivotLo)

var float lastSwingHigh = na
var float lastSwingLow  = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar  = na

if isSwingHigh
    lastSwingHigh := pivotHi
    lastSwingHighBar := bar_index - rightBars
if isSwingLow
    lastSwingLow := pivotLo
    lastSwingLowBar := bar_index - rightBars

float majorPivotHi = ta.pivothigh(high, majorLeftBars, majorRightBars)
float majorPivotLo = ta.pivotlow(low, majorLeftBars, majorRightBars)
bool isMajorSwingHigh = not na(majorPivotHi)
bool isMajorSwingLow  = not na(majorPivotLo)

var float lastMajorSwingHigh = na
var float lastMajorSwingLow  = na
var int   lastMajorSwingHighBar = na
var int   lastMajorSwingLowBar  = na

if isMajorSwingHigh
    lastMajorSwingHigh := majorPivotHi
    lastMajorSwingHighBar := bar_index - majorRightBars
if isMajorSwingLow
    lastMajorSwingLow := majorPivotLo
    lastMajorSwingLowBar := bar_index - majorRightBars

// ============================================================================
// MODULE: break of structure — micro + major
// ============================================================================

bool microBullBOS = not na(lastSwingHigh) and close > lastSwingHigh + bosBuffer and close[1] <= lastSwingHigh + bosBuffer
bool microBearBOS = not na(lastSwingLow) and close < lastSwingLow - bosBuffer and close[1] >= lastSwingLow - bosBuffer
bool majorBullBOS = not na(lastMajorSwingHigh) and close > lastMajorSwingHigh + bosBuffer and close[1] <= lastMajorSwingHigh + bosBuffer
bool majorBearBOS = not na(lastMajorSwingLow) and close < lastMajorSwingLow - bosBuffer and close[1] >= lastMajorSwingLow - bosBuffer
bool bullishBOS = microBullBOS or majorBullBOS
bool bearishBOS = microBearBOS or majorBearBOS

// ============================================================================
// MODULE: fake breaks, spring, upthrust
// ============================================================================

bool fakeBreakout       = not na(lastSwingHigh) and high > lastSwingHigh and close <= lastSwingHigh
bool fakeBreakdown      = not na(lastSwingLow) and low < lastSwingLow and close >= lastSwingLow
bool majorFakeBreakout  = not na(lastMajorSwingHigh) and high > lastMajorSwingHigh and close <= lastMajorSwingHigh
bool majorFakeBreakdown = not na(lastMajorSwingLow) and low < lastMajorSwingLow and close >= lastMajorSwingLow

bool isSpring        = fakeBreakdown and lowerWickRatio >= minWickRatio and candleATR >= minCandleATR
bool isUpthrust      = fakeBreakout and upperWickRatio >= minWickRatio and candleATR >= minCandleATR
bool isMajorSpring   = majorFakeBreakdown and lowerWickRatio >= minWickRatio and candleATR >= minCandleATR
bool isMajorUpthrust = majorFakeBreakout and upperWickRatio >= minWickRatio and candleATR >= minCandleATR

// ============================================================================
// MODULE: rejection candle
// ============================================================================

bool isBullRejection = lowerWickRatio >= rejWickRatio and bodyToRange <= rejBodyMax and close > open
bool isBearRejection = upperWickRatio >= rejWickRatio and bodyToRange <= rejBodyMax and close < open

// ============================================================================
// MODULE: event quality grading
// ============================================================================

f_eventQuality(bool triggered, float wickR, float cATR, float rv, float sweepD, float sWickR, float sCATR, float sVolF, float sSweep) =>
    int q = 0
    if triggered
        int factors = 0
        if wickR >= sWickR
            factors += 1
        if cATR >= sCATR
            factors += 1
        if rv >= sVolF
            factors += 1
        if sweepD >= sSweep
            factors += 1
        q := factors >= 3 ? 3 : factors >= 1 ? 2 : 1
    q

f_bosQuality(bool triggered, float sweep, float rv, float sVolF) =>
    int q = 0
    if triggered
        int factors = 0
        if sweep >= 0.1
            factors += 1
        if sweep >= 0.3
            factors += 1
        if rv >= sVolF
            factors += 1
        q := factors >= 2 ? 3 : factors >= 1 ? 2 : 1
    q

f_qualityTag(int q) =>
    q == 3 ? "★" : q == 2 ? "" : q == 1 ? "~" : ""

// Spring quality
float springSweepDepth = isSpring and not na(lastSwingLow) and atrValue > 0 ? (lastSwingLow - low) / atrValue : 0.0
float majorSpringSweepDepth = isMajorSpring and not na(lastMajorSwingLow) and atrValue > 0 ? (lastMajorSwingLow - low) / atrValue : 0.0
int springQuality = f_eventQuality(isSpring, lowerWickRatio, candleATR, relVol, springSweepDepth, strongWickRatio, strongCandleATR, strongVolFactor, strongSweepATR)
int majorSpringQuality = f_eventQuality(isMajorSpring, lowerWickRatio, candleATR, relVol, majorSpringSweepDepth, strongWickRatio, strongCandleATR, strongVolFactor, strongSweepATR)

// Upthrust quality
float upthrustSweepDepth = isUpthrust and not na(lastSwingHigh) and atrValue > 0 ? (high - lastSwingHigh) / atrValue : 0.0
float majorUpthrustSweepDepth = isMajorUpthrust and not na(lastMajorSwingHigh) and atrValue > 0 ? (high - lastMajorSwingHigh) / atrValue : 0.0
int upthrustQuality = f_eventQuality(isUpthrust, upperWickRatio, candleATR, relVol, upthrustSweepDepth, strongWickRatio, strongCandleATR, strongVolFactor, strongSweepATR)
int majorUpthrustQuality = f_eventQuality(isMajorUpthrust, upperWickRatio, candleATR, relVol, majorUpthrustSweepDepth, strongWickRatio, strongCandleATR, strongVolFactor, strongSweepATR)

// BOS quality
float bullBOSSweep = microBullBOS and not na(lastSwingHigh) and atrValue > 0 ? (close - lastSwingHigh) / atrValue : 0.0
float majorBullBOSSweep = majorBullBOS and not na(lastMajorSwingHigh) and atrValue > 0 ? (close - lastMajorSwingHigh) / atrValue : 0.0
float bearBOSSweep = microBearBOS and not na(lastSwingLow) and atrValue > 0 ? (lastSwingLow - close) / atrValue : 0.0
float majorBearBOSSweep = majorBearBOS and not na(lastMajorSwingLow) and atrValue > 0 ? (lastMajorSwingLow - close) / atrValue : 0.0
int microBullBOSQuality = f_bosQuality(microBullBOS, bullBOSSweep, relVol, strongVolFactor)
int majorBullBOSQuality = f_bosQuality(majorBullBOS, majorBullBOSSweep, relVol, strongVolFactor)
int microBearBOSQuality = f_bosQuality(microBearBOS, bearBOSSweep, relVol, strongVolFactor)
int majorBearBOSQuality = f_bosQuality(majorBearBOS, majorBearBOSSweep, relVol, strongVolFactor)

// Rejection quality
int bullRejQuality = f_eventQuality(isBullRejection, lowerWickRatio, candleATR, relVol, 0.0, strongWickRatio, strongCandleATR, strongVolFactor, 0.0)
int bearRejQuality = f_eventQuality(isBearRejection, upperWickRatio, candleATR, relVol, 0.0, strongWickRatio, strongCandleATR, strongVolFactor, 0.0)

// ============================================================================
// MODULE: climax candle + sequence state machine
// ============================================================================

bool isClimaxCandle = candleATR >= climaxRangeATR and avgVol > 0 and volume >= climaxVolFactor * avgVol
bool isSellingClimax = isClimaxCandle and close < open
bool isBuyingClimax  = isClimaxCandle and close > open

var int   clxState    = 0
var int   clxDirection = 0
var float clxClose    = na
var float clxHigh     = na
var float clxLow      = na
var float clxRange    = na
var float clxVolume   = na
var int   clxBar      = na
var float clxReactionExtreme = na
var int   clxTestBar  = na

if isClimaxCandle
    clxState    := 1
    clxDirection := isSellingClimax ? 1 : isBuyingClimax ? -1 : 0
    clxClose    := close
    clxHigh     := high
    clxLow      := low
    clxRange    := candleRange
    clxVolume   := volume
    clxBar      := bar_index
    clxReactionExtreme := na
    clxTestBar  := na

bool hasActiveClx = clxState >= 1 and not na(clxBar) and (bar_index - clxBar) <= testLookback * 2

if hasActiveClx and clxState == 1
    if clxDirection == 1 and close > clxClose
        clxState := 2
        clxReactionExtreme := high
    if clxDirection == -1 and close < clxClose
        clxState := 2
        clxReactionExtreme := low

if hasActiveClx and clxState == 2
    if clxDirection == 1
        clxReactionExtreme := math.max(nz(clxReactionExtreme), high)
    if clxDirection == -1
        clxReactionExtreme := math.min(nz(clxReactionExtreme, high), low)
    bool returningToZone = false
    if clxDirection == 1 and not na(clxClose) and atrValue > 0
        returningToZone := close < clxClose + 1.5 * atrValue and close > clxLow - 0.5 * atrValue
    if clxDirection == -1 and not na(clxClose) and atrValue > 0
        returningToZone := close > clxClose - 1.5 * atrValue and close < clxHigh + 0.5 * atrValue
    if returningToZone and (bar_index - clxBar) >= 2
        clxState := 3

if hasActiveClx and clxState == 3
    bool isTestBar = not na(clxRange) and not na(clxVolume) and candleRange <= clxRange * testRangeFactor and volume <= clxVolume * testVolFactor and candleRange > 0
    bool inZone = not na(clxClose) and atrValue > 0 and math.abs(close - clxClose) <= 1.5 * atrValue
    if isTestBar and inZone
        clxState   := 4
        clxTestBar := bar_index

if hasActiveClx and clxState == 4
    if clxDirection == 1 and (microBullBOS or majorBullBOS)
        clxState := 5
    if clxDirection == -1 and (microBearBOS or majorBearBOS)
        clxState := 5

if hasActiveClx and not na(clxBar) and (bar_index - clxBar) > testLookback * 2
    clxState := 0

bool clxDetected     = clxState >= 1
bool clxTestPending  = clxState == 3
bool clxTestValid    = clxState == 4 or clxState == 5
bool clxConfirmed    = clxState == 5
bool clxBullSequence = clxDirection == 1 and clxState >= 1
bool clxBearSequence = clxDirection == -1 and clxState >= 1

var int barsSinceLastTest = 999
barsSinceLastTest += 1
bool isTestCandle = clxState == 4 and bar_index == clxTestBar and barsSinceLastTest >= 3
if isTestCandle
    barsSinceLastTest := 0

string clxStateStr = clxState == 0 ? "—" : clxState == 1 ? "CLX" : clxState == 2 ? "REACTING" : clxState == 3 ? "TEST PENDING" : clxState == 4 ? "TEST VALID" : clxState == 5 ? "CONFIRMED" : "—"
string clxDirStr = clxDirection == 1 ? "Bull" : clxDirection == -1 ? "Bear" : "—"

// ============================================================================
// MODULE: zone management
// ============================================================================

type Zone
    int    zoneType
    float  upper
    float  lower
    float  mid
    int    direction
    int    quality
    int    createBar
    int    status
    int    touchCount
    float  score
    box    zoneBox
    label  zoneLabel
    // Assessment fields
    int    goodBounces
    int    weakBounces
    float  maxBounce
    float  lastBounce
    int    deepPenetrations

var array<Zone> zones = array.new<Zone>()

f_zoneTypeStr(int t) =>
    t == 1 ? "S/R Swing" : t == 2 ? "S/R Swing" : t == 3 ? "Spring" : t == 4 ? "Upthrust" : t == 5 ? "BOS Flip" : t == 6 ? "BOS Flip" : t == 7 ? "CLX Zone" : t == 8 ? "CLX Zone" : "?"

f_statusStr(int s) =>
    s == 0 ? "Fresh" : s == 1 ? "Tested" : s == 2 ? "Confirmed" : s == 3 ? "Broken" : s == 4 ? "Flipped" : "?"

f_zoneScore(int zType, int qual, int status, int age, int touches) =>
    float base = zType == 3 or zType == 4 ? 3.0 : zType == 5 or zType == 6 ? 2.5 : zType == 7 or zType == 8 ? 2.0 : 2.0
    float qBonus = qual == 3 ? 1.5 : qual == 2 ? 0.5 : 0.0
    float sBonus = status == 2 ? 1.5 : status == 1 ? 0.5 : status == 4 ? 1.0 : 0.0
    float aPenalty = age > 100 ? math.min(2.0, (age - 100) / 100.0) : 0.0
    float tBonus = math.min(1.0, touches * 0.3)
    math.max(0.0, base + qBonus + sBonus + tBonus - aPenalty)

addZone(int zType, float upper, float lower, int dir, int qual) =>
    Zone z = Zone.new()
    z.zoneType  := zType
    z.upper     := upper
    z.lower     := lower
    z.mid       := (upper + lower) / 2.0
    z.direction := dir
    z.quality   := qual
    z.createBar := bar_index
    z.status    := 0
    z.touchCount := 0
    z.score     := 0.0
    z.zoneBox   := na
    z.zoneLabel := na
    z.goodBounces := 0
    z.weakBounces := 0
    z.maxBounce   := 0.0
    z.lastBounce  := 0.0
    z.deepPenetrations := 0
    array.push(zones, z)

// ── Zone creation from events ──
float halfWidth = atrValue * zoneWidthATR / 2.0

if showSwingZones and not na(majorPivotHi)
    addZone(2, majorPivotHi + halfWidth, majorPivotHi - halfWidth, -1, 2)
if showSwingZones and not na(majorPivotLo)
    addZone(1, majorPivotLo + halfWidth, majorPivotLo - halfWidth, 1, 2)

if showSpringZones and isMajorSpring and not na(lastMajorSwingLow)
    int qual = lowerWickRatio >= 0.55 and candleATR >= 0.8 ? 3 : 2
    addZone(3, math.max(low, lastMajorSwingLow), math.min(low, lastMajorSwingLow), 1, qual)
else if showSpringZones and isSpring and not na(lastSwingLow)
    int qual = lowerWickRatio >= 0.55 and candleATR >= 0.8 ? 3 : lowerWickRatio >= minWickRatio ? 2 : 1
    addZone(3, math.max(low, lastSwingLow), math.min(low, lastSwingLow), 1, qual)

if showSpringZones and isMajorUpthrust and not na(lastMajorSwingHigh)
    int qual = upperWickRatio >= 0.55 and candleATR >= 0.8 ? 3 : 2
    addZone(4, math.max(high, lastMajorSwingHigh), math.min(high, lastMajorSwingHigh), -1, qual)
else if showSpringZones and isUpthrust and not na(lastSwingHigh)
    int qual = upperWickRatio >= 0.55 and candleATR >= 0.8 ? 3 : upperWickRatio >= minWickRatio ? 2 : 1
    addZone(4, math.max(high, lastSwingHigh), math.min(high, lastSwingHigh), -1, qual)

if showBOSFlips and majorBullBOS and not na(lastMajorSwingHigh)
    addZone(5, lastMajorSwingHigh + halfWidth, lastMajorSwingHigh - halfWidth, 1, 2)
if showBOSFlips and majorBearBOS and not na(lastMajorSwingLow)
    addZone(6, lastMajorSwingLow + halfWidth, lastMajorSwingLow - halfWidth, -1, 2)

if showClimaxZones and isClimaxCandle
    int dir = close < open ? 1 : -1
    int qual = relVol >= climaxVolFactor * 1.5 ? 3 : 2
    addZone(dir == 1 ? 7 : 8, high, low, dir, qual)

// ── Zone status updates ──
int totalZones = array.size(zones)
if totalZones > 0
    for i = totalZones - 1 to 0
        Zone z = array.get(zones, i)
        int age = bar_index - z.createBar
        if z.status == 3 and not showBrokenZones
            continue
        if age > zoneExpireBars
            if not na(z.zoneBox)
                box.delete(z.zoneBox)
            if not na(z.zoneLabel)
                label.delete(z.zoneLabel)
            array.remove(zones, i)
            continue
        bool priceInZone = high >= z.lower and low <= z.upper
        bool priceAbove  = close > z.upper
        bool priceBelow  = close < z.lower
        if priceInZone and z.status == 0
            z.status := 1
            z.touchCount += 1
        if priceInZone and z.status == 1
            z.touchCount += 1
        if z.status == 1 and z.direction == 1 and priceInZone and close > z.mid and close > open
            z.status := 2
            float bounce = atrValue > 0 ? (close - z.lower) / atrValue : 0.0
            z.lastBounce := bounce
            z.maxBounce := math.max(z.maxBounce, bounce)
            if bounce >= 0.5
                z.goodBounces += 1
            else
                z.weakBounces += 1
        if z.status == 1 and z.direction == -1 and priceInZone and close < z.mid and close < open
            z.status := 2
            float bounce = atrValue > 0 ? (z.upper - close) / atrValue : 0.0
            z.lastBounce := bounce
            z.maxBounce := math.max(z.maxBounce, bounce)
            if bounce >= 0.5
                z.goodBounces += 1
            else
                z.weakBounces += 1
        // Deep penetration tracking
        if z.direction == 1 and priceInZone and close < z.mid
            z.deepPenetrations += 1
        if z.direction == -1 and priceInZone and close > z.mid
            z.deepPenetrations += 1
        // Broken
        if z.direction == 1 and priceBelow and close[1] >= z.lower
            z.status := 3
        if z.direction == -1 and priceAbove and close[1] <= z.upper
            z.status := 3
        if z.status == 3 and z.direction == 1 and priceInZone and close < z.mid
            z.status    := 4
            z.direction := -1
        if z.status == 3 and z.direction == -1 and priceInZone and close > z.mid
            z.status    := 4
            z.direction := 1
        z.score := f_zoneScore(z.zoneType, z.quality, z.status, age, z.touchCount)
        array.set(zones, i, z)

// ============================================================================
// MODULE: visuals — event labels
// ============================================================================

bool isDebug    = displayMode == "Debug" or displayMode == "Research"
bool isResearch = displayMode == "Research"
float offsetUnit = atrValue * 0.4

// Swing dots
if showSwings and isSwingHigh
    label.new(bar_index - rightBars, pivotHi, "·", style=label.style_label_down, color=color.new(#ef5350, 50), textcolor=color.white, size=size.tiny, tooltip="Swing High: " + str.tostring(pivotHi, "#.####"))
if showSwings and isSwingLow
    label.new(bar_index - rightBars, pivotLo, "·", style=label.style_label_up, color=color.new(#66bb6a, 50), textcolor=color.white, size=size.tiny, tooltip="Swing Low: " + str.tostring(pivotLo, "#.####"))

// Spring / Upthrust
if showSpringUT and isMajorSpring
    int q = majorSpringQuality
    label.new(bar_index, low - offsetUnit * 1.2, f_qualityTag(q) + " SPRING", style=label.style_label_up, color=q == 3 ? color.lime : q == 2 ? color.new(color.lime, 15) : color.new(color.lime, 35), textcolor=color.black, size=size.normal, tooltip="MAJOR Spring [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nSweep: " + str.tostring(majorSpringSweepDepth, "#.00") + " ATR | Wick: " + str.tostring(lowerWickRatio * 100, "#.0") + "% | Vol: " + str.tostring(relVol, "#.0") + "x")
else if showSpringUT and isSpring
    int q = springQuality
    label.new(bar_index, low - offsetUnit, f_qualityTag(q) + " spring", style=label.style_label_up, color=q == 3 ? color.lime : q == 2 ? color.new(color.lime, 25) : color.new(color.lime, 50), textcolor=color.black, size=size.small, tooltip="Micro Spring [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nSweep: " + str.tostring(springSweepDepth, "#.00") + " ATR | Wick: " + str.tostring(lowerWickRatio * 100, "#.0") + "%")

if showSpringUT and isMajorUpthrust
    int q = majorUpthrustQuality
    label.new(bar_index, high + offsetUnit * 1.2, f_qualityTag(q) + " UPTHRUST", style=label.style_label_down, color=q == 3 ? color.red : q == 2 ? color.new(color.red, 15) : color.new(color.red, 35), textcolor=color.white, size=size.normal, tooltip="MAJOR Upthrust [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nSweep: " + str.tostring(majorUpthrustSweepDepth, "#.00") + " ATR | Wick: " + str.tostring(upperWickRatio * 100, "#.0") + "%")
else if showSpringUT and isUpthrust
    int q = upthrustQuality
    label.new(bar_index, high + offsetUnit, f_qualityTag(q) + " upthrust", style=label.style_label_down, color=q == 3 ? color.red : q == 2 ? color.new(color.red, 25) : color.new(color.red, 50), textcolor=color.white, size=size.small, tooltip="Micro Upthrust [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nSweep: " + str.tostring(upthrustSweepDepth, "#.00") + " ATR | Wick: " + str.tostring(upperWickRatio * 100, "#.0") + "%")

// BOS
if showBOS and majorBullBOS
    int q = majorBullBOSQuality
    label.new(bar_index, low - offsetUnit * 0.5, f_qualityTag(q) + " BOS ↑↑", style=label.style_label_up, color=q == 3 ? color.new(#00e676, 0) : q == 2 ? color.new(#00e676, 15) : color.new(#00e676, 35), textcolor=color.white, size=size.small, tooltip="MAJOR Bull BOS [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]")
else if showBOS and microBullBOS
    int q = microBullBOSQuality
    label.new(bar_index, low - offsetUnit * 0.3, f_qualityTag(q) + " bos ↑", style=label.style_label_up, color=q == 3 ? color.new(#00e676, 20) : q == 2 ? color.new(#00e676, 40) : color.new(#00e676, 60), textcolor=color.white, size=size.tiny, tooltip="Micro Bull BOS [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]")

if showBOS and majorBearBOS
    int q = majorBearBOSQuality
    label.new(bar_index, high + offsetUnit * 0.5, f_qualityTag(q) + " BOS ↓↓", style=label.style_label_down, color=q == 3 ? color.new(#ff1744, 0) : q == 2 ? color.new(#ff1744, 15) : color.new(#ff1744, 35), textcolor=color.white, size=size.small, tooltip="MAJOR Bear BOS [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]")
else if showBOS and microBearBOS
    int q = microBearBOSQuality
    label.new(bar_index, high + offsetUnit * 0.3, f_qualityTag(q) + " bos ↓", style=label.style_label_down, color=q == 3 ? color.new(#ff1744, 20) : q == 2 ? color.new(#ff1744, 40) : color.new(#ff1744, 60), textcolor=color.white, size=size.tiny, tooltip="Micro Bear BOS [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]")

// Climax sequence
if showClimax and isClimaxCandle
    string clxType = isSellingClimax ? "Selling CLX" : isBuyingClimax ? "Buying CLX" : "CLX"
    label.new(bar_index, high + offsetUnit, clxType, style=label.style_label_down, color=color.new(#e040fb, 10), textcolor=color.white, size=size.small, tooltip="Climax [" + clxDirStr + "]\nRange: " + str.tostring(candleATR, "#.0") + "x ATR | Vol: " + str.tostring(relVol, "#.0") + "x")

if showTest and isTestCandle
    string tstDir = clxDirection == 1 ? "↑" : clxDirection == -1 ? "↓" : ""
    label.new(bar_index, clxDirection == 1 ? low - offsetUnit * 0.3 : high + offsetUnit * 0.3, "TST " + tstDir, style=clxDirection == 1 ? label.style_label_up : label.style_label_down, color=color.new(#ce93d8, 15), textcolor=color.white, size=size.small, tooltip="Test Validated [" + clxDirStr + "]")

if showClimax and clxConfirmed and clxState[1] == 4
    color confCol = clxDirection == 1 ? color.new(#00e676, 0) : color.new(#ff1744, 0)
    string confText = clxDirection == 1 ? "CLX→TST→BOS ↑" : "CLX→TST→BOS ↓"
    label.new(bar_index, clxDirection == 1 ? low - offsetUnit * 1.5 : high + offsetUnit * 1.5, confText, style=clxDirection == 1 ? label.style_label_up : label.style_label_down, color=confCol, textcolor=color.white, size=size.normal, tooltip="CONFIRMED Reversal Sequence — strongest signal")

// Fake breaks
if showFakeBreaks and fakeBreakout and not isUpthrust
    label.new(bar_index, high + offsetUnit * 0.7, "FB", style=label.style_label_down, color=color.new(#ff9800, 20), textcolor=color.white, size=size.tiny, tooltip="Fake Breakout")
if showFakeBreaks and fakeBreakdown and not isSpring
    label.new(bar_index, low - offsetUnit * 0.7, "FB", style=label.style_label_up, color=color.new(#ff9800, 20), textcolor=color.white, size=size.tiny, tooltip="Fake Breakdown")

// Rejections
if showRejection and isBullRejection and not isSpring and not isMajorSpring
    int q = bullRejQuality
    label.new(bar_index, low, f_qualityTag(q) + "rej", style=label.style_label_up, color=q == 3 ? color.new(#4db6ac, 10) : q == 2 ? color.new(#4db6ac, 30) : color.new(#4db6ac, 50), textcolor=color.white, size=size.tiny, tooltip="Bull Rejection [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]")
if showRejection and isBearRejection and not isUpthrust and not isMajorUpthrust
    int q = bearRejQuality
    label.new(bar_index, high, f_qualityTag(q) + "rej", style=label.style_label_down, color=q == 3 ? color.new(#c62828, 10) : q == 2 ? color.new(#c62828, 30) : color.new(#c62828, 50), textcolor=color.white, size=size.tiny, tooltip="Bear Rejection [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]")

// Debug swing lines
plot(isDebug ? lastSwingHigh : na, "Micro Swing High", color=color.new(#ef5350, 55), style=plot.style_stepline, linewidth=1)
plot(isDebug ? lastSwingLow : na, "Micro Swing Low", color=color.new(#66bb6a, 55), style=plot.style_stepline, linewidth=1)
plot(isDebug ? lastMajorSwingHigh : na, "Major Swing High", color=color.new(#ef5350, 20), style=plot.style_stepline, linewidth=2)
plot(isDebug ? lastMajorSwingLow : na, "Major Swing Low", color=color.new(#66bb6a, 20), style=plot.style_stepline, linewidth=2)

// ============================================================================
// MODULE: visuals — zone rendering (priority-based, last bar only)
// ============================================================================

int renderCount = math.min(maxZones, array.size(zones))

if barstate.islast and array.size(zones) > 0
    for i = 0 to array.size(zones) - 1
        Zone z = array.get(zones, i)
        if not na(z.zoneBox)
            box.delete(z.zoneBox)
            z.zoneBox := na
        if not na(z.zoneLabel)
            label.delete(z.zoneLabel)
            z.zoneLabel := na
        array.set(zones, i, z)

    var array<int> rendered = array.new_int()
    array.clear(rendered)

    for r = 0 to renderCount - 1
        float bestScore = -1.0
        int bestIdx = -1
        for i = 0 to array.size(zones) - 1
            Zone z = array.get(zones, i)
            if z.score > bestScore and (z.status != 3 or showBrokenZones)
                bool alreadyDone = false
                if array.size(rendered) > 0
                    for j = 0 to array.size(rendered) - 1
                        if array.get(rendered, j) == i
                            alreadyDone := true
                            break
                if not alreadyDone
                    bestScore := z.score
                    bestIdx := i

        if bestIdx >= 0
            array.push(rendered, bestIdx)
            Zone z = array.get(zones, bestIdx)

            color baseCol = z.status == 4 ? flipColor : z.direction == 1 ? supportColor : resistColor
            color boxCol = z.status == 3 ? color.new(color.gray, 85) : z.quality == 3 ? color.new(baseCol, 75) : z.quality == 2 ? color.new(baseCol, 82) : color.new(baseCol, 88)
            color borderCol = z.status == 3 ? color.new(color.gray, 60) : z.quality == 3 ? color.new(baseCol, 30) : z.quality == 2 ? color.new(baseCol, 50) : color.new(baseCol, 65)

            z.zoneBox := box.new(z.createBar, z.upper, bar_index + 10, z.lower, border_color=borderCol, border_width=1, bgcolor=boxCol)

            if showZoneLabels
                string typeStr = f_zoneTypeStr(z.zoneType)
                string statusStr = f_statusStr(z.status)
                string qualStr = z.quality == 3 ? "★" : z.quality == 1 ? "~" : ""
                string labelText = qualStr + typeStr
                if isDebug
                    labelText := labelText + " [" + statusStr + " | " + str.tostring(z.score, "#.0") + "]"
                color lblCol = z.status == 3 ? color.new(color.gray, 40) : color.new(baseCol, 20)
                z.zoneLabel := label.new(bar_index + 5, z.mid, labelText, style=label.style_label_left, color=color.new(color.black, 100), textcolor=lblCol, size=size.small, tooltip=typeStr + "\nStatus: " + statusStr + "\nScore: " + str.tostring(z.score, "#.0") + "\nTouches: " + str.tostring(z.touchCount) + "\nQuality: " + str.tostring(z.quality) + "/3")

            array.set(zones, bestIdx, z)

// ============================================================================
// MODULE: data window
// ============================================================================

int eventCode = 0
eventCode += isSwingHigh ? 1 : 0
eventCode += isSwingLow ? 2 : 0
eventCode += microBullBOS ? 4 : 0
eventCode += microBearBOS ? 8 : 0
eventCode += majorBullBOS ? 16 : 0
eventCode += majorBearBOS ? 32 : 0
eventCode += isSpring ? 64 : 0
eventCode += isUpthrust ? 128 : 0
eventCode += isMajorSpring ? 256 : 0
eventCode += isMajorUpthrust ? 512 : 0
eventCode += isClimaxCandle ? 1024 : 0
eventCode += isTestCandle ? 2048 : 0
eventCode += isBullRejection ? 4096 : 0
eventCode += isBearRejection ? 8192 : 0

plot(eventCode, "Event Code", display=display.data_window, color=color.new(color.gray, 100))
plot(springQuality, "Spring Quality (0-3)", display=display.data_window, color=color.new(color.gray, 100))
plot(upthrustQuality, "Upthrust Quality (0-3)", display=display.data_window, color=color.new(color.gray, 100))
plot(clxState, "CLX State (0-5)", display=display.data_window, color=color.new(color.gray, 100))
plot(clxDirection, "CLX Dir (1=bull,-1=bear)", display=display.data_window, color=color.new(color.gray, 100))
plot(clxConfirmed ? 1 : 0, "CLX Confirmed", display=display.data_window, color=color.new(color.gray, 100))
plot(array.size(zones), "Total Zones", display=display.data_window, color=color.new(color.gray, 100))

// ============================================================================
// MODULE: research table
// ============================================================================

var int swHighCount = 0
var int swLowCount = 0
var int bosUpCount = 0
var int bosDnCount = 0
var int springCount = 0
var int utCount = 0
var int climaxCount = 0

if isSwingHigh
    swHighCount += 1
if isSwingLow
    swLowCount += 1
if bullishBOS
    bosUpCount += 1
if bearishBOS
    bosDnCount += 1
if isSpring or isMajorSpring
    springCount += 1
if isUpthrust or isMajorUpthrust
    utCount += 1
if isClimaxCandle
    climaxCount += 1

var table statsTable = na
if isResearch and barstate.islast
    // Count zone stats
    int zCount = array.size(zones)
    int supportCount = 0
    int resistCount  = 0
    for i = 0 to zCount - 1
        Zone z = array.get(zones, i)
        if z.direction == 1
            supportCount += 1
        else
            resistCount += 1

    statsTable := table.new(position.top_right, 2, 12, bgcolor=color.new(#1a1a2e, 5), border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.gray, 50), frame_width=2)
    table.cell(statsTable, 0, 0, "Vein Structure & Zones", text_color=color.white, text_size=size.normal)
    table.cell(statsTable, 1, 0, "v0.3", text_color=color.gray, text_size=size.normal, text_halign=text.align_right)
    // Events
    table.cell(statsTable, 0, 1, "─ EVENTS ─", text_color=color.new(color.white, 40), text_size=size.small)
    table.cell(statsTable, 1, 1, "", text_size=size.small)
    table.cell(statsTable, 0, 2, "Swing H/L", text_color=color.new(color.white, 30), text_size=size.normal)
    table.cell(statsTable, 1, 2, str.tostring(swHighCount) + " / " + str.tostring(swLowCount), text_color=color.new(color.white, 30), text_size=size.normal, text_halign=text.align_right)
    table.cell(statsTable, 0, 3, "BOS ↑/↓", text_color=color.new(color.white, 30), text_size=size.normal)
    table.cell(statsTable, 1, 3, str.tostring(bosUpCount) + " / " + str.tostring(bosDnCount), text_color=color.new(color.white, 30), text_size=size.normal, text_halign=text.align_right)
    table.cell(statsTable, 0, 4, "Springs", text_color=color.lime, text_size=size.normal)
    table.cell(statsTable, 1, 4, str.tostring(springCount), text_color=color.lime, text_size=size.normal, text_halign=text.align_right)
    table.cell(statsTable, 0, 5, "Upthrusts", text_color=color.red, text_size=size.normal)
    table.cell(statsTable, 1, 5, str.tostring(utCount), text_color=color.red, text_size=size.normal, text_halign=text.align_right)
    table.cell(statsTable, 0, 6, "Climax", text_color=color.fuchsia, text_size=size.normal)
    table.cell(statsTable, 1, 6, str.tostring(climaxCount), text_color=color.fuchsia, text_size=size.normal, text_halign=text.align_right)
    // Zones
    table.cell(statsTable, 0, 7, "─ ZONES ─", text_color=color.new(color.white, 40), text_size=size.small)
    table.cell(statsTable, 1, 7, "", text_size=size.small)
    table.cell(statsTable, 0, 8, "Total", text_color=color.white, text_size=size.normal)
    table.cell(statsTable, 1, 8, str.tostring(zCount), text_color=color.white, text_size=size.normal, text_halign=text.align_right)
    table.cell(statsTable, 0, 9, "Support", text_color=supportColor, text_size=size.normal)
    table.cell(statsTable, 1, 9, str.tostring(supportCount), text_color=supportColor, text_size=size.normal, text_halign=text.align_right)
    table.cell(statsTable, 0, 10, "Resistance", text_color=resistColor, text_size=size.normal)
    table.cell(statsTable, 1, 10, str.tostring(resistCount), text_color=resistColor, text_size=size.normal, text_halign=text.align_right)
    table.cell(statsTable, 0, 11, "Visible", text_color=color.new(color.white, 30), text_size=size.normal)
    table.cell(statsTable, 1, 11, str.tostring(renderCount), text_color=color.new(color.white, 30), text_size=size.normal, text_halign=text.align_right)

// ============================================================================
// MODULE: zone assessment — nearest zone evaluation
// ============================================================================

// Find nearest support (below price) and resistance (above price)
var int nearSupIdx = -1
var int nearResIdx = -1
var float nearSupDist = 999.0
var float nearResDist = 999.0

nearSupIdx := -1
nearResIdx := -1
nearSupDist := 999.0
nearResDist := 999.0

if (showAssessLabels or showAssessTable) and array.size(zones) > 0
    for i = 0 to array.size(zones) - 1
        Zone z = array.get(zones, i)
        if z.status == 3
            continue
        float distATR = atrValue > 0 ? math.abs(close - z.mid) / atrValue : 999.0
        if distATR > maxAssessDistATR
            continue
        if z.direction == 1 and z.mid < close and distATR < nearSupDist
            nearSupDist := distATR
            nearSupIdx := i
        if z.direction == -1 and z.mid > close and distATR < nearResDist
            nearResDist := distATR
            nearResIdx := i

// Assessment functions
f_structuralStr(Zone z) =>
    float s = z.zoneType == 3 or z.zoneType == 4 ? 30.0 : z.zoneType == 5 or z.zoneType == 6 ? 25.0 : z.zoneType == 7 or z.zoneType == 8 ? 25.0 : 20.0
    s += z.quality == 3 ? 20.0 : z.quality == 2 ? 10.0 : 4.0
    s += z.status == 2 ? 20.0 : z.status == 1 ? 10.0 : z.status == 0 ? 6.0 : -25.0
    int age = bar_index - z.createBar
    s += age < 30 ? 10.0 : age < 80 ? 5.0 : age > 150 ? -5.0 : 0.0
    math.max(0.0, math.min(100.0, s))

f_histRespect(Zone z) =>
    float h = 30.0
    h += math.min(30.0, z.goodBounces * 12.0)
    h += z.maxBounce >= 1.0 ? 15.0 : z.maxBounce >= 0.5 ? 8.0 : 0.0
    h -= math.min(20.0, z.deepPenetrations * 5.0)
    h -= z.weakBounces > z.goodBounces ? 10.0 : 0.0
    h -= z.touchCount > 3 ? (z.touchCount - 3) * 5.0 : 0.0
    if z.goodBounces >= 2 and z.lastBounce < z.maxBounce * 0.5
        h -= 10.0
    math.max(0.0, math.min(100.0, h))

f_approachQ(Zone z) =>
    float aq = 0.0
    float avgRange = ta.sma(high - low, approachBars)
    float recentRange = high - low
    if z.direction == 1
        aq += recentRange < avgRange * 0.8 ? 15.0 : 0.0
        aq += volume < avgVol * 0.9 and close < close[1] ? 10.0 : 0.0
        aq += lowerWickRatio > 0.3 and lowerWickRatio > lowerWickRatio[1] ? 10.0 : 0.0
        aq += rsi14 < 35 ? 10.0 : 0.0
        aq += mfi14 < 30 ? 8.0 : 0.0
        aq -= recentRange > avgRange * 1.2 and close < open ? 15.0 : 0.0
        aq -= volume > avgVol * 1.3 and close < open ? 12.0 : 0.0
        aq -= majorBearBOS ? 18.0 : 0.0
    else
        aq += recentRange < avgRange * 0.8 ? 15.0 : 0.0
        aq += volume < avgVol * 0.9 and close > close[1] ? 10.0 : 0.0
        aq += upperWickRatio > 0.3 and upperWickRatio > upperWickRatio[1] ? 10.0 : 0.0
        aq += rsi14 > 65 ? 10.0 : 0.0
        aq += mfi14 > 70 ? 8.0 : 0.0
        aq -= recentRange > avgRange * 1.2 and close > open ? 15.0 : 0.0
        aq -= volume > avgVol * 1.3 and close > open ? 12.0 : 0.0
        aq -= majorBullBOS ? 18.0 : 0.0
    math.max(-100.0, math.min(100.0, aq))

f_contextA(Zone z) =>
    float ca = 0.0
    if z.direction == 1
        ca += isRange ? 15.0 : isTrendDown ? -20.0 : 5.0
    else
        ca += isRange ? 15.0 : isTrendUp ? -20.0 : 5.0
    ca += effRatio < 0.25 ? 10.0 : 0.0
    math.max(-100.0, math.min(100.0, ca))

f_reachL(float distATR, Zone z) =>
    float r = distATR <= 0.5 ? 75.0 : distATR <= 1.0 ? 60.0 : distATR <= 2.0 ? 40.0 : 20.0
    if z.direction == 1 and close < close[1] and close[1] < close[2]
        r += 15.0
    if z.direction == -1 and close > close[1] and close[1] > close[2]
        r += 15.0
    if z.direction == 1 and close > close[1] and close[1] > close[2]
        r -= 15.0
    if z.direction == -1 and close < close[1] and close[1] < close[2]
        r -= 15.0
    math.max(0.0, math.min(100.0, r))

f_holdL(float structural, float respect, float aqRaw, float caRaw) =>
    float aqM = (aqRaw + 100.0) / 2.0
    float caM = (caRaw + 100.0) / 2.0
    math.max(0.0, math.min(100.0, 0.30 * structural + 0.25 * respect + 0.30 * aqM + 0.15 * caM))

f_breakL(float hold, float aqRaw, Zone z) =>
    float br = 100.0 - hold
    br += aqRaw < -30 ? 10.0 : 0.0
    br += z.touchCount > 3 ? z.touchCount * 3.0 : 0.0
    br += z.weakBounces > z.goodBounces ? 10.0 : 0.0
    if z.goodBounces >= 2 and z.lastBounce < z.maxBounce * 0.4
        br += 12.0
    math.max(0.0, math.min(100.0, br))

f_holdClass(float h) =>
    h < 31 ? "weak" : h < 51 ? "fair" : h < 71 ? "solid" : "strong"
f_reachClass(float r) =>
    r < 26 ? "low" : r < 51 ? "moderate" : r < 76 ? "elevated" : "high"
f_breakClass(float b) =>
    b < 26 ? "niedrig" : b < 51 ? "mittel" : b < 76 ? "erhoeht" : "hoch"
f_stateCalc(float hold, float brk, float aqRaw, Zone z) =>
    brk >= 65 and aqRaw < -20 ? "BREAK WAHRSCH." : hold >= 65 ? "REAKTION WAHRSCH." : hold >= 50 and brk >= 50 ? "UNTER DRUCK" : z.touchCount > 3 and z.lastBounce < z.maxBounce * 0.5 ? "SCHWAECHELT" : hold >= 50 ? "HALT MOEGLICH" : "STABIL"

// Run assessment
var float supStruct = 0.0
var float supResp   = 0.0
var float supAQ     = 0.0
var float supCA     = 0.0
var float supReach  = 0.0
var float supHold   = 0.0
var float supBreak  = 0.0
var string supState = "—"
var string supType  = "—"
var bool  supOK     = false

var float resStruct = 0.0
var float resResp   = 0.0
var float resAQ     = 0.0
var float resCA     = 0.0
var float resReach  = 0.0
var float resHold   = 0.0
var float resBreak  = 0.0
var string resState = "—"
var string resType  = "—"
var bool  resOK     = false

if (showAssessLabels or showAssessTable) and nearSupIdx >= 0 and nearSupIdx < array.size(zones)
    Zone z = array.get(zones, nearSupIdx)
    supStruct := f_structuralStr(z)
    supResp   := f_histRespect(z)
    supAQ     := f_approachQ(z)
    supCA     := f_contextA(z)
    supReach  := f_reachL(nearSupDist, z)
    supHold   := f_holdL(supStruct, supResp, supAQ, supCA)
    supBreak  := f_breakL(supHold, supAQ, z)
    supState  := f_stateCalc(supHold, supBreak, supAQ, z)
    supType   := f_zoneTypeStr(z.zoneType)
    supOK     := true
else
    supOK := false

if (showAssessLabels or showAssessTable) and nearResIdx >= 0 and nearResIdx < array.size(zones)
    Zone z = array.get(zones, nearResIdx)
    resStruct := f_structuralStr(z)
    resResp   := f_histRespect(z)
    resAQ     := f_approachQ(z)
    resCA     := f_contextA(z)
    resReach  := f_reachL(nearResDist, z)
    resHold   := f_holdL(resStruct, resResp, resAQ, resCA)
    resBreak  := f_breakL(resHold, resAQ, z)
    resState  := f_stateCalc(resHold, resBreak, resAQ, z)
    resType   := f_zoneTypeStr(z.zoneType)
    resOK     := true
else
    resOK := false

// Assessment labels on chart
var label supAssessLabel = na
var label resAssessLabel = na

if barstate.islast
    if not na(supAssessLabel)
        label.delete(supAssessLabel)
    if not na(resAssessLabel)
        label.delete(resAssessLabel)

    if showAssessLabels and supOK and nearSupIdx >= 0 and nearSupIdx < array.size(zones)
        Zone z = array.get(zones, nearSupIdx)
        string txt = "H" + str.tostring(supHold, "#") + " B" + str.tostring(supBreak, "#") + " R" + str.tostring(supReach, "#")
        color col = supHold > supBreak + 10 ? color.new(#00e676, 10) : supBreak > supHold + 10 ? color.new(#ff1744, 10) : color.new(#ffab00, 10)
        supAssessLabel := label.new(bar_index + 8, z.mid, txt, style=label.style_label_left, color=color.new(color.black, 100), textcolor=col, size=size.normal, tooltip="Support: " + supType + "\nReach: " + str.tostring(supReach, "#") + " " + f_reachClass(supReach) + "\nHold: " + str.tostring(supHold, "#") + " " + f_holdClass(supHold) + "\nBreak: " + str.tostring(supBreak, "#") + " " + f_breakClass(supBreak) + "\nState: " + supState + "\nStructure: " + str.tostring(supStruct, "#") + " | Respect: " + str.tostring(supResp, "#") + "\nApproach: " + str.tostring(supAQ, "#") + " | Context: " + str.tostring(supCA, "#"))

    if showAssessLabels and resOK and nearResIdx >= 0 and nearResIdx < array.size(zones)
        Zone z = array.get(zones, nearResIdx)
        string txt = "H" + str.tostring(resHold, "#") + " B" + str.tostring(resBreak, "#") + " R" + str.tostring(resReach, "#")
        color col = resHold > resBreak + 10 ? color.new(#ff1744, 10) : resBreak > resHold + 10 ? color.new(#00e676, 10) : color.new(#ffab00, 10)
        resAssessLabel := label.new(bar_index + 8, z.mid, txt, style=label.style_label_left, color=color.new(color.black, 100), textcolor=col, size=size.normal, tooltip="Resistance: " + resType + "\nReach: " + str.tostring(resReach, "#") + " " + f_reachClass(resReach) + "\nHold: " + str.tostring(resHold, "#") + " " + f_holdClass(resHold) + "\nBreak: " + str.tostring(resBreak, "#") + " " + f_breakClass(resBreak) + "\nState: " + resState + "\nStructure: " + str.tostring(resStruct, "#") + " | Respect: " + str.tostring(resResp, "#") + "\nApproach: " + str.tostring(resAQ, "#") + " | Context: " + str.tostring(resCA, "#"))

// Assessment table
var table assessTable = na
if showAssessTable and barstate.islast
    assessTable := table.new(position.top_left, 3, 12, bgcolor=color.new(#1a1a2e, 5), border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.gray, 50), frame_width=2)
    table.cell(assessTable, 0, 0, "Zone Assessment", text_color=color.white, text_size=size.normal)
    table.cell(assessTable, 1, 0, "SUPPORT", text_color=#00e676, text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 2, 0, "RESISTANCE", text_color=#ff1744, text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 0, 1, "Zone", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 1, supOK ? supType : "—", text_color=supOK ? color.new(color.white, 20) : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 1, resOK ? resType : "—", text_color=resOK ? color.new(color.white, 20) : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 0, 2, "Distance", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 2, supOK ? str.tostring(nearSupDist, "#.1") + " ATR" : "—", text_color=color.new(color.white, 20), text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 2, resOK ? str.tostring(nearResDist, "#.1") + " ATR" : "—", text_color=color.new(color.white, 20), text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 0, 3, "Structure", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 3, supOK ? str.tostring(supStruct, "#") : "—", text_color=supOK and supStruct >= 60 ? #00e676 : supOK and supStruct >= 40 ? color.yellow : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 3, resOK ? str.tostring(resStruct, "#") : "—", text_color=resOK and resStruct >= 60 ? #ff1744 : resOK and resStruct >= 40 ? color.yellow : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 0, 4, "Respect", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 4, supOK ? str.tostring(supResp, "#") : "—", text_color=supOK and supResp >= 60 ? #00e676 : supOK and supResp >= 40 ? color.yellow : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 4, resOK ? str.tostring(resResp, "#") : "—", text_color=resOK and resResp >= 60 ? #ff1744 : resOK and resResp >= 40 ? color.yellow : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 0, 5, "Approach", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 5, supOK ? str.tostring(supAQ, "#") : "—", text_color=supOK and supAQ > 10 ? #00e676 : supOK and supAQ < -10 ? #ff1744 : color.yellow, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 5, resOK ? str.tostring(resAQ, "#") : "—", text_color=resOK and resAQ > 10 ? #ff1744 : resOK and resAQ < -10 ? #00e676 : color.yellow, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 0, 6, "Context", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 6, supOK ? str.tostring(supCA, "#") : "—", text_color=supOK and supCA > 5 ? #00e676 : supOK and supCA < -5 ? #ff1744 : color.yellow, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 6, resOK ? str.tostring(resCA, "#") : "—", text_color=resOK and resCA > 5 ? #ff1744 : resOK and resCA < -5 ? #00e676 : color.yellow, text_size=size.small, text_halign=text.align_center)
    // Results
    table.cell(assessTable, 0, 7, "─ RESULT ─", text_color=color.new(color.white, 40), text_size=size.small)
    table.cell(assessTable, 1, 7, "", text_size=size.small)
    table.cell(assessTable, 2, 7, "", text_size=size.small)
    table.cell(assessTable, 0, 8, "Reach", text_color=color.new(color.white, 30), text_size=size.normal)
    table.cell(assessTable, 1, 8, supOK ? str.tostring(supReach, "#") + " " + f_reachClass(supReach) : "—", text_color=supOK and supReach >= 60 ? #00e676 : color.new(color.white, 30), text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 2, 8, resOK ? str.tostring(resReach, "#") + " " + f_reachClass(resReach) : "—", text_color=resOK and resReach >= 60 ? #ff1744 : color.new(color.white, 30), text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 0, 9, "Hold", text_color=color.new(color.white, 30), text_size=size.normal)
    table.cell(assessTable, 1, 9, supOK ? str.tostring(supHold, "#") + " " + f_holdClass(supHold) : "—", text_color=supOK and supHold >= 60 ? #00e676 : supOK and supHold >= 45 ? color.yellow : color.gray, text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 2, 9, resOK ? str.tostring(resHold, "#") + " " + f_holdClass(resHold) : "—", text_color=resOK and resHold >= 60 ? #ff1744 : resOK and resHold >= 45 ? color.yellow : color.gray, text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 0, 10, "Break", text_color=color.new(color.white, 30), text_size=size.normal)
    table.cell(assessTable, 1, 10, supOK ? str.tostring(supBreak, "#") + " " + f_breakClass(supBreak) : "—", text_color=supOK and supBreak >= 60 ? #ff1744 : supOK and supBreak >= 45 ? color.yellow : #00e676, text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 2, 10, resOK ? str.tostring(resBreak, "#") + " " + f_breakClass(resBreak) : "—", text_color=resOK and resBreak >= 60 ? #00e676 : resOK and resBreak >= 45 ? color.yellow : #ff1744, text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 0, 11, "Status", text_color=color.white, text_size=size.normal)
    color supSCol = supState == "REAKTION WAHRSCH." ? #00e676 : supState == "BREAK WAHRSCH." ? #ff1744 : str.contains(supState, "DRUCK") or str.contains(supState, "SCHWAECHELT") ? #ffab00 : color.new(color.white, 30)
    color resSCol = resState == "REAKTION WAHRSCH." ? #ff1744 : resState == "BREAK WAHRSCH." ? #00e676 : str.contains(resState, "DRUCK") or str.contains(resState, "SCHWAECHELT") ? #ffab00 : color.new(color.white, 30)
    table.cell(assessTable, 1, 11, supOK ? supState : "—", text_color=supSCol, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 11, resOK ? resState : "—", text_color=resSCol, text_size=size.small, text_halign=text.align_center)

// Assessment alerts
bool supNear = supOK and nearSupDist <= 1.0
bool resNear = resOK and nearResDist <= 1.0
alertcondition(supNear and supReach >= 60, "Support Relevant", "Vein: Support zone becoming relevant")
alertcondition(resNear and resReach >= 60, "Resistance Relevant", "Vein: Resistance zone becoming relevant")
alertcondition(supNear and supHold >= 60 and supBreak < 45, "Likely Support Hold", "Vein: Support likely to hold")
alertcondition(resNear and resHold >= 60 and resBreak < 45, "Likely Resist Hold", "Vein: Resistance likely to hold")
alertcondition(supNear and supBreak >= 60 and supHold < 45, "Likely Support Break", "Vein: Support break risk elevated")
alertcondition(resNear and resBreak >= 60 and resHold < 45, "Likely Resist Break", "Vein: Resistance break risk elevated")
