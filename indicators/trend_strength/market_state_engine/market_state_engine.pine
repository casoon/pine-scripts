        label trackedLabel = array.get(breakoutFollowupLabels, i)
        int trackedDirection = array.get(breakoutFollowupDirections, i)
        int trackedStartBar = array.get(breakoutFollowupStartBars, i)
        int trackedStatus = array.get(breakoutFollowupStatuses, i)
        float trackedHigh = array.get(breakoutFollowupHighs, i)
        float trackedLow = array.get(breakoutFollowupLows, i)
        string trackedTooltip = array.get(breakoutFollowupTooltips, i)
        int trackedAge = bar_index - trackedStartBar
        if trackedAge > 0
            if trackedDirection == 1
                if close < trackedHigh
                    trackedStatus := BREAKOUT_FAILED
                else if low <= trackedHigh + safeAtr * 0.15 and close > trackedHigh
                    trackedStatus := BREAKOUT_RETESTED
                else if trackedAge >= 2 and trackedStatus == BREAKOUT_NONE
                    trackedStatus := BREAKOUT_HELD
            else
                if close > trackedLow
                    trackedStatus := BREAKOUT_FAILED
                else if high >= trackedLow - safeAtr * 0.15 and close < trackedLow
                    trackedStatus := BREAKOUT_RETESTED
                else if trackedAge >= 2 and trackedStatus == BREAKOUT_NONE
                    trackedStatus := BREAKOUT_HELD
        array.set(breakoutFollowupStatuses, i, trackedStatus)
        label.set_tooltip(trackedLabel, trackedTooltip + "\nFollow-up: " + f_breakoutFollowupName(trackedStatus))
        if trackedAge >= breakoutFollowupBars
            array.remove(breakoutFollowupLabels, i)
            array.remove(breakoutFollowupDirections, i)
            array.remove(breakoutFollowupStartBars, i)
            array.remove(breakoutFollowupStatuses, i)
            array.remove(breakoutFollowupHighs, i)
            array.remove(breakoutFollowupLows, i)
            array.remove(breakoutFollowupTooltips, i)
// ─────────────────────────────────────────────────────────────────────────────
// VISUALS
// ─────────────────────────────────────────────────────────────────────────────
color currentStateColor = f_stateColor(confirmedState, 0)
int backgroundTransparency = confirmedState == STATE_COMPRESSION ? 91 : 94
color backgroundColor = na
if showBackground and engineReady
    backgroundColor := f_stateColor(confirmedState, backgroundTransparency)
bgcolor(backgroundColor)
plot(
     showZoneVwap ? zoneVwapPlotValue : na,
     "Box VWAP",
     color = color.new(color.rgb(60, 115, 190), 25),
     linewidth = 1,
     style = plot.style_linebr
)
// Adaptive value zone
pValueUpper = plot(
     showValueZone ? valueUpper : na,
     "Value High",
     color = color.new(color.rgb(110, 130, 160), 62),
     linewidth = 1
)
pFairValue = plot(
     showValueZone ? fairValue : na,
     "Fair Value",
     color = color.new(color.rgb(80, 105, 145), 12),
     linewidth = 2
)
pValueLower = plot(
     showValueZone ? valueLower : na,
     "Value Low",
     color = color.new(color.rgb(110, 130, 160), 62),
     linewidth = 1
)
color valueAreaFillColor = na
if showValueZone
    valueAreaFillColor := color.new(color.rgb(95, 120, 155), 91)
fill(
     pValueUpper,
     pValueLower,
     color = valueAreaFillColor,
     title = "Adaptive Value Area"
)
// Structure
plot(
     showStructureLines ? structureFast : na,
     "Fast Structure",
     color = color.new(currentStateColor, 18),
     linewidth = 2
)
plot(
     showStructureLines ? structureSlow : na,
     "Slow Structure",
     color = color.new(currentStateColor, 55),
     linewidth = 2
)
// Optional candle coloring
color candleColor = na
if colorBars and engineReady
    candleColor := f_stateColor(confirmedState, 28)
barcolor(candleColor)
// State transitions
bool expansionStarted =
     confirmedStateChanged and
     (
         confirmedState == STATE_BULL_EXPANSION or
         confirmedState == STATE_BEAR_EXPANSION
     )
if showStateTransitions and expansionStarted
    bool bullishExpansion = confirmedState == STATE_BULL_EXPANSION
    label.new(
         bar_index,
         bullishExpansion ? low : high,
         "EXP",
         color = bullishExpansion ? color.rgb(25, 160, 95) : color.rgb(205, 65, 70),
         textcolor = color.white,
         yloc = bullishExpansion ? yloc.belowbar : yloc.abovebar,
         style = bullishExpansion ? label.style_label_up : label.style_label_down,
         size = size.tiny,
         tooltip = f_expansionTooltip(
             confirmedState,
             rawStateConfidence,
             bullishExpansion ? bullExpansionScore : bearExpansionScore,
             marketQuality,
             normalizedLocation,
             directionalBias,
             htfContext
         )
    )
// Context readiness markers
plotshape(
     showCompatibilityMarkers and
     longReadinessStarted,
     title = "Long Context Ready",
     style = shape.triangleup,
     location = location.belowbar,
     color = color.new(color.rgb(25, 160, 95), 10),
     size = size.tiny
)
plotshape(
     showCompatibilityMarkers and
     shortReadinessStarted,
     title = "Short Context Ready",
     style = shape.triangledown,
     location = location.abovebar,
     color = color.new(color.rgb(205, 65, 70), 10),
     size = size.tiny
)
// ─────────────────────────────────────────────────────────────────────────────
// DASHBOARD
// ─────────────────────────────────────────────────────────────────────────────
color tc = color.new(color.gray, 20)
color hd = color.new(color.gray, 90)

var table dashboard = table.new(
     position.top_right,
     2,
     13,
     bgcolor = color.new(color.white, 5),
     border_color = color.new(color.gray, 60),
     border_width = 1,
     frame_color = color.new(color.gray, 40),
     frame_width = 1
)
if barstate.islast and showDashboard
    table.cell(
         dashboard,
         0,
         0,
         "MARKET STATE",
         text_color = tc,
         bgcolor = hd,
         text_size = size.small
    )
    table.cell(
         dashboard,
         1,
         0,
         "ENGINE",
         text_color = tc,
         bgcolor = hd,
         text_size = size.small
    )
    table.cell(
         dashboard,
         0,
         1,
         "State",
         text_color = tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         1,
         1,
         f_stateDisplayName(engineReady, confirmedState, confirmedTransitionReason),
         text_color = color.white,
         bgcolor = engineReady ? f_stateColor(confirmedState, 10) : color.new(color.gray, 45),
         text_size = size.small
    )
    table.cell(
         dashboard,
         0,
         2,
         "Location",
         text_color = tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         1,
         2,
         engineReady ? f_locationName(normalizedLocation) : "—",
         text_color = engineReady ? f_locationColor(normalizedLocation) : tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         0,
         3,
         "Auction Pressure",
         text_color = tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         1,
         3,
         engineReady ? f_biasName(directionalBias) : "—",
         text_color = engineReady ? f_biasColor(directionalBias, 0) : tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         0,
         4,
         "Energy",
         text_color = tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         1,
         4,
         engineReady ? f_energyPhaseName(energyPhase) : "—",
         text_color = tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         0,
         5,
         "State Quality",
         text_color = tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         1,
         5,
         engineReady ? f_qualityName(marketQuality) : "—",
         text_color = tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         0,
         6,
         "After Impulse",
         text_color = tc,
         text_size = size.small
    )
    color balanceContextColor = tc
    if balanceHasImpulseContext and not impulseTrendIntact
        balanceContextColor := color.rgb(255, 111, 0)
    else if balanceHasImpulseContext and lastImpulseDirection == 1
        balanceContextColor := color.rgb(0, 150, 45)
    else if balanceHasImpulseContext and lastImpulseDirection == -1
        balanceContextColor := color.rgb(213, 0, 0)
    table.cell(
         dashboard,
         1,
         6,
         engineReady and balanceContextState ? balanceContextName : "—",
         text_color = balanceContextColor,
         text_size = size.small
    )
    table.cell(dashboard, 0, 7, "", bgcolor = color.new(color.gray, 80))
    table.cell(dashboard, 1, 7, "", bgcolor = color.new(color.gray, 80))
    table.cell(
         dashboard,
         0,
         8,
         "HTF",
         text_color = tc,
         text_size = size.small
    )
    color htfTextColor = tc
    if htfEnabled and htfBull
        htfTextColor := color.rgb(0, 150, 45)
    else if htfEnabled and htfBear
        htfTextColor := color.rgb(213, 0, 0)
    table.cell(
         dashboard,
         1,
         8,
         engineReady ? htfContext : "—",
         text_color = engineReady ? htfTextColor : tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         0,
         9,
         "Long Context",
         text_color = tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         1,
         9,
         engineReady ? f_contextLevelName(longContextLevel) : "—",
         text_color = engineReady and longContextLevel >= CONTEXT_COMPATIBLE ? color.white : tc,
         bgcolor = engineReady and longContextLevel >= CONTEXT_COMPATIBLE ? color.new(color.rgb(0, 150, 45), longContextLevel == CONTEXT_PREFERRED ? 0 : 18) : color.new(color.gray, 80),
         text_size = size.small
    )
    table.cell(
         dashboard,
         0,
         10,
         "Short Context",
         text_color = tc,
         text_size = size.small
    )
    table.cell(
         dashboard,
         1,
         10,
         engineReady ? f_contextLevelName(shortContextLevel) : "—",
         text_color = engineReady and shortContextLevel >= CONTEXT_COMPATIBLE ? color.white : tc,
         bgcolor = engineReady and shortContextLevel >= CONTEXT_COMPATIBLE ? color.new(color.rgb(213, 0, 0), shortContextLevel == CONTEXT_PREFERRED ? 0 : 18) : color.new(color.gray, 80),
         text_size = size.small
    )
    table.cell(dashboard, 0, 11, "Structure", text_color = tc, text_size = size.small)
    table.cell(
         dashboard,
         1,
         11,
         engineReady ? f_regimeName(structureRegime) : "—",
         text_color = tc,
         text_size = size.small
    )
    table.cell(dashboard, 0, 12, "Transition", text_color = tc, text_size = size.small)
    table.cell(
         dashboard,
         1,
         12,
         confirmedState == STATE_TRANSITION ? f_transitionReasonName(confirmedTransitionReason) : "—",
         text_color = tc,
         text_size = size.small
    )
// ─────────────────────────────────────────────────────────────────────────────
// DATA WINDOW OUTPUTS
// ─────────────────────────────────────────────────────────────────────────────
plot(
     engineReady ? 1 : 0,
     "Engine Ready",
     display = display.data_window
)
plot(
     confirmedState,
     "Confirmed State ID",
     display = display.data_window
)
plot(
     rawState,
     "Raw State ID",
     display = display.data_window
)
plot(structureRegime, "Structure Regime ID", display = display.data_window)
plot(energyPhase, "Energy Phase ID", display = display.data_window)
plot(confirmedTransitionReason, "Transition Reason ID", display = display.data_window)
plot(longContextLevel, "Long Context Level", display = display.data_window)
plot(shortContextLevel, "Short Context Level", display = display.data_window)
plot(
     rawStateConfidence * 100.0,
     "Raw State Confidence %",
     display = display.data_window
)
plot(
     compressionScore * 100.0,
     "Compression Score %",
     display = display.data_window
)
plot(
     expansionScore * 100.0,
     "Expansion Score %",
     display = display.data_window
)
plot(
     bullExpansionScore * 100.0,
     "Bull Expansion Score %",
     display = display.data_window
)
plot(
     bearExpansionScore * 100.0,
     "Bear Expansion Score %",
     display = display.data_window
)
plot(
     exhaustionScore * 100.0,
     "Exhaustion Score %",
     display = display.data_window
)
plot(
     balanceScore * 100.0,
     "Balance Score %",
     display = display.data_window
)
plot(bestStateScore * 100.0, "Best State Candidate %", display = display.data_window)
plot(secondStateScore * 100.0, "Second State Candidate %", display = display.data_window)
plot(stateDominance * 100.0, "State Dominance %", display = display.data_window)
plot(
     marketQuality * 100.0,
     "State Quality %",
     display = display.data_window
)
plot(trendQuality * 100.0, "Trend Quality %", display = display.data_window)
plot(balanceQuality * 100.0, "Balance Quality %", display = display.data_window)
plot(
     directionalBias * 100.0,
     "Auction Pressure Score",
     display = display.data_window
)
plot(
     normalizedLocation,
     "Normalized Value Location",
     display = display.data_window
)
plot(
     efficiencyRatio * 100.0,
     "Market Efficiency %",
     display = display.data_window
)
plot(
     lastImpulseDirection,
     "Prior Impulse Direction",
     display = display.data_window
)
plot(lastImpulseSizeAtr, "Prior Impulse Net Progress ATR", display = display.data_window)
plot(lastImpulseGrossRangeAtr, "Prior Impulse Gross Range ATR", display = display.data_window)
plot(lastImpulseEfficiency * 100.0, "Prior Impulse Efficiency %", display = display.data_window)
plot(
     balanceHasImpulseContext ? correctionDepth * 100.0 : na,
     "Correction Depth %",
     display = display.data_window
)
// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(
     confirmedStateChanged,
     "MSE: Market State Changed",
     "Market State Engine: The confirmed market state has changed."
)
alertcondition(
     confirmedStateChanged and confirmedState == STATE_COMPRESSION,
     "MSE: Compression Started",
     "Market State Engine: A confirmed compression phase has started."
)
alertcondition(
     confirmedStateChanged and confirmedState == STATE_BULL_EXPANSION,
     "MSE: Bull Expansion Started",
     "Market State Engine: A confirmed bullish expansion has started."
)
alertcondition(
     confirmedStateChanged and confirmedState == STATE_BEAR_EXPANSION,
     "MSE: Bear Expansion Started",
     "Market State Engine: A confirmed bearish expansion has started."
)
alertcondition(
     confirmedStateChanged and confirmedState == STATE_BULL_EXHAUSTION,
     "MSE: Bull Exhaustion",
     "Market State Engine: The current upward move shows exhaustion characteristics."
)
alertcondition(
     confirmedStateChanged and confirmedState == STATE_BEAR_EXHAUSTION,
     "MSE: Bear Exhaustion",
     "Market State Engine: The current downward move shows exhaustion characteristics."
)
alertcondition(
     bullZoneBreak,
     "MSE: Zone Breakout Up",
     "Market State Engine: Confirmed upper breakout from a Balance/Compression zone; this identifies direction, not the zone's prior pressure."
)
alertcondition(
     bearZoneBreak,
     "MSE: Zone Breakout Down",
     "Market State Engine: Confirmed lower breakout from a Balance/Compression zone; this identifies direction, not the zone's prior pressure."
)
alertcondition(
     longReadinessStarted,
     "MSE: Long Context Ready",
     "Market State Engine: The market context is suitable for evaluating a long signal."
)
alertcondition(
     shortReadinessStarted,
     "MSE: Short Context Ready",
     "Market State Engine: The market context is suitable for evaluating a short signal."
)
alertcondition(
     postImpulseContextStarted,
     "MSE: Post-Impulse Zone Started",
     "Market State Engine: A Balance/Compression phase has started after a prior impulse; it may be classified as a pause, correction, or phase without clear continuation."
)
