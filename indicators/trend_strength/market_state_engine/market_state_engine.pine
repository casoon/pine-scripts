     "State Background",
     group = GROUP_VISUAL
)
bool showValueZone = input.bool(
     true,
     "Adaptive Value Zone",
     group = GROUP_VISUAL
)
bool showStructureLines = input.bool(
     false,
     "Structure Lines",
     group = GROUP_VISUAL
)
bool colorBars = input.bool(
     false,
