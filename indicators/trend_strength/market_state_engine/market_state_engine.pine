     group = GROUP_VISUAL
)
bool showDashboard = input.bool(
     false,
     "Context Dashboard",
     group = GROUP_VISUAL
)
// ─────────────────────────────────────────────────────────────────────────────
// INPUT VALIDATION
// ──────────────────────────────────────────────────────────────────────────────
float chartTimeframeSeconds = timeframe.in_seconds()
float contextTimeframeSeconds = timeframe.in_seconds(higherTimeframe)
bool htfTimeframeIsValid =
     na(chartTimeframeSeconds) or
     na(contextTimeframeSeconds) or
     contextTimeframeSeconds > chartTimeframeSeconds
bool htfEnabled = useHigherTimeframe and htfTimeframeIsValid
if barstate.isfirst
    if isCustom and customFastLen >= customSlowLen
        runtime.error("Custom: Fast Structure must be shorter than Slow Structure.")
    if trendAdxThreshold >= strongTrendAdx
        runtime.error("ADX Trend Threshold must be lower than ADX Strong Trend Threshold.")
    if math.abs(discountThreshold) >= extremeLocationThreshold or premiumThreshold >= extremeLocationThreshold
        runtime.error("Value Location: Discount and Premium thresholds must remain inside the Extreme Location threshold.")
    if minimumZoneBars > maximumZoneBars
        runtime.error("Zones: Minimum zone duration must not exceed maximum zone length.")
// ─────────────────────────────────────────────────────────────────────────────
// HELPER FUNCTIONS
// ─────────────────────────────────────────────────────────────────────────────
f_clamp(float value, float minimum, float maximum) =>
    math.max(minimum, math.min(maximum, value))
f_safeDiv(float numerator, float denominator, float fallback) =>
    math.abs(denominator) > 0.0000001 ? numerator / denominator : fallback
f_normalize(float value, float low, float high) =>
    f_clamp(f_safeDiv(value - low, high - low, 0.0), 0.0, 1.0)
f_kama(series float source, simple int length) =>
    float change = math.abs(source - source[length])
    float volatility = math.sum(math.abs(source - source[1]), length)
    float efficiency = volatility != 0.0 ? change / volatility : 0.0
    float smoothing = math.pow(
         efficiency * (2.0 / 3.0 - 2.0 / 31.0) + 2.0 / 31.0,
         2.0
    )
    var float kama = na
    kama := nz(kama[1], source) + smoothing * (source - nz(kama[1], source))
    kama
f_jma(series float source, simple int length) =>
    var float jma = na
    var float e0 = na
    var float e1 = na
    var float e2 = na
    float phaseRatio = 1.5
    float beta = 0.45 * (length - 1) / (0.45 * (length - 1) + 2.0)
    float alpha = math.pow(beta, 2.0)
    e0 := (1.0 - alpha) * source + alpha * nz(e0[1], source)
    e1 := (source - e0) * (1.0 - beta) + beta * nz(e1[1], 0.0)
    e2 :=
         (e0 + phaseRatio * e1 - nz(jma[1], source)) * math.pow(1.0 - alpha, 2.0) +
         math.pow(alpha, 2.0) * nz(e2[1], 0.0)
    jma := nz(jma[1], source) + e2
    jma
f_structureAverage(series float source, simple int length) =>
    switch structureSmoothing
        "DEMA" =>
            float firstEma = ta.ema(source, length)
            2.0 * firstEma - ta.ema(firstEma, length)
        "KAMA" => f_kama(source, length)
        "JMA Approx" => f_jma(source, length)
        => ta.ema(source, length)
f_htfStructureSnapshot() =>
    float fastStructure = f_structureAverage(close, fastLen)
    float slowStructure = f_structureAverage(close, slowLen)
    [close[1], fastStructure[1], slowStructure[1], slowStructure[2], ta.atr(atrLen)[1]]
f_regimeName(int regime) =>
    switch regime
        REGIME_BALANCED => "Balanced"
        REGIME_BULLISH  => "Bullish"
        REGIME_BEARISH  => "Bearish"
        => "Conflicted"
f_energyPhaseName(int phase) =>
    switch phase
        ENERGY_CONTRACTING => "Contracting"
        ENERGY_EXPANDING   => "Expanding"
        ENERGY_EXHAUSTING  => "Exhausting"
        => "Neutral"
f_transitionReasonName(int reason) =>
    switch reason
        TRANSITION_NO_DATA     => "Initializing"
        TRANSITION_CONFLICT    => "State conflict"
        TRANSITION_TREND_BUILD => "Trend forming"
        TRANSITION_BREAK       => "Structure break"
        TRANSITION_CHAOTIC     => "Chaotic conditions"
        => "None"
f_contextLevelName(int level) =>
    switch level
        CONTEXT_PREFERRED   => "Preferred"
        CONTEXT_COMPATIBLE  => "Compatible"
        CONTEXT_NEUTRAL     => "Neutral"
        => "Unfavorable"
f_breakoutFollowupName(int status) =>
    switch status
        BREAKOUT_HELD     => "Breakout held"
        BREAKOUT_RETESTED => "Retest passed"
        BREAKOUT_FAILED   => "Back inside the box"
        => "Pending"
f_stateName(int state) =>
    switch state
        STATE_BALANCE         => "Balance"
        STATE_COMPRESSION     => "Compression"
        STATE_BULL_EXPANSION  => "Bull Expansion"
        STATE_BEAR_EXPANSION  => "Bear Expansion"
        STATE_BULL_PULLBACK   => "Bull Pullback"
        STATE_BEAR_PULLBACK   => "Bear Pullback"
        STATE_BULL_EXHAUSTION => "Bull Exhaustion"
        STATE_BEAR_EXHAUSTION => "Bear Exhaustion"
        => "Transition"
f_stateShortName(int state) =>
    switch state
        STATE_BALANCE         => "BAL"
        STATE_COMPRESSION     => "COMP"
        STATE_BULL_EXPANSION  => "EXP ↑"
        STATE_BEAR_EXPANSION  => "EXP ↓"
        STATE_BULL_PULLBACK   => "PB ↑"
        STATE_BEAR_PULLBACK   => "PB ↓"
        STATE_BULL_EXHAUSTION => "EXH ↑"
        STATE_BEAR_EXHAUSTION => "EXH ↓"
        => "TRANS"
f_stateDisplayName(bool ready, int state, int transitionReason) =>
    string result = "Initializing"
    if ready
        result := state == STATE_TRANSITION ?
             "TRANS · " + f_transitionReasonName(transitionReason) :
             f_stateShortName(state)
    result
f_stateColor(int state, int transparency) =>
    color baseColor = switch state
        STATE_BALANCE         => color.rgb(120, 130, 145)
        STATE_COMPRESSION     => color.rgb(230, 170, 40)
        STATE_BULL_EXPANSION  => color.rgb(20, 160, 95)
        STATE_BEAR_EXPANSION  => color.rgb(205, 65, 70)
        STATE_BULL_PULLBACK   => color.rgb(70, 145, 115)
        STATE_BEAR_PULLBACK   => color.rgb(170, 90, 95)
        STATE_BULL_EXHAUSTION => color.rgb(190, 135, 35)
        STATE_BEAR_EXHAUSTION => color.rgb(175, 105, 35)
        => color.rgb(135, 105, 180)
    color.new(baseColor, transparency)
f_biasName(float bias) =>
    string result = "Balanced"
    if bias > directionalBiasThreshold
        result := "Buying Pressure"
    else if bias < -directionalBiasThreshold
        result := "Selling Pressure"
    result
f_biasColor(float bias, int transparency) =>
    color result = color.new(color.rgb(125, 130, 140), transparency)
    if bias > directionalBiasThreshold
        result := color.new(color.rgb(25, 155, 95), transparency)
    else if bias < -directionalBiasThreshold
        result := color.new(color.rgb(205, 65, 70), transparency)
    result
f_zoneLabelColor(int impulseDirection, bool trendIntact) =>
    color result = color.rgb(125, 130, 140)
    if trendIntact and impulseDirection == 1
        result := color.rgb(20, 160, 95)
    else if trendIntact and impulseDirection == -1
        result := color.rgb(205, 65, 70)
    else if impulseDirection != 0
        result := color.rgb(190, 135, 35)
    result
f_locationName(float normalizedLocation) =>
    string result = "Extreme Premium"
    if normalizedLocation <= -extremeLocationThreshold
        result := "Extreme Discount"
    else if normalizedLocation <= discountThreshold
        result := "Discount"
    else if normalizedLocation < premiumThreshold
        result := "Value"
    else if normalizedLocation < extremeLocationThreshold
        result := "Premium"
    result
f_locationColor(float normalizedLocation) =>
    color result = color.rgb(200, 75, 70)
    if normalizedLocation <= -extremeLocationThreshold
        result := color.rgb(20, 145, 95)
    else if normalizedLocation <= discountThreshold
        result := color.rgb(65, 160, 115)
    else if normalizedLocation < premiumThreshold
        result := color.rgb(125, 130, 140)
    else if normalizedLocation < extremeLocationThreshold
        result := color.rgb(190, 135, 45)
    result
f_qualityName(float quality) =>
    string result = "Chaotic"
    if quality >= 0.80
        result := "Very Clean"
    else if quality >= 0.65
        result := "Clean"
    else if quality >= 0.48
        result := "Mixed"
    else if quality >= 0.32
        result := "Noisy"
    result
f_stateIsBullish(int state) =>
    state == STATE_BULL_EXPANSION or
     state == STATE_BULL_PULLBACK or
     state == STATE_BULL_EXHAUSTION
f_stateIsBearish(int state) =>
    state == STATE_BEAR_EXPANSION or
     state == STATE_BEAR_PULLBACK or
     state == STATE_BEAR_EXHAUSTION
f_breakoutQualityName(float score) =>
    string result = "Weak"
    if score >= 0.72
        result := "Strong"
    else if score >= 0.50
        result := "Clean"
    result
f_compactNumber(float value) =>
    string result = str.tostring(value, "#.##")
    if value >= 1000000000000.0
        result := str.tostring(value / 1000000000000.0, "#.##") + "T"
    else if value >= 1000000000.0
        result := str.tostring(value / 1000000000.0, "#.##") + "B"
    else if value >= 1000000.0
        result := str.tostring(value / 1000000.0, "#.##") + "M"
    else if value >= 1000.0
        result := str.tostring(value / 1000.0, "#.##") + "K"
    result
f_zoneTooltip(
     string stateLabel,
     float bias,
     float quality,
     int startBar,
     bool zoneClosed,
     float zoneLow,
     float zoneHigh,
     float widthAtr,
     int upperEdgeTests,
     int lowerEdgeTests,
     int upperFailedBreaks,
     int lowerFailedBreaks,
     float zoneVwap,
     float zoneVolume,
     float zoneVolumeRatio,
     bool zoneHasVolume,
     string outcome,
     string eventDetails,
     string impulseRelation
 ) =>
    int durationBars = math.max(bar_index - startBar + (zoneClosed ? 0 : 1), 1)
    string result = str.format(
         "{0}\nAuction pressure (latest): {1} ({2})\nZone quality: {3} ({4})\nZone duration: {5} bars\nZone range: {6} – {7}",
         stateLabel,
         f_biasName(bias),
         str.tostring(bias, "#.##"),
         f_qualityName(quality),
         str.tostring(quality, "#.##"),
         durationBars,
         str.tostring(zoneLow, format.mintick),
         str.tostring(zoneHigh, format.mintick)
    )
    result += "\nWidth: " + str.tostring(widthAtr, "#.##") + " ATR"
    result += "\nEdge tests since confirmation (upper/lower): " + str.tostring(upperEdgeTests) + " / " + str.tostring(lowerEdgeTests)
    result += "\nFailed breaks since confirmation (upper/lower): " + str.tostring(upperFailedBreaks) + " / " + str.tostring(lowerFailedBreaks)
    if not na(zoneVwap)
        float vwapLocation = f_safeDiv(zoneVwap - zoneLow, zoneHigh - zoneLow, 0.5)
        string vwapArea = vwapLocation <= 0.33 ? "lower third" : vwapLocation >= 0.67 ? "upper third" : "middle"
        result += "\nBox-VWAP: " + str.tostring(zoneVwap, format.mintick) + " (" + vwapArea + ")"
    if zoneHasVolume
        result += "\nBox volume: " + f_compactNumber(zoneVolume)
        result += "\nAverage volume per bar: " + str.tostring(zoneVolumeRatio, "#.##") + "× normal"
    else
        result += "\nBox volume: Not available"
    if outcome != ""
        result += "\nOutcome: " + outcome
    if eventDetails != ""
        result += "\n" + eventDetails
    if impulseRelation != ""
        result += "\nRelation to prior impulse: " + impulseRelation
    result
f_expansionTooltip(
     int state,
     float confidence,
     float expansion,
     float quality,
     float location,
     float bias,
     string htf
 ) =>
    str.format(
         "{0}\nConfidence: {1}%\nExpansion: {2}%\nState quality: {3} ({4})\nLocation: {5}\nAuction pressure: {6} ({7})\nHTF: {8}",
         f_stateName(state),
         str.tostring(confidence * 100.0, "#.0"),
         str.tostring(expansion * 100.0, "#.0"),
         f_qualityName(quality),
         str.tostring(quality, "#.##"),
         f_locationName(location),
         f_biasName(bias),
         str.tostring(bias, "#.##"),
         htf
    )
f_zoneContextHeading(
     string stateLabel,
     string contextLabel,
     int impulseDirection,
     bool trendIntact,
     float impulseSizeAtr,
     float impulseEfficiency,
     float depth,
     string riskReason,
     int zoneStartState,
     int zoneCurrentState,
     int balanceBars,
     int compressionBars
 ) =>
    string result = stateLabel + " Zone"
    int zoneTypeBars = balanceBars + compressionBars
    string zoneEvolution = f_stateName(zoneStartState)
    if zoneCurrentState != zoneStartState
        zoneEvolution += " → " + f_stateName(zoneCurrentState)
    result += "\nZone evolution: " + zoneEvolution
    if zoneTypeBars > 0
        float compressionShare = float(compressionBars) / zoneTypeBars
        result += "\nCompression share: " + str.tostring(compressionShare * 100.0, "#.0") + "%"
    if impulseDirection != 0 and not na(depth)
        string impulseName = impulseDirection == 1 ? "Long" : "Short"
        result += "\nPrior impulse: " + impulseName + " (" + str.tostring(impulseSizeAtr, "#.##") + " ATR)"
        if not na(impulseEfficiency)
            result += "\nImpulse efficiency: " + str.tostring(impulseEfficiency * 100.0, "#.0") + "%"
        result += "\nPhase after impulse: " + contextLabel
        result += "\nRetracement against impulse: " + str.tostring(depth * 100.0, "#.0") + "%"
        if trendIntact
            result += "\nPreferred direction: " + impulseName
        else
            result += "\nPreferred direction: None"
            if riskReason != ""
                result += "\nReason: " + riskReason
    else
        result += "\nPrior impulse: None detected"
    result
f_breakoutTooltip(
     bool bullishBreakout,
     string stateLabel,
     string zoneHeading,
     float bias,
     float quality,
     int startBar,
     float zoneLow,
     float zoneHigh,
     float widthAtr,
     int upperEdgeTests,
     int lowerEdgeTests,
     int upperFailedBreaks,
     int lowerFailedBreaks,
     float zoneVwap,
     float zoneVolume,
     float zoneVolumeRatio,
     bool zoneHasVolume,
     string impulseRelation,
     float breakoutQuality,
     float breakoutDistanceAtr,
     float breakoutVolumeRatio,
     bool breakoutHasVolume
 ) =>
    string direction = bullishBreakout ? "Long" : "Short"
    string side = bullishBreakout ? "upper" : "lower"
    string result = "Breakout through the " + side + " edge of " + stateLabel
    result += "\nBreakout direction: " + direction
    result += "\nConfirmed: " + str.tostring(breakoutConfirmationBars) + " close(s) beyond the ATR-buffered zone plus quality gate"
    result += "\nBreakout quality: " + f_breakoutQualityName(breakoutQuality) + " (" + str.tostring(breakoutQuality * 100.0, "#.0") + "%)"
    result += "\nDistance beyond zone: " + str.tostring(breakoutDistanceAtr, "#.##") + " ATR"
    if breakoutHasVolume
        result += "\nVolume: " + str.tostring(breakoutVolumeRatio, "#.##") + "× average"
    result += "\n\n" + f_zoneTooltip(
         zoneHeading,
         bias,
         quality,
         startBar,
         true,
         zoneLow,
         zoneHigh,
         widthAtr,
         upperEdgeTests,
         lowerEdgeTests,
         upperFailedBreaks,
         lowerFailedBreaks,
         zoneVwap,
         zoneVolume,
         zoneVolumeRatio,
         zoneHasVolume,
         "",
         "",
         impulseRelation
    )
    result
f_zoneDirectionalShortName(
     int state,
     int impulseDirection,
     bool trendIntact
 ) =>
    string result = f_stateShortName(state)
    if impulseDirection == 1
        result += trendIntact ? " ↑" : " ?"
    else if impulseDirection == -1
        result += trendIntact ? " ↓" : " ?"
    result
// ─────────────────────────────────────────────────────────────────────────────
// BASE CALCULATIONS
// ─────────────────────────────────────────────────────────────────────────────
float atr = ta.atr(atrLen)
float safeAtr = math.max(atr, syminfo.mintick)
float structureFast = f_structureAverage(close, fastLen)
float structureSlow = f_structureAverage(close, slowLen)
float fastSlope = f_safeDiv(structureFast - structureFast[3], safeAtr * 3.0, 0.0)
float slowSlope = f_safeDiv(structureSlow - structureSlow[5], safeAtr * 5.0, 0.0)
float structureSeparation = f_safeDiv(
     math.abs(structureFast - structureSlow),
     safeAtr,
     0.0
)
[plusDI, minusDI, adx] = ta.dmi(diLen, adxSmooth)
float directionalDI = f_safeDiv(
     plusDI - minusDI,
     plusDI + minusDI,
     0.0
)
// ─────────────────────────────────────────────────────────────────────────────
// MARKET EFFICIENCY
// ─────────────────────────────────────────────────────────────────────────────
float pathTravel = math.sum(math.abs(ta.change(close)), energyLen)
float netTravel = math.abs(close - close[energyLen])
float efficiencyRatio = f_clamp(
     f_safeDiv(netTravel, pathTravel, 0.0),
     0.0,
     1.0
)
float efficiencyDirection = 0.0
if close > close[energyLen]
    efficiencyDirection := 1.0
else if close < close[energyLen]
    efficiencyDirection := -1.0
float signedEfficiency = efficiencyRatio * efficiencyDirection
// Candle overlap measures how much successive candle ranges overlap.
// High overlap generally belongs to balance or compression.
float overlapTop = math.min(high, high[1])
float overlapBottom = math.max(low, low[1])
float overlapAmount = math.max(overlapTop - overlapBottom, 0.0)
float previousRange = math.max(high[1] - low[1], syminfo.mintick)
float currentRange = math.max(high - low, syminfo.mintick)
float overlapRatio = f_clamp(
     f_safeDiv(
         overlapAmount,
         math.min(previousRange, currentRange),
         0.0
     ),
     0.0,
     1.0
)
float averageOverlap = ta.ema(overlapRatio, energyLen)
// ─────────────────────────────────────────────────────────────────────────────
// STRUCTURE DIRECTION
// ─────────────────────────────────────────────────────────────────────────────
float structureBullScore =
     0.30 * f_normalize(structureFast - structureSlow, -safeAtr, safeAtr) +
     0.25 * f_normalize(fastSlope, -0.20, 0.20) +
     0.20 * f_normalize(slowSlope, -0.12, 0.12) +
     0.15 * f_normalize(directionalDI, -0.35, 0.35) +
     0.10 * f_normalize(signedEfficiency, -0.40, 0.40)
float structureBearScore = 1.0 - structureBullScore
float structureDirection = structureBullScore - structureBearScore
bool structuralBull =
     structureFast > structureSlow and
     slowSlope > -0.02 and
     structureDirection > 0.08
bool structuralBear =
     structureFast < structureSlow and
     slowSlope < 0.02 and
     structureDirection < -0.08
// ─────────────────────────────────────────────────────────────────────────────
// HIGHER TIMEFRAME CONTEXT
// ─────────────────────────────────────────────────────────────────────────────
[htfClose, htfFast, htfSlow, htfSlowPrevious, htfAtr] = request.security(
     syminfo.tickerid,
     higherTimeframe,
     f_htfStructureSnapshot(),
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_on
)
float htfSlowSlope = f_safeDiv(
     htfSlow - htfSlowPrevious,
     math.max(htfAtr, syminfo.mintick),
     0.0
)
bool htfBull =
     not htfEnabled or
     (
         htfFast > htfSlow and
         htfClose > htfSlow and
         htfSlowSlope >= 0
     )
bool htfBear =
     not htfEnabled or
     (
         htfFast < htfSlow and
         htfClose < htfSlow and
         htfSlowSlope <= 0
     )
string htfContext = "Neutral"
if not useHigherTimeframe
    htfContext := "Off"
else if not htfTimeframeIsValid
    htfContext := "TF ≤ Chart"
else if htfBull
    htfContext := "Bullish"
else if htfBear
    htfContext := "Bearish"
// ─────────────────────────────────────────────────────────────────────────────
// ADAPTIVE VALUE
// ─────────────────────────────────────────────────────────────────────────────
float emaValue = ta.ema(hlc3, valueLen)
float vwmaValue = ta.vwma(hlc3, valueLen)
bool hasUsableVolume =
     not na(volume) and
     ta.sma(volume, volumeLen) > 0
float effectiveVwma = hasUsableVolume ? vwmaValue : emaValue
float fairValue = switch valueMethod
    "EMA"    => emaValue
    "Hybrid" => (emaValue + effectiveVwma) / 2.0
    => effectiveVwma
float valueResidual = close - fairValue
float residualDeviation = ta.stdev(valueResidual, valueLen)
float adaptiveDeviation = math.max(
     residualDeviation,
     safeAtr * 0.60
)
float valueUpper = fairValue + adaptiveDeviation * valueWidth
float valueLower = fairValue - adaptiveDeviation * valueWidth
float normalizedLocation = f_safeDiv(
     close - fairValue,
     adaptiveDeviation * valueWidth,
     0.0
)
// Separate range-relative location.
// This prevents a moving average alone from defining "cheap" and "expensive".
float rollingHigh = ta.highest(high, rangeLen)
float rollingLow = ta.lowest(low, rangeLen)
float rollingWidth = math.max(rollingHigh - rollingLow, syminfo.mintick)
float rangeLocation = f_clamp(
     f_safeDiv(close - rollingLow, rollingWidth, 0.5),
     0.0,
     1.0
)
// ─────────────────────────────────────────────────────────────────────────────
// VOLATILITY AND COMPRESSION
// ─────────────────────────────────────────────────────────────────────────────
float atrPercent = f_safeDiv(atr, close, 0.0)
float atrBaseline = ta.sma(atrPercent, compressionLen)
float atrCompression = 1.0 - f_clamp(
     f_safeDiv(atrPercent, atrBaseline * 1.25, 1.0),
     0.0,
     1.0
)
float basis = ta.sma(close, energyLen)
float deviation = ta.stdev(close, energyLen)
float bbWidth = f_safeDiv(
     deviation * 4.0,
     basis,
     0.0
)
float bbWidthBaseline = ta.sma(bbWidth, compressionLen)
float bandCompression = 1.0 - f_clamp(
     f_safeDiv(bbWidth, bbWidthBaseline * 1.20, 1.0),
     0.0,
     1.0
)
float rangeAtrRatio = f_safeDiv(
     rollingWidth,
     safeAtr * math.sqrt(rangeLen),
     0.0
)
float rangeContainment = 1.0 - f_normalize(
     rangeAtrRatio,
     1.50,
     4.50
)
float compressionScore =
     0.32 * atrCompression +
     0.28 * bandCompression +
     0.22 * averageOverlap +
     0.18 * rangeContainment
compressionScore := f_clamp(compressionScore, 0.0, 1.0)
// ─────────────────────────────────────────────────────────────────────────────
// EXPANSION
// ─────────────────────────────────────────────────────────────────────────────
float candleBody = math.abs(close - open)
float bodyEfficiency = f_clamp(
     f_safeDiv(candleBody, currentRange, 0.0),
     0.0,
     1.0
)
float closeLocationInBar = f_clamp(
     f_safeDiv(close - low, currentRange, 0.5),
     0.0,
     1.0
)
float bullBodyQuality = f_clamp(
     f_safeDiv(close - open, currentRange, 0.0),
     0.0,
     1.0
)
float bearBodyQuality = f_clamp(
     f_safeDiv(open - close, currentRange, 0.0),
     0.0,
     1.0
)
float bullCloseQuality = closeLocationInBar
float bearCloseQuality = 1.0 - closeLocationInBar
float rangeExpansion = f_normalize(
     currentRange,
     safeAtr * 0.70,
     safeAtr * 1.80
)
float atrAcceleration = f_normalize(
     f_safeDiv(atr, atr[5], 1.0),
     0.90,
     1.25
)
float adxExpansion = f_normalize(
     adx,
     trendAdxThreshold - 5.0,
     strongTrendAdx + 8.0
)
float directionalProgress = f_safeDiv(
     close - close[energyLen],
     safeAtr * math.sqrt(energyLen),
     0.0
)
float bullProgress = f_normalize(directionalProgress, 0.0, 2.0)
float bearProgress = f_normalize(-directionalProgress, 0.0, 2.0)
float bullExpansionScore =
     0.22 * efficiencyRatio +
     0.18 * adxExpansion +
     0.16 * rangeExpansion +
     0.12 * atrAcceleration +
     0.12 * bullBodyQuality +
     0.12 * bullCloseQuality +
     0.08 * bullProgress
bullExpansionScore := f_clamp(bullExpansionScore, 0.0, 1.0)
float bearExpansionScore =
     0.22 * efficiencyRatio +
     0.18 * adxExpansion +
     0.16 * rangeExpansion +
     0.12 * atrAcceleration +
     0.12 * bearBodyQuality +
     0.12 * bearCloseQuality +
     0.08 * bearProgress
bearExpansionScore := f_clamp(bearExpansionScore, 0.0, 1.0)
// Generic energy output remains available for dashboards and existing consumers.
float expansionScore = math.max(bullExpansionScore, bearExpansionScore)
// ─────────────────────────────────────────────────────────────────────────────
// VOLUME AND DIRECTIONAL PRESSURE
// ─────────────────────────────────────────────────────────────────────────────
float volumeAverage = ta.sma(volume, volumeLen)
float volumeDeviation = ta.stdev(volume, volumeLen)
bool hasUsableZoneVolume = useZoneVolume and hasUsableVolume
float volumeZ = 0.0
if hasUsableVolume
    volumeZ := f_safeDiv(volume - volumeAverage, volumeDeviation, 0.0)
float volumeStrength = 0.50
if useVolume and hasUsableVolume
    volumeStrength := f_normalize(volumeZ, -0.50, 2.50)
// Signed close position:
// +1 means candle closed near its high.
// -1 means candle closed near its low.
float signedClosePosition = closeLocationInBar * 2.0 - 1.0
// Effort-versus-result:
// High volume with limited directional result can indicate absorption.
float directionalResult = f_safeDiv(
     math.abs(close - close[1]),
     safeAtr,
     0.0
)
float effortResultMismatch = 0.0
if useVolume and hasUsableVolume
    effortResultMismatch := f_clamp(
         f_normalize(volumeZ, 0.50, 2.50) *
         (1.0 - f_normalize(directionalResult, 0.20, 1.20)),
         0.0,
         1.0
     )
// Failed auctions around rolling structure.
float priorStructureLow = ta.lowest(low[1], swingLen * 2)
float priorStructureHigh = ta.highest(high[1], swingLen * 2)
bool failedBreakdown =
     low < priorStructureLow and
     close > priorStructureLow and
     closeLocationInBar > 0.55
bool failedBreakout =
     high > priorStructureHigh and
     close < priorStructureHigh and
     closeLocationInBar < 0.45
float failedAuctionBias = 0.0
if failedBreakdown
    failedAuctionBias := 1.0
else if failedBreakout
    failedAuctionBias := -1.0
// Price response around value extremes.
float valueResponseBias = 0.0
if normalizedLocation < discountThreshold and signedClosePosition > 0
    valueResponseBias := signedClosePosition
else if normalizedLocation > premiumThreshold and signedClosePosition < 0
    valueResponseBias := signedClosePosition
// Volume-pressure proxy.
// It does not claim to be true order flow.
float pressureRaw =
     signedClosePosition *
     bodyEfficiency *
     (0.50 + volumeStrength * 0.50)
float pressureSmoothed = ta.ema(pressureRaw, energyLen)
// Auction Pressure combines:
// 1. persistent directional pressure,
// 2. failed auctions,
// 3. absorption at useful locations,
// 4. price response around adaptive value.
float absorptionDirection = 0.0
if rangeLocation < 0.35 and signedClosePosition > 0
    absorptionDirection := 1.0
else if rangeLocation > 0.65 and signedClosePosition < 0
    absorptionDirection := -1.0
float absorptionBias = effortResultMismatch * absorptionDirection
float directionalBias =
     0.40 * pressureSmoothed +
     0.25 * failedAuctionBias +
     0.20 * absorptionBias +
     0.15 * valueResponseBias
directionalBias := f_clamp(directionalBias, -1.0, 1.0)
float smoothedDirectionalBias = ta.ema(directionalBias, 3)
// ─────────────────────────────────────────────────────────────────────────────
// EXHAUSTION
// ─────────────────────────────────────────────────────────────────────────────
// Price extension is context, not a reversal signal.
float bullExtensionScore = f_normalize(normalizedLocation, 0.70, 2.20)
float bearExtensionScore = f_normalize(-normalizedLocation, 0.70, 2.20)
float directionalExtensionScore =
     structuralBull ? bullExtensionScore :
     structuralBear ? bearExtensionScore :
     0.0
// Momentum deceleration:
// Trend may still point in the same direction while its rate deteriorates.
float momentumFast = ta.roc(close, math.max(3, int(math.round(energyLen * 0.35))))
float momentumSlow = ta.roc(close, energyLen)
float momentumDelta = momentumFast - momentumFast[3]
float momentumDeltaDeviation = ta.stdev(momentumDelta, energyLen)
float normalizedMomentumDelta = f_safeDiv(
     momentumDelta,
     math.max(nz(momentumDeltaDeviation, 0.0), 0.0001),
     0.0
)
float bullDeceleration = momentumSlow > 0 ?
     f_normalize(-normalizedMomentumDelta, 0.0, 2.5) :
     0.0
float bearDeceleration = momentumSlow < 0 ?
     f_normalize(normalizedMomentumDelta, 0.0, 2.5) :
     0.0
float directionalDeceleration = 0.0
if structuralBull
    directionalDeceleration := bullDeceleration
else if structuralBear
    directionalDeceleration := bearDeceleration
float trendAge = ta.barssince(
     structuralBull != structuralBull[1] or
     structuralBear != structuralBear[1]
)
float ageScore = f_normalize(
     nz(trendAge, 0),
     energyLen,
     energyLen * 4.0
)
float failedProgress = 0.0
if efficiencyRatio < efficiencyRatio[5]
    failedProgress := f_normalize(
         efficiencyRatio[5] - efficiencyRatio,
         0.0,
         0.25
     )
float exhaustionScore =
     0.30 * directionalExtensionScore +
     0.25 * directionalDeceleration +
     0.18 * ageScore +
     0.17 * failedProgress +
     0.10 * effortResultMismatch
float directionalExpansionPersistence =
     structuralBull ? bullExpansionScore :
     structuralBear ? bearExpansionScore :
     0.0
exhaustionScore *= 1.0 - directionalExpansionPersistence * 0.30
exhaustionScore := f_clamp(exhaustionScore, 0.0, 1.0)
bool hasExhaustionTrigger =
     directionalDeceleration >= 0.30 or
     failedProgress >= 0.35 or
     effortResultMismatch >= 0.55
// Confirmed impulse memory is declared before pullback scoring so the current
// raw read can use only information committed by prior confirmed bars.
var int activeImpulseDirection = 0
var float activeImpulseStartPrice = na
var float activeImpulseEndPrice = na
var float activeImpulseHigh = na
var float activeImpulseLow = na
var float activeImpulseAtrSum = 0.0
var float activeImpulseQualitySum = 0.0
var int activeImpulseBars = 0
var int lastImpulseDirection = 0
var int lastImpulseEndBar = na
var float lastImpulseStartPrice = na
var float lastImpulseEndPrice = na
var float lastImpulseHigh = na
var float lastImpulseLow = na
var float lastImpulseCounterExtreme = na
var float lastImpulseCounterCloseExtreme = na
var float lastImpulseSizeAtr = na
var float lastImpulseGrossRangeAtr = na
var float lastImpulseEfficiency = na
var float lastImpulseQuality = na
var int lastImpulseBars = 0
// ─────────────────────────────────────────────────────────────────────────────
// PULLBACK DETECTION
// ─────────────────────────────────────────────────────────────────────────────
int pullbackMemoryBars = math.max(20, compressionLen)
int priorImpulseAge = na(lastImpulseEndBar) ? pullbackMemoryBars + 1 : bar_index - lastImpulseEndBar
bool recentBullImpulse =
     activeImpulseDirection == 1 or
     (
         lastImpulseDirection == 1 and
         priorImpulseAge <= pullbackMemoryBars and
         nz(lastImpulseEfficiency, 0.0) >= 0.45
     )
bool recentBearImpulse =
     activeImpulseDirection == -1 or
     (
         lastImpulseDirection == -1 and
         priorImpulseAge <= pullbackMemoryBars and
         nz(lastImpulseEfficiency, 0.0) >= 0.45
     )
float bullImpulseStart = activeImpulseDirection == 1 ? activeImpulseStartPrice : lastImpulseStartPrice
float bullImpulseExtreme = activeImpulseDirection == 1 ? activeImpulseHigh : lastImpulseHigh
float bearImpulseStart = activeImpulseDirection == -1 ? activeImpulseStartPrice : lastImpulseStartPrice
float bearImpulseExtreme = activeImpulseDirection == -1 ? activeImpulseLow : lastImpulseLow
float bullPullbackDepth = recentBullImpulse ? f_clamp(
     f_safeDiv(bullImpulseExtreme - close, bullImpulseExtreme - bullImpulseStart, 0.0),
     0.0,
     1.50
) : na
float bearPullbackDepth = recentBearImpulse ? f_clamp(
     f_safeDiv(close - bearImpulseExtreme, bearImpulseStart - bearImpulseExtreme, 0.0),
     0.0,
     1.50
) : na
float bullPullbackLocationScore =
     1.0 - f_normalize(math.abs(close - structureSlow), safeAtr * 0.10, safeAtr * 1.20)
float bearPullbackLocationScore =
     1.0 - f_normalize(math.abs(close - structureSlow), safeAtr * 0.10, safeAtr * 1.20)
float bullPullbackScore =
     recentBullImpulse and structuralBull and not na(bullPullbackDepth) ?
         f_clamp(
             0.30 * structureBullScore +
             0.25 * bullPullbackLocationScore +
             0.20 * (1.0 - bearExpansionScore) +
             0.15 * (1.0 - f_normalize(bullPullbackDepth, 0.55, 0.85)) +
             0.10 * f_normalize(bullPullbackDepth, 0.08, 0.30),
             0.0,
             1.0
         ) :
         0.0
float bearPullbackScore =
     recentBearImpulse and structuralBear and not na(bearPullbackDepth) ?
         f_clamp(
             0.30 * structureBearScore +
             0.25 * bearPullbackLocationScore +
             0.20 * (1.0 - bullExpansionScore) +
             0.15 * (1.0 - f_normalize(bearPullbackDepth, 0.55, 0.85)) +
             0.10 * f_normalize(bearPullbackDepth, 0.08, 0.30),
             0.0,
             1.0
         ) :
         0.0
bool bullPullback =
     bullPullbackScore >= minimumStateScore and
     close < structureFast and
     close >= structureSlow - safeAtr * 0.35 and
     bullPullbackDepth > 0.08 and
     bullPullbackDepth < 0.80 and
     fastSlope > -0.12
bool bearPullback =
     bearPullbackScore >= minimumStateScore and
     close > structureFast and
     close <= structureSlow + safeAtr * 0.35 and
     bearPullbackDepth > 0.08 and
     bearPullbackDepth < 0.80 and
     fastSlope < 0.12
// ─────────────────────────────────────────────────────────────────────────────
// BALANCE DETECTION
// ─────────────────────────────────────────────────────────────────────────────
float balanceScore =
     0.28 * (1.0 - efficiencyRatio) +
     0.24 * averageOverlap +
     0.20 * (1.0 - adxExpansion) +
     0.16 * (1.0 - f_normalize(structureSeparation, 0.20, 1.50)) +
     0.12 * rangeContainment
balanceScore := f_clamp(balanceScore, 0.0, 1.0)
bool balanceCandidate =
     balanceScore >= 0.56 and
     adx < strongTrendAdx and
     math.abs(structureDirection) < 0.48
bool compressionCandidate =
     compressionScore >= compressionThreshold and
     balanceScore >= 0.44
// ─────────────────────────────────────────────────────────────────────────────
// TREND QUALITY
// ─────────────────────────────────────────────────────────────────────────────
float directionalAgreement = 0.0
if structuralBull
    directionalAgreement := f_normalize(structureDirection, 0.0, 0.65)
else if structuralBear
    directionalAgreement := f_normalize(-structureDirection, 0.0, 0.65)
float htfAgreementScore = 0.45
if not htfEnabled
    htfAgreementScore := 0.65
else if structuralBull and htfBull
    htfAgreementScore := 1.0
else if structuralBear and htfBear
    htfAgreementScore := 1.0
else if structuralBull and htfBear
    htfAgreementScore := 0.0
else if structuralBear and htfBull
    htfAgreementScore := 0.0
float trendQuality =
     0.30 * efficiencyRatio +
     0.22 * adxExpansion +
     0.18 * directionalAgreement +
     0.15 * (1.0 - averageOverlap) +
     0.15 * htfAgreementScore
trendQuality := f_clamp(trendQuality, 0.0, 1.0)
float balanceQuality =
     0.40 * balanceScore +
     0.35 * compressionScore +
     0.25 * averageOverlap
balanceQuality := f_clamp(balanceQuality, 0.0, 1.0)
bool localEngineReady =
     not na(structureFast) and
     not na(structureSlow) and
     not na(atr) and
     not na(adx) and
     not na(atrBaseline) and
     not na(bbWidthBaseline) and
     not na(residualDeviation) and
     not na(averageOverlap) and
     not na(momentumSlow) and
     not na(momentumDeltaDeviation)
bool htfDataReady =
     not htfEnabled or
     (
         not na(htfClose) and
         not na(htfFast) and
         not na(htfSlow) and
         not na(htfSlowPrevious) and
         not na(htfAtr)
     )
bool engineReady = localEngineReady and htfDataReady
// ─────────────────────────────────────────────────────────────────────────────
// ORTHOGONAL MARKET AXES
// ─────────────────────────────────────────────────────────────────────────────
int structureRegime = REGIME_CONFLICTED
if engineReady
    if balanceCandidate
        structureRegime := REGIME_BALANCED
    else if structuralBull
        structureRegime := REGIME_BULLISH
    else if structuralBear
        structureRegime := REGIME_BEARISH
    else if balanceScore >= 0.44
        structureRegime := REGIME_BALANCED
float contractingEvidence = compressionScore
float expandingEvidence = math.max(bullExpansionScore, bearExpansionScore)
float exhaustingEvidence = hasExhaustionTrigger ? exhaustionScore : 0.0
int energyPhase = ENERGY_NEUTRAL
float strongestEnergyEvidence = math.max(
     contractingEvidence,
     math.max(expandingEvidence, exhaustingEvidence)
)
if engineReady and strongestEnergyEvidence >= 0.45
    if strongestEnergyEvidence == contractingEvidence
        energyPhase := ENERGY_CONTRACTING
    else if strongestEnergyEvidence == exhaustingEvidence
        energyPhase := ENERGY_EXHAUSTING
    else
        energyPhase := ENERGY_EXPANDING
// ─────────────────────────────────────────────────────────────────────────────
// STATE CANDIDATE SCORES AND ARBITRATION
// ─────────────────────────────────────────────────────────────────────────────
bool bullExpansionAllowed =
     structuralBull and
     (
         not requireHtfAgreement or
         htfBull
     )
bool bearExpansionAllowed =
     structuralBear and
     (
         not requireHtfAgreement or
         htfBear
     )
bool bullExhausted =
     structuralBull and
     exhaustionScore >= exhaustionThreshold and
     hasExhaustionTrigger
bool bearExhausted =
     structuralBear and
     exhaustionScore >= exhaustionThreshold and
     hasExhaustionTrigger
bool bullExpanding =
     bullExpansionAllowed and
     bullExpansionScore >= expansionThreshold and
     signedEfficiency >= efficiencyTrendThreshold
bool bearExpanding =
     bearExpansionAllowed and
     bearExpansionScore >= expansionThreshold and
     signedEfficiency <= -efficiencyTrendThreshold
float balanceCandidateScore = balanceCandidate ?
     balanceScore * (1.0 - 0.20 * compressionScore) :
     0.0
float compressionCandidateScore = compressionCandidate ?
     0.72 * compressionScore + 0.28 * balanceScore :
     0.0
float bullExpansionCandidateScore = bullExpanding ?
     0.72 * bullExpansionScore + 0.28 * structureBullScore :
     0.0
float bearExpansionCandidateScore = bearExpanding ?
     0.72 * bearExpansionScore + 0.28 * structureBearScore :
     0.0
float bullPullbackCandidateScore = bullPullback ? bullPullbackScore : 0.0
float bearPullbackCandidateScore = bearPullback ? bearPullbackScore : 0.0
float bullExhaustionCandidateScore = bullExhausted ?
     0.72 * exhaustionScore + 0.28 * structureBullScore :
     0.0
float bearExhaustionCandidateScore = bearExhausted ?
     0.72 * exhaustionScore + 0.28 * structureBearScore :
     0.0
int bestState = STATE_TRANSITION
float bestStateScore = 0.0
float secondStateScore = 0.0
if engineReady
    if balanceCandidateScore > bestStateScore
        secondStateScore := bestStateScore
        bestStateScore := balanceCandidateScore
        bestState := STATE_BALANCE
    else if balanceCandidateScore > secondStateScore
        secondStateScore := balanceCandidateScore
    if compressionCandidateScore > bestStateScore
        secondStateScore := bestStateScore
        bestStateScore := compressionCandidateScore
        bestState := STATE_COMPRESSION
    else if compressionCandidateScore > secondStateScore
        secondStateScore := compressionCandidateScore
    if bullExpansionCandidateScore > bestStateScore
        secondStateScore := bestStateScore
        bestStateScore := bullExpansionCandidateScore
        bestState := STATE_BULL_EXPANSION
    else if bullExpansionCandidateScore > secondStateScore
        secondStateScore := bullExpansionCandidateScore
    if bearExpansionCandidateScore > bestStateScore
        secondStateScore := bestStateScore
        bestStateScore := bearExpansionCandidateScore
        bestState := STATE_BEAR_EXPANSION
    else if bearExpansionCandidateScore > secondStateScore
        secondStateScore := bearExpansionCandidateScore
    if bullPullbackCandidateScore > bestStateScore
        secondStateScore := bestStateScore
        bestStateScore := bullPullbackCandidateScore
        bestState := STATE_BULL_PULLBACK
    else if bullPullbackCandidateScore > secondStateScore
        secondStateScore := bullPullbackCandidateScore
    if bearPullbackCandidateScore > bestStateScore
        secondStateScore := bestStateScore
        bestStateScore := bearPullbackCandidateScore
        bestState := STATE_BEAR_PULLBACK
    else if bearPullbackCandidateScore > secondStateScore
        secondStateScore := bearPullbackCandidateScore
    if bullExhaustionCandidateScore > bestStateScore
        secondStateScore := bestStateScore
        bestStateScore := bullExhaustionCandidateScore
        bestState := STATE_BULL_EXHAUSTION
    else if bullExhaustionCandidateScore > secondStateScore
        secondStateScore := bullExhaustionCandidateScore
    if bearExhaustionCandidateScore > bestStateScore
        secondStateScore := bestStateScore
        bestStateScore := bearExhaustionCandidateScore
        bestState := STATE_BEAR_EXHAUSTION
    else if bearExhaustionCandidateScore > secondStateScore
        secondStateScore := bearExhaustionCandidateScore
float stateDominance = bestStateScore - secondStateScore
int rawState =
     engineReady and
     bestStateScore >= minimumStateScore and
     stateDominance >= stateDominanceMargin ?
         bestState :
         STATE_TRANSITION
float rawStateConfidence = rawState == STATE_TRANSITION ?
     engineReady ?
         f_clamp(
             bestStateScore < minimumStateScore ? 1.0 - bestStateScore : 1.0 - stateDominance,
             0.0,
             1.0
         ) :
         0.0 :
     bestStateScore
float stateQuality = rawState == STATE_TRANSITION ?
     f_clamp(math.max(trendQuality, balanceQuality) * (1.0 - stateDominance), 0.0, 1.0) :
     bestStateScore
// Backward-compatible internal alias. Visible output calls this State Quality.
float marketQuality = stateQuality
// ─────────────────────────────────────────────────────────────────────────────
// STATE MACHINE WITH CONFIRMATION AND HYSTERESIS
// ─────────────────────────────────────────────────────────────────────────────
var int confirmedState = STATE_TRANSITION
var int candidateState = STATE_TRANSITION
var int candidateBars = 0
var int barsInConfirmedState = 0
var int confirmedTransitionReason = TRANSITION_NO_DATA
int transitionReason = TRANSITION_NONE
if not engineReady
    transitionReason := TRANSITION_NO_DATA
else if rawState != STATE_TRANSITION
    transitionReason := confirmedState == STATE_TRANSITION ? TRANSITION_TREND_BUILD : TRANSITION_NONE
else if rawState == STATE_TRANSITION
    if bestStateScore >= minimumStateScore and stateDominance < stateDominanceMargin
        transitionReason := TRANSITION_CONFLICT
    else if (
             f_stateIsBullish(confirmedState) and not structuralBull
         ) or
         (
             f_stateIsBearish(confirmedState) and not structuralBear
         )
        transitionReason := TRANSITION_BREAK
    else if structureRegime == REGIME_BULLISH or
         structureRegime == REGIME_BEARISH
        transitionReason := TRANSITION_TREND_BUILD
    else
        transitionReason := TRANSITION_CHAOTIC
bool rawIsOppositeExpansion =
     (
         f_stateIsBullish(confirmedState) and
         rawState == STATE_BEAR_EXPANSION
     ) or
     (
         f_stateIsBearish(confirmedState) and
         rawState == STATE_BULL_EXPANSION
     )
bool emergencyStateChange =
     rawIsOppositeExpansion and
     rawStateConfidence >= oppositeBreakThreshold
bool stateShouldChange = false
if barstate.isconfirmed and engineReady
    if rawState == candidateState
        candidateBars += 1
    else
        candidateState := rawState
        candidateBars := 1
    barsInConfirmedState += 1
    bool normalStateChangeAllowed =
         barsInConfirmedState >= minimumStateBars and
         candidateBars >= confirmBars
    stateShouldChange :=
         candidateState != confirmedState and
         (
             normalStateChangeAllowed or
             emergencyStateChange
         )
    if stateShouldChange
        confirmedState := candidateState
        barsInConfirmedState := 0
    if confirmedState == STATE_TRANSITION
        confirmedTransitionReason := transitionReason
bool confirmedStateChanged =
     barstate.isconfirmed and
     confirmedState != confirmedState[1]
marketQuality := switch confirmedState
    STATE_BALANCE         => balanceCandidateScore
    STATE_COMPRESSION     => compressionCandidateScore
    STATE_BULL_EXPANSION  => bullExpansionCandidateScore
    STATE_BEAR_EXPANSION  => bearExpansionCandidateScore
    STATE_BULL_PULLBACK   => bullPullbackCandidateScore
    STATE_BEAR_PULLBACK   => bearPullbackCandidateScore
    STATE_BULL_EXHAUSTION => bullExhaustionCandidateScore
    STATE_BEAR_EXHAUSTION => bearExhaustionCandidateScore
    => stateQuality
// ─────────────────────────────────────────────────────────────────────────────
// IMPULSE MEMORY AND CORRECTION CONTEXT
// ─────────────────────────────────────────────────────────────────────────────
int currentImpulseDirection =
     confirmedState == STATE_BULL_EXPANSION ? 1 :
     confirmedState == STATE_BEAR_EXPANSION ? -1 :
     0
if barstate.isconfirmed
    if activeImpulseDirection != 0 and currentImpulseDirection != activeImpulseDirection
        float activeImpulseAvgAtr = activeImpulseBars > 0 ? activeImpulseAtrSum / activeImpulseBars : safeAtr
        float activeImpulseGrossRange = math.max(activeImpulseHigh - activeImpulseLow, syminfo.mintick)
        float activeImpulseNetProgress = activeImpulseDirection == 1 ?
             activeImpulseEndPrice - activeImpulseStartPrice :
             activeImpulseStartPrice - activeImpulseEndPrice
        lastImpulseDirection := activeImpulseDirection
        lastImpulseEndBar := bar_index - 1
        lastImpulseStartPrice := activeImpulseStartPrice
        lastImpulseEndPrice := activeImpulseEndPrice
        lastImpulseHigh := activeImpulseHigh
        lastImpulseLow := activeImpulseLow
        lastImpulseCounterExtreme := activeImpulseDirection == 1 ? activeImpulseHigh : activeImpulseLow
        lastImpulseCounterCloseExtreme := activeImpulseEndPrice
        lastImpulseSizeAtr := f_safeDiv(math.max(activeImpulseNetProgress, 0.0), activeImpulseAvgAtr, 0.0)
        lastImpulseGrossRangeAtr := f_safeDiv(activeImpulseGrossRange, activeImpulseAvgAtr, 0.0)
        lastImpulseEfficiency := f_clamp(
             f_safeDiv(math.max(activeImpulseNetProgress, 0.0), activeImpulseGrossRange, 0.0),
             0.0,
             1.0
        )
        lastImpulseQuality := activeImpulseBars > 0 ? activeImpulseQualitySum / activeImpulseBars : 0.0
        lastImpulseBars := activeImpulseBars
        activeImpulseDirection := 0
        activeImpulseStartPrice := na
        activeImpulseEndPrice := na
        activeImpulseHigh := na
        activeImpulseLow := na
        activeImpulseAtrSum := 0.0
        activeImpulseQualitySum := 0.0
        activeImpulseBars := 0
    if currentImpulseDirection != 0
        if activeImpulseDirection == 0
            activeImpulseDirection := currentImpulseDirection
            activeImpulseStartPrice := close[1]
            activeImpulseEndPrice := close
            activeImpulseHigh := math.max(high, close[1])
            activeImpulseLow := math.min(low, close[1])
            activeImpulseAtrSum := safeAtr
            activeImpulseQualitySum := marketQuality
            activeImpulseBars := 1
        else
            activeImpulseEndPrice := close
            activeImpulseHigh := math.max(activeImpulseHigh, high)
            activeImpulseLow := math.min(activeImpulseLow, low)
            activeImpulseAtrSum += safeAtr
            activeImpulseQualitySum += marketQuality
            activeImpulseBars += 1
    if lastImpulseDirection == 1 and currentImpulseDirection == 0
        lastImpulseCounterExtreme := math.min(nz(lastImpulseCounterExtreme, lastImpulseHigh), low)
        lastImpulseCounterCloseExtreme := math.min(nz(lastImpulseCounterCloseExtreme, lastImpulseEndPrice), close)
    else if lastImpulseDirection == -1 and currentImpulseDirection == 0
        lastImpulseCounterExtreme := math.max(nz(lastImpulseCounterExtreme, lastImpulseLow), high)
        lastImpulseCounterCloseExtreme := math.max(nz(lastImpulseCounterCloseExtreme, lastImpulseEndPrice), close)

bool balanceContextState =
     confirmedState == STATE_BALANCE or
     confirmedState == STATE_COMPRESSION
int correctionMemoryBars = math.max(20, compressionLen)
int lastImpulseAge = na(lastImpulseEndBar) ? correctionMemoryBars + 1 : bar_index - lastImpulseEndBar
bool hasRecentImpulse =
     lastImpulseDirection != 0 and
     lastImpulseAge >= 1 and
     lastImpulseAge <= correctionMemoryBars and
     lastImpulseBars >= 1 and
     lastImpulseSizeAtr >= 0.80 and
     lastImpulseEfficiency >= 0.45 and
     lastImpulseQuality >= 0.35
float impulseWickRange = lastImpulseDirection == 1 ?
     math.max(nz(lastImpulseHigh - lastImpulseStartPrice), syminfo.mintick) :
     math.max(nz(lastImpulseStartPrice - lastImpulseLow), syminfo.mintick)
float impulseCloseRange = math.max(
     math.abs(nz(lastImpulseEndPrice - lastImpulseStartPrice)),
     syminfo.mintick
)
float correctionDepth = na
if hasRecentImpulse
    float wickDepth = lastImpulseDirection == 1 ?
         f_safeDiv(lastImpulseHigh - lastImpulseCounterExtreme, impulseWickRange, 0.0) :
         f_safeDiv(lastImpulseCounterExtreme - lastImpulseLow, impulseWickRange, 0.0)
    float closeDepth = lastImpulseDirection == 1 ?
         f_safeDiv(lastImpulseEndPrice - lastImpulseCounterCloseExtreme, impulseCloseRange, 0.0) :
         f_safeDiv(lastImpulseCounterCloseExtreme - lastImpulseEndPrice, impulseCloseRange, 0.0)
    correctionDepth := f_clamp(0.35 * wickDepth + 0.65 * closeDepth, 0.0, 1.50)
bool oppositeStructure =
     (lastImpulseDirection == 1 and structuralBear) or
     (lastImpulseDirection == -1 and structuralBull)
bool impulseStructureHeld =
     lastImpulseDirection == 1 ?
         (structureFast >= structureSlow - safeAtr * 0.20 and slowSlope > -0.08) :
     lastImpulseDirection == -1 ?
         (structureFast <= structureSlow + safeAtr * 0.20 and slowSlope < 0.08) :
     false
bool htfDoesNotOpposeImpulse =
     not htfEnabled or
     (lastImpulseDirection == 1 and not htfBear) or
     (lastImpulseDirection == -1 and not htfBull)
bool opposingBias =
     (lastImpulseDirection == 1 and directionalBias < -directionalBiasThreshold) or
     (lastImpulseDirection == -1 and directionalBias > directionalBiasThreshold)
bool impulseTrendIntact =
     hasRecentImpulse and
     correctionDepth < 0.75 and
     not oppositeStructure and
     impulseStructureHeld and
     htfDoesNotOpposeImpulse
string impulseRiskReason = ""
if hasRecentImpulse and not impulseTrendIntact
    if correctionDepth >= 0.75
        impulseRiskReason := "Retracement is at least 75%"
    else if oppositeStructure
        impulseRiskReason := "Opposing structure detected"
    else if not impulseStructureHeld
        impulseRiskReason := "Structure lines no longer support the impulse"
    else if not htfDoesNotOpposeImpulse
        impulseRiskReason := "Higher timeframe is opposing the impulse"
bool balanceHasImpulseContext = balanceContextState and hasRecentImpulse
string balanceContextName = "No clear impulse"
if balanceHasImpulseContext
    if not impulseTrendIntact
        balanceContextName := "No clear continuation"
    else if confirmedState == STATE_COMPRESSION and correctionDepth < 0.38 and not opposingBias
        balanceContextName := lastImpulseDirection == 1 ? "Pause after advance" : "Pause after decline"
    else
        balanceContextName := lastImpulseDirection == 1 ? "Correction after advance" : "Correction after decline"
bool postImpulseContextStarted =
     barstate.isconfirmed and
     balanceHasImpulseContext and
     not balanceHasImpulseContext[1]
// ─────────────────────────────────────────────────────────────────────────────
// STATE DIRECTION AND TRADE COMPATIBILITY
// ─────────────────────────────────────────────────────────────────────────────
bool bullPullbackReaction =
     confirmedState == STATE_BULL_PULLBACK and
     close > open and
     closeLocationInBar >= 0.60 and
     (
         low <= structureSlow + safeAtr * 0.20 or
         low <= valueUpper
     ) and
     directionalBias > 0
bool bearPullbackReaction =
     confirmedState == STATE_BEAR_PULLBACK and
     close < open and
     closeLocationInBar <= 0.40 and
     (
         high >= structureSlow - safeAtr * 0.20 or
         high >= valueLower
     ) and
     directionalBias < 0
int longContextLevel = CONTEXT_NEUTRAL
int shortContextLevel = CONTEXT_NEUTRAL
if engineReady
    if confirmedState == STATE_BULL_EXPANSION
        longContextLevel := normalizedLocation >= extremeLocationThreshold ? CONTEXT_NEUTRAL : CONTEXT_COMPATIBLE
        shortContextLevel := CONTEXT_UNFAVORABLE
    else if confirmedState == STATE_BEAR_EXPANSION
        longContextLevel := CONTEXT_UNFAVORABLE
        shortContextLevel := normalizedLocation <= -extremeLocationThreshold ? CONTEXT_NEUTRAL : CONTEXT_COMPATIBLE
    else if confirmedState == STATE_BULL_PULLBACK
        longContextLevel := bullPullbackReaction ? CONTEXT_PREFERRED : CONTEXT_COMPATIBLE
        shortContextLevel := CONTEXT_UNFAVORABLE
    else if confirmedState == STATE_BEAR_PULLBACK
        longContextLevel := CONTEXT_UNFAVORABLE
        shortContextLevel := bearPullbackReaction ? CONTEXT_PREFERRED : CONTEXT_COMPATIBLE
    else if confirmedState == STATE_BULL_EXHAUSTION
        longContextLevel := CONTEXT_NEUTRAL
        shortContextLevel := normalizedLocation >= premiumThreshold ? CONTEXT_COMPATIBLE : CONTEXT_NEUTRAL
    else if confirmedState == STATE_BEAR_EXHAUSTION
        longContextLevel := normalizedLocation <= discountThreshold ? CONTEXT_COMPATIBLE : CONTEXT_NEUTRAL
        shortContextLevel := CONTEXT_NEUTRAL
    else if confirmedState == STATE_BALANCE or confirmedState == STATE_COMPRESSION
        if balanceHasImpulseContext and impulseTrendIntact
            longContextLevel := lastImpulseDirection == 1 ? CONTEXT_COMPATIBLE : CONTEXT_UNFAVORABLE
            shortContextLevel := lastImpulseDirection == -1 ? CONTEXT_COMPATIBLE : CONTEXT_UNFAVORABLE
        else
            longContextLevel := normalizedLocation >= premiumThreshold ? CONTEXT_UNFAVORABLE : CONTEXT_NEUTRAL
            shortContextLevel := normalizedLocation <= discountThreshold ? CONTEXT_UNFAVORABLE : CONTEXT_NEUTRAL
        if normalizedLocation <= discountThreshold and directionalBias > 0 and not (balanceHasImpulseContext and impulseTrendIntact and lastImpulseDirection == -1)
            longContextLevel := CONTEXT_PREFERRED
        if normalizedLocation >= premiumThreshold and directionalBias < 0 and not (balanceHasImpulseContext and impulseTrendIntact and lastImpulseDirection == 1)
            shortContextLevel := CONTEXT_PREFERRED
        if confirmedState == STATE_COMPRESSION and directionalBias > directionalBiasThreshold and longContextLevel >= CONTEXT_NEUTRAL
            longContextLevel := math.max(longContextLevel, CONTEXT_COMPATIBLE)
        if confirmedState == STATE_COMPRESSION and directionalBias < -directionalBiasThreshold and shortContextLevel >= CONTEXT_NEUTRAL
            shortContextLevel := math.max(shortContextLevel, CONTEXT_COMPATIBLE)
    if htfEnabled and htfBear
        longContextLevel := math.min(longContextLevel, CONTEXT_NEUTRAL)
    if htfEnabled and htfBull
        shortContextLevel := math.min(shortContextLevel, CONTEXT_NEUTRAL)
bool longContextCompatible = longContextLevel >= CONTEXT_COMPATIBLE
bool shortContextCompatible = shortContextLevel >= CONTEXT_COMPATIBLE
// Higher-quality contextual readiness.
// These are not entries.
bool longReadiness =
     longContextCompatible and
     (
         bullPullbackReaction or
         (
             confirmedState == STATE_COMPRESSION and
             directionalBias > directionalBiasThreshold
         ) or
         (
             confirmedState == STATE_BALANCE and
             normalizedLocation <= discountThreshold and
             directionalBias > 0
         )
     )
bool shortReadiness =
     shortContextCompatible and
     (
         bearPullbackReaction or
         (
             confirmedState == STATE_COMPRESSION and
             directionalBias < -directionalBiasThreshold
         ) or
         (
             confirmedState == STATE_BALANCE and
             normalizedLocation >= premiumThreshold and
             directionalBias < 0
         )
     )
bool longReadinessStarted =
     barstate.isconfirmed and
     longReadiness and
     not longReadiness[1]
bool shortReadinessStarted =
     barstate.isconfirmed and
     shortReadiness and
     not shortReadiness[1]
// ─────────────────────────────────────────────────────────────────────────────
// COMPRESSION / BALANCE ZONES
// ─────────────────────────────────────────────────────────────────────────────
// Raw (undebounced) zone extents — tracks the true onset and range of a
// balance/compression episode independently of the confirmed-state machine's
// confirmation lag, so the box reflects the actual structure instead of a
// fixed short lookback window. A shock bar (range >> ATR) can never start or
// extend the raw zone — one violent bar shouldn't set the zone's height.
bool isShockBar = currentRange > safeAtr * shockBarAtrMult
bool rawBalanceState =
     rawState == STATE_COMPRESSION or
     rawState == STATE_BALANCE
bool rawZoneState = barstate.isconfirmed and rawBalanceState and not isShockBar
var int rawZoneStart = na
var int rawZoneStartState = STATE_BALANCE
var float rawZoneHigh = na
var float rawZoneLow = na
var float rawZoneQualitySum = 0.0
var float rawZoneAtrSum = 0.0
var float rawZonePriceVolumeSum = 0.0
var float rawZoneVolumeSum = 0.0
var float rawZoneVolumeBaselineSum = 0.0
var int rawZoneVolumeCount = 0
var int rawZoneQualityCount = 0
var int rawZoneBalanceBars = 0
var int rawZoneCompressionBars = 0
var int rawZoneInterruptions = 0
bool rawZoneExists = not na(rawZoneStart)
bool rawZoneGeometricBreak =
     rawZoneExists and
     (
         close > rawZoneHigh + safeAtr * zoneBreakAtr or
         close < rawZoneLow - safeAtr * zoneBreakAtr
     )
if barstate.isconfirmed
    if rawZoneState
        if not rawZoneExists
            rawZoneStart := bar_index
            rawZoneStartState := rawState
            rawZoneHigh := high
            rawZoneLow := low
            rawZoneQualitySum := stateQuality
            rawZoneAtrSum := safeAtr
            rawZonePriceVolumeSum := hasUsableZoneVolume ? hlc3 * volume : 0.0
            rawZoneVolumeSum := hasUsableZoneVolume ? volume : 0.0
            rawZoneVolumeBaselineSum := hasUsableZoneVolume ? volumeAverage : 0.0
            rawZoneVolumeCount := hasUsableZoneVolume ? 1 : 0
            rawZoneQualityCount := 1
            rawZoneBalanceBars := rawState == STATE_BALANCE ? 1 : 0
            rawZoneCompressionBars := rawState == STATE_COMPRESSION ? 1 : 0
        else
            rawZoneHigh := math.max(rawZoneHigh, high)
            rawZoneLow := math.min(rawZoneLow, low)
            rawZoneQualitySum += stateQuality
            rawZoneAtrSum += safeAtr
            if hasUsableZoneVolume
                rawZonePriceVolumeSum += hlc3 * volume
                rawZoneVolumeSum += volume
                rawZoneVolumeBaselineSum += volumeAverage
                rawZoneVolumeCount += 1
            rawZoneQualityCount += 1
            rawZoneBalanceBars += rawState == STATE_BALANCE ? 1 : 0
            rawZoneCompressionBars += rawState == STATE_COMPRESSION ? 1 : 0
        rawZoneInterruptions := 0
    else if rawZoneExists
        rawZoneInterruptions += 1
        if rawZoneGeometricBreak or rawZoneInterruptions > rawZoneGraceBars
            rawZoneStart := na
            rawZoneStartState := STATE_BALANCE
            rawZoneHigh := na
            rawZoneLow := na
            rawZoneQualitySum := 0.0
            rawZoneAtrSum := 0.0
            rawZonePriceVolumeSum := 0.0
            rawZoneVolumeSum := 0.0
            rawZoneVolumeBaselineSum := 0.0
            rawZoneVolumeCount := 0
            rawZoneQualityCount := 0
            rawZoneBalanceBars := 0
            rawZoneCompressionBars := 0
            rawZoneInterruptions := 0

bool zoneState =
     balanceContextState
var int zoneBars = 0
if barstate.isconfirmed
    if zoneState
        if not zoneState[1]
            zoneBars := 1
        else
