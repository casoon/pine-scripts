//@version=6
// ============================================================================
// Smart Money Dashboard [WavesUnchained]
// Version: 1.0.0
// Author: WavesUnchained
// ============================================================================
// Order flow, SMC patterns, and liquidity in a single dashboard with confluence scoring.
//
// Features:
//   ✓ Order Flow imbalances (buying/selling pressure)
//   ✓ Order Blocks (institutional entry zones)
//   ✓ Fair Value Gaps (price inefficiencies)
//   ✓ Equal Highs/Lows (liquidity pools)
//   ✓ Real-time confluence score (0–100)
//
// ============================================================================

indicator("Smart Money Dashboard", "SMD", overlay=true, max_boxes_count=100, max_lines_count=100, max_labels_count=50)

// ============================================================================
// USER INPUTS
// ============================================================================

var g1 = "Order Flow"
enableOrderFlow  = input.bool(true, "Show Order Flow",          group=g1)
flowThreshold    = input.int(65,   "Imbalance Threshold %",     group=g1, minval=50, maxval=90)
flowLen          = input.int(20,   "Order Flow Length",          group=g1, minval=5,  maxval=100)

var g2 = "SMC Patterns"
enableOrderBlocks = input.bool(true,  "Show Order Blocks",       group=g2)
enableFVGs        = input.bool(true,  "Show Fair Value Gaps",    group=g2)
maxOBs            = input.int(5,      "Max Order Blocks",        group=g2, minval=1, maxval=20)
maxFVGs           = input.int(3,      "Max FVGs",                group=g2, minval=1, maxval=10)
obDispMult        = input.float(1.2,  "OB Displacement ATR ×",  group=g2, minval=0.5, maxval=3.0, step=0.1)

var g3 = "Liquidity"
enableLiquidity   = input.bool(true, "Show Equal Highs/Lows",   group=g3)
liquidityLookback = input.int(15,    "Lookback Period",          group=g3, minval=5, maxval=50)
eqlTolerance      = input.float(0.05,"Equal Level Tolerance %", group=g3, minval=0.01, maxval=0.5, step=0.01)

var g4 = "Display"
showDashboard    = input.bool(true, "Show Dashboard",            group=g4)
showOrderFlowBG  = input.bool(true, "Order Flow Background",     group=g4)

// ============================================================================
// TYPES
// ============================================================================

type OBLevel
    int    barIdx
    float  hi
    float  lo
    string obType
    bool   mitigated

type FVGLevel
    int    barIdx
    float  hi
    float  lo
    string fvgType
    bool   filled

type LiqLevel
    float  price
    int    lastBar
    int    touchCount
    bool   swept

// ============================================================================
// ORDER FLOW
// ============================================================================

bullVol    = close > open ? volume : 0.0
bearVol    = close <= open ? volume : 0.0
bullVolSum = math.sum(bullVol, flowLen)
bearVolSum = math.sum(bearVol, flowLen)
totalVol   = bullVolSum + bearVolSum

imbalanceDirection = totalVol > 0 ? (bullVolSum > bearVolSum ? 1 : bullVolSum < bearVolSum ? -1 : 0) : 0
imbalanceStrength  = totalVol > 0 ? math.round(math.max(bullVolSum, bearVolSum) / totalVol * 100) : 50

// ============================================================================
// ORDER BLOCKS
// ============================================================================

var array<OBLevel> obLevels = array.new<OBLevel>()

atr14        = ta.atr(14)
displacement = atr14 * obDispMult

// Bullish OB: last bearish candle before a bullish impulse
if close - close[1] > displacement and close[1] < open[1]
    array.unshift(obLevels, OBLevel.new(bar_index - 1, high[1], low[1], "BULLISH", false))
    if array.size(obLevels) > maxOBs * 2
        array.pop(obLevels)

// Bearish OB: last bullish candle before a bearish impulse
if close[1] - close > displacement and close[1] > open[1]
    array.unshift(obLevels, OBLevel.new(bar_index - 1, high[1], low[1], "BEARISH", false))
    if array.size(obLevels) > maxOBs * 2
        array.pop(obLevels)

// Mitigate OBs
for ob in obLevels
    if not ob.mitigated
        if ob.obType == "BULLISH" and low < ob.lo
            ob.mitigated := true
        else if ob.obType == "BEARISH" and high > ob.hi
            ob.mitigated := true

activeOBs() =>
    result = array.new<OBLevel>()
    count  = 0
    for ob in obLevels
        if not ob.mitigated and count < maxOBs
            array.push(result, ob)
            count += 1
    result

// ============================================================================
// FAIR VALUE GAPS
// ============================================================================

var array<FVGLevel> fvgLevels = array.new<FVGLevel>()

// Bullish FVG: gap between candle[2] high and candle[0] low
if low > high[2]
    array.unshift(fvgLevels, FVGLevel.new(bar_index - 1, low, high[2], "BULLISH", false))
    if array.size(fvgLevels) > maxFVGs * 2
        array.pop(fvgLevels)

// Bearish FVG: gap between candle[2] low and candle[0] high
if high < low[2]
    array.unshift(fvgLevels, FVGLevel.new(bar_index - 1, low[2], high, "BEARISH", false))
    if array.size(fvgLevels) > maxFVGs * 2
        array.pop(fvgLevels)

// Fill FVGs
for fvg in fvgLevels
    if not fvg.filled
        if fvg.fvgType == "BULLISH" and low <= fvg.hi
            fvg.filled := true
        else if fvg.fvgType == "BEARISH" and high >= fvg.lo
            fvg.filled := true

unfilledFVGs() =>
    result = array.new<FVGLevel>()
    count  = 0
    for fvg in fvgLevels
        if not fvg.filled and count < maxFVGs
            array.push(result, fvg)
            count += 1
    result

// ============================================================================
// EQUAL HIGHS / LOWS
// ============================================================================

var array<LiqLevel> equalHighs = array.new<LiqLevel>()
var array<LiqLevel> equalLows  = array.new<LiqLevel>()

tolerance  = close * eqlTolerance / 100
swingHigh  = ta.pivothigh(high, liquidityLookback, liquidityLookback)
swingLow   = ta.pivotlow(low,   liquidityLookback, liquidityLookback)

if not na(swingHigh)
    found = false
    for lvl in equalHighs
        if math.abs(lvl.price - swingHigh) <= tolerance
            lvl.touchCount += 1
            lvl.lastBar     := bar_index
            found           := true
            break
    if not found
        array.push(equalHighs, LiqLevel.new(swingHigh, bar_index, 1, false))
    if array.size(equalHighs) > 20
        array.shift(equalHighs)

if not na(swingLow)
    found = false
    for lvl in equalLows
        if math.abs(lvl.price - swingLow) <= tolerance
            lvl.touchCount += 1
            lvl.lastBar     := bar_index
            found           := true
            break
    if not found
        array.push(equalLows, LiqLevel.new(swingLow, bar_index, 1, false))
    if array.size(equalLows) > 20
        array.shift(equalLows)

// Sweep detection
for lvl in equalHighs
    if not lvl.swept and high > lvl.price
        lvl.swept := true
for lvl in equalLows
    if not lvl.swept and low < lvl.price
        lvl.swept := true

// Near liquidity
nearLiquidityUp   = false
nearLiquidityDown = false
for lvl in equalHighs
    if not lvl.swept and math.abs(close - lvl.price) <= atr14 * 1.5
        nearLiquidityUp := true
for lvl in equalLows
    if not lvl.swept and math.abs(close - lvl.price) <= atr14 * 1.5
        nearLiquidityDown := true

// ============================================================================
// CONFLUENCE SCORING
// ============================================================================

curActiveOBs  = activeOBs()
curFVGs       = unfilledFVGs()

confluenceScore = 0.0
signals = 0

if imbalanceStrength >= flowThreshold
    confluenceScore += 25.0
    signals         += 1

if array.size(curActiveOBs) > 0
    for i = 0 to array.size(curActiveOBs) - 1
        ob = array.get(curActiveOBs, i)
        if math.abs(close - ob.lo) / close < 0.02 or math.abs(close - ob.hi) / close < 0.02
            confluenceScore += 25.0
            signals         += 1
            break

if array.size(curFVGs) > 0
    for i = 0 to array.size(curFVGs) - 1
        fvg = array.get(curFVGs, i)
        if low <= fvg.hi and high >= fvg.lo
            confluenceScore += 25.0
            signals         += 1
            break

if nearLiquidityUp or nearLiquidityDown
    confluenceScore += 25.0
    signals         += 1

// ============================================================================
// ORDER FLOW VISUALIZATION
// ============================================================================

if enableOrderFlow and showOrderFlowBG
    flowBgColor = imbalanceDirection == 1 ? color.new(color.green, 92) :
         imbalanceDirection == -1 ? color.new(color.red, 92) : na
    bgcolor(flowBgColor, title="Order Flow")

// ============================================================================
// VISUALIZATIONS — drawn on last bar only to respect box/line limits
// ============================================================================

if barstate.islast

    if enableOrderBlocks and array.size(curActiveOBs) > 0
        displayCount = math.min(array.size(curActiveOBs), maxOBs)
        for i = 0 to displayCount - 1
            ob    = array.get(curActiveOBs, i)
            obCol = ob.obType == "BULLISH" ? color.new(color.green, 75) : color.new(color.red, 75)
            box.new(ob.barIdx, ob.hi, bar_index + 10, ob.lo,
                 border_color=obCol, bgcolor=obCol, border_width=2, extend=extend.right)
            labelText = ob.obType == "BULLISH" ? "OB +" : "OB -"
            label.new(ob.barIdx, ob.obType == "BULLISH" ? ob.lo : ob.hi, labelText,
                 color=obCol, textcolor=color.white,
                 style=ob.obType == "BULLISH" ? label.style_label_up : label.style_label_down,
                 size=size.small)

    if enableFVGs and array.size(curFVGs) > 0
        displayCount = math.min(array.size(curFVGs), maxFVGs)
        for i = 0 to displayCount - 1
            fvg    = array.get(curFVGs, i)
            fvgCol = fvg.fvgType == "BULLISH" ? color.new(color.blue, 85) : color.new(color.orange, 85)
            box.new(fvg.barIdx, fvg.hi, bar_index + 10, fvg.lo,
                 border_color=fvgCol, bgcolor=fvgCol, border_width=1,
                 border_style=line.style_dashed, extend=extend.right)
            label.new(fvg.barIdx, fvg.fvgType == "BULLISH" ? fvg.lo : fvg.hi, "FVG",
                 color=fvgCol, textcolor=color.white,
                 style=fvg.fvgType == "BULLISH" ? label.style_label_up : label.style_label_down,
                 size=size.tiny)

    if enableLiquidity
        if array.size(equalHighs) > 0
            for i = 0 to math.min(array.size(equalHighs) - 1, 3)
                lvl = array.get(equalHighs, i)
                if lvl.touchCount >= 2 and not lvl.swept
                    line.new(lvl.lastBar - liquidityLookback, lvl.price, bar_index + 5, lvl.price,
                         color=color.new(color.red, 50), style=line.style_dashed, width=1)
        if array.size(equalLows) > 0
            for i = 0 to math.min(array.size(equalLows) - 1, 3)
                lvl = array.get(equalLows, i)
                if lvl.touchCount >= 2 and not lvl.swept
                    line.new(lvl.lastBar - liquidityLookback, lvl.price, bar_index + 5, lvl.price,
                         color=color.new(color.green, 50), style=line.style_dashed, width=1)

// ============================================================================
// DASHBOARD
// ============================================================================

if showDashboard and barstate.islast
    var table dashboard = table.new(position.top_right, 2, 10,
         border_width=2, border_color=color.new(color.gray, 50),
         frame_width=1,  frame_color=color.new(color.gray, 70))

    table.cell(dashboard, 0, 0, "SMART MONEY",
         text_color=color.white, bgcolor=color.new(color.purple, 20),
         text_size=size.normal, text_halign=text.align_center)
    table.merge_cells(dashboard, 0, 0, 1, 0)

    flowDirText = imbalanceDirection == 1 ? "BULLISH" : imbalanceDirection == -1 ? "BEARISH" : "NEUTRAL"
    flowDirCol  = imbalanceDirection == 1 ? color.lime : imbalanceDirection == -1 ? color.red : color.gray
    table.cell(dashboard, 0, 1, "Order Flow",  text_color=color.gray,   text_size=size.small)
    table.cell(dashboard, 1, 1, flowDirText,   text_color=flowDirCol,   text_size=size.small)

    table.cell(dashboard, 0, 2, "Strength",    text_color=color.gray,   text_size=size.small)
    table.cell(dashboard, 1, 2, str.tostring(imbalanceStrength, "#") + "%",
         text_color=color.white, text_size=size.small)

    obCount = array.size(curActiveOBs)
    table.cell(dashboard, 0, 3, "Order Blocks", text_color=color.gray,  text_size=size.small)
    table.cell(dashboard, 1, 3, str.tostring(obCount),
         text_color=obCount > 0 ? color.yellow : color.gray, text_size=size.small)

    fvgCount = array.size(curFVGs)
    table.cell(dashboard, 0, 4, "FVGs",         text_color=color.gray,  text_size=size.small)
    table.cell(dashboard, 1, 4, str.tostring(fvgCount),
         text_color=fvgCount > 0 ? color.aqua : color.gray, text_size=size.small)

    eqhCount = 0
    for lvl in equalHighs
        if not lvl.swept
            eqhCount += 1
    eqlCount = 0
    for lvl in equalLows
        if not lvl.swept
            eqlCount += 1
    table.cell(dashboard, 0, 5, "Liquidity",   text_color=color.gray,   text_size=size.small)
    table.cell(dashboard, 1, 5, str.format("↑{0} ↓{1}", eqhCount, eqlCount),
         text_color=color.white, text_size=size.small)

    table.cell(dashboard, 0, 6, "", bgcolor=color.new(color.gray, 80))
    table.merge_cells(dashboard, 0, 6, 1, 6)

    scoreColor = confluenceScore >= 75 ? color.lime  : confluenceScore >= 50 ? color.yellow :
         confluenceScore >= 25 ? color.orange : color.gray
    table.cell(dashboard, 0, 7, "Confluence",  text_color=color.gray,   text_size=size.small)
    table.cell(dashboard, 1, 7, str.format("{0}/100", str.tostring(confluenceScore, "#")),
         text_color=scoreColor, text_size=size.normal)

    table.cell(dashboard, 0, 8, "Signals",     text_color=color.gray,   text_size=size.small)
    table.cell(dashboard, 1, 8, str.format("{0}/4", signals),
         text_color=color.white, text_size=size.small)

    recommendation = confluenceScore >= 75 ? "STRONG"   : confluenceScore >= 50 ? "MODERATE" :
         confluenceScore >= 25 ? "WEAK" : "NO SETUP"
    recColor = confluenceScore >= 75 ? color.new(color.green,  30) :
         confluenceScore >= 50 ? color.new(color.yellow, 30) :
         confluenceScore >= 25 ? color.new(color.orange, 30) : color.new(color.gray, 60)
    table.cell(dashboard, 0, 9, "Setup",       text_color=color.gray,   text_size=size.small)
    table.cell(dashboard, 1, 9, recommendation,
         text_color=color.white, bgcolor=recColor, text_size=size.small, text_halign=text.align_center)

// ============================================================================
// ALERTS
// ============================================================================

strongBullish = imbalanceDirection == 1  and imbalanceStrength >= 75 and confluenceScore >= 75
strongBearish = imbalanceDirection == -1 and imbalanceStrength >= 75 and confluenceScore >= 75

alertcondition(strongBullish, "Strong Bullish Setup", "Smart Money: Strong bullish confluence detected")
alertcondition(strongBearish, "Strong Bearish Setup", "Smart Money: Strong bearish confluence detected")
alertcondition(confluenceScore >= 75 and confluenceScore[1] < 75, "High Confluence",
     str.format("Smart Money: Confluence {0}/100", confluenceScore))
