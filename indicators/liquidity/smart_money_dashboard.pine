//@version=6
indicator("Smart Money Dashboard [RTA]", "💎 Smart Money", overlay=true, max_boxes_count=100, max_lines_count=100, max_labels_count=50)

// ============================================================================
// SMART MONEY DASHBOARD - Comprehensive Institutional Analysis
// ============================================================================
// @description
// Combines Order Flow, Liquidity Mapping, and SMC Patterns for complete
// institutional activity analysis.
//
// Features:
//   - Order Flow imbalances (buying/selling pressure)
//   - Order Blocks (institutional entry zones)
//   - Fair Value Gaps (price inefficiencies)
//   - Equal Highs/Lows (liquidity pools)
//   - Real-time dashboard with confluence scoring
//
// @author Waves Unchained
// @version 1.0.0
// ============================================================================

import WavesUnchained/RTAMarketStructure/1 as MS
import WavesUnchained/RTAAdvanced/1 as ADV

// ============================================================================
// USER INPUTS
// ============================================================================

// --- Order Flow ---
var g1 = "📊 Order Flow"
enableOrderFlow = input.bool(true, "Show Order Flow", group=g1)
flowThreshold = input.int(65, "Imbalance Threshold %", minval=50, maxval=90, group=g1)

// --- SMC Patterns ---
var g2 = "🎯 SMC Patterns"
enableOrderBlocks = input.bool(true, "Show Order Blocks", group=g2)
enableFVGs = input.bool(true, "Show Fair Value Gaps", group=g2)
maxOBs = input.int(5, "Max Order Blocks", minval=1, maxval=20, group=g2)
maxFVGs = input.int(3, "Max FVGs", minval=1, maxval=10, group=g2)

// --- Liquidity ---
var g3 = "💧 Liquidity"
enableLiquidity = input.bool(true, "Show Equal Highs/Lows", group=g3)
liquidityLookback = input.int(15, "Lookback Period", minval=5, maxval=50, group=g3)

// --- Display ---
var g4 = "🎨 Display"
showDashboard = input.bool(true, "Show Dashboard", group=g4)
showOrderFlowBG = input.bool(true, "Order Flow Background", group=g4)
obColor = input.color(color.new(color.purple, 70), "Order Block", group=g4)
fvgColor = input.color(color.new(color.blue, 80), "FVG", group=g4)

// ============================================================================
// INITIALIZE STATES
// ============================================================================

var orderFlow = MS.newOrderFlowState()
var smcState = ADV.newSMCState()
var liquidityState = MS.newLiquidityState()

// ============================================================================
// UPDATE ALL SYSTEMS
// ============================================================================

// Order Flow
MS.updateOrderFlow(orderFlow)

// SMC Patterns
smcConfig = ADV.newSMCConfig()
smcConfig.maxOBs := maxOBs
smcConfig.maxFVGs := maxFVGs
ADV.updateSMCPatterns(smcState, smcConfig)

// Liquidity Mapping
MS.updateLiquidityMapping(liquidityState, liquidityLookback, 0.0005)

// ============================================================================
// ORDER FLOW VISUALIZATION
// ============================================================================

if enableOrderFlow and showOrderFlowBG
    // Background color based on imbalance
    flowColor = orderFlow.imbalanceDirection == 1 ?
        color.new(color.green, 92) :
        orderFlow.imbalanceDirection == -1 ?
        color.new(color.red, 92) : na

    bgcolor(flowColor, title="Order Flow")

// ============================================================================
// ORDER BLOCKS VISUALIZATION
// ============================================================================

if enableOrderBlocks
    activeOBs = ADV.getActiveOrderBlocks(smcState)

    if array.size(activeOBs) > 0
        displayCount = math.min(array.size(activeOBs), maxOBs)

        for i = 0 to displayCount - 1
            ob = array.get(activeOBs, i)

            obColor := ob.obType == "BULLISH" ?
                color.new(color.green, 75) : color.new(color.red, 75)

            // Draw OB box
            box.new(
                ob.obBar,
                ob.obHigh,
                bar_index + 10,
                ob.obLow,
                border_color=obColor,
                bgcolor=obColor,
                border_width=2,
                extend=extend.right
            )

            // Label
            if bar_index - ob.obBar < 3
                labelText = ob.obType == "BULLISH" ? "OB 🟢" : "OB 🔴"
                label.new(
                    ob.obBar,
                    ob.obType == "BULLISH" ? ob.obLow : ob.obHigh,
                    labelText,
                    color=obColor,
                    textcolor=color.white,
                    style=ob.obType == "BULLISH" ?
                        label.style_label_up : label.style_label_down,
                    size=size.small
                )

// ============================================================================
// FAIR VALUE GAPS VISUALIZATION
// ============================================================================

if enableFVGs
    unfilledFVGs = ADV.getUnfilledFVGs(smcState)

    if array.size(unfilledFVGs) > 0
        displayCount = math.min(array.size(unfilledFVGs), maxFVGs)

        for i = 0 to displayCount - 1
            fvg = array.get(unfilledFVGs, i)

            fvgColor := fvg.fvgType == "BULLISH" ?
                color.new(color.blue, 85) : color.new(color.orange, 85)

            // Draw FVG box
            box.new(
                fvg.fvgBar,
                fvg.fvgHigh,
                bar_index + 10,
                fvg.fvgLow,
                border_color=fvgColor,
                bgcolor=fvgColor,
                border_width=1,
                border_style=line.style_dashed,
                extend=extend.right
            )

            // Label
            if bar_index == fvg.fvgBar
                label.new(
                    fvg.fvgBar,
                    fvg.fvgType == "BULLISH" ? fvg.fvgLow : fvg.fvgHigh,
                    "FVG",
                    color=fvgColor,
                    textcolor=color.white,
                    style=fvg.fvgType == "BULLISH" ?
                        label.style_label_up : label.style_label_down,
                    size=size.tiny
                )

// ============================================================================
// EQUAL HIGHS/LOWS VISUALIZATION
// ============================================================================

if enableLiquidity
    activeEqualHighs = MS.getActiveEqualHighs(liquidityState)
    activeEqualLows = MS.getActiveEqualLows(liquidityState)

    // Draw Equal Highs
    if array.size(activeEqualHighs) > 0
        for i = 0 to math.min(array.size(activeEqualHighs) - 1, 3)
            level = array.get(activeEqualHighs, i)
            if level.touchCount >= 2 and not level.swept
                line.new(
                    level.lastBar - liquidityLookback,
                    level.price,
                    bar_index + 5,
                    level.price,
                    color=color.new(color.red, 50),
                    style=line.style_dashed,
                    width=1
                )

    // Draw Equal Lows
    if array.size(activeEqualLows) > 0
        for i = 0 to math.min(array.size(activeEqualLows) - 1, 3)
            level = array.get(activeEqualLows, i)
            if level.touchCount >= 2 and not level.swept
                line.new(
                    level.lastBar - liquidityLookback,
                    level.price,
                    bar_index + 5,
                    level.price,
                    color=color.new(color.green, 50),
                    style=line.style_dashed,
                    width=1
                )

// ============================================================================
// CONFLUENCE SCORING
// ============================================================================

// Calculate confluence score (0-100)
confluenceScore = 0.0
signals = 0

// Order Flow confirmation
if orderFlow.imbalanceStrength >= flowThreshold
    confluenceScore += 25.0
    signals += 1

// Order Block nearby
activeOBs = ADV.getActiveOrderBlocks(smcState)
if array.size(activeOBs) > 0
    for i = 0 to array.size(activeOBs) - 1
        ob = array.get(activeOBs, i)
        if math.abs(close - ob.obLow) / close < 0.02 or
             math.abs(close - ob.obHigh) / close < 0.02
            confluenceScore += 25.0
            signals += 1
            break

// FVG nearby
unfilledFVGs = ADV.getUnfilledFVGs(smcState)
if array.size(unfilledFVGs) > 0
    for i = 0 to array.size(unfilledFVGs) - 1
        fvg = array.get(unfilledFVGs, i)
        if low <= fvg.fvgHigh and high >= fvg.fvgLow
            confluenceScore += 25.0
            signals += 1
            break

// Liquidity nearby
currentATR = ta.atr(14)
[nearUp, nearDown] = MS.isNearLiquidity(liquidityState, currentATR, 1.5)
if nearUp or nearDown
    confluenceScore += 25.0
    signals += 1

// ============================================================================
// DASHBOARD
// ============================================================================

if showDashboard and barstate.islast
    var table dashboard = table.new(position.top_right, 2, 10,
        border_width=2,
        border_color=color.new(color.gray, 50),
        frame_width=1,
        frame_color=color.new(color.gray, 70))

    // Header
    table.cell(dashboard, 0, 0, "💎 SMART MONEY",
        text_color=color.white,
        bgcolor=color.new(color.purple, 20),
        text_size=size.normal,
        text_halign=text.align_center)
    table.merge_cells(dashboard, 0, 0, 1, 0)

    // Order Flow
    flowDirection = orderFlow.imbalanceDirection == 1 ? "BULLISH" :
        orderFlow.imbalanceDirection == -1 ? "BEARISH" : "NEUTRAL"
    flowColor := orderFlow.imbalanceDirection == 1 ? color.lime :
        orderFlow.imbalanceDirection == -1 ? color.red : color.gray

    table.cell(dashboard, 0, 1, "Order Flow", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 1, 1, flowDirection, text_color=flowColor, text_size=size.small)

    // Imbalance Strength
    table.cell(dashboard, 0, 2, "Strength", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 1, 2,
        str.tostring(orderFlow.imbalanceStrength, "#") + "%",
        text_color=color.white, text_size=size.small)

    // Order Blocks
    obCount = array.size(ADV.getActiveOrderBlocks(smcState))
    table.cell(dashboard, 0, 3, "Order Blocks", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 1, 3, str.tostring(obCount),
        text_color=obCount > 0 ? color.yellow : color.gray, text_size=size.small)

    // Fair Value Gaps
    fvgCount = array.size(ADV.getUnfilledFVGs(smcState))
    table.cell(dashboard, 0, 4, "FVGs", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 1, 4, str.tostring(fvgCount),
        text_color=fvgCount > 0 ? color.aqua : color.gray, text_size=size.small)

    // Equal Highs/Lows
    eqhCount = array.size(MS.getActiveEqualHighs(liquidityState))
    eqlCount = array.size(MS.getActiveEqualLows(liquidityState))
    table.cell(dashboard, 0, 5, "Liquidity", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 1, 5,
        str.format("↑{0} ↓{1}", eqhCount, eqlCount),
        text_color=color.white, text_size=size.small)

    // Separator
    table.cell(dashboard, 0, 6, "", bgcolor=color.new(color.gray, 80))
    table.merge_cells(dashboard, 0, 6, 1, 6)

    // Confluence Score
    scoreColor = confluenceScore >= 75 ? color.lime :
        confluenceScore >= 50 ? color.yellow :
        confluenceScore >= 25 ? color.orange : color.gray

    table.cell(dashboard, 0, 7, "Confluence", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 1, 7,
        str.format("{0}/100", str.tostring(confluenceScore, "#")),
        text_color=scoreColor,
        text_size=size.normal)

    // Signal Count
    table.cell(dashboard, 0, 8, "Signals", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 1, 8,
        str.format("{0}/4", signals),
        text_color=color.white, text_size=size.small)

    // Recommendation
    recommendation = confluenceScore >= 75 ? "🟢 STRONG" :
        confluenceScore >= 50 ? "🟡 MODERATE" :
        confluenceScore >= 25 ? "🟠 WEAK" : "⚪ NO SETUP"

    recColor = confluenceScore >= 75 ? color.new(color.green, 30) :
        confluenceScore >= 50 ? color.new(color.yellow, 30) :
        confluenceScore >= 25 ? color.new(color.orange, 30) :
        color.new(color.gray, 60)

    table.cell(dashboard, 0, 9, "Setup", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 1, 9, recommendation,
        text_color=color.white,
        bgcolor=recColor,
        text_size=size.small,
        text_halign=text.align_center)

// ============================================================================
// ALERTS
// ============================================================================

strongBullish = orderFlow.imbalanceDirection == 1 and
     orderFlow.imbalanceStrength >= 75 and confluenceScore >= 75

strongBearish = orderFlow.imbalanceDirection == -1 and
     orderFlow.imbalanceStrength >= 75 and confluenceScore >= 75

alertcondition(strongBullish, "Strong Bullish Setup",
    "Smart Money: Strong bullish confluence detected")

alertcondition(strongBearish, "Strong Bearish Setup",
    "Smart Money: Strong bearish confluence detected")

alertcondition(confluenceScore >= 75 and confluenceScore[1] < 75,
    "High Confluence",
    str.format("Smart Money: Confluence {0}/100", confluenceScore))
