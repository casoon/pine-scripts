//@version=6
// ============================================================================
// Liquidity Hunter [WavesUnchained]
// Version: 1.0.0
// Author: WavesUnchained
// ============================================================================
// Identifies and visualizes institutional liquidity zones where large orders cluster.
// Based on Smart Money Concepts: price is magnetically attracted to liquidity.
//
// Features:
//   ✓ Equal Highs/Lows (liquidity pools)
//   ✓ Unfilled Gaps (magnet zones)
//   ✓ Round Number Levels (psychological zones)
//   ✓ Stop Hunt Detection (liquidity grabs)
//   ✓ Real-time proximity alerts
//
// ============================================================================

indicator("Liquidity Hunter [WavesUnchained]", "💧 Liquidity Hunter", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

import WavesUnchained/RTAMarketStructure/1 as MS

// ============================================================================
// USER INPUTS
// ============================================================================

// --- Equal Highs/Lows Settings ---
var g1 = "🔹 Equal Highs/Lows"
enableEqualLevels = input.bool(true, "Show Equal Highs/Lows", group=g1)
lookbackPeriod = input.int(20, "Lookback Period", minval=5, maxval=100, group=g1)
tolerancePercent = input.float(0.05, "Price Tolerance %", minval=0.01, maxval=1.0, step=0.01, group=g1) / 100
minTouches = input.int(2, "Minimum Touches", minval=2, maxval=5, group=g1)
showSweptLevels = input.bool(false, "Show Swept Levels", group=g1)

// --- Gap Settings ---
var g2 = "📊 Gap Detection"
enableGaps = input.bool(true, "Show Unfilled Gaps", group=g2)
maxGapsDisplay = input.int(5, "Max Gaps to Display", minval=1, maxval=20, group=g2)
minGapSize = input.float(0.1, "Min Gap Size %", minval=0.0, maxval=5.0, step=0.1, group=g2) / 100

// --- Round Numbers ---
var g3 = "🎯 Round Numbers"
enableRoundNumbers = input.bool(true, "Show Round Numbers", group=g3)
numberOfLevels = input.int(5, "Levels Above/Below", minval=1, maxval=10, group=g3)
maxDistancePercent = input.float(3.0, "Max Distance %", minval=0.5, maxval=10.0, step=0.5, group=g3) / 100

// --- Stop Hunts ---
var g4 = "⚡ Stop Hunts"
enableStopHunts = input.bool(true, "Detect Stop Hunts", group=g4)
showUnconfirmed = input.bool(false, "Show Unconfirmed Hunts", group=g4)
maxHuntsDisplay = input.int(10, "Max Hunts to Show", minval=1, maxval=50, group=g4)

// --- Alerts & Dashboard ---
var g5 = "🔔 Alerts & Display"
enableProximityAlerts = input.bool(true, "Proximity Alerts", group=g5)
alertDistance = input.float(1.0, "Alert Distance (ATR)", minval=0.5, maxval=5.0, step=0.5, group=g5)
showDashboard = input.bool(true, "Show Dashboard", group=g5)
dashboardPosition = input.string("top_right", "Dashboard Position",
     options=["top_left", "top_center", "top_right", "middle_left", "middle_center", "middle_right", "bottom_left", "bottom_center", "bottom_right"], group=g5)

// --- Styling ---
var g6 = "🎨 Styling"
equalHighColor = input.color(color.new(color.red, 20), "Equal Highs", group=g6)
equalLowColor = input.color(color.new(color.green, 20), "Equal Lows", group=g6)
gapBullishColor = input.color(color.new(color.blue, 80), "Bullish Gap", group=g6)
gapBearishColor = input.color(color.new(color.orange, 80), "Bearish Gap", group=g6)
roundNumberColor = input.color(color.new(color.gray, 60), "Round Numbers", group=g6)
stopHuntColor = input.color(color.new(color.yellow, 70), "Stop Hunt", group=g6)

// ============================================================================
// INITIALIZE STATE
// ============================================================================

var liquidityState = MS.newLiquidityState()

// ============================================================================
// UPDATE LIQUIDITY MAPPING
// ============================================================================

MS.updateLiquidityMapping(liquidityState, lookbackPeriod, tolerancePercent)

// ============================================================================
// GET DATA
// ============================================================================

activeEqualHighs = MS.getActiveEqualHighs(liquidityState)
activeEqualLows = MS.getActiveEqualLows(liquidityState)
unfilledGaps = MS.getUnfilledGaps(liquidityState)
nearbyRoundNumbers = MS.getNearbyRoundNumbers(liquidityState, close * maxDistancePercent)
recentHunts = MS.getRecentStopHunts(liquidityState, maxHuntsDisplay)

currentATR = ta.atr(14)
[nearUp, nearDown] = MS.isNearLiquidity(liquidityState, currentATR, alertDistance)

// ============================================================================
// VISUALIZATION - EQUAL HIGHS/LOWS
// ============================================================================

if enableEqualLevels
    // Draw Equal Highs
    if array.size(activeEqualHighs) > 0
        for i = 0 to math.min(array.size(activeEqualHighs) - 1, 19)
            level = array.get(activeEqualHighs, i)

            if level.touchCount >= minTouches
                // Only show if not swept or if user wants swept levels
                if not level.swept or showSweptLevels
                    lineStyle = level.swept ? line.style_dotted : line.style_solid
                    lineColor = level.swept ? color.new(equalHighColor, 70) : equalHighColor

                    // Draw horizontal line
                    line.new(
                        level.lastBar - lookbackPeriod,
                        level.price,
                        bar_index + 10,
                        level.price,
                        color=lineColor,
                        style=lineStyle,
                        width=level.swept ? 1 : 2
                    )

                    // Add label
                    if bar_index == level.lastBar or (bar_index - level.lastBar) % 20 == 0
                        labelText = str.format("EQH {0}x", level.touchCount)
                        label.new(
                            level.lastBar,
                            level.price,
                            labelText,
                            color=lineColor,
                            textcolor=color.white,
                            style=label.style_label_down,
                            size=size.small
                        )

    // Draw Equal Lows
    if array.size(activeEqualLows) > 0
        for i = 0 to math.min(array.size(activeEqualLows) - 1, 19)
            level = array.get(activeEqualLows, i)

            if level.touchCount >= minTouches
                if not level.swept or showSweptLevels
                    lineStyle = level.swept ? line.style_dotted : line.style_solid
                    lineColor = level.swept ? color.new(equalLowColor, 70) : equalLowColor

                    line.new(
                        level.lastBar - lookbackPeriod,
                        level.price,
                        bar_index + 10,
                        level.price,
                        color=lineColor,
                        style=lineStyle,
                        width=level.swept ? 1 : 2
                    )

                    if bar_index == level.lastBar or (bar_index - level.lastBar) % 20 == 0
                        labelText = str.format("EQL {0}x", level.touchCount)
                        label.new(
                            level.lastBar,
                            level.price,
                            labelText,
                            color=lineColor,
                            textcolor=color.white,
                            style=label.style_label_up,
                            size=size.small
                        )

// ============================================================================
// VISUALIZATION - GAPS
// ============================================================================

if enableGaps and array.size(unfilledGaps) > 0
    displayCount = math.min(array.size(unfilledGaps), maxGapsDisplay)

    for i = 0 to displayCount - 1
        gap = array.get(unfilledGaps, i)
        gapSizePercent = gap.gapSize / close * 100

        if gapSizePercent >= (minGapSize * 100)
            gapColor = gap.direction == 1 ? gapBullishColor : gapBearishColor

            // Draw gap box
            box.new(
                gap.gapBar,
                gap.gapHigh,
                bar_index + 10,
                gap.gapLow,
                border_color=gapColor,
                bgcolor=gapColor,
                border_width=1,
                border_style=line.style_dashed,
                extend=extend.right
            )

            // Add gap label
            if bar_index == gap.gapBar
                gapLabel = gap.direction == 1 ? "GAP ⬆" : "GAP ⬇"
                label.new(
                    gap.gapBar,
                    gap.direction == 1 ? gap.gapLow : gap.gapHigh,
                    str.format("{0}\n{1}%", gapLabel, str.tostring(gapSizePercent, "#.##")),
                    color=gapColor,
                    textcolor=color.white,
                    style=gap.direction == 1 ? label.style_label_up : label.style_label_down,
                    size=size.small
                )

// ============================================================================
// VISUALIZATION - ROUND NUMBERS
// ============================================================================

if enableRoundNumbers and array.size(nearbyRoundNumbers) > 0
    for i = 0 to array.size(nearbyRoundNumbers) - 1
        rnLevel = array.get(nearbyRoundNumbers, i)

        // Major levels (00) vs half levels (50)
        lineWidth = rnLevel.level == 0 ? 2 : 1
        lineStyle = rnLevel.tested ? line.style_dotted : line.style_dashed
        lineColor = rnLevel.tested ? color.new(roundNumberColor, 80) : roundNumberColor

        // Draw round number line
        line.new(
            bar_index - 50,
            rnLevel.price,
            bar_index + 10,
            rnLevel.price,
            color=lineColor,
            style=lineStyle,
            width=lineWidth
        )

// ============================================================================
// VISUALIZATION - STOP HUNTS
// ============================================================================

if enableStopHunts and array.size(recentHunts) > 0
    for i = 0 to array.size(recentHunts) - 1
        hunt = array.get(recentHunts, i)

        // Only show confirmed hunts, unless user wants unconfirmed
        if hunt.reversalConfirmed or showUnconfirmed
            huntColor = hunt.reversalConfirmed ? stopHuntColor : color.new(stopHuntColor, 50)

            // Highlight stop hunt candle
            bgcolor(bar_index == hunt.huntBar ? huntColor : na)

            // Add marker
            if bar_index == hunt.huntBar
                huntSymbol = hunt.direction == 1 ? "⚡ HUNT ⬆" : "⚡ HUNT ⬇"
                huntInfo = str.format("{0}\nVol: {1}x", huntSymbol, str.tostring(hunt.volumeSpike, "#.#"))

                label.new(
                    hunt.huntBar,
                    hunt.direction == 1 ? hunt.huntPrice : hunt.huntPrice,
                    huntInfo,
                    color=huntColor,
                    textcolor=color.black,
                    style=hunt.direction == 1 ? label.style_label_down : label.style_label_up,
                    size=size.normal,
                    textalign=text.align_center
                )

// ============================================================================
// PROXIMITY HIGHLIGHTS
// ============================================================================

// Highlight when price is near liquidity
nearLiquidityColor = nearUp ? color.new(color.red, 90) :
     nearDown ? color.new(color.green, 90) : na

bgcolor(nearLiquidityColor, title="Near Liquidity")

// ============================================================================
// DASHBOARD
// ============================================================================

if showDashboard and barstate.islast
    var table dashboard = table.new(
        dashboardPosition == "top_left" ? position.top_left :
        dashboardPosition == "top_center" ? position.top_center :
        dashboardPosition == "top_right" ? position.top_right :
        dashboardPosition == "middle_left" ? position.middle_left :
        dashboardPosition == "middle_center" ? position.middle_center :
        dashboardPosition == "middle_right" ? position.middle_right :
        dashboardPosition == "bottom_left" ? position.bottom_left :
        dashboardPosition == "bottom_center" ? position.bottom_center :
        position.bottom_right,
        7, 6,
        border_width=2,
        border_color=color.new(color.gray, 50),
        frame_width=1,
        frame_color=color.new(color.gray, 70)
    )

    // Header
    table.cell(dashboard, 0, 0, "💧 Liquidity Hunter",
        text_color=color.white, bgcolor=color.new(color.blue, 30),
        text_size=size.normal, text_halign=text.align_center)
    table.merge_cells(dashboard, 0, 0, 6, 0)

    // Labels
    table.cell(dashboard, 0, 1, "Metric", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 1, 1, "Count", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 2, 1, "Status", text_color=color.gray, text_size=size.small)

    // Equal Highs
    eqHighCount = array.size(activeEqualHighs)
    table.cell(dashboard, 0, 2, "Equal Highs", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 2, str.tostring(eqHighCount), text_color=color.white, text_size=size.small)
    table.cell(dashboard, 2, 2, eqHighCount > 3 ? "🔴 High" : "🟢 Normal",
        text_color=color.white, text_size=size.small)

    // Equal Lows
    eqLowCount = array.size(activeEqualLows)
    table.cell(dashboard, 0, 3, "Equal Lows", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 3, str.tostring(eqLowCount), text_color=color.white, text_size=size.small)
    table.cell(dashboard, 2, 3, eqLowCount > 3 ? "🟢 High" : "🔴 Normal",
        text_color=color.white, text_size=size.small)

    // Gaps
    gapCount = array.size(unfilledGaps)
    table.cell(dashboard, 0, 4, "Unfilled Gaps", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 4, str.tostring(gapCount), text_color=color.white, text_size=size.small)
    table.cell(dashboard, 2, 4, gapCount > 0 ? "🟡 Active" : "⚪ None",
        text_color=color.white, text_size=size.small)

    // Stop Hunts
    huntCount = array.size(recentHunts)
    table.cell(dashboard, 0, 5, "Recent Hunts", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 5, str.tostring(huntCount), text_color=color.white, text_size=size.small)
    table.cell(dashboard, 2, 5, huntCount > 0 ? "⚡ Detected" : "⚪ None",
        text_color=color.white, text_size=size.small)

    // Proximity Status
    proximityStatus = nearUp ? "🔴 Near Resistance" :
         nearDown ? "🟢 Near Support" : "⚪ Clear"
    table.cell(dashboard, 3, 1, "Proximity", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 4, 1, proximityStatus, text_color=color.white, text_size=size.small)
    table.merge_cells(dashboard, 3, 1, 6, 1)

    // Nearest Liquidity Up
    upText = not na(liquidityState.nearestLiquidityUp) ?
        str.format("{0} (+{1}%)",
            str.tostring(liquidityState.nearestLiquidityUp, format.mintick),
            str.tostring((liquidityState.nearestLiquidityUp - close) / close * 100, "#.##")) :
        "N/A"
    table.cell(dashboard, 3, 2, "↑ Above", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 4, 2, upText, text_color=equalHighColor, text_size=size.small)
    table.merge_cells(dashboard, 3, 2, 6, 2)

    // Nearest Liquidity Down
    downText = not na(liquidityState.nearestLiquidityDown) ?
        str.format("{0} ({1}%)",
            str.tostring(liquidityState.nearestLiquidityDown, format.mintick),
            str.tostring((liquidityState.nearestLiquidityDown - close) / close * 100, "#.##")) :
        "N/A"
    table.cell(dashboard, 3, 3, "↓ Below", text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 4, 3, downText, text_color=equalLowColor, text_size=size.small)
    table.merge_cells(dashboard, 3, 3, 6, 3)

// ============================================================================
// ALERTS
// ============================================================================

if enableProximityAlerts
    alertcondition(nearUp, "Near Liquidity Above", "Price approaching liquidity resistance")
    alertcondition(nearDown, "Near Liquidity Below", "Price approaching liquidity support")

    if enableStopHunts and array.size(recentHunts) > 0
        latestHunt = array.get(recentHunts, 0)
        if latestHunt.reversalConfirmed and bar_index == latestHunt.huntBar
            alertcondition(true, "Stop Hunt Confirmed",
                str.format("Stop hunt confirmed: {0}",
                    latestHunt.direction == 1 ? "Upside" : "Downside"))
