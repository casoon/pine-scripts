// ===== SHARED: HELPERS =====
// ============================================================================
// SHARED HELPERS - Universal Utility Functions (SHARED MODULE)
// ============================================================================
// @version=6
// @description: Common utility functions shared across indicators
//
// Purpose:
//   - Math utilities (normalization, clamping, etc.)
//   - Pivot detection
//   - Zone calculations
//   - Array utilities
//
// Used by: CPM, ZigZag Corridors, Pattern Pilot, Wave Analysis
//
// Integration:
//   Reference in config.json: "../_shared/helpers.pine"
//
// Note: Indicator-specific logic should remain in local modules.
//       Only truly generic utilities belong here.
// ============================================================================

// ==== MATH UTILITIES ====

// Calculate z-score (standardization)
// @param src: Source series
// @param len: Lookback period
// @returns Z-score
f_zscore(float src, int len) =>
    float ma = ta.sma(src, len)
    float sd = ta.stdev(src, len)
    sd == 0.0 ? 0.0 : (src - ma) / sd

// Map value to signed range [-1, +1]
// @param x: Input value
// @param lo: Lower bound
// @param hi: Upper bound
// @returns Normalized value in [-1, +1]
f_signed(float x, float lo, float hi) =>
    float cl = math.max(lo, math.min(hi, x))
    (cl - lo) / (hi - lo) * 2.0 - 1.0

// Clamp value to range
// @param x: Input value
// @param min: Minimum value
// @param max: Maximum value
// @returns Clamped value
f_clamp(float x, float min, float max) =>
    math.max(min, math.min(max, x))

// Normalize value to [0, 1] range
// @param x: Input value
// @param lo: Lower bound
// @param hi: Upper bound
// @returns Normalized value in [0, 1]
f_normalize(float x, float lo, float hi) =>
    float rangeVal = hi - lo
    rangeVal == 0.0 ? 0.5 : (x - lo) / rangeVal

// Safe division (avoid divide by zero)
// @param numerator: Numerator
// @param denominator: Denominator
// @param defaultVal: Value to return if denominator is zero
// @returns Division result or default
f_safeDivide(float numerator, float denominator, float defaultVal = 0.0) =>
    denominator == 0.0 ? defaultVal : numerator / denominator

// ==== PIVOT DETECTION ====

// Generic pivot high detection
// @param src: Source series (typically high)
// @param leftBars: Bars to left of pivot
// @param rightBars: Bars to right of pivot
// @returns Pivot high price or na
pivotHigh(series float src, int leftBars, int rightBars) =>
    ta.pivothigh(src, leftBars, rightBars)

// Generic pivot low detection
// @param src: Source series (typically low)
// @param leftBars: Bars to left of pivot
// @param rightBars: Bars to right of pivot
// @returns Pivot low price or na
pivotLow(series float src, int leftBars, int rightBars) =>
    ta.pivotlow(src, leftBars, rightBars)

// Get last confirmed pivot (with index)
// @param src: Source series
// @param leftBars: Bars to left
// @param rightBars: Bars to right
// @param isHigh: True for pivot high, False for pivot low
// @returns [pivotPrice, pivotIndex]
f_lastPivot(series float src, int leftBars, int rightBars, bool isHigh) =>
    var float lastVal = na
    var int lastIdx = na
    
    if isHigh
        float ph = pivotHigh(src, leftBars, rightBars)
        if not na(ph)
            lastVal := ph
            lastIdx := bar_index - rightBars
    else
        float pl = pivotLow(src, leftBars, rightBars)
        if not na(pl)
            lastVal := pl
            lastIdx := bar_index - rightBars
    
    [lastVal, lastIdx]

// ==== ZONE UTILITIES ====

// Calculate overlap percentage between two zones
// @param aLo: Zone A lower bound
// @param aHi: Zone A upper bound
// @param bLo: Zone B lower bound
// @param bHi: Zone B upper bound
// @returns Overlap percentage (0-100)
f_overlap(float aLo, float aHi, float bLo, float bHi) =>
    float lo = math.max(aLo, bLo)
    float hi = math.min(aHi, bHi)
    float inter = math.max(0.0, hi - lo)
    float base = math.max(aHi - aLo, bHi - bLo)
    base > 0 ? inter / base * 100.0 : 0.0

// Calculate proximity to level (ATR-normalized)
// @param price: Current price
// @param level: Target level
// @param atr: ATR value
// @returns Distance in ATR units
f_proximity(float price, float level, float atr) =>
    atr > 0 ? math.abs(price - level) / atr : 10.0

// Check if price is within zone
// @param price: Price to check
// @param zoneLo: Zone lower bound
// @param zoneHi: Zone upper bound
// @returns True if price in zone
f_inZone(float price, float zoneLo, float zoneHi) =>
    price >= zoneLo and price <= zoneHi

// ==== OSCILLATOR UTILITIES ====

// RSI z-score
// @param len: RSI length
// @param zscore_len: Z-score lookback
// @returns RSI z-score
f_rsi_zscore(int len, int zscore_len) =>
    float rsi = ta.rsi(close, len)
    f_zscore(rsi, zscore_len)

// ==== ARRAY UTILITIES ====

// Safe array get with default value
// @param arr: Float array
// @param idx: Index
// @param defaultVal: Default if index invalid
// @returns Array value or default
f_get_float(array<float> arr, int idx, float defaultVal) =>
    idx >= 0 and idx < array.size(arr) ? array.get(arr, idx) : defaultVal

// Safe array get with default value (int)
// @param arr: Int array
// @param idx: Index
// @param defaultVal: Default if index invalid
// @returns Array value or default
f_get_int(array<int> arr, int idx, int defaultVal) =>
    idx >= 0 and idx < array.size(arr) ? array.get(arr, idx) : defaultVal

// ==== TIMEFRAME UTILITIES ====

// Check if current bar is start of new session
// @returns True if new session started
f_isNewSession() =>
    ta.change(time("D"))

// Check if current bar is start of new week
// @returns True if new week started
f_isNewWeek() =>
    ta.change(time("W"))

// Check if current bar is start of new month
// @returns True if new month started
f_isNewMonth() =>
    ta.change(time("M"))

// ==== VOLATILITY UTILITIES ====

// (Volatility functions moved to _shared/indicators.pine)

// ==== TREND UTILITIES ====

// Calculate simple slope
// @param src: Source series
// @param len: Lookback length
// @returns Slope (change per bar)
f_slope(series float src, int len) =>
    (src - src[len]) / len

// Check if series is rising
// @param src: Source series
// @param len: Lookback length
// @returns True if rising
f_isRising(series float src, int len) =>
    ta.rising(src, len)

// Check if series is falling
// @param src: Source series
// @param len: Lookback length
// @returns True if falling
f_isFalling(series float src, int len) =>
    ta.falling(src, len)

// ==== VOLUME UTILITIES ====

// Volume strength score (0-1 scale)
// @param length: Volume MA period
// @returns Strength score based on volume ratio
f_volumeStrength(int length = 20) =>
    float volMA = ta.sma(volume, length)
    float ratio = volMA > 0 ? volume / volMA : 1.0
    // 0.0 = below 50% of MA, 0.5 = at MA, 1.0 = 2x MA or more
    math.min(ratio / 2.0, 1.0)

// Volume confirmation check
// @param length: Volume MA period
// @param threshold: Minimum ratio threshold (default 1.5x MA)
// @returns Boolean confirmation
f_volumeConfirmation(int length = 20, float threshold = 1.5) =>
    float volMA = ta.sma(volume, length)
    float ratio = volMA > 0 ? volume / volMA : 1.0
    ratio >= threshold

// Relative volume compared to specific bars
// @param barsAgo: Bars to compare to
// @returns Volume ratio vs previous bar
f_volumeRelative(int barsAgo = 1) =>
    float prevVol = nz(volume[barsAgo], volume)
    prevVol > 0 ? volume / prevVol : 1.0

// Volume spike detection
// @param length: Volume MA period
// @param spikeMultiplier: Multiplier for spike (default 2.0)
// @returns True if volume spike detected
f_volumeSpike(int length = 20, float spikeMultiplier = 2.0) =>
    float volMA = ta.sma(volume, length)
    float ratio = volMA > 0 ? volume / volMA : 1.0
    ratio >= spikeMultiplier

// Average volume over period
// @param length: Period length
// @returns Average volume
f_volumeAvg(int length = 20) =>
    ta.sma(volume, length)

// ==== MOMENTUM UTILITIES ====

// Get momentum at historical bar
// @param momentumSeries: Momentum series (RSI, MACD, etc.)
// @param barsAgo: Bars back to check
// @returns Momentum value at that bar
f_momentumAtBar(series float momentumSeries, int barsAgo) =>
    barsAgo >= 0 ? momentumSeries[barsAgo] : na

// Check momentum directional confirmation
// @param momentum1: First momentum value (earlier)
// @param momentum2: Second momentum value (recent)
// @param direction: Expected direction ("UP" or "DOWN")
// @param momentumType: Type ("RSI", "MACD")
// @returns Confirmation score (0-100)
f_momentumConfirmation(float momentum1, float momentum2, string direction, string momentumType = "RSI") =>
    float score = 50.0  // Neutral
    
    if not na(momentum1) and not na(momentum2)
        if direction == "UP"
            if momentumType == "RSI"
                // RSI should be increasing and above 50
                score := (momentum2 > momentum1 and momentum2 > 50) ? 100.0 : 
                         (momentum2 > momentum1) ? 75.0 : 
                         (momentum2 > 50) ? 60.0 : 40.0
            else if momentumType == "MACD"
                // MACD should be increasing and positive
                score := (momentum2 > momentum1 and momentum2 > 0) ? 100.0 : 
                         (momentum2 > momentum1) ? 75.0 : 
                         (momentum2 > 0) ? 60.0 : 40.0
        else if direction == "DOWN"
            if momentumType == "RSI"
                // RSI should be decreasing and below 50
                score := (momentum2 < momentum1 and momentum2 < 50) ? 100.0 : 
                         (momentum2 < momentum1) ? 75.0 : 
                         (momentum2 < 50) ? 60.0 : 40.0
            else if momentumType == "MACD"
                // MACD should be decreasing and negative
                score := (momentum2 < momentum1 and momentum2 < 0) ? 100.0 : 
                         (momentum2 < momentum1) ? 75.0 : 
                         (momentum2 < 0) ? 60.0 : 40.0
    
    score

// Check momentum divergence from price
// @param priceChange: Price change (positive or negative)
// @param momentumChange: Momentum change
// @returns [isDivergent, strength]
f_momentumDivergence(float priceChange, float momentumChange) =>
    bool isDivergent = (priceChange > 0 and momentumChange < 0) or 
                       (priceChange < 0 and momentumChange > 0)
    float strength = isDivergent ? math.abs(priceChange - momentumChange) : 0.0
    [isDivergent, strength]

// Calculate momentum strength score
// @param momentum: Current momentum value
// @param momentumType: Type ("RSI", "MACD")
// @returns Strength score (0-1)
f_momentumStrength(float momentum, string momentumType = "RSI") =>
    float strength = 0.5  // Neutral
    
    if momentumType == "RSI"
        // RSI 0-100 -> normalize to 0-1
        strength := momentum / 100.0
    else if momentumType == "MACD"
        // MACD is unbounded, use normalization
        strength := na(momentum) ? 0.5 : math.min(math.abs(momentum) / 10.0, 1.0)
    
    strength

// ==== PRICE ACTION UTILITIES ====

// Check if current bar is bullish
// @returns True if close > open
f_isBullBar() =>
    close > open

// Check if current bar is bearish
// @returns True if close < open
f_isBearBar() =>
    close < open

// Calculate bar body size
// @returns Absolute body size
f_bodySize() =>
    math.abs(close - open)

// Calculate upper wick size
// @returns Upper wick size
f_upperWick() =>
    high - math.max(open, close)

// Calculate lower wick size
// @returns Lower wick size
f_lowerWick() =>
    math.min(open, close) - low

// Body as percentage of total range
// @returns Body percentage (0-1)
f_bodyRatio() =>
    float rangeVal = high - low
    rangeVal > 0 ? f_bodySize() / rangeVal : 0.0

