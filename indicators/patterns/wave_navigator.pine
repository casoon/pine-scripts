// ===== MODULE: UPDATE_CORRECTION =====
// Helper: Update single correction wave drawing
f_update_correction_drawing(CorrectionDrawing cd, PatternCandidate p, int rank) =>
    // DEBUG: Log when this function is called
    if showDebug and barstate.islast
        log.info("=== CORRECTION DRAWING UPDATE ===")
        log.info("Rank: {0}, Pattern: {1}", rank, p.patternType)
        log.info("StartIdx: {0}, PivotCount: {1}", p.startIdx, p.pivotCount)
    
    // Get pivot data
    pA = f_get_pivot_price(p.startIdx)
    pB = f_get_pivot_price(p.startIdx + 1)
    pC = f_get_pivot_price(p.startIdx + 2)
    pD = f_get_pivot_price(p.startIdx + 3)
    xA = f_get_pivot_index(p.startIdx)
    xB = f_get_pivot_index(p.startIdx + 1)
    xC = f_get_pivot_index(p.startIdx + 2)
    xD = f_get_pivot_index(p.startIdx + 3)
    dA = f_get_pivot_dir(p.startIdx)
    dB = f_get_pivot_dir(p.startIdx + 1)
    dC = f_get_pivot_dir(p.startIdx + 2)
    dD = f_get_pivot_dir(p.startIdx + 3)
    
    // DEBUG: Log pivot values
    if showDebug and barstate.islast
        log.info("Pivot A: Price={0}, Index={1}, Dir={2}", pA, xA, dA)
        log.info("Pivot B: Price={0}, Index={1}, Dir={2}", pB, xB, dB)
        log.info("Pivot C: Price={0}, Index={1}, Dir={2}", pC, xC, dC)
        log.info("NA checks: pA={0}, xA={1}, pB={2}, xB={3}, pC={4}, xC={5}", na(pA), na(xA), na(pB), na(xB), na(pC), na(xC))
    
    // Colors
    alpha = rank == 0 ? 30 : 70
    lineColor = colorCorrection  // Orange from settings
    labelColor = color.white
    bgColor = color(na)
    // LARGE labels for better visibility
    labelSize = rank == 0 ? size.large : size.normal
    suffix = rank > 0 ? "*" : ""
    
    // Update lines
    if not na(pB) and not na(xB)
        cd.lAB.set_xy1(xA, pA)
        cd.lAB.set_xy2(xB, pB)
        cd.lAB.set_color(color.new(lineColor, alpha))
        cd.lAB.set_width(2)
    else
        cd.lAB.set_color(na)
    
    if not na(pC) and not na(xC)
        cd.lBC.set_xy1(xB, pB)
        cd.lBC.set_xy2(xC, pC)
        cd.lBC.set_color(color.new(lineColor, alpha))
        cd.lBC.set_width(2)
    else
        cd.lBC.set_color(na)
    
    if not na(pD) and not na(xD)
        cd.lCD.set_xy1(xC, pC)
        cd.lCD.set_xy2(xD, pD)
        cd.lCD.set_color(color.new(lineColor, alpha))
        cd.lCD.set_width(2)
    else
        cd.lCD.set_color(na)
    
    // Update labels with COLORED backgrounds for visibility
    color labelBg = rank == 0 ? color.new(lineColor, 80) : color.new(color.gray, 90)
    
    // DEBUG: Log label creation
    if showDebug and barstate.islast
        log.info("Creating labels with size: {0}, bg color transparency: {1}", labelSize, 80)
    
    if not na(pA) and not na(xA)
        cd.bA.set_xy(xA, pA)
        cd.bA.set_text("A" + suffix)
        cd.bA.set_style(dA > 0 ? label.style_label_down : label.style_label_up)
        cd.bA.set_textcolor(color.white)
        cd.bA.set_color(labelBg)
        cd.bA.set_size(labelSize)
        if showDebug and barstate.islast
            log.info("✓ Label A created at x={0}, y={1}, text={2}", xA, pA, "A" + suffix)
    else
        cd.bA.set_textcolor(na)
        if showDebug and barstate.islast
            log.warning("✗ Label A NOT created - NA values")
    
    if not na(pB) and not na(xB)
        cd.bB.set_xy(xB, pB)
        cd.bB.set_text("B" + suffix)
        cd.bB.set_style(dB > 0 ? label.style_label_down : label.style_label_up)
        cd.bB.set_textcolor(color.white)
        cd.bB.set_color(labelBg)
        cd.bB.set_size(labelSize)
        if showDebug and barstate.islast
            log.info("✓ Label B created at x={0}, y={1}, text={2}", xB, pB, "B" + suffix)
    else
        cd.bB.set_textcolor(na)
        if showDebug and barstate.islast
            log.warning("✗ Label B NOT created - NA values")
    
    if not na(pC) and not na(xC)
        cd.bC.set_xy(xC, pC)
        cd.bC.set_text("C" + suffix)
        cd.bC.set_style(dC > 0 ? label.style_label_down : label.style_label_up)
        cd.bC.set_textcolor(color.white)
        cd.bC.set_color(labelBg)
        cd.bC.set_size(labelSize)
        if showDebug and barstate.islast
            log.info("✓ Label C created at x={0}, y={1}, text={2}", xC, pC, "C" + suffix)
    else
        cd.bC.set_textcolor(na)
        if showDebug and barstate.islast
            log.warning("✗ Label C NOT created - NA values")
    
    // Label D is not used for ABC corrections, hide it
    cd.bD.set_textcolor(na)
    
    // ═══════════════════════════════════════════════════════════════════════════
    // WAVE C PROJECTION (NEW - Sprint 6 Preview)
    // ═══════════════════════════════════════════════════════════════════════════
    // Project Wave C target based on Wave A length and Fibonacci ratios
    // Standard ABC: C = 0.618×A, 1.0×A, 1.618×A
    // ───────────────────────────────────────────────────────────────────────────
    if rank == 0 and showProjection and showTargets and not na(pA) and not na(pB) and not na(xB)
        // Calculate Wave A amplitude
        float waveA = math.abs(pB - pA)
        bool isDown = pB < pA  // Wave A direction
        
        // Wave C projects from B
        // Standard Fibonacci projections for Wave C:
        // Min: 0.618 × Wave A
        // Ideal: 1.0 × Wave A (equal to A)
        // Max: 1.618 × Wave A (extended)
        float cMin = isDown ? pB - (waveA * 0.618) : pB + (waveA * 0.618)
        float cIdeal = isDown ? pB - (waveA * 1.0) : pB + (waveA * 1.0)
        float cMax = isDown ? pB - (waveA * 1.618) : pB + (waveA * 1.618)
        
        // Projection lines extend to the right
        int projEndBar = bar_index + 30
        int labelBar = bar_index + 15
        
        // Min Target (dotted line)
        cd.projMin.set_xy1(xB, cMin)
        cd.projMin.set_xy2(projEndBar, cMin)
        cd.projMin.set_color(color.new(lineColor, 70))
        cd.projMin.set_style(line.style_dotted)
        cd.projMin.set_width(1)
        
        // Ideal Target (solid line, prominent)
        cd.projIdeal.set_xy1(xB, cIdeal)
        cd.projIdeal.set_xy2(projEndBar, cIdeal)
        cd.projIdeal.set_color(color.new(lineColor, 20))
        cd.projIdeal.set_style(line.style_solid)
        cd.projIdeal.set_width(3)
        
        // Max Target (dotted line)
        cd.projMax.set_xy1(xB, cMax)
        cd.projMax.set_xy2(projEndBar, cMax)
        cd.projMax.set_color(color.new(lineColor, 70))
        cd.projMax.set_style(line.style_dotted)
        cd.projMax.set_width(1)
        
        // Labels with Wave C projection info
        cd.projMinLabel.set_xy(labelBar, cMin)
        cd.projMinLabel.set_text("C Min: " + str.tostring(cMin, format.mintick) + " [0.618×A]")
        cd.projMinLabel.set_textcolor(color.white)
        cd.projMinLabel.set_color(color.new(lineColor, 40))
        cd.projMinLabel.set_style(label.style_label_left)
        cd.projMinLabel.set_size(size.normal)
        
        cd.projIdealLabel.set_xy(labelBar, cIdeal)
        cd.projIdealLabel.set_text("🎯 C Target: " + str.tostring(cIdeal, format.mintick) + " [1.0×A]")
        cd.projIdealLabel.set_textcolor(color.white)
        cd.projIdealLabel.set_color(color.new(lineColor, 10))
        cd.projIdealLabel.set_style(label.style_label_left)
        cd.projIdealLabel.set_size(size.large)
        
        cd.projMaxLabel.set_xy(labelBar, cMax)
        cd.projMaxLabel.set_text("C Max: " + str.tostring(cMax, format.mintick) + " [1.618×A]")
        cd.projMaxLabel.set_textcolor(color.white)
        cd.projMaxLabel.set_color(color.new(lineColor, 40))
        cd.projMaxLabel.set_style(label.style_label_left)
        cd.projMaxLabel.set_size(size.normal)
    else
        // Hide projections if not applicable
        cd.projMin.set_color(na)
        cd.projIdeal.set_color(na)
        cd.projMax.set_color(na)
        cd.projMinLabel.set_textcolor(na)
        cd.projIdealLabel.set_textcolor(na)
        cd.projMaxLabel.set_textcolor(na)

// ===== MODULE: UPDATE_IMPULSE =====
// 8) PERSISTENT VISUALIZATION UPDATE (Sprint 5: Dynamic Updates Every Bar)
// ───────────────────────────────────────────────────────────────────────────
// IMPORTANT NOTE ON ZOOM/PAN BEHAVIOR:
// ───────────────────────────────────────────────────────────────────────────
// PineScript has a fundamental limitation: chart viewport changes (zoom/pan)
// do NOT trigger script re-execution. This means:
//
// ✅ What works:
//   - Lines/labels update when NEW BARS appear
//   - Coordinates are price-based (yloc.price) so they scale theoretically
//   - Live pivot tracking ensures latest pivot moves with price action
//
// ❌ What doesn't work:
//   - Pure zoom/pan WITHOUT new bars won't re-render existing objects
//   - This is a TradingView platform limitation, not a code issue
//
// 🔧 Workarounds:
//   - Wait for next bar to see correct positioning
//   - Refresh //   - Change timeframe or any input parameter
//
// This behavior is consistent with most professional TradingView indicators.
// ───────────────────────────────────────────────────────────────────────────

// Helper: Update single impulse wave drawing
f_update_impulse_drawing(WaveDrawing wd, PatternCandidate p, int rank) =>
    // Get all pivot data
    p0 = f_get_pivot_price(p.startIdx)
    p1 = f_get_pivot_price(p.startIdx + 1)
    p2 = f_get_pivot_price(p.startIdx + 2)
    p3 = f_get_pivot_price(p.startIdx + 3)
    p4 = f_get_pivot_price(p.startIdx + 4)
    p5 = f_get_pivot_price(p.startIdx + 5)
    x0 = f_get_pivot_index(p.startIdx)
    x1 = f_get_pivot_index(p.startIdx + 1)
    x2 = f_get_pivot_index(p.startIdx + 2)
    x3 = f_get_pivot_index(p.startIdx + 3)
    x4 = f_get_pivot_index(p.startIdx + 4)
    x5 = f_get_pivot_index(p.startIdx + 5)
    d0 = f_get_pivot_dir(p.startIdx)
    d1 = f_get_pivot_dir(p.startIdx + 1)
    d2 = f_get_pivot_dir(p.startIdx + 2)
    d3 = f_get_pivot_dir(p.startIdx + 3)
    d4 = f_get_pivot_dir(p.startIdx + 4)
    d5 = f_get_pivot_dir(p.startIdx + 5)
    
    // Colors and styling
    alpha = rank == 0 ? 30 : 70
    lineColor = p.direction == "UP" ? colorUp : colorDown
    labelColor = color.white
    bgColor = color(na)
    
    // Update lines (0→1, 1→2, 2→3, 3→4, 4→5)
    // IMPORTANT: Always update coordinates, even if they haven't changed
    // This forces PineScript to re-render the objects with current chart scale
    if not na(p1) and not na(x1)
        wd.l01.set_xy1(x0, p0)
        wd.l01.set_xy2(x1, p1)
        wd.l01.set_color(color.new(lineColor, alpha))
        wd.l01.set_width(2)
    else
        wd.l01.set_color(na)
    
    if not na(p2) and not na(x2)
        wd.l12.set_xy1(x1, p1)
        wd.l12.set_xy2(x2, p2)
        wd.l12.set_color(color.new(lineColor, alpha))
        wd.l12.set_width(2)
    else
        wd.l12.set_color(na)
    
    if not na(p3) and not na(x3)
        wd.l23.set_xy1(x2, p2)
        wd.l23.set_xy2(x3, p3)
        wd.l23.set_color(color.new(lineColor, alpha))
        wd.l23.set_width(2)
    else
        wd.l23.set_color(na)
    
    if not na(p4) and not na(x4)
        wd.l34.set_xy1(x3, p3)
        wd.l34.set_xy2(x4, p4)
        wd.l34.set_color(color.new(lineColor, alpha))
        wd.l34.set_width(2)
    else
        wd.l34.set_color(na)
    
    if not na(p5) and not na(x5)
        wd.l45.set_xy1(x4, p4)
        wd.l45.set_xy2(x5, p5)
        wd.l45.set_color(color.new(lineColor, alpha))
        wd.l45.set_width(2)
    else
        wd.l45.set_color(na)
    
    // Update labels (0, 1, 2, 3, 4, 5)
    // LARGE labels for primary pattern, NORMAL for alternatives
    labelSize = rank == 0 ? size.large : size.normal
    suffix = rank > 0 ? "*" : ""
    
    if not na(p0) and not na(x0)
        wd.b0.set_xy(x0, p0)
        wd.b0.set_text("0" + suffix)
        wd.b0.set_style(d0 > 0 ? label.style_label_down : label.style_label_up)
        wd.b0.set_textcolor(labelColor)
        wd.b0.set_color(bgColor)
        wd.b0.set_size(labelSize)
    else
        wd.b0.set_textcolor(na)
    
    if not na(p1) and not na(x1)
        wd.b1.set_xy(x1, p1)
        wd.b1.set_text("1" + suffix)
        wd.b1.set_style(d1 > 0 ? label.style_label_down : label.style_label_up)
        wd.b1.set_textcolor(labelColor)
        wd.b1.set_color(bgColor)
        wd.b1.set_size(labelSize)
    else
        wd.b1.set_textcolor(na)
    
    if not na(p2) and not na(x2)
        wd.b2.set_xy(x2, p2)
        wd.b2.set_text("2" + suffix)
        wd.b2.set_style(d2 > 0 ? label.style_label_down : label.style_label_up)
        wd.b2.set_textcolor(labelColor)
        wd.b2.set_color(bgColor)
        wd.b2.set_size(labelSize)
    else
        wd.b2.set_textcolor(na)
    
    if not na(p3) and not na(x3)
        wd.b3.set_xy(x3, p3)
        wd.b3.set_text("3" + suffix)
        wd.b3.set_style(d3 > 0 ? label.style_label_down : label.style_label_up)
        wd.b3.set_textcolor(labelColor)
        wd.b3.set_color(bgColor)
        wd.b3.set_size(labelSize)
    else
        wd.b3.set_textcolor(na)
    
    if not na(p4) and not na(x4)
        wd.b4.set_xy(x4, p4)
        wd.b4.set_text("4" + suffix)
        wd.b4.set_style(d4 > 0 ? label.style_label_down : label.style_label_up)
        wd.b4.set_textcolor(labelColor)
        wd.b4.set_color(bgColor)
        wd.b4.set_size(labelSize)
    else
        wd.b4.set_textcolor(na)
    
    if not na(p5) and not na(x5)
        wd.b5.set_xy(x5, p5)
        wd.b5.set_text("5" + suffix)
        wd.b5.set_style(d5 > 0 ? label.style_label_down : label.style_label_up)
        wd.b5.set_textcolor(labelColor)
        wd.b5.set_color(bgColor)
        wd.b5.set_size(labelSize)
    else
        wd.b5.set_textcolor(na)
    
    // Update projections if needed (rank 0 only)
    // IMPORTANT: Re-calculate targets on EVERY bar using current pivot prices
    // This ensures projections move correctly with zoom/pan and live pivot updates
    if rank == 0 and showProjection and showTargets
        // Debug logging for projection updates
        if showDebug and barstate.islast
            log.info("--- Projection Calculation ---")
            log.info("Current bar_index: {0}", bar_index)
            log.info("P0={0}, P1={1}, P2={2}, P3={3}, P4={4}, P5={5}", p0, p1, p2, p3, p4, p5)
        // Projection for Wave 5 (if after Wave 4)
        if not na(p4) and not na(x5)
            // Re-calculate with current pivot prices (may have changed with live tracking)
            [minT, idealT, maxT] = f_calculate_wave_targets("WAVE_5", p.direction == "UP", p0, p1, p2, p3, p4)
            string scenario = f_get_projection_scenario("WAVE_5", p0, p1, p2, p3, p4)
            
            if showDebug and barstate.islast
                log.info("Wave 5 Projection: Min={0}, Ideal={1}, Max={2}", minT, idealT, maxT)
                log.info("Scenario: {0}", scenario)
            
            if not na(idealT)
                // Use current bar_index for dynamic positioning
                int projEndBar = bar_index + 30
                int labelBar = bar_index + 15
                
                // Min Target (dashed line)
                wd.projMin.set_xy1(x5, minT)
                wd.projMin.set_xy2(projEndBar, minT)
                wd.projMin.set_color(color.new(lineColor, 70))
                wd.projMin.set_style(line.style_dotted)
                wd.projMin.set_width(1)
                
                // Ideal Target (solid line, prominent)
                wd.projIdeal.set_xy1(x5, idealT)
                wd.projIdeal.set_xy2(projEndBar, idealT)
                wd.projIdeal.set_color(color.new(lineColor, 20))
                wd.projIdeal.set_style(line.style_solid)
                wd.projIdeal.set_width(3)
                
                // Max Target (dashed line)
                wd.projMax.set_xy1(x5, maxT)
                wd.projMax.set_xy2(projEndBar, maxT)
                wd.projMax.set_color(color.new(lineColor, 70))
                wd.projMax.set_style(line.style_dotted)
                wd.projMax.set_width(1)
                
                // Labels with scenario info - LARGER for better visibility
                wd.projMinLabel.set_xy(labelBar, minT)
                wd.projMinLabel.set_text("W5 Min: " + str.tostring(minT, format.mintick))
                wd.projMinLabel.set_textcolor(color.white)
                wd.projMinLabel.set_color(color.new(lineColor, 40))
                wd.projMinLabel.set_style(label.style_label_left)
                wd.projMinLabel.set_size(size.normal)
                
                wd.projIdealLabel.set_xy(labelBar, idealT)
                wd.projIdealLabel.set_text("🎯 W5 Target: " + str.tostring(idealT, format.mintick) + " [" + scenario + "]")
                wd.projIdealLabel.set_textcolor(color.white)
                wd.projIdealLabel.set_color(color.new(lineColor, 10))
                wd.projIdealLabel.set_style(label.style_label_left)
                wd.projIdealLabel.set_size(size.large)
                
                wd.projMaxLabel.set_xy(labelBar, maxT)
                wd.projMaxLabel.set_text("W5 Max: " + str.tostring(maxT, format.mintick))
                wd.projMaxLabel.set_textcolor(color.white)
                wd.projMaxLabel.set_color(color.new(lineColor, 40))
                wd.projMaxLabel.set_style(label.style_label_left)
                wd.projMaxLabel.set_size(size.normal)
            else
                wd.projMin.set_color(na)
                wd.projIdeal.set_color(na)
                wd.projMax.set_color(na)
                wd.projMinLabel.set_textcolor(na)
                wd.projIdealLabel.set_textcolor(na)
                wd.projMaxLabel.set_textcolor(na)
        // Projection for Wave 3 (if after Wave 2, before or at Wave 3)
        else if not na(p2) and not na(x2)
            // Re-calculate with current pivot prices
            [minT, idealT, maxT] = f_calculate_wave_targets("WAVE_3", p.direction == "UP", p0, p1, p2, na, na)
            string scenario = f_get_projection_scenario("WAVE_3", p0, p1, p2, na, na)
            
            if showDebug and barstate.islast
                log.info("Wave 3 Projection: Min={0}, Ideal={1}, Max={2}", minT, idealT, maxT)
                log.info("Scenario: {0}", scenario)
            
            if not na(idealT)
                int projEndBar = bar_index + 30
                int labelBar = bar_index + 15
                
                // Min Target (dashed line)
                wd.projMin.set_xy1(x2, minT)
                wd.projMin.set_xy2(projEndBar, minT)
                wd.projMin.set_color(color.new(lineColor, 70))
                wd.projMin.set_style(line.style_dotted)
                wd.projMin.set_width(1)
                
                // Ideal Target (solid line, prominent)
                wd.projIdeal.set_xy1(x2, idealT)
                wd.projIdeal.set_xy2(projEndBar, idealT)
                wd.projIdeal.set_color(color.new(lineColor, 20))
                wd.projIdeal.set_style(line.style_solid)
                wd.projIdeal.set_width(3)
                
                // Max Target (dashed line)
                wd.projMax.set_xy1(x2, maxT)
                wd.projMax.set_xy2(projEndBar, maxT)
                wd.projMax.set_color(color.new(lineColor, 70))
                wd.projMax.set_style(line.style_dotted)
                wd.projMax.set_width(1)
                
                // Labels with scenario info - LARGER for better visibility
                wd.projMinLabel.set_xy(labelBar, minT)
                wd.projMinLabel.set_text("W3 Min: " + str.tostring(minT, format.mintick))
                wd.projMinLabel.set_textcolor(color.white)
                wd.projMinLabel.set_color(color.new(lineColor, 40))
                wd.projMinLabel.set_style(label.style_label_left)
                wd.projMinLabel.set_size(size.normal)
                
                wd.projIdealLabel.set_xy(labelBar, idealT)
                wd.projIdealLabel.set_text("🎯 W3 Target: " + str.tostring(idealT, format.mintick) + " [" + scenario + "]")
                wd.projIdealLabel.set_textcolor(color.white)
                wd.projIdealLabel.set_color(color.new(lineColor, 10))
                wd.projIdealLabel.set_style(label.style_label_left)
                wd.projIdealLabel.set_size(size.large)
                
                wd.projMaxLabel.set_xy(labelBar, maxT)
                wd.projMaxLabel.set_text("W3 Max: " + str.tostring(maxT, format.mintick))
                wd.projMaxLabel.set_textcolor(color.white)
                wd.projMaxLabel.set_color(color.new(lineColor, 40))
                wd.projMaxLabel.set_style(label.style_label_left)
                wd.projMaxLabel.set_size(size.normal)
            else
                wd.projMin.set_color(na)
                wd.projIdeal.set_color(na)
                wd.projMax.set_color(na)
                wd.projMinLabel.set_textcolor(na)
                wd.projIdealLabel.set_textcolor(na)
                wd.projMaxLabel.set_textcolor(na)
        else
            wd.projMin.set_color(na)
            wd.projIdeal.set_color(na)
            wd.projMax.set_color(na)
            wd.projMinLabel.set_textcolor(na)
            wd.projIdealLabel.set_textcolor(na)
            wd.projMaxLabel.set_textcolor(na)
    else
        wd.projMin.set_color(na)
        wd.projIdeal.set_color(na)
        wd.projMax.set_color(na)
        wd.projMinLabel.set_textcolor(na)
        wd.projIdealLabel.set_textcolor(na)
        wd.projMaxLabel.set_textcolor(na)

// ===== MODULE: DETECTION_CORRECTION =====
// Scan sliding windows for 3-wave correction (ABC)
f_detect_3_wave_patterns() =>
    int pc = array.size(pivPrice)
    if enablePatterns and pc >= minPivotsFor3
        int startLatest = pc - minPivotsFor3
        int startEarliest = math.max(0, startLatest - (windowsBack3 - 1))
        // Only run loop if we have valid range
        int span = startLatest - startEarliest
        if span >= 0
            // iterate with positive step using offset
            for off = 0 to span
                int startIdx = startLatest - off
                float pA0 = f_get_pivot_price(startIdx)
                float pA1 = f_get_pivot_price(startIdx + 1)
                float pB1 = f_get_pivot_price(startIdx + 2)
                float pC1 = f_get_pivot_price(startIdx + 3)
                if na(pA0) or na(pC1)
                    continue
                c = PatternCandidate.new("CORRECTION", startIdx, startIdx + 3, 4, false, "UNKNOWN", array.new_string(), 0.0, 0.0, 0.0, 0.0, 100.0, 70.0, 70.0)
                bool alternates = f_check_alternation(startIdx, 4)
                if not alternates
                    array.push(c.violations, "No alternation")
                c.structureScore := alternates ? 100.0 : 30.0
                if enableFibChecks
                    [scoreB, retrB] = f_check_waveB_retracement(pA0, pA1, pB1)
                    [scoreC, ratioC] = f_check_waveC_extension(pA0, pA1, pB1, pC1)
                    c.retracementScore := scoreB
                    c.extensionScore   := scoreC
                    if retrB < 0.30 or retrB > 0.85
                        array.push(c.violations, str.format("B {0,number,#.##}%", retrB*100))
                    if ratioC < 0.7 or ratioC > 2.0
                        array.push(c.violations, str.format("C={0,number,#.##}×A", ratioC))
                int dir1 = f_get_pivot_dir(startIdx + 1)
                c.direction := dir1 > 0 ? "UP" : "DOWN"
                c.isValid := alternates
                c.confidence := (c.structureScore * 0.35) + (c.retracementScore * 0.25) + (c.overlapScore * 0.15) + (c.extensionScore * 0.08) + (c.timeScore * 0.07) + (c.momentumScore * 0.10)
                array.push(detectedPatterns, c)

// ===== MODULE: UPDATE_HIDE =====
// Helper: Hide a wave drawing
f_hide_impulse_drawing(WaveDrawing wd) =>
    wd.l01.set_color(na)
    wd.l12.set_color(na)
    wd.l23.set_color(na)
    wd.l34.set_color(na)
    wd.l45.set_color(na)
    wd.b0.set_textcolor(na)
    wd.b1.set_textcolor(na)
    wd.b2.set_textcolor(na)
    wd.b3.set_textcolor(na)
    wd.b4.set_textcolor(na)
    wd.b5.set_textcolor(na)
    wd.projMin.set_color(na)
    wd.projIdeal.set_color(na)
    wd.projMax.set_color(na)
    wd.projMinLabel.set_textcolor(na)
    wd.projIdealLabel.set_textcolor(na)
    wd.projMaxLabel.set_textcolor(na)

f_hide_correction_drawing(CorrectionDrawing cd) =>
    cd.lAB.set_color(na)
    cd.lBC.set_color(na)
    cd.lCD.set_color(na)
    cd.bA.set_textcolor(na)
    cd.bB.set_textcolor(na)
    cd.bC.set_textcolor(na)
    cd.bD.set_textcolor(na)
    // Hide Wave C projections
    cd.projMin.set_color(na)
    cd.projIdeal.set_color(na)
    cd.projMax.set_color(na)
    cd.projMinLabel.set_textcolor(na)
    cd.projIdealLabel.set_textcolor(na)
    cd.projMaxLabel.set_textcolor(na)

// ===== MODULE: SERIES =====
// 2) SERIES & THRESHOLDS
// ───────────────────────────────────────────────────────────────────────────
float src    = smoothLen > 0 ? ta.sma(hl2, smoothLen) : hl2
float atrVal = ta.atr(atrLen)
float thrAbs = switch mode
    "ATR"     => atrMult * atrVal
    "Percent" => percentThr / 100.0 * close
    => atrMult * atrVal

// Momentum series (global)
float rsiSeries = ta.rsi(close, momentumLen)
[macdLine, macdSignal, macdHist] = ta.macd(close, 12, 26, 9)

// ===== MODULE: UPDATE_DIAGONAL =====
// Helper: Update single diagonal wave drawing (v2.0 Phase 1)
f_update_diagonal_drawing(DiagonalDrawing dd, PatternCandidate p, int rank) =>
    // Get all pivot data
    p0 = f_get_pivot_price(p.startIdx)
    p1 = f_get_pivot_price(p.startIdx + 1)
    p2 = f_get_pivot_price(p.startIdx + 2)
    p3 = f_get_pivot_price(p.startIdx + 3)
    p4 = f_get_pivot_price(p.startIdx + 4)
    p5 = f_get_pivot_price(p.startIdx + 5)
    x0 = f_get_pivot_index(p.startIdx)
    x1 = f_get_pivot_index(p.startIdx + 1)
    x2 = f_get_pivot_index(p.startIdx + 2)
    x3 = f_get_pivot_index(p.startIdx + 3)
    x4 = f_get_pivot_index(p.startIdx + 4)
    x5 = f_get_pivot_index(p.startIdx + 5)
    d0 = f_get_pivot_dir(p.startIdx)
    d1 = f_get_pivot_dir(p.startIdx + 1)
    d2 = f_get_pivot_dir(p.startIdx + 2)
    d3 = f_get_pivot_dir(p.startIdx + 3)
    d4 = f_get_pivot_dir(p.startIdx + 4)
    d5 = f_get_pivot_dir(p.startIdx + 5)
    
    // Colors and styling (purple for diagonals)
    alpha = rank == 0 ? 30 : 70
    lineColor = color.new(#9C27B0, 0)  // Purple for diagonals
    labelColor = color.white
    bgColor = color(na)
    labelSize = rank == 0 ? size.normal : size.small
    suffix = rank > 0 ? "*" : ""
    
    // Update wave lines (0→1, 1→2, 2→3, 3→4, 4→5)
    if not na(p1) and not na(x1)
        dd.l01.set_xy1(x0, p0)
        dd.l01.set_xy2(x1, p1)
        dd.l01.set_color(color.new(lineColor, alpha))
        dd.l01.set_width(2)
    else
        dd.l01.set_color(na)
    
    if not na(p2) and not na(x2)
        dd.l12.set_xy1(x1, p1)
        dd.l12.set_xy2(x2, p2)
        dd.l12.set_color(color.new(lineColor, alpha))
        dd.l12.set_width(2)
    else
        dd.l12.set_color(na)
    
    if not na(p3) and not na(x3)
        dd.l23.set_xy1(x2, p2)
        dd.l23.set_xy2(x3, p3)
        dd.l23.set_color(color.new(lineColor, alpha))
        dd.l23.set_width(2)
    else
        dd.l23.set_color(na)
    
    if not na(p4) and not na(x4)
        dd.l34.set_xy1(x3, p3)
        dd.l34.set_xy2(x4, p4)
        dd.l34.set_color(color.new(lineColor, alpha))
        dd.l34.set_width(2)
    else
        dd.l34.set_color(na)
    
    if not na(p5) and not na(x5)
        dd.l45.set_xy1(x4, p4)
        dd.l45.set_xy2(x5, p5)
        dd.l45.set_color(color.new(lineColor, alpha))
        dd.l45.set_width(2)
    else
        dd.l45.set_color(na)
    
    // Update wave labels (0, 1, 2, 3, 4, 5)
    if not na(p0) and not na(x0)
        dd.b0.set_xy(x0, p0)
        dd.b0.set_text("0" + suffix)
        dd.b0.set_style(d0 > 0 ? label.style_label_down : label.style_label_up)
        dd.b0.set_textcolor(labelColor)
        dd.b0.set_color(bgColor)
        dd.b0.set_size(labelSize)
    else
        dd.b0.set_textcolor(na)
    
    if not na(p1) and not na(x1)
        dd.b1.set_xy(x1, p1)
        dd.b1.set_text("1" + suffix)
        dd.b1.set_style(d1 > 0 ? label.style_label_down : label.style_label_up)
        dd.b1.set_textcolor(labelColor)
        dd.b1.set_color(bgColor)
        dd.b1.set_size(labelSize)
    else
        dd.b1.set_textcolor(na)
    
    if not na(p2) and not na(x2)
        dd.b2.set_xy(x2, p2)
        dd.b2.set_text("2" + suffix)
        dd.b2.set_style(d2 > 0 ? label.style_label_down : label.style_label_up)
        dd.b2.set_textcolor(labelColor)
        dd.b2.set_color(bgColor)
        dd.b2.set_size(labelSize)
    else
        dd.b2.set_textcolor(na)
    
    if not na(p3) and not na(x3)
        dd.b3.set_xy(x3, p3)
        dd.b3.set_text("3" + suffix)
        dd.b3.set_style(d3 > 0 ? label.style_label_down : label.style_label_up)
        dd.b3.set_textcolor(labelColor)
        dd.b3.set_color(bgColor)
        dd.b3.set_size(labelSize)
    else
        dd.b3.set_textcolor(na)
    
    if not na(p4) and not na(x4)
        dd.b4.set_xy(x4, p4)
        dd.b4.set_text("4" + suffix)
        dd.b4.set_style(d4 > 0 ? label.style_label_down : label.style_label_up)
        dd.b4.set_textcolor(labelColor)
        dd.b4.set_color(bgColor)
        dd.b4.set_size(labelSize)
    else
        dd.b4.set_textcolor(na)
    
    if not na(p5) and not na(x5)
        dd.b5.set_xy(x5, p5)
        dd.b5.set_text("5" + suffix)
        dd.b5.set_style(d5 > 0 ? label.style_label_down : label.style_label_up)
        dd.b5.set_textcolor(labelColor)
        dd.b5.set_color(bgColor)
        dd.b5.set_size(labelSize)
    else
        dd.b5.set_textcolor(na)
    
    // Draw converging trendlines (wedge shape)
    // ═════════════════════════════════════════════════════════════════════════
    // TRENDLINE LOGIC:
    // - Upper trendline connects the peaks (direction-dependent)
    // - Lower trendline connects the troughs (direction-dependent)
    // - Extended 15 bars beyond Wave 5 to show convergence clearly
    // ═════════════════════════════════════════════════════════════════════════
    if not na(p0) and not na(p2) and not na(p4) and not na(x0) and not na(x2) and not na(x4)
        // Calculate extended endpoint for visual clarity
        int extendBars = 15
        int extendedX = x5 + extendBars
        
        if p.direction == "UP"
            // BULLISH DIAGONAL:
            // Upper boundary: 1-3-5 (highs) - slopes upward
            // Lower boundary: 0-2-4 (lows) - slopes upward but slower (converging)
            
            // Calculate slope for upper trendline (1→5)
            float upperSlope = not na(x5) and (x5 - x1) != 0 ? (p5 - p1) / (x5 - x1) : 0
            float extendedUpperY = p5 + (upperSlope * extendBars)
            
            dd.trendLine1.set_xy1(x1, p1)
            dd.trendLine1.set_xy2(extendedX, extendedUpperY)
            
            // Calculate slope for lower trendline (0→4)
            float lowerSlope = not na(x4) and (x4 - x0) != 0 ? (p4 - p0) / (x4 - x0) : 0
            float extendedLowerY = p4 + (lowerSlope * extendBars)
            
            dd.trendLine2.set_xy1(x0, p0)
            dd.trendLine2.set_xy2(extendedX, extendedLowerY)
        else
            // BEARISH DIAGONAL:
            // Upper boundary: 0-2-4 (highs) - slopes downward
            // Lower boundary: 1-3-5 (lows) - slopes downward faster (converging)
            
            // Calculate slope for upper trendline (0→4)
            float upperSlope = not na(x4) and (x4 - x0) != 0 ? (p4 - p0) / (x4 - x0) : 0
            float extendedUpperY = p4 + (upperSlope * extendBars)
            
            dd.trendLine1.set_xy1(x0, p0)
            dd.trendLine1.set_xy2(extendedX, extendedUpperY)
            
            // Calculate slope for lower trendline (1→5)
            float lowerSlope = not na(x5) and (x5 - x1) != 0 ? (p5 - p1) / (x5 - x1) : 0
            float extendedLowerY = p5 + (lowerSlope * extendBars)
            
            dd.trendLine2.set_xy1(x1, p1)
            dd.trendLine2.set_xy2(extendedX, extendedLowerY)
        
        // Style the trendlines (dashed, semi-transparent purple)
        dd.trendLine1.set_color(color.new(lineColor, 40))  // More visible than 50
        dd.trendLine1.set_style(line.style_dashed)
        dd.trendLine1.set_width(2)  // Thicker for better visibility
        
        dd.trendLine2.set_color(color.new(lineColor, 40))
        dd.trendLine2.set_style(line.style_dashed)
        dd.trendLine2.set_width(2)
    else
        dd.trendLine1.set_color(na)
        dd.trendLine2.set_color(na)
    
    // Type label ("Leading Diagonal" or "Ending Diagonal")
    // ═════════════════════════════════════════════════════════════════════════
    // Display diagonal type with confidence score
    // ═════════════════════════════════════════════════════════════════════════
    if not na(p5) and not na(x5)
        string diagonalType = p.patternType == "LEADING_DIAGONAL" ? "Leading Diagonal" : "Ending Diagonal"
        string confidenceStr = str.format("{0,number,#}%", p.confidence)
        string typeText = diagonalType + " (" + confidenceStr + ")"
        
        if rank > 0
            typeText += "*"
        
        // Position label slightly offset from Wave 5
        int labelOffset = 3
        int labelX = x5 + labelOffset
        
        dd.typeLabel.set_xy(labelX, p5)
        dd.typeLabel.set_text(typeText)
        dd.typeLabel.set_style(d5 > 0 ? label.style_label_down : label.style_label_up)
        dd.typeLabel.set_textcolor(labelColor)
        dd.typeLabel.set_color(color.new(#9C27B0, rank == 0 ? 60 : 80))  // More opaque for primary
        dd.typeLabel.set_size(rank == 0 ? size.normal : size.small)
    else
        dd.typeLabel.set_textcolor(na)

f_hide_diagonal_drawing(DiagonalDrawing dd) =>
    dd.l01.set_color(na)
    dd.l12.set_color(na)
    dd.l23.set_color(na)
    dd.l34.set_color(na)
    dd.l45.set_color(na)
    dd.trendLine1.set_color(na)
    dd.trendLine2.set_color(na)
    dd.b0.set_textcolor(na)
    dd.b1.set_textcolor(na)
    dd.b2.set_textcolor(na)
    dd.b3.set_textcolor(na)
    dd.b4.set_textcolor(na)
    dd.b5.set_textcolor(na)
    dd.typeLabel.set_textcolor(na)

