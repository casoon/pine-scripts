// ===== MODULE: CHECKS_DIAGONAL =====
// ═══════════════════════════════════════════════════════════════════════════
// DIAGONAL CHECKS (v2.0 Phase 1)
// ═══════════════════════════════════════════════════════════════════════════

// Leading Diagonal: 5-3-5-3-5 structure, converging trendlines
// Occurs in Wave 1 or Wave A, overlap IS allowed
f_check_leading_diagonal(float p0, float p1, float p2, float p3, float p4, float p5) =>
    float w1 = math.abs(p1 - p0)
    float w2 = math.abs(p2 - p1)
    float w3 = math.abs(p3 - p2)
    float w4 = math.abs(p4 - p3)
    float w5 = math.abs(p5 - p4)
    
    // Deep retracements (Wave 2/4: 66-81% of previous wave)
    float retr2 = w1 > 0 ? w2 / w1 : 0
    float retr4 = w3 > 0 ? w4 / w3 : 0
    
    // Progressive shortening (wedge shape)
    bool deepRetracements = (retr2 >= 0.66 and retr2 <= 0.85) and (retr4 >= 0.66 and retr4 <= 0.85)
    bool shorteningWaves = w5 < w3 and w3 < w1 * 1.8
    
    bool isValid = deepRetracements and shorteningWaves
    float confidence = 0.0
    
    if isValid
        // Score based on how well it fits
        float retrScore = ((retr2 >= 0.70 and retr2 <= 0.79) and (retr4 >= 0.70 and retr4 <= 0.79)) ? 100.0 : 80.0
        float shapeScore = (w5 < w3 * 0.9 and w3 < w1 * 1.2) ? 100.0 : 75.0
        confidence := (retrScore + shapeScore) / 2.0
    else
        confidence := 30.0
    
    [isValid, confidence, retr2, retr4]

// Ending Diagonal: 3-3-3-3-3 structure, converging trendlines
// Occurs in Wave 5 or Wave C, overlap IS allowed, strictly converging
f_check_ending_diagonal(float p0, float p1, float p2, float p3, float p4, float p5) =>
    float w1 = math.abs(p1 - p0)
    float w2 = math.abs(p2 - p1)
    float w3 = math.abs(p3 - p2)
    float w4 = math.abs(p4 - p3)
    float w5 = math.abs(p5 - p4)
    
    // Deep retracements (like Leading)
    float retr2 = w1 > 0 ? w2 / w1 : 0
    float retr4 = w3 > 0 ? w4 / w3 : 0
    
    // Strict convergence (W5 < W3 < W1)
    bool deepRetracements = (retr2 >= 0.66 and retr2 <= 0.85) and (retr4 >= 0.66 and retr4 <= 0.85)
    bool strictConverging = w5 < w3 and w3 < w1
    
    bool isValid = deepRetracements and strictConverging
    float confidence = 0.0
    
    if isValid
        float retrScore = ((retr2 >= 0.70 and retr2 <= 0.79) and (retr4 >= 0.70 and retr4 <= 0.79)) ? 100.0 : 80.0
        float convergeScore = (w5 < w3 * 0.85 and w3 < w1 * 0.85) ? 100.0 : 75.0
        confidence := (retrScore + convergeScore) / 2.0
    else
        confidence := 30.0
    
    [isValid, confidence, retr2, retr4]

// ===== MODULE: CHECKS_IMPULSE =====
// Impulse checks (prices are pivot prices p0..p5)
f_check_wave2_retracement(float p0, float p1, float p2) =>
    float wave1 = math.abs(p1 - p0)
    float wave2 = math.abs(p2 - p1)
    float retrace = wave1 > 0 ? wave2 / wave1 : 0
    bool in382 = f_in_fib_range(retrace, 0.382, fibTolerance)
    bool in500 = f_in_fib_range(retrace, 0.500, fibTolerance)
    bool in618 = f_in_fib_range(retrace, 0.618, fibTolerance)
    float score = in500 ? 100.0 : (in382 or in618 ? 80.0 : (retrace >= 0.25 and retrace <= 0.75 ? 50.0 : 20.0))
    [score, retrace]

f_check_wave4_retracement(float p1, float p2, float p3, float p4) =>
    float wave3 = math.abs(p3 - p2)
    float wave4 = math.abs(p4 - p3)
    float retrace = wave3 > 0 ? wave4 / wave3 : 0
    bool in236 = f_in_fib_range(retrace, 0.236, fibTolerance)
    bool in382 = f_in_fib_range(retrace, 0.382, fibTolerance)
    bool in500 = f_in_fib_range(retrace, 0.500, fibTolerance)
    float score = in382 ? 100.0 : ((in236 or in500) ? 80.0 : (retrace >= 0.15 and retrace <= 0.65 ? 50.0 : 20.0))
    [score, retrace]

f_check_wave3_extension(float p0, float p1, float p2, float p3) =>
    float wave1 = math.abs(p1 - p0)
    float wave3 = math.abs(p3 - p2)
    float ratio = wave1 > 0 ? wave3 / wave1 : 0
    bool is100 = f_in_fib_range(ratio, 1.000, fibTolerance)
    bool is162 = f_in_fib_range(ratio, 1.618, fibTolerance)
    bool is262 = f_in_fib_range(ratio, 2.618, fibTolerance)
    float score = is162 ? 100.0 : (is262 ? 90.0 : (is100 ? 70.0 : (ratio >= 1.0 ? 60.0 : 30.0)))
    [score, ratio]

f_check_wave5_extension(float p0, float p1, float p4, float p5) =>
    float wave1 = math.abs(p1 - p0)
    float wave5 = math.abs(p5 - p4)
    float ratio = wave1 > 0 ? wave5 / wave1 : 0
    bool is062 = f_in_fib_range(ratio, 0.618, fibTolerance)
    bool is100 = f_in_fib_range(ratio, 1.000, fibTolerance)
    bool is162 = f_in_fib_range(ratio, 1.618, fibTolerance)
    float score = (is062 or is100) ? 100.0 : (is162 ? 80.0 : (ratio >= 0.4 and ratio <= 1.8 ? 60.0 : 30.0))
    [score, ratio]

f_check_wave3_not_shortest(float p0, float p1, float p2, float p3, float p4, float p5) =>
    float w1 = math.abs(p1 - p0)
    float w3 = math.abs(p3 - p2)
    float w5 = math.abs(p5 - p4)
    bool valid = w3 >= w1 and w3 >= w5
    float score = valid ? 100.0 : 0.0
    [score, valid]

// ===== MODULE: DETECTION_DIAGONAL =====
// Scan for DIAGONAL patterns (v2.0 Phase 1)
f_detect_diagonal_patterns() =>
    int pc = array.size(pivPrice)
    if enablePatterns and enableDiagonals and pc >= minPivotsFor5
        int startLatest = pc - minPivotsFor5
        int startEarliest = math.max(0, startLatest - (windowsBack5 - 1))
        int span = startLatest - startEarliest
        if span >= 0
            for off = 0 to span
                int startIdx = startLatest - off
                float p0 = f_get_pivot_price(startIdx)
                float p1 = f_get_pivot_price(startIdx + 1)
                float p2 = f_get_pivot_price(startIdx + 2)
                float p3 = f_get_pivot_price(startIdx + 3)
                float p4 = f_get_pivot_price(startIdx + 4)
                float p5 = f_get_pivot_price(startIdx + 5)
                if na(p0) or na(p5)
                    continue
                
                // Check for Leading Diagonal
                [isLeading, leadingConf, retr2L, retr4L] = f_check_leading_diagonal(p0, p1, p2, p3, p4, p5)
                if isLeading
                    c = PatternCandidate.new("LEADING_DIAGONAL", startIdx, startIdx + 5, 6, true, "UNKNOWN", array.new_string(), leadingConf, 100.0, 100.0, 0.0, 100.0, 70.0, 70.0)
                    bool alternates = f_check_alternation(startIdx, 6)
                    if not alternates
                        array.push(c.violations, "No alternation")
                    if retr2L < 0.66 or retr2L > 0.85
                        array.push(c.violations, str.format("W2 {0,number,#.##}% (deep)", retr2L*100))
                    if retr4L < 0.66 or retr4L > 0.85
                        array.push(c.violations, str.format("W4 {0,number,#.##}% (deep)", retr4L*100))
                    int dir1 = f_get_pivot_dir(startIdx + 1)
                    c.direction := dir1 > 0 ? "UP" : "DOWN"
                    array.push(detectedPatterns, c)
                
                // Check for Ending Diagonal
                [isEnding, endingConf, retr2E, retr4E] = f_check_ending_diagonal(p0, p1, p2, p3, p4, p5)
                if isEnding
                    c = PatternCandidate.new("ENDING_DIAGONAL", startIdx, startIdx + 5, 6, true, "UNKNOWN", array.new_string(), endingConf, 100.0, 100.0, 0.0, 100.0, 70.0, 70.0)
                    bool alternates = f_check_alternation(startIdx, 6)
                    if not alternates
                        array.push(c.violations, "No alternation")
                    if retr2E < 0.66 or retr2E > 0.85
                        array.push(c.violations, str.format("W2 {0,number,#.##}% (deep)", retr2E*100))
                    if retr4E < 0.66 or retr4E > 0.85
                        array.push(c.violations, str.format("W4 {0,number,#.##}% (deep)", retr4E*100))
                    int dir1 = f_get_pivot_dir(startIdx + 1)
                    c.direction := dir1 > 0 ? "UP" : "DOWN"
                    array.push(detectedPatterns, c)

// ===== MODULE: CHECKS_FLAT =====
// ═══════════════════════════════════════════════════════════════════════════
// FLAT CORRECTION CHECKS (v2.0 Phase 2 - Priority 2)
// ═══════════════════════════════════════════════════════════════════════════
// Flat Corrections: 3-3-5 structure (A-B-C where all are corrective)
// Three types: Regular, Expanded, Running

// Flat Correction Validation
// A = 3-wave, B = 3-wave (retraces 90-138% of A), C = 5-wave
f_check_flat_correction(float p0, float p1, float p2, float p3) =>
    float waveA = math.abs(p1 - p0)
    float waveB = math.abs(p2 - p1)
    float waveC = math.abs(p3 - p2)
    
    // B wave must retrace 90-138% of A (key flat characteristic)
    float bRetrace = waveA > 0 ? waveB / waveA : 0
    bool validBRetrace = bRetrace >= 0.90 and bRetrace <= 1.38
    
    if not validBRetrace
        [false, "NONE", 0.0, 0.0, 0.0]
    else
        // Determine flat type based on B and C relationships
        string flatType = "REGULAR"
        float confidence = 70.0
        
        // Get direction from Wave A
        bool isUp = p1 > p0
        
        // Check Wave B endpoint relative to Wave A start
        float bVsA = isUp ? (p2 - p0) / waveA : (p0 - p2) / waveA
        
        // Check Wave C endpoint relative to Wave A start
        float cVsA = isUp ? (p0 - p3) / waveA : (p3 - p0) / waveA
        
        // ─────────────────────────────────────────────────────────────────────
        // FLAT TYPE CLASSIFICATION:
        // ─────────────────────────────────────────────────────────────────────
        // Regular Flat: B ≈ A (90-105%), C ≈ A (90-110%)
        // Expanded Flat: B > A (100-138%), C > A (110-161.8%)
        // Running Flat: B > A (100-138%), C < A (falls short)
        // ─────────────────────────────────────────────────────────────────────
        
        if bRetrace >= 1.00 and bRetrace <= 1.38
            // B exceeds A start → Check for Expanded or Running
            if cVsA >= 1.10 and cVsA <= 1.618
                // C breaks beyond A start significantly → EXPANDED FLAT
                flatType := "EXPANDED"
                // Score based on how well C extends
                float cExtensionScore = (cVsA >= 1.272 and cVsA <= 1.382) ? 100.0 : 85.0
                float bRetraceScore = (bRetrace >= 1.05 and bRetrace <= 1.15) ? 100.0 : 85.0
                confidence := (cExtensionScore + bRetraceScore) / 2.0
            else if cVsA < 1.10
                // C fails to break significantly → RUNNING FLAT
                flatType := "RUNNING"
                // Score based on B strength and C weakness
                float bRetraceScore = (bRetrace >= 1.10 and bRetrace <= 1.25) ? 100.0 : 85.0
                float cFailScore = (cVsA >= 0.90 and cVsA <= 1.05) ? 100.0 : 85.0
                confidence := (bRetraceScore + cFailScore) / 2.0
            else
                // C extends too much → still expanded but lower confidence
                flatType := "EXPANDED"
                confidence := 75.0
        else
            // B doesn't exceed A start → REGULAR FLAT
            flatType := "REGULAR"
            // Score based on equality of A, B, C
            float bScore = (bRetrace >= 0.95 and bRetrace <= 1.05) ? 100.0 : 85.0
            float cEqualityScore = (cVsA >= 0.90 and cVsA <= 1.10) ? 100.0 : 85.0
            confidence := (bScore + cEqualityScore) / 2.0
        
        // Wave C should be roughly equal to or longer than Wave A (for all flats)
        bool validCLength = waveC >= waveA * 0.90 and waveC <= waveA * 1.618
        
        if not validCLength
            confidence := confidence * 0.8  // Reduce confidence if C length is off
        
        [true, flatType, confidence, bRetrace, cVsA]

// ===== MODULE: PIVOT_ENGINE =====
// 7) PIVOT ENGINE (No-repaint)
// ───────────────────────────────────────────────────────────────────────────
if na(lastExtreme)
    lastExtreme   := src
    lastExtremeIdx:= bar_index
    trendStart    := src
    trendStartIdx := bar_index
    currentDir    := 0

bool extremeUpdated = false
if currentDir >= 0 and src > lastExtreme
    lastExtreme    := src
    lastExtremeIdx := bar_index
    currentDir     := 1
    extremeUpdated := true
if currentDir <= 0 and src < lastExtreme
    lastExtreme    := src
    lastExtremeIdx := bar_index
    currentDir     := -1
    extremeUpdated := true

float retracement = math.abs(src - lastExtreme)
int   barsSince   = bar_index - lastExtremeIdx
bool  confirmed   = retracement >= thrAbs and barsSince >= minSwingBars

if confirmed and not extremeUpdated
    // Confirm pivot at last extreme
    f_add_pivot(lastExtreme, lastExtremeIdx, currentDir)
    f_calc_swing_metrics()
    f_draw_zigzag_line()
    if showPivots
        string labelText = currentDir > 0 ? "H" : "L"
        if showMetrics and array.size(swingAmp) > 0
            int sidx = array.size(swingAmp) - 1
            labelText += str.format("\n{0} | {1}b", str.tostring(array.get(swingAmp, sidx), format.mintick), array.get(swingBars, sidx))
        label.new(lastExtremeIdx, lastExtreme, labelText, xloc.bar_index, yloc.price, currentDir > 0 ? colorUp : colorDown, currentDir > 0 ? label.style_label_down : label.style_label_up, color.white, size.small)
    // Reset trend tracking and flip direction
    trendStart     := src
    trendStartIdx  := bar_index
    lastExtreme    := src
    lastExtremeIdx := bar_index
    currentDir     := -currentDir
    // Detect patterns after each new pivot
    if enablePatterns
        f_detect_5_wave_patterns()
        f_detect_3_wave_patterns()
        f_detect_diagonal_patterns()  // v2.0 Phase 1
        f_detect_flat_patterns()  // v2.0 Phase 2 - Priority 2

