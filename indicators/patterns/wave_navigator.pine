        array.push(impulseDrawings, wd)
    
    // Create correction wave drawing pool (with Wave C projections)
    for i = 0 to maxActiveWaves - 1
        cd = CorrectionDrawing.new(line.new(na, na, na, na, xloc=xloc.bar_index, color=na), line.new(na, na, na, na, xloc=xloc.bar_index, color=na), line.new(na, na, na, na, xloc=xloc.bar_index, color=na), label.new(na, na, "A", xloc=xloc.bar_index, yloc=yloc.price, color=color(na), textcolor=na, style=label.style_label_down), label.new(na, na, "B", xloc=xloc.bar_index, yloc=yloc.price, color=color(na), textcolor=na, style=label.style_label_up), label.new(na, na, "C", xloc=xloc.bar_index, yloc=yloc.price, color=color(na), textcolor=na, style=label.style_label_down), label.new(na, na, "D", xloc=xloc.bar_index, yloc=yloc.price, color=color(na), textcolor=na, style=label.style_label_up), line.new(na, na, na, na, xloc=xloc.bar_index, color=na), line.new(na, na, na, na, xloc=xloc.bar_index, color=na), line.new(na, na, na, na, xloc=xloc.bar_index, color=na), label.new(na, na, "C Min", xloc=xloc.bar_index, yloc=yloc.price, color=color(na), textcolor=na, style=label.style_none), label.new(na, na, "C Target", xloc=xloc.bar_index, yloc=yloc.price, color=color(na), textcolor=na, style=label.style_none), label.new(na, na, "C Max", xloc=xloc.bar_index, yloc=yloc.price, color=color(na), textcolor=na, style=label.style_none), false, -1)
