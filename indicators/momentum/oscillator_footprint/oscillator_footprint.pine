//@version=6
// ============================================================================
// Oscillator Footprint [WavesUnchained]
// Version: 1.1
// Author: WavesUnchained
// Build: 2026-06-11 00:00:00
// ============================================================================
// Shows WT, StochRSI and MFI momentum energy directly beside each candle as
// mini-bars extending right of the price bar. Height is ATR-normalized so
// strong oscillator readings produce taller bars. Acceleration state is encoded
// in color: bright = rising (accelerating), dark = falling (decelerating).
//
// Due to Pine's box limits, only the last N bars are visualized (configurable).
//
// Features:
//   ✓ Per-bar momentum mini-bars in price space (right of each candle)
//   ✓ Three lanes: WaveTrend | StochRSI | MFI — each offset to avoid overlap
//   ✓ Height scaled by ATR so signal strength is comparable across symbols
//   ✓ Color encodes acceleration: bright = building, dark = fading
//   ✓ Configurable lookback window and scale factor
//
// ============================================================================

indicator("Oscillator Footprint [WavesUnchained]", "Osc Footprint [WU]", overlay=true,
     max_boxes_count=500, max_bars_back=500)

// ─── Inputs ───────────────────────────────────────────────────────────────────

grP       = "Profile"
lookback  = input.int(60,    "Bars to Display",   minval=5,  maxval=150, group=grP,
     tooltip="Number of historical bars to show mini-bars for. Higher values use more boxes (limit: 500).")
scaleFact = input.float(0.5, "Height Scale",      minval=0.1, maxval=3.0, step=0.1, group=grP,
     tooltip="Scales mini-bar height relative to ATR. 0.5 = half an ATR range per full oscillator deflection.")
barOffset = input.int(1,     "Lane Offset (bars)", minval=1, maxval=5, group=grP,
     tooltip="Horizontal offset between the candle right-edge and the first mini-bar lane.")
laneWidth = input.int(2,     "Lane Width (bars)",  minval=1, maxval=5, group=grP)

grWT    = "WaveTrend Lane"
showWT  = input.bool(true, "Show", group=grWT)
wtChLen = input.int(10,   "Channel Length", minval=1, group=grWT)
wtAvLen = input.int(21,   "Average Length", minval=1, group=grWT)
wtBull  = input.color(color.new(#26a69a, 30), "Bull Color", group=grWT)
wtBear  = input.color(color.new(#ef5350, 30), "Bear Color", group=grWT)

grSt     = "StochRSI Lane"
showSt   = input.bool(true, "Show", group=grSt)
rsiLen   = input.int(14,   "RSI Length",   minval=1, group=grSt)
stochLen = input.int(14,   "Stoch Length", minval=1, group=grSt)
kSmooth  = input.int(3,    "K Smoothing",  minval=1, group=grSt)
stBull   = input.color(color.new(#2962ff, 40), "Bull Color", group=grSt)
stBear   = input.color(color.new(#ff6d00, 40), "Bear Color", group=grSt)

grMfi   = "MFI Lane"
showMfi = input.bool(false, "Show", group=grMfi)
mfiLen  = input.int(14,    "MFI Length", minval=1, group=grMfi)
mfiBull = input.color(color.new(#ce93d8, 30), "Bull Color", group=grMfi)
mfiBear = input.color(color.new(#ce93d8, 60), "Bear Color", group=grMfi)

// ─── Oscillator series ────────────────────────────────────────────────────────

_wtEsa = ta.ema(hlc3, wtChLen)
_wtD   = ta.ema(math.abs(hlc3 - _wtEsa), wtChLen)
_wtCi  = (hlc3 - _wtEsa) / (0.015 * math.max(_wtD, syminfo.mintick))
wtOsc  = ta.ema(_wtCi, wtAvLen)

_r1     = ta.rsi(close, rsiLen)
_stRaw  = ta.stoch(_r1, _r1, _r1, stochLen)
stochK  = ta.sma(_stRaw, kSmooth)
// Center StochRSI at 0 for signed height: (k - 50) / 50 maps to -1..+1
stCent  = (stochK - 50.0) / 50.0

_mfiTyp = (high + low + close) / 3
_mfiRaw = _mfiTyp * math.max(nz(volume), 1.0)
_mfiPos = math.sum(_mfiTyp > _mfiTyp[1] ? _mfiRaw : 0.0, mfiLen)
_mfiNeg = math.sum(_mfiTyp < _mfiTyp[1] ? _mfiRaw : 0.0, mfiLen)
mfiSer  = _mfiNeg == 0 ? 100.0 : 100.0 - 100.0 / (1.0 + _mfiPos / _mfiNeg)
mfiCent = (mfiSer - 50.0) / 50.0  // -1..+1

atr14 = ta.atr(14)

// Fading momentum (|osc| shrinking vs previous bar) = darker (more transparent)
f_fade(color c, bool fading) =>
    fading ? color.new(c, math.min(color.t(c) + 35, 95)) : c

// ─── Draw mini-bars (last bar only) ──────────────────────────────────────────

var array<box> footBoxes = array.new<box>()

if barstate.islast
    for b in footBoxes
        box.delete(b)
    footBoxes.clear()

    maxBars = math.min(lookback, last_bar_index)

    for bI = maxBars to 0
        bIdx  = bar_index - bI
        atr_  = nz(atr14[bI], atr14)
        mid_  = (high[bI] + low[bI]) / 2.0  // vertical midpoint for centering

        // WT lane (lane 0)
        if showWT
            wt_   = nz(wtOsc[bI])
            wtPrev = nz(wtOsc[bI + 1], wt_)
            // Normalize: WT ~100 max → 1.0, height in price units = scaleFact * atr
            wtNorm = math.max(math.min(wt_ / 100.0, 1.0), -1.0)
            wtH    = math.abs(wtNorm) * scaleFact * atr_
            if wtH >= syminfo.mintick
                boxL = bIdx + barOffset
                boxR = boxL + laneWidth
                wtC  = f_fade(wt_ >= 0 ? wtBull : wtBear, math.abs(wt_) < math.abs(wtPrev))
                footBoxes.push(box.new(boxL, mid_ + wtH / 2, boxR, mid_ - wtH / 2,
                     bgcolor=wtC, border_color=color.new(color.gray, 80)))

        // StochRSI lane (lane 1)
        if showSt
            st_   = nz(stCent[bI])
            stPrev = nz(stCent[bI + 1], st_)
            stH   = math.abs(st_) * scaleFact * atr_
            if stH >= syminfo.mintick
                boxL = bIdx + barOffset + laneWidth + 1
                boxR = boxL + laneWidth
                stC  = f_fade(st_ >= 0 ? stBull : stBear, math.abs(st_) < math.abs(stPrev))
                footBoxes.push(box.new(boxL, mid_ + stH / 2, boxR, mid_ - stH / 2,
                     bgcolor=stC, border_color=color.new(color.gray, 80)))

        // MFI lane (lane 2)
        if showMfi
            mf_  = nz(mfiCent[bI])
            mfPrev = nz(mfiCent[bI + 1], mf_)
            mfH  = math.abs(mf_) * scaleFact * atr_
            if mfH >= syminfo.mintick
                boxL = bIdx + barOffset + (laneWidth + 1) * 2
                boxR = boxL + laneWidth
                mfC  = f_fade(mf_ >= 0 ? mfiBull : mfiBear, math.abs(mf_) < math.abs(mfPrev))
                footBoxes.push(box.new(boxL, mid_ + mfH / 2, boxR, mid_ - mfH / 2,
                     bgcolor=mfC, border_color=color.new(color.gray, 80)))
