//@version=6
// ============================================================================
// MTF WaveTrend — Tide / Wave / Ripple [WavesUnchained]
// Version: 0.7
// Author: WavesUnchained
// Build: 2026-06-27 00:00:00
// ============================================================================
// Markets are nested cycles, so the timeframes contradict each other by nature —
// that is information, not error. This reads WaveTrend across three FIXED-role
// horizons and decodes the nesting instead of forcing one "optimal" signal:
//
//   Tide   (long  · default 1D)  → bias / regime         — same on every chart
//   Wave   (mid   · default 4h)  → the tradeable setup    — same on every chart
//   Ripple (short · CHART TF)    → the entry timing (cross)
//
// You look in ONE place: the Ripple cross on your chart IS the signal (both
// directions, every TF). Nothing gates it — it is GRADED 0–5 by its own extreme
// depth plus Wave/Tide/Stoch agreement (strong = bold, weak = dim). Quality is
// shown, never suppressed; depth lets a real reversal survive even when every
// higher TF still lags the turn. Every TF stays symmetric, not long-biased.
//
// WaveTrend is the centre; two thin stabilisers keep the cross honest:
//   ✓ Price/WT Divergence   (the classic exhaustion confirm)
//   ✓ StochRSI agreement    (a cheap second oscillator)
//
// ============================================================================

indicator("MTF WaveTrend Tide/Wave/Ripple [WavesUnchained]", shorttitle="WT TWR", overlay=false, max_labels_count=300, max_lines_count=500)

// ============================================================================
// Inputs
// ============================================================================

int chartSec0 = timeframe.in_seconds(timeframe.period)
bool isHtf = not na(chartSec0) and chartSec0 > 14400   // chart TF above 4h (Daily+)

g_wt = "WaveTrend"
n1 = input.int(10, "Channel Length", minval=2, group=g_wt)
n2 = input.int(21, "Average Length", minval=2, group=g_wt)
autoLenHtf = input.bool(true, "Auto-shorten WT length above 4h", group=g_wt,
     tooltip="Above a 4h chart (Daily+), WaveTrend over daily bars with the base lengths is too slow — the crosses lag and become unusable, and smoothing only adds more lag. When on, the channel/average/signal lengths below replace the base lengths on those charts. Tune them to taste.")
n1Htf = input.int(5,  "Channel Length (>4h)", minval=2, group=g_wt)
n2Htf = input.int(11, "Average Length (>4h)", minval=2, group=g_wt)
signalLen = input.int(4, "Signal Length", minval=1, group=g_wt)
signalLenHtf = input.int(3, "Signal Length (>4h)", minval=1, group=g_wt)
simple int n1Eff = autoLenHtf and isHtf ? n1Htf : n1
simple int n2Eff = autoLenHtf and isHtf ? n2Htf : n2
simple int signalLenEff = autoLenHtf and isHtf ? signalLenHtf : signalLen
wtSmooth = input.string("EMA", "WT Smoothing", options=["EMA", "HMA", "SuperSmoother", "JMA Approx"], group=g_wt,
     tooltip="MA used to smooth WaveTrend (WT1). EMA = raw LazyBear. HMA = low-lag Hull. SuperSmoother and JMA Approx are smoother low-lag options.")
jmaPhase = input.int(50, "JMA Phase", minval=-100, maxval=100, group=g_wt)
jmaPower = input.float(2.0, "JMA Power", minval=1.0, maxval=4.0, step=0.25, group=g_wt)
obLevel1 = input.float(60, "Overbought (phase extreme)", group=g_wt)
osLevel1 = input.float(-60, "Oversold (phase extreme)", group=g_wt)
obLevel2 = input.float(100, "Overbought 2 (overheat)", group=g_wt)
osLevel2 = input.float(-100, "Oversold 2 (overheat)", group=g_wt)

g_scale = "Scale"
scaleMode = input.string("Adaptive ±100", "WT Scale Mode",
     options=["Classic", "Clamp ±100", "Adaptive ±100"], group=g_scale,
     tooltip="Classic: raw WaveTrend values. Clamp ±100: hard clips to ±100. Adaptive ±100: rescales each horizon to ±100 from its recent WT range, useful for consistent overheat/oversold thresholds.")
scaleLookback = input.int(200, "Adaptive Lookback", minval=20, group=g_scale,
     tooltip="Lookback used for Adaptive ±100 normalization. Crosses still use raw WT values, so scaling does not create or remove crossovers.")

g_hz = "Horizons (Ripple = chart TF)"
mtfMode = input.string("Auto", "MTF grading (Wave + Tide)", options=["Auto", "On", "Off"], group=g_hz,
     tooltip="On: the grade adds Wave + Tide (+ Wave-Stoch) alignment on top of depth. Off: single-TF mode — grade is the chart-TF depth only (Reversal strength). Auto (default): on up to a 4h chart, OFF above 4h (Daily+) in Fixed mode, where the Tide/Wave nesting degenerates (Tide=chart, Wave=intraday noise). Relative mode keeps it on at every TF.")
horizonMode = input.string("Fixed", "Horizon Mode", options=["Fixed", "Relative"], group=g_hz,
     tooltip="Fixed: Tide/Wave are absolute TFs — same on every chart, but the nesting degenerates when the chart TF reaches the Wave TF (4h chart) or above (Daily). Relative: Tide/Wave scale as multiples of the chart TF, so the Ripple < Wave < Tide nesting always holds — including on 4h and Daily.")
tideTf = input.timeframe("D",   "Tide TF (Fixed mode)",  group=g_hz)
waveTf = input.timeframe("240", "Wave TF (Fixed mode)",  group=g_hz)
waveMult = input.int(4,  "Wave × chart (Relative mode)", minval=2, group=g_hz,
     tooltip="Wave TF = chart TF × this. Default 4 reproduces a 4h Wave on a 1h chart.")
tideMult = input.int(24, "Tide × chart (Relative mode)", minval=3, group=g_hz,
     tooltip="Tide TF = chart TF × this. Default 24 reproduces a ~1D Tide on a 1h chart.")
string waveTfEff = horizonMode == "Relative" ? timeframe.from_seconds(chartSec0 * waveMult) : waveTf
string tideTfEff = horizonMode == "Relative" ? timeframe.from_seconds(chartSec0 * tideMult) : tideTf
// Auto = MTF on up to 4h; off above 4h in Fixed mode (degenerate nesting). Relative never degenerates.
bool useMTF = mtfMode == "On" ? true : mtfMode == "Off" ? false : (horizonMode == "Relative" or chartSec0 <= 14400)

g_sig = "Ripple Trigger"
triggerMode = input.string("WT-Cross", "Trigger Type", options=["WT-Cross", "WT-Turn"], group=g_sig,
     tooltip="WT-Cross: classic WT1 crossing its signal line WT2. WT-Turn: fires when WT1 ITSELF turns (slope flip out of the extreme), ~1 bar earlier than the cross — the V/Λ on WT1, before WT2 is crossed. Same zone, grade and cooldown apply to both.")
zoneLevel = input.float(25, "Trigger Zone (|WT| ≥)", minval=0, maxval=80, group=g_sig,
     tooltip="The Ripple cross only triggers if WT reached this deep into oversold/overbought within the Extreme Lookback window — filters mid-range continuation crosses.")
extremeLookback = input.int(8, "Extreme Lookback (bars)", minval=1, maxval=30, group=g_sig,
     tooltip="Bars to look back from a cross for zone/deep scoring. Smoother WT modes can cross several bars after the actual oscillator extreme; higher values keep those reversal crosses graded correctly.")
useExhaustion = input.bool(true, "Use Exhaustion for Zone (shallow) Score", group=g_sig,
     tooltip="When enabled, the SHALLOW zone point (|WT| between zone and extreme) is only awarded after WT has pulled back from its recent extreme — filters early shallow crosses. The DEEP extreme tier is NOT affected: a deep cross always scores its depth, so a real reversal at the extreme is never dropped.")
exhaustionPullback = input.float(8.0, "Exhaustion Pullback (WT pts)", minval=0.0, maxval=40.0, step=0.5, group=g_sig,
     tooltip="Minimum WT pullback from the recent high/low before the shallow zone point counts. Higher values shift shallow grades later. Does not affect the deep extreme tier.")
signalLevelSource = input.string("Scaled ±100", "Signal Level Source", options=["Scaled ±100", "Raw WT"], group=g_sig,
     tooltip="Source for zone/deep threshold checks. Crosses always use raw WT. Scaled ±100 makes thresholds more comparable across symbols but less classic; Raw WT keeps classic WT threshold behavior.")
cooldownBars = input.int(8, "Cooldown (bars, thin repeats)", minval=0, maxval=100, group=g_sig,
     tooltip="Minimum bars between two same-direction signals — collapses the close-together repeats within one wave-leg to the first. 0 = show every trigger.")
minGrade = input.int(2, "Min Grade (0–5)", minval=0, maxval=5, group=g_sig,
     tooltip="Every Ripple cross is graded by exhaustion depth + Wave + Tide + Wave-Stoch. Exhausted trigger-zone visit counts 1 point, exhausted deep extreme counts 2 points. With Wave-Stoch on, max grade is 5; without it, max grade is 4.")

g_stab = "Grade components & Premium"
useWaveStoch = input.bool(true, "Wave StochRSI in grade", group=g_stab,
     tooltip="Counts the WAVE StochRSI toward the grade: +1 when K is above D, actually rising and not overbought for a long (opposite for short). Off = grade is depth + Wave + Tide only.")
useDiv = input.bool(true, "Divergence ★ premium marker", group=g_stab,
     tooltip="When a price/WT divergence is present at a signal, it is marked ★ = high-conviction reversal. Drawing/marking only; whether it also lifts the grade is the next option.")
useDivGrade = input.bool(true, "Divergence adds to grade (+1)", group=g_stab,
     tooltip="On: a present divergence adds +1 to the grade (and counts the signal as Reversal). This lets a counter-HTF reversal at the zone (depth 1 + divergence) reach the min grade instead of being dropped. Still never a gate — it only adds, never blocks. Off: divergence is the ★ marker only, exactly as before.")
divLb = input.int(3, "Divergence Pivot Bars", minval=2, maxval=20, group=g_stab)
usePricePivDiv = input.bool(false, "Experimental: price-pivot divergence", group=g_stab,
     tooltip="Off by default. Price-pivot divergence can show more cases, but it may connect oscillator points that are not true WT swing pivots. WT-pivot divergence is the stricter default.")
divMinLevel = input.float(25, "Divergence Min WT Zone", minval=0, maxval=100, group=g_stab,
     tooltip="At least one divergence endpoint must be this deep in the matching WT zone. Filters loose mid-range divergences that look wrong visually.")
divWin = input.int(6, "Divergence Window (bars)", minval=1, maxval=30, group=g_stab)
srRsiLen = input.int(14, "StochRSI: RSI Length", group=g_stab)
srStochLen = input.int(14, "StochRSI: Stoch Length", group=g_stab)
srK = input.int(3, "StochRSI: K", group=g_stab)
srD = input.int(3, "StochRSI: D", group=g_stab)
srOs = input.float(20, "StochRSI Oversold", group=g_stab)
srOb = input.float(80, "StochRSI Overbought", group=g_stab)

g_vis = "Visuals & Logging"
showTable    = input.bool(false, "Show Horizon Phase Map", group=g_vis)
showWtShadow = input.bool(true,  "Show WT Shadow Fill",    group=g_vis,
     tooltip="Gradient fill between WT1 and the zero line — bear tint above, bull tint below. Fades toward transparent at the zero line.")
showWtFill   = input.bool(true,  "Show WT / Signal Fill",  group=g_vis,
     tooltip="Tint between WT1 and WT2 — bull when WT1 > WT2, bear when below.")
showHeatZones = input.bool(true, "Show Heating Zones", group=g_vis)
showCrossDots = input.bool(true, "Show All WT Trigger Dots", group=g_vis,
     tooltip="Shows every raw trigger event (WT cross or WT turn, per Trigger Type) in the oscillator pane. Trade signals remain filtered separately by zone, grade and cooldown.")
showFollowUp = input.bool(true, "Show Grade-1 Follow-Up Hints", group=g_vis,
     tooltip="Faint marker for a triggered cross one grade below the minimum. Not a signal — just shows there was still a move here, without a full-grade setup.")
watchStyle = input.string("Label", "Watch Marker Style", options=["Label", "Dot", "Triangle", "Background", "Off"], group=g_vis,
     tooltip="How the early-warning ('reversal setup forming') is drawn ON THE PRICE CHART when WT reaches its deep extreme — long below the bar, short above it. Label = a ⚠ glyph. Dot = small circle. Triangle = arrow. Background = faint column highlight. Off = no marker (the ⚠️ Watch alert still fires regardless).")
showDivLines = input.bool(true, "Show Divergence Lines", group=g_vis)
visualSignalOffset = input.float(3.0, "Visual WT2 Offset", minval=0.0, maxval=12.0, step=0.5, group=g_vis,
     tooltip="Visual-only separation for the signal line so crosses are easier to see. Signal logic still uses the true WT1/WT2 values.")
enableLog = input.bool(true, "Log Trade Signals", group=g_vis)
debugCand = input.bool(false, "Debug: log trigger candidates", group=g_vis,
     tooltip="Logs EVERY ripple cross out of the zone (long/short candidate) and which gate blocks it. Turn on, run on 15m and on 1h, and compare the SHORT-CAND lines — that shows whether the 1h simply has fewer short candidates or whether a filter is blocking them.")

// ============================================================================
// Helpers
// ============================================================================

f_supersmoother(series float x, simple int len) =>
    float pi = math.pi
    float a1 = math.exp(-1.414 * pi / len)
    float b1 = 2.0 * a1 * math.cos(1.414 * pi / len)
    float c2 = b1
    float c3 = -(a1 * a1)
    float c1 = 1.0 - c2 - c3
    var float ss = na
    ss := c1 * (x + nz(x[1])) / 2.0 + c2 * nz(ss[1]) + c3 * nz(ss[2])
    ss

f_jma(series float x, simple int len, simple int phase, simple float power) =>
    var float jma = na
    var float e0  = na
    var float e1  = na
    var float e2  = na
    float phaseRatio = phase < -100 ? 0.5 : phase > 100 ? 2.5 : phase / 100.0 + 1.5
    float beta       = 0.45 * (len - 1) / (0.45 * (len - 1) + 2.0)
    float alpha      = math.pow(beta, power)
    e0  := (1.0 - alpha) * x + alpha * nz(e0[1], x)
    e1  := (x - e0) * (1.0 - beta) + beta * nz(e1[1], 0.0)
    e2  := (e0 + phaseRatio * e1 - nz(jma[1], x)) * math.pow(1.0 - alpha, 2.0) + math.pow(alpha, 2.0) * nz(e2[1], 0.0)
    jma := nz(jma[1], x) + e2
    jma

f_smooth(series float src, simple int length, simple string mode) =>
    switch mode
        "HMA"           => ta.hma(src, length)
        "SuperSmoother" => f_supersmoother(src, length)
        "JMA Approx"    => f_jma(src, length, jmaPhase, jmaPower)
        =>                 ta.ema(src, length)

// WaveTrend core with the selected smoother applied consistently to channel,
// deviation, oscillator, and signal line.
f_wt() =>
    float ap = hlc3
    float esa = f_smooth(ap, n1Eff, wtSmooth)
    float devRaw = f_smooth(math.abs(ap - esa), n1Eff, wtSmooth)
    float dev = math.max(math.abs(devRaw), 1e-10)
    float ci = (ap - esa) / (0.015 * dev)
    float wt1 = f_smooth(ci, n2Eff, wtSmooth)
    float wt2 = f_smooth(wt1, signalLenEff, wtSmooth)
    [wt1, wt2]

f_scale(series float x, float sharedMax) =>
    if scaleMode == "Clamp ±100"
        math.max(math.min(x, 100.0), -100.0)
    else if scaleMode == "Adaptive ±100"
        sharedMax != 0.0 ? 100.0 * x / sharedMax : 0.0
    else
        x

f_wtData() =>
    [w1Raw, w2Raw] = f_wt()
    float scaleAbs = ta.highest(math.max(math.abs(w1Raw), math.abs(w2Raw)), scaleLookback)
    float w1 = f_scale(w1Raw, scaleAbs)
    float w2 = f_scale(w2Raw, scaleAbs)
    [w1Raw, w2Raw, w1, w2]

// Wave horizon: WT + its own StochRSI (the real second-oscillator confirm)
f_waveData() =>
    [w1Raw, w2Raw, w1, w2] = f_wtData()
    float r = ta.rsi(close, srRsiLen)
    float st = ta.stoch(r, r, r, srStochLen)
    float k = ta.sma(st, srK)
    float dd = ta.sma(k, srD)
    bool kRising = k > k[1]
    bool kFalling = k < k[1]
    [w1Raw, w2Raw, w1, w2, k, dd, kRising, kFalling]

// Phase of a horizon from WT position + slope: 0 Bottom, 1 Up, 2 Top, 3 Down
f_phase(float w1, float w2) =>
    bool up = w1 > w2
    bool os = w1 <= osLevel1
    bool ob = w1 >= obLevel1
    up ? (os ? 0 : 1) : (ob ? 2 : 3)
f_phaseName(int p) => p == 0 ? "Bottom" : p == 1 ? "Up" : p == 2 ? "Top" : "Down"
f_phaseCol(int p)  => p == 0 ? color.new(#00c853, 0) : p == 1 ? color.new(#00c853, 45) : p == 2 ? color.new(#d50000, 0) : color.new(#d50000, 45)

// Regular divergence of an oscillator vs price at WT pivots and, optionally,
// price pivots. Price-pivot mode is less sparse and closer to how divergences
// are read manually on price swings.
// Also returns bar indices and osc values at both pivot endpoints for line drawing.
f_div(float osc, int lb) =>
    bool plF = not na(ta.pivotlow(osc, lb, lb))
    bool phF = not na(ta.pivothigh(osc, lb, lb))
    bool pricePlF = not na(ta.pivotlow(low, lb, lb))
    bool pricePhF = not na(ta.pivothigh(high, lb, lb))
    float curOscL  = ta.valuewhen(plF, osc[lb], 0)
    float prevOscL = ta.valuewhen(plF, osc[lb], 1)
    float curLowP  = ta.valuewhen(plF, low[lb], 0)
    float prevLowP = ta.valuewhen(plF, low[lb], 1)
    int   curBarL  = ta.valuewhen(plF, bar_index[lb], 0)
    int   prevBarL = ta.valuewhen(plF, bar_index[lb], 1)
    bool bullOsc = plF and curOscL > prevOscL and curLowP < prevLowP and math.min(curOscL, prevOscL) <= -divMinLevel
    float curOscLP  = ta.valuewhen(pricePlF, osc[lb], 0)
    float prevOscLP = ta.valuewhen(pricePlF, osc[lb], 1)
    float curLowPP  = ta.valuewhen(pricePlF, low[lb], 0)
    float prevLowPP = ta.valuewhen(pricePlF, low[lb], 1)
    int   curBarLP  = ta.valuewhen(pricePlF, bar_index[lb], 0)
    int   prevBarLP = ta.valuewhen(pricePlF, bar_index[lb], 1)
    bool bullPrice = usePricePivDiv and pricePlF and curOscLP > prevOscLP and curLowPP < prevLowPP and math.min(curOscLP, prevOscLP) <= -divMinLevel
    bool bull = bullOsc or bullPrice
    float bullPrevOsc = bullPrice ? prevOscLP : prevOscL
    float bullCurOsc = bullPrice ? curOscLP : curOscL
    int bullPrevBar = bullPrice ? prevBarLP : prevBarL
    int bullCurBar = bullPrice ? curBarLP : curBarL
    float curOscH   = ta.valuewhen(phF, osc[lb], 0)
    float prevOscH  = ta.valuewhen(phF, osc[lb], 1)
    float curHighP  = ta.valuewhen(phF, high[lb], 0)
    float prevHighP = ta.valuewhen(phF, high[lb], 1)
    int   curBarH   = ta.valuewhen(phF, bar_index[lb], 0)
    int   prevBarH  = ta.valuewhen(phF, bar_index[lb], 1)
    bool bearOsc = phF and curOscH < prevOscH and curHighP > prevHighP and math.max(curOscH, prevOscH) >= divMinLevel
    float curOscHP   = ta.valuewhen(pricePhF, osc[lb], 0)
    float prevOscHP  = ta.valuewhen(pricePhF, osc[lb], 1)
    float curHighPP  = ta.valuewhen(pricePhF, high[lb], 0)
    float prevHighPP = ta.valuewhen(pricePhF, high[lb], 1)
    int   curBarHP   = ta.valuewhen(pricePhF, bar_index[lb], 0)
    int   prevBarHP  = ta.valuewhen(pricePhF, bar_index[lb], 1)
    bool bearPrice = usePricePivDiv and pricePhF and curOscHP < prevOscHP and curHighPP > prevHighPP and math.max(curOscHP, prevOscHP) >= divMinLevel
    bool bear = bearOsc or bearPrice
    float bearPrevOsc = bearPrice ? prevOscHP : prevOscH
    float bearCurOsc = bearPrice ? curOscHP : curOscH
    int bearPrevBar = bearPrice ? prevBarHP : prevBarH
    int bearCurBar = bearPrice ? curBarHP : curBarH
    [bull, bear, bullPrevBar, bullCurBar, bullPrevOsc, bullCurOsc, bearPrevBar, bearCurBar, bearPrevOsc, bearCurOsc]

f_tfName(string tf) => tf == "" ? timeframe.period : tf

// ============================================================================
// Layer 1 — WaveTrend engine per horizon
// ============================================================================

// Ripple = chart TF (native, exact timing)
[rw1Raw, rw2Raw, rw1, rw2] = f_wtData()
// Tide / Wave = fixed higher TFs (same on every chart)
[ww1Raw, ww2Raw, ww1, ww2, wk, wd, wkRising, wkFalling] = request.security(syminfo.tickerid, waveTfEff, f_waveData(), lookahead=barmerge.lookahead_off)
[tw1Raw, tw2Raw, tw1, tw2] = request.security(syminfo.tickerid, tideTfEff, f_wtData(), lookahead=barmerge.lookahead_off)
int chartSec = timeframe.in_seconds(timeframe.period)
int waveSec = timeframe.in_seconds(waveTfEff)
bool chartTooHigh = not na(chartSec) and not na(waveSec) and chartSec > waveSec

// ============================================================================
// Layer 2 — Phase map
// ============================================================================

int ripplePh = f_phase(rw1, rw2)
int wavePh   = f_phase(ww1, ww2)
int tidePh   = f_phase(tw1, tw2)
bool rippleUp = rw1 > rw2
bool waveUp = ww1 > ww2
bool tideUp = tw1 > tw2

// Room — has the higher TF already pushed into its own zone in the trade direction, or is there
// still space to run? Measured against the trigger ZONE (±zoneLevel), NOT the ±extreme: at signal
// time the HTF is almost never at its own ±extreme, so the extreme check read "yes" every time.
// A read-out only (§9), never a gate: a deep reversal often has NO room and is still valid.
bool longHasRoom  = ww1 < zoneLevel  and tw1 < zoneLevel
bool shortHasRoom = ww1 > -zoneLevel and tw1 > -zoneLevel

// ============================================================================
// Layer 3 — Signal: Ripple cross × Wave/Tide phase × stabiliser
// ============================================================================

// Active Ripple trigger: WT-Cross (WT1×WT2) or the earlier WT-Turn (WT1 slope-flip — a V/Λ on
// WT1 itself). The Turn fires the bar after the WT1 extreme, ~1 bar before WT2 is crossed. This
// is WT-velocity timing (design §8), NOT a price pivot — it never feeds a grade/dedup, only timing.
bool wtCrossBull = ta.crossover(rw1Raw, rw2Raw)
bool wtCrossBear = ta.crossunder(rw1Raw, rw2Raw)
bool wtTurnBull  = rw1Raw > rw1Raw[1] and rw1Raw[1] < rw1Raw[2]
bool wtTurnBear  = rw1Raw < rw1Raw[1] and rw1Raw[1] > rw1Raw[2]
bool turnMode = triggerMode == "WT-Turn"
rippleBull = turnMode ? wtTurnBull : wtCrossBull
rippleBear = turnMode ? wtTurnBear : wtCrossBear
// TRIGGER = the Ripple (chart) cross out of its OWN extreme zone — both directions, every TF.
// The Wave/Tide do NOT gate it: a hard wave-direction gate starved shorts on every TF below the
// Wave, because the Wave WT lags the faster top (at the chart top the 4h still reads "up", so the
// short was suppressed). On the 4h chart Ripple == Wave, so the gate was trivially satisfied and
// only the 4h looked correct. Now the cross is the signal; Wave/Tide GRADE it (see below).
float rSig = signalLevelSource == "Raw WT" ? rw1Raw : rw1

zoneBull = ta.lowest(rSig, extremeLookback) <= -zoneLevel
zoneBear = ta.highest(rSig, extremeLookback) >=  zoneLevel
longTrig  = rippleBull and zoneBull
shortTrig = rippleBear and zoneBear

// Wave (4h) StochRSI with room: rising & not overbought for a long, falling & not oversold for a
// short. A real second oscillator on the higher TF — now a GRADE component, not a gate.
bool waveStochBull = wk > wd and wkRising and wk < srOb
bool waveStochBear = wk < wd and wkFalling and wk > srOs

// Signal STRENGTH — a cross from a DEEP extreme (|WT| ≥ obLevel1, not just the ≥zoneLevel trigger)
// is a high-quality reversal on its own merit. This is the key: a real top/bottom reversal cannot
// have HTF agreement (the Wave/Tide lag the turn), so without a depth component the strongest
// reversals grade 0 and get filtered (e.g. the 06-04 top short in an uptrend). Depth fixes that.
bool longDeep  = ta.lowest(rSig, extremeLookback)  <= osLevel1
bool shortDeep = ta.highest(rSig, extremeLookback) >=  obLevel1
float recentLow = ta.lowest(rSig, extremeLookback)
float recentHigh = ta.highest(rSig, extremeLookback)
// WT-Turn is itself the rollover (the V/Λ on WT1), so it satisfies exhaustion on its own bar —
// requiring the extra pullback on top would re-delay the turn and defeat its earlier timing.
bool longExhausted = not useExhaustion or turnMode or rSig - recentLow >= exhaustionPullback
bool shortExhausted = not useExhaustion or turnMode or recentHigh - rSig >= exhaustionPullback

// Deep tier (|WT| ≥ extreme) is decoupled from exhaustion: a cross out of a deep extreme IS the
// rollover, so it scores 2 immediately — without it, a real bottom/top reversal that just printed
// its extreme (no pullback yet) graded 0 and was dropped (the recurring over-filter failure). Only
// the SHALLOW zone tier (zone..extreme) still needs the exhaustion pullback to filter early noise.
int longDepthScore = longDeep ? 2 : (longExhausted and zoneBull ? 1 : 0)
int shortDepthScore = shortDeep ? 2 : (shortExhausted and zoneBear ? 1 : 0)

// DIVERGENCE — a price/WT divergence is independent reversal evidence (exhaustion, pipeline
// stage 2). The ★ marker is unchanged; with "Divergence adds to grade" it also lifts the grade
// by +1, so a counter-HTF reversal at the zone (depth 1 + divergence) reaches the min grade.
// Computed here, before the grade, so it can feed it. Still never a gate — it only adds.
[bullDiv, bearDiv, _divPrevBarL, _divCurBarL, _divPrevOscL, _divCurOscL, _divPrevBarH, _divCurBarH, _divPrevOscH, _divCurOscH] = f_div(rw1, divLb)
bool bullPrem = useDiv and ta.barssince(bullDiv) <= divWin
bool bearPrem = useDiv and ta.barssince(bearDiv) <= divWin
bool longDivBoost  = useDivGrade and bullPrem
bool shortDivBoost = useDivGrade and bearPrem

// GRADE — signal strength (depth) + alignment with the bigger picture (Wave + Tide + Stoch) +
// divergence. NOT a direction filter: a shallow cross against everything still fires (grade 0),
// shown dim. A deep reversal (or a divergence) scores even when every HTF lags, so it can compete
// with shallow HTF alignment. MTF off → single-TF: grade is depth (+ divergence) only.
int maxGrade = (not useMTF ? 2 : useWaveStoch ? 5 : 4) + (useDivGrade ? 1 : 0)
int activeMinGrade = minGrade > maxGrade ? maxGrade : minGrade
int longGrade  = longDepthScore  + (useMTF and waveUp ? 1 : 0)     + (useMTF and tideUp ? 1 : 0)     + (useMTF and useWaveStoch and waveStochBull ? 1 : 0) + (longDivBoost ? 1 : 0)
int shortGrade = shortDepthScore + (useMTF and not waveUp ? 1 : 0) + (useMTF and not tideUp ? 1 : 0) + (useMTF and useWaveStoch and waveStochBear ? 1 : 0) + (shortDivBoost ? 1 : 0)

// SIGNAL TYPE — same grade, different meaning (§7). A deep cross OR a divergence is an exhaustion
// REVERSAL; a shallow cross WITH Wave+Tide aligned is a trend CONTINUATION; anything else is mixed.
string longSigType  = (longDepthScore  >= 2 or longDivBoost)  ? "Reversal" : (useMTF and longDepthScore  <= 1 and waveUp and tideUp) ? "Continuation" : "Mixed"
string shortSigType = (shortDepthScore >= 2 or shortDivBoost) ? "Reversal" : (useMTF and shortDepthScore <= 1 and not waveUp and not tideUp) ? "Continuation" : "Mixed"

// Cooldown thins repeated same-direction signals down to one per stretch
var int lastLongBar  = -100000
var int lastShortBar = -100000
bool longCool  = bar_index - lastLongBar  >= cooldownBars
bool shortCool = bar_index - lastShortBar >= cooldownBars
longSignal  = longTrig  and longGrade  >= activeMinGrade and longCool
shortSignal = shortTrig and shortGrade >= activeMinGrade and shortCool
if longSignal
    lastLongBar := bar_index
if shortSignal
    lastShortBar := bar_index
// high grade = stronger score → bold; lower accepted grades stay dim
withLong  = longSignal  and longGrade  >= 3
withShort = shortSignal and shortGrade >= 3

// WATCH = early warning: WT just reached its deep extreme, a reversal setup is forming BEFORE the
// trigger cross. Shown as a small yellow marker and available as an alert (lead time on 1h/4h).
bool longWatch  = ta.crossunder(rSig, osLevel1)
bool shortWatch = ta.crossover(rSig,  obLevel1)

// Suppressed-trigger HINTS — a triggered cross that scored at least 1 but stayed below the min
// grade (e.g. a 1h long crossing while 4h+1D are both down, so it only earns depth: Grade 1).
// Never a signal (§9): it answers "there WAS a cross here, why no signal" — the HTF was against
// it. Shown faint only; direction-agnostic so counter-HTF suppression is visible, not hidden.
bool longFollowUp  = showFollowUp and longTrig  and longGrade  >= 1 and longGrade  < activeMinGrade
bool shortFollowUp = showFollowUp and shortTrig and shortGrade >= 1 and shortGrade < activeMinGrade

// ============================================================================
// Last-bias state for the optional table. This is the last SIGNAL direction, not a
// held position: an opposite signal can close and re-open on the same bar, so it
// tracks "which way did the last signal point", not "is a trade open".
// ============================================================================
var int   posDir   = 0       // 0 flat, 1 long-bias, -1 short-bias

bool ripBearTop = rippleBear and ta.highest(rSig, extremeLookback) >=  zoneLevel   // ripple rolls over from the top zone
bool ripBullBot = rippleBull and ta.lowest(rSig, extremeLookback)  <= -zoneLevel   // ripple turns up from the bottom zone
bool closeLong  = posDir ==  1 and (ripBearTop or shortSignal)
bool closeShort = posDir == -1 and (ripBullBot or longSignal)
if closeLong or closeShort
    posDir := 0
// open a fresh position when a signal fires while flat
if longSignal and posDir == 0
    posDir   := 1
if shortSignal and posDir == 0
    posDir   := -1

// ============================================================================
// Oscillator pane (Ripple = chart TF)
// ============================================================================

hOB2 = hline(obLevel2, "OB 2", color=color.new(#ef5350, 45), linestyle=hline.style_solid, linewidth=1)
hOB1 = hline(obLevel1, "OB 1", color=color.new(#ef5350, 65), linestyle=hline.style_dashed, linewidth=1)
hOS1 = hline(osLevel1, "OS 1", color=color.new(#26a69a, 65), linestyle=hline.style_dashed, linewidth=1)
hOS2 = hline(osLevel2, "OS 2", color=color.new(#26a69a, 45), linestyle=hline.style_solid, linewidth=1)

fill(hOB1, hOB2, color=showHeatZones ? color.new(#ef5350, 90) : na, title="OB Heating Zone")
fill(hOS2, hOS1, color=showHeatZones ? color.new(#26a69a, 90) : na, title="OS Heating Zone")

pZero = plot(0, "Zero", color=color.new(color.gray, 50))

float histVal    = rw1 - rw2
bool  histRising = histVal >= histVal[1]
color histCol    = histVal >= 0.0
     ? (histRising  ? color.new(#26a69a, 55) : color.new(#26a69a, 80))
     : (not histRising ? color.new(#ef5350, 55) : color.new(#ef5350, 80))
plot(histVal, "WT Hist", color=histCol, style=plot.style_columns)

color wtCol1 = color.from_gradient(rw1, osLevel1, obLevel1, #26a69a, #ef5350)
color wtCol2 = color.from_gradient(rw2, osLevel1, obLevel1, color.new(#26a69a, 40), color.new(#ef5350, 40))
float rw2Vis = rw2 + (rw1 >= rw2 ? -visualSignalOffset : visualSignalOffset)
pWT2 = plot(rw2Vis, "WT2", color=wtCol2, linewidth=1)
pWT1 = plot(rw1, "WT1", color=wtCol1, linewidth=2)
pWT2True = plot(rw2, display=display.none)
float crossY = (rw1 + rw2) / 2.0
float longSignalY = osLevel2 - 6.0
float shortSignalY = obLevel2 + 6.0

fill(pWT1, pZero, obLevel1, 0.0, color.new(#ef5350, 78), color.new(#ef5350, 100),
     title="Bear Shadow", display=showWtShadow ? display.all : display.none)
fill(pWT1, pZero, 0.0, osLevel1, color.new(#26a69a, 100), color.new(#26a69a, 78),
     title="Bull Shadow", display=showWtShadow ? display.all : display.none)

fill(pWT1, pWT2True,
     color=showWtFill ? (rw1 >= rw2 ? color.new(#26a69a, 88) : color.new(#ef5350, 88)) : na,
     title="Momentum Fill")

if useDiv and showDivLines and bullDiv and not na(_divPrevBarL)
    line.new(_divPrevBarL, _divPrevOscL, _divCurBarL, _divCurOscL, color=color.new(#26a69a, 0), width=2)
if useDiv and showDivLines and bearDiv and not na(_divPrevBarH)
    line.new(_divPrevBarH, _divPrevOscH, _divCurBarH, _divCurOscH, color=color.new(#ef5350, 0), width=2)

plotshape(showCrossDots and rippleBull ? crossY : na, "WT Trigger Up",
     style=shape.circle, location=location.absolute, color=color.new(#00bcd4, 0), size=size.tiny)
plotshape(showCrossDots and rippleBear ? crossY : na, "WT Trigger Down",
     style=shape.circle, location=location.absolute, color=color.new(#f06292, 0), size=size.tiny)

plotshape(useDiv and bullDiv ? _divCurOscL : na, "Bull Divergence Pivot",
     style=shape.diamond, location=location.absolute, color=color.new(#00c853, 0), size=size.tiny, offset=-divLb)
plotshape(useDiv and bearDiv ? _divCurOscH : na, "Bear Divergence Pivot",
     style=shape.diamond, location=location.absolute, color=color.new(#d50000, 0), size=size.tiny, offset=-divLb)

// Watch (early warning) on the PRICE chart — long below the bar, short above it. Style-selectable.
plotchar(watchStyle == "Label" and longWatch,  "Watch Long (label)",  "⚠", location.belowbar, color.new(#ffb300, 0), size=size.tiny, force_overlay=true)
plotchar(watchStyle == "Label" and shortWatch, "Watch Short (label)", "⚠", location.abovebar, color.new(#ffb300, 0), size=size.tiny, force_overlay=true)
plotshape(watchStyle == "Dot" and longWatch,  "Watch Long (dot)",  style=shape.circle, location=location.belowbar, color=color.new(#ffd600, 0), size=size.tiny, force_overlay=true)
plotshape(watchStyle == "Dot" and shortWatch, "Watch Short (dot)", style=shape.circle, location=location.abovebar, color=color.new(#ffd600, 0), size=size.tiny, force_overlay=true)
plotshape(watchStyle == "Triangle" and longWatch,  "Watch Long (tri)",  style=shape.triangleup,   location=location.belowbar, color=color.new(#ffd600, 0), size=size.tiny, force_overlay=true)
plotshape(watchStyle == "Triangle" and shortWatch, "Watch Short (tri)", style=shape.triangledown, location=location.abovebar, color=color.new(#ffd600, 0), size=size.tiny, force_overlay=true)
bgcolor(watchStyle == "Background" and (longWatch or shortWatch) ? color.new(#ffd600, 90) : na, title="Watch Highlight", force_overlay=true)

plotshape(longSignal ? longSignalY : na, "MTF Long Signal",
     style=shape.triangleup, location=location.absolute, color=color.new(#00e676, 0), size=size.tiny)
plotshape(shortSignal ? shortSignalY : na, "MTF Short Signal",
     style=shape.triangledown, location=location.absolute, color=color.new(#d50000, 0), size=size.tiny)

plotshape(longFollowUp ? longSignalY : na, "Long Follow-Up Hint",
     style=shape.circle, location=location.absolute, color=color.new(#00e676, 75), size=size.tiny)
plotshape(shortFollowUp ? shortSignalY : na, "Short Follow-Up Hint",
     style=shape.circle, location=location.absolute, color=color.new(#d50000, 75), size=size.tiny)

// ============================================================================
// Signals on the PRICE chart — with-trend = bold, counter-tide = dim
// ============================================================================

plotshape(withLong,                  "Long (high grade)",   shape.triangleup,   location.belowbar, color.new(#00e676, 0),  size=size.small, force_overlay=true)
plotshape(withShort,                 "Short (high grade)",  shape.triangledown, location.abovebar, color.new(#d50000, 0),  size=size.small, force_overlay=true)
plotshape(longSignal  and not withLong,  "Long (low grade)",  shape.triangleup,   location.belowbar, color.new(#00e676, 60), size=size.tiny, force_overlay=true)
plotshape(shortSignal and not withShort, "Short (low grade)", shape.triangledown, location.abovebar, color.new(#d50000, 60), size=size.tiny, force_overlay=true)

f_sigTip(bool isLong, int grade, bool prem, string sigType, bool hasRoom) =>
    (isLong ? "LONG" : "SHORT") + " · Grade " + str.tostring(grade) + "/" + str.tostring(maxGrade) + (grade >= 3 ? " (strong)" : grade >= 2 ? " (deep / aligned)" : " (shallow · counter)") + (prem ? " · ★ Divergence" : "") + "\n" + sigType + " · Room " + (hasRoom ? "yes" : "no") + "\nWave " + f_phaseName(wavePh) + " · Tide " + f_phaseName(tidePh) + " · Ripple " + f_phaseName(ripplePh) + "\nGrade = Exhausted Zone(1) / Depth(2)" + (useMTF ? " + Wave + Tide" + (useWaveStoch ? " + Wave-Stoch" : "") : " · single-TF (MTF off)") + (useDivGrade ? " + Div" : "")
if longSignal
    label.new(bar_index, low, "▲" + str.tostring(longGrade) + (bullPrem ? "★" : ""), style=label.style_label_up, color=color.new(#00e676, withLong ? 0 : 55), textcolor=color.white, size=size.tiny, yloc=yloc.belowbar, force_overlay=true, tooltip=f_sigTip(true, longGrade, bullPrem, longSigType, longHasRoom))
if shortSignal
    label.new(bar_index, high, "▼" + str.tostring(shortGrade) + (bearPrem ? "★" : ""), style=label.style_label_down, color=color.new(#d50000, withShort ? 0 : 55), textcolor=color.white, size=size.tiny, yloc=yloc.abovebar, force_overlay=true, tooltip=f_sigTip(false, shortGrade, bearPrem, shortSigType, shortHasRoom))

// ============================================================================
// Horizon Phase Map table + verdict (same on every chart for Tide/Wave)
// ============================================================================

color tc = color.new(color.gray, 20)
color hd = color.new(color.gray, 90)

var table t = table.new(position.top_right, 3, 9,
     bgcolor=color.new(color.white, 5),
     border_color=color.new(color.gray, 60),
     border_width=1,
     frame_color=color.new(color.gray, 40),
     frame_width=1)

f_hrow(int row, string name, string tf, int ph, bool up) =>
    table.cell(t, 0, row, name + " " + tf, text_color=tc, text_size=size.small)
    table.cell(t, 1, row, f_phaseName(ph), text_color=f_phaseCol(ph), text_size=size.small)
    table.cell(t, 2, row, up ? "↑" : "↓", text_color=up ? color.new(#00c853, 0) : color.new(#d50000, 0), text_size=size.small)

if showTable and barstate.islast
    table.cell(t, 0, 0, "Horizon", text_color=tc, bgcolor=hd, text_size=size.small)
    table.cell(t, 1, 0, "Phase",   text_color=tc, bgcolor=hd, text_size=size.small)
    table.cell(t, 2, 0, "Dir",     text_color=tc, bgcolor=hd, text_size=size.small)
    f_hrow(1, "Tide",   f_tfName(tideTfEff), tidePh, tideUp)
    f_hrow(2, "Wave",   f_tfName(waveTfEff), wavePh, waveUp)
    f_hrow(3, "Ripple", f_tfName(""),     ripplePh, rippleUp)
    // Verdict — the live grade a Ripple cross in each direction would earn right now.
    string vSetup = "Long G" + str.tostring(longGrade) + "/" + str.tostring(maxGrade) + " · Short G" + str.tostring(shortGrade) + "/" + str.tostring(maxGrade)
    color vCol = longGrade > shortGrade ? color.new(#00c853, 0) : shortGrade > longGrade ? color.new(#d50000, 0) : tc
    string vState = waveUp ? (ww1 >= obLevel1 ? "Wave up · stretched (long grade fades)" : "Wave up · room") : (ww1 <= osLevel1 ? "Wave down · stretched (short grade fades)" : "Wave down · room")
    table.cell(t, 0, 4, "Grade", text_color=tc, bgcolor=hd, text_size=size.small)
    table.cell(t, 1, 4, vSetup, text_color=vCol, text_size=size.small)
    table.merge_cells(t, 1, 4, 2, 4)
    table.cell(t, 0, 5, "Wave", text_color=tc, bgcolor=hd, text_size=size.small)
    table.cell(t, 1, 5, vState, text_color=tc, text_size=size.small)
    table.merge_cells(t, 1, 5, 2, 5)
    string posTxt = posDir == 1 ? "LONG" : posDir == -1 ? "SHORT" : "flat"
    color posCol = posDir == 1 ? color.new(#00c853, 0) : posDir == -1 ? color.new(#d50000, 0) : tc
    table.cell(t, 0, 6, "Last Bias", text_color=tc, bgcolor=hd, text_size=size.small)
    table.cell(t, 1, 6, posTxt, text_color=posCol, text_size=size.small)
    table.merge_cells(t, 1, 6, 2, 6)
    if minGrade > maxGrade
        table.cell(t, 0, 7, "Min", text_color=tc, bgcolor=hd, text_size=size.small)
        table.cell(t, 1, 7, "MinGrade capped to " + str.tostring(maxGrade), text_color=color.new(#d50000, 0), text_size=size.small)
        table.merge_cells(t, 1, 7, 2, 7)
    if not useMTF
        table.cell(t, 0, 8, "Mode", text_color=tc, bgcolor=hd, text_size=size.small)
        table.cell(t, 1, 8, (mtfMode == "Auto" ? "MTF auto-off (>4h)" : "MTF off") + " · depth only", text_color=color.new(#ff6f00, 0), text_size=size.small)
        table.merge_cells(t, 1, 8, 2, 8)
    else if chartTooHigh
        table.cell(t, 0, 8, "TF", text_color=tc, bgcolor=hd, text_size=size.small)
        table.cell(t, 1, 8, "Chart TF ≥ Wave — turn MTF off", text_color=color.new(#d50000, 0), text_size=size.small)
        table.merge_cells(t, 1, 8, 2, 8)

// ============================================================================
// Logging — each trade signal with the full horizon read (measurable)
// ============================================================================

if enableLog and (longSignal or shortSignal)
    string dir = longSignal ? "LONG" : "SHORT"
    int gr = longSignal ? longGrade : shortGrade
    bool prem = longSignal ? bullPrem : bearPrem
    string sigType = longSignal ? longSigType : shortSigType
    bool hasRoom = longSignal ? longHasRoom : shortHasRoom
    log.info("TWR " + dir + " G" + str.tostring(gr) + (prem ? " ★" : "") + " " + sigType + " room=" + (hasRoom ? "Y" : "N") + " | Tide=" + f_phaseName(tidePh) + " Wave=" + f_phaseName(wavePh) + " Ripple=" + f_phaseName(ripplePh) + " | rippleWT=" + str.tostring(rw1, "#.0") + " waveStochK=" + str.tostring(wk, "#"))

// Diagnostic — every trigger CANDIDATE (a ripple cross out of the zone) and which gate it hits.
// Run on 15m and 1h and compare: are there fewer short candidates, or are they being blocked?
if debugCand and rippleBear and zoneBear
    log.info("SHORT-CAND | G" + str.tostring(shortGrade) + " depth=" + str.tostring(shortDepthScore) + " exhausted=" + (shortExhausted ? "Y" : "N") + " div=" + (shortDivBoost ? "Y" : "N") + " pullback=" + str.tostring(recentHigh - rSig, "#.0") + " waveDown=" + (not waveUp ? "Y" : "N") + " stochBear=" + (waveStochBear ? "Y" : "N") + " cool=" + (shortCool ? "Y" : "N") + " → " + (shortSignal ? "SIGNAL" : "blocked") + " | Wave=" + f_phaseName(wavePh) + " rippleWT=" + str.tostring(rw1, "#") + " waveStochK=" + str.tostring(wk, "#"))
if debugCand and rippleBull and zoneBull
    log.info("LONG-CAND  | G" + str.tostring(longGrade) + " depth=" + str.tostring(longDepthScore) + " exhausted=" + (longExhausted ? "Y" : "N") + " div=" + (longDivBoost ? "Y" : "N") + " pullback=" + str.tostring(rSig - recentLow, "#.0") + " waveUp=" + (waveUp ? "Y" : "N") + " stochBull=" + (waveStochBull ? "Y" : "N") + " cool=" + (longCool  ? "Y" : "N") + " → " + (longSignal  ? "SIGNAL" : "blocked") + " | Wave=" + f_phaseName(wavePh) + " rippleWT=" + str.tostring(rw1, "#") + " waveStochK=" + str.tostring(wk, "#"))

// ============================================================================
// Alerts — two tiers: ⚠️ WATCH (early warning, setup forming) → ✅ SIGNAL (trigger fired)
// ============================================================================

// One dynamic alert covers both tiers with the full data (alertcondition messages can't carry series
// values like grade/type/★ — alert() can). Forced to bar close, so it never repaints on intrabar HTF
// updates. Set up ONE alert via "any alert() function call", frequency "Once Per Bar Close".
if longWatch or shortWatch
    string wDir = longWatch ? "LONG" : "SHORT"
    alert("⚠️ TWR WATCH " + wDir + " · " + syminfo.ticker + " " + timeframe.period + " — " + (longWatch ? "oversold" : "overbought") + " extreme, reversal setup forming @ " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
if longSignal or shortSignal
    string aDir  = longSignal ? "LONG" : "SHORT"
    int    aGr   = longSignal ? longGrade   : shortGrade
    bool   aPrem = longSignal ? bullPrem    : bearPrem
    string aType = longSignal ? longSigType : shortSigType
    alert("✅ TWR " + aDir + " G" + str.tostring(aGr) + "/" + str.tostring(maxGrade) + (aPrem ? " ★" : "") + " " + aType + " · " + syminfo.ticker + " " + timeframe.period + " @ " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)

// Named alerts — pick a single tier/direction if you don't want the combined alert() above.
alertcondition(longWatch,  title="⚠️ TWR Watch Long (warning)",  message="⚠️ TWR WATCH LONG {{ticker}} {{interval}} — oversold extreme, reversal setup @ {{close}}")
alertcondition(shortWatch, title="⚠️ TWR Watch Short (warning)", message="⚠️ TWR WATCH SHORT {{ticker}} {{interval}} — overbought extreme, reversal setup @ {{close}}")
alertcondition(longSignal,  title="✅ TWR Long (signal)",  message="✅ TWR LONG {{ticker}} {{interval}} @ {{close}}")
alertcondition(shortSignal, title="✅ TWR Short (signal)", message="✅ TWR SHORT {{ticker}} {{interval}} @ {{close}}")
alertcondition(withLong,  title="✅ TWR Long (high grade only)",  message="✅ TWR high-grade LONG {{ticker}} {{interval}} @ {{close}}")
alertcondition(withShort, title="✅ TWR Short (high grade only)", message="✅ TWR high-grade SHORT {{ticker}} {{interval}} @ {{close}}")
