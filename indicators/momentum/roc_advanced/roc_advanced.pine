//@version=6
// ============================================================================
// ROC Advanced [WavesUnchained]
// Version: 1.0
// Author: WavesUnchained
// Build: 2026-06-30 16:00:00
// ============================================================================
// Rate of Change with trend context, stall/absorption, conviction markers, and
// directional long/short coloring on a zero-centered momentum core.
//
// Features:
//   ✓ Classic percentage ROC core with pluggable smoothing and signal line
//   ✓ Zero-centered panel with configurable positive/negative stretch zones
//   ✓ Stall/absorption context: marks crosses contradicted by flat price as weak
//   ✓ Trend context line (slow ROC): support the fast line rests on
//   ✓ Trend↔ROC divergence wedge: fast and trend move opposite
//   ✓ Long/Short coloring for trend context, histogram, and divergence wedge
//   ✓ Gradient line color, shadow fills, stretch zone fills, and alerts
//
// ============================================================================

indicator("ROC Advanced [WavesUnchained]", "ROC·ADV", overlay=false, max_labels_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

g_core = "1 · Core"
src    = input.source(close, "Source",         group=g_core)
rocLen = input.int(12,     "ROC Length",       minval=1, group=g_core)
avgLen = input.int(3,      "Average Length",   minval=1, group=g_core)
sigLen = input.int(3,      "Signal Length",    minval=1, group=g_core)
smoothType = input.string("EMA", "Smoothing Type",
     options=["EMA", "SMA", "RMA", "WMA", "SuperSmoother", "T3", "KAMA", "JMA Approx"],
     group=g_core)
jmaPhase = input.int(50,    "  JMA Phase", minval=-100, maxval=100,             group=g_core)
jmaPower = input.float(2.0, "  JMA Power", minval=1.0,  maxval=4.0, step=0.25, group=g_core)

g_levels = "2 · Mid / Levels"
midLine    = input.float(0.0,  "Midline",             group=g_levels)
obLevel    = input.float(5.0,  "Positive Stretch",    minval=0, step=0.5, group=g_levels)
osLevel    = input.float(-5.0, "Negative Stretch",    maxval=0, step=0.5, group=g_levels)
upperBound = input.float(20.0, "Upper Zone Boundary", minval=0, step=1, group=g_levels)
lowerBound = input.float(-20.0, "Lower Zone Boundary", maxval=0, step=1, group=g_levels)

g_stall = "3 · Stall / Absorption"
useStall     = input.bool(true, "Detect Stall (ROC moves, price holds)", group=g_stall)
stallLen     = input.int(5,     "Stall Lookback (bars)", minval=1, group=g_stall)
stallFlatATR = input.float(0.5, "Max Price Move (ATR)",  minval=0.0, step=0.1, group=g_stall)
stallRocMin  = input.float(3.0, "Min ROC Move",          minval=0,   step=0.5, group=g_stall)

g_ctx = "4 · Trend Context"
useCtx = input.bool(true, "Show Trend Context Line", group=g_ctx)
ctxLen = input.int(50, "Trend ROC Length", minval=2, group=g_ctx)

g_conv = "5 · Conviction"
useExtremeOnly  = input.bool(true, "Extreme Signals: require stretch zone", group=g_conv)
lookbackExtreme = input.int(5,     "Stretch Lookback (bars)",               minval=1, group=g_conv)
showMidCross    = input.bool(true, "Show Zero-Cross Markers",               group=g_conv)

g_div = "6 · Divergence"
showDiv = input.bool(true, "Highlight Trend ↔ ROC Divergence", group=g_div)
divLen  = input.int(4,    "Divergence Slope Lookback", minval=1, group=g_div)
divMin  = input.float(2,  "Min Fast Slope",            minval=0, step=0.5, group=g_div)

g_plots = "7 · Plots"
showShadow   = input.bool(true, "Shadow Fill (ROC vs Zero)", group=g_plots)
showFill     = input.bool(true, "Fill ROC / Signal",         group=g_plots)
showZoneFill = input.bool(true, "Fill Stretch Zones",        group=g_plots)
showHist     = input.bool(true, "Show Histogram",            group=g_plots)
showSignals  = input.bool(true, "Show Signal Markers",       group=g_plots)

g_col = "7 · Plots · Colors"
colBull   = input.color(#00bcd4,                "Bull (level)",           group=g_col)
colBear   = input.color(#f06292,                "Bear (level)",           group=g_col)
colLong   = input.color(#00c853,                "Long (trend/momentum)",  group=g_col)
colShort  = input.color(#d50000,                "Short (trend/momentum)", group=g_col)
colZoneOB = input.color(color.new(#f06292, 90), "Positive Stretch Fill",  group=g_col)
colZoneOS = input.color(color.new(#00bcd4, 90), "Negative Stretch Fill",  group=g_col)

// ─────────────────────────────────────────────────────────────────────────────
// SMOOTHING FUNCTIONS
// ─────────────────────────────────────────────────────────────────────────────

f_supersmoother(series float x, simple int len) =>
    float a1 = math.exp(-1.414 * math.pi / len)
    float b1 = 2.0 * a1 * math.cos(1.414 * math.pi / len)
    float c2 = b1
    float c3 = -(a1 * a1)
    float c1 = 1.0 - c2 - c3
    var float ss = na
    ss := c1 * (x + nz(x[1])) / 2.0 + c2 * nz(ss[1]) + c3 * nz(ss[2])
    ss

f_t3(series float x, simple int len) =>
    float b = 0.7
    float e1 = ta.ema(x, len)
    float e2 = ta.ema(e1, len)
    float e3 = ta.ema(e2, len)
    float e4 = ta.ema(e3, len)
    float e5 = ta.ema(e4, len)
    float e6 = ta.ema(e5, len)
    -(b * b * b) * e6 + (3.0 * b * b + 3.0 * b * b * b) * e5 + (-6.0 * b * b - 3.0 * b - 3.0 * b * b * b) * e4 + (1.0 + 3.0 * b + b * b * b + 3.0 * b * b) * e3

f_kama(series float x, simple int len) =>
    float change = math.abs(x - x[len])
    float vol = math.sum(math.abs(x - x[1]), len)
    float er = vol != 0.0 ? change / vol : 0.0
    float sc = math.pow(er * (2.0 / 3.0 - 2.0 / 31.0) + 2.0 / 31.0, 2)
    var float kama = na
    kama := nz(kama[1], x) + sc * (x - nz(kama[1], x))
    kama

f_jma(series float x, simple int len, simple int phase, simple float power) =>
    var float jma = na
    var float e0 = na
    var float e1 = na
    var float e2 = na
    float phaseRatio = phase < -100 ? 0.5 : phase > 100 ? 2.5 : phase / 100.0 + 1.5
    float beta = 0.45 * (len - 1) / (0.45 * (len - 1) + 2.0)
    float alpha = math.pow(beta, power)
    e0 := (1.0 - alpha) * x + alpha * nz(e0[1], x)
    e1 := (x - e0) * (1.0 - beta) + beta * nz(e1[1], 0.0)
    e2 := (e0 + phaseRatio * e1 - nz(jma[1], x)) * math.pow(1.0 - alpha, 2.0) + math.pow(alpha, 2.0) * nz(e2[1], 0.0)
    jma := nz(jma[1], x) + e2
    jma

f_smooth(series float x, simple int len, simple string mode) =>
    switch mode
        "SMA"           => ta.sma(x, len)
        "RMA"           => ta.rma(x, len)
        "WMA"           => ta.wma(x, len)
        "SuperSmoother" => f_supersmoother(x, len)
        "T3"            => f_t3(x, len)
        "KAMA"          => f_kama(x, len)
        "JMA Approx"    => f_jma(x, len, jmaPhase, jmaPower)
        =>                 ta.ema(x, len)

f_roc(series float x, simple int len) =>
    x[len] != 0.0 ? 100.0 * (x - x[len]) / x[len] : 0.0

// ─────────────────────────────────────────────────────────────────────────────
// ROC CORE
// ─────────────────────────────────────────────────────────────────────────────

rocRaw  = f_roc(src, rocLen)
rocLine = f_smooth(rocRaw, avgLen, smoothType)
signal  = f_smooth(rocLine, sigLen, smoothType)
hist    = rocLine - signal

ctxRaw  = f_roc(src, ctxLen)
ctxLine = f_smooth(ctxRaw, avgLen, smoothType)

// ─────────────────────────────────────────────────────────────────────────────
// MID / LEVELS
// ─────────────────────────────────────────────────────────────────────────────

wasOversold   = ta.lowest(rocLine,  lookbackExtreme) <= osLevel
wasOverbought = ta.highest(rocLine, lookbackExtreme) >= obLevel

// ─────────────────────────────────────────────────────────────────────────────
// STALL / ABSORPTION
// ─────────────────────────────────────────────────────────────────────────────

bullCross    = ta.crossover(rocLine, signal)
bearCross    = ta.crossunder(rocLine, signal)
bullExtreme  = bullCross and (not useExtremeOnly or wasOversold)
bearExtreme  = bearCross and (not useExtremeOnly or wasOverbought)
bullMidCross = ta.crossover(rocLine, midLine)
bearMidCross = ta.crossunder(rocLine, midLine)

float atrRef = ta.atr(14)
float rocChg = rocLine - rocLine[stallLen]
float priceChg = atrRef != 0.0 ? (close - close[stallLen]) / atrRef : 0.0
bool flatPx = math.abs(priceChg) < stallFlatATR
bool stallBull = useStall and rocChg < -stallRocMin and flatPx
bool stallBear = useStall and rocChg >  stallRocMin and flatPx
bool stallNow = stallBull or stallBear

// ─────────────────────────────────────────────────────────────────────────────
// TREND CONTEXT
// ─────────────────────────────────────────────────────────────────────────────

bool ctxBull = ctxLine > midLine
bool ctxBear = ctxLine < midLine
bool bearCounter = useCtx and bearExtreme and ctxBull
bool bullCounter = useCtx and bullExtreme and ctxBear

// ─────────────────────────────────────────────────────────────────────────────
// CONVICTION
// ─────────────────────────────────────────────────────────────────────────────

bool bearStrong = bearExtreme and not (stallBull or bearCounter)
bool bearWeak = bearExtreme and (stallBull or bearCounter)
bool bullStrong = bullExtreme and not (stallBear or bullCounter)
bool bullWeak = bullExtreme and (stallBear or bullCounter)

// ─────────────────────────────────────────────────────────────────────────────
// DIVERGENCE
// ─────────────────────────────────────────────────────────────────────────────

float fastDir = rocLine - rocLine[divLen]
float slowDir = ctxLine - ctxLine[divLen]
bool divBull = useCtx and showDiv and fastDir < -divMin and slowDir > 0.0
bool divBear = useCtx and showDiv and fastDir >  divMin and slowDir < 0.0

// ─────────────────────────────────────────────────────────────────────────────
// COLORS
// ─────────────────────────────────────────────────────────────────────────────

color lineCol = color.from_gradient(rocLine, osLevel, obLevel, colBull, colBear)
color lineCol2 = color.from_gradient(signal, osLevel, obLevel, color.new(colBull, 40), color.new(colBear, 40))
color ctxCol = ctxLine >= midLine ? color.new(colLong, 55) : color.new(colShort, 55)

histRising = hist >= hist[1]
histColor = hist >= 0.0
     ? (histRising ? colLong : color.new(colLong, 55))
     : (not histRising ? colShort : color.new(colShort, 55))

// ─────────────────────────────────────────────────────────────────────────────
// HLINES + ZONE FILLS
// ─────────────────────────────────────────────────────────────────────────────

hTop = hline(upperBound, "Upper Boundary", color=color.new(color.gray, 85))
hMid = hline(midLine, "Zero", color=color.new(color.gray, 60), linestyle=hline.style_dotted, linewidth=1)
hBot = hline(lowerBound, "Lower Boundary", color=color.new(color.gray, 85))
hOB  = hline(obLevel, "Positive Stretch", color=color.new(color.red, 65), linestyle=hline.style_dashed, linewidth=1)
hOS  = hline(osLevel, "Negative Stretch", color=color.new(#00bcd4, 65), linestyle=hline.style_dashed, linewidth=1)

fill(hOB, hTop, color=showZoneFill ? colZoneOB : na, title="Positive Stretch Zone")
fill(hBot, hOS, color=showZoneFill ? colZoneOS : na, title="Negative Stretch Zone")

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────

color histColorFinal = stallNow ? color.new(histColor, 78) : histColor
plot(showHist ? hist : na, "Histogram", style=plot.style_columns, color=histColorFinal)

pMid = plot(midLine, display=display.none)
pCtx = plot(useCtx ? ctxLine : na, "Trend Context", color=ctxCol, linewidth=2)
pSig = plot(signal, "ROC Signal", color=lineCol2, linewidth=1)
pROC = plot(rocLine, "ROC", color=lineCol, linewidth=2)

fill(pROC, pCtx, color=divBull ? color.new(colLong, 80) : divBear ? color.new(colShort, 80) : na,
     title="Trend Divergence")

fill(pROC, pMid, obLevel, midLine, color.new(colBear, 78), color.new(colBear, 100),
     title="Bear Shadow", display=showShadow ? display.all : display.none)
fill(pROC, pMid, midLine, osLevel, color.new(colBull, 100), color.new(colBull, 78),
     title="Bull Shadow", display=showShadow ? display.all : display.none)

fill(pROC, pSig, color=showFill ? (rocLine >= signal ? color.new(colBull, 88) : color.new(colBear, 88)) : na,
     title="ROC Fill")

// ─────────────────────────────────────────────────────────────────────────────
// SIGNAL MARKERS
// ─────────────────────────────────────────────────────────────────────────────

plotshape(showSignals and bullStrong, "Bull Stretch", style=shape.triangleup, location=location.bottom, color=colBull, size=size.small)
plotshape(showSignals and bullWeak, "Bull Stretch (absorbed)", style=shape.triangleup, location=location.bottom, color=color.new(colBull, 65), size=size.tiny)
plotshape(showSignals and bearStrong, "Bear Stretch", style=shape.triangledown, location=location.top, color=colBear, size=size.small)
plotshape(showSignals and bearWeak, "Bear Stretch (absorbed)", style=shape.triangledown, location=location.top, color=color.new(colBear, 65), size=size.tiny)

plotshape(showSignals and showMidCross and bullMidCross ? rocLine : na, "Bull Zero Cross", style=shape.circle, location=location.absolute, color=color.new(colBull, 20), size=size.tiny)
plotshape(showSignals and showMidCross and bearMidCross ? rocLine : na, "Bear Zero Cross", style=shape.circle, location=location.absolute, color=color.new(colBear, 20), size=size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────

bool alertsOnBarClose = input.bool(true, "Alerts only on bar close (confirmed)", group="8 · Alerts")
bool alertOk = not alertsOnBarClose or barstate.isconfirmed

alertcondition(alertOk and bullExtreme,  "ROC Bull Signal",       "ROCA · BULL CROSS NEGATIVE STRETCH · {{ticker}} {{interval}}")
alertcondition(alertOk and bearExtreme,  "ROC Bear Signal",       "ROCA · BEAR CROSS POSITIVE STRETCH · {{ticker}} {{interval}}")
alertcondition(alertOk and bullMidCross, "ROC Cross Above Zero",  "ROCA · CROSS ABOVE ZERO · {{ticker}} {{interval}}")
alertcondition(alertOk and bearMidCross, "ROC Cross Below Zero",  "ROCA · CROSS BELOW ZERO · {{ticker}} {{interval}}")
