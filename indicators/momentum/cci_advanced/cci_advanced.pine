//@version=6
// ============================================================================
// CCI Advanced [WavesUnchained]
// Version: 1.0
// Author: WavesUnchained
// Build: 2026-06-18 00:00:00
// ============================================================================
// CCI with pluggable smoothing, adaptive scaling, and rich visualization.
// Designed as a standalone oscillator and as context layer for hybrid setups.
//
// Features:
//   ✓ Pluggable smoothing (EMA, SMA, RMA, WMA, SuperSmoother, T3, KAMA, JMA Approx)
//   ✓ Three scale modes: Classic, Clamp ±200, Adaptive ±100
//   ✓ Averaged CCI + signal line with fill
//   ✓ 4-state histogram
//   ✓ Gradient line color (bull ↔ bear based on CCI level)
//   ✓ Gradient shadow fills between CCI and zero
//   ✓ OB/OS zone fills
//   ✓ Extreme zone and zero-line cross signal markers
//   ✓ Alert conditions
//
// ============================================================================

indicator("CCI Advanced [WavesUnchained]", "CCI·ADV", overlay=false, max_labels_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

g_cci = "1 · CCI"
src    = input.source(hlc3, "Source",        group=g_cci)
cciLen = input.int(20,      "CCI Length",    minval=1, group=g_cci)
avgLen = input.int(3,       "Average Length", minval=1, group=g_cci,
     tooltip="Smooth the raw CCI before computing the signal. Lengthens the main line without changing the lookback.")
sigLen = input.int(3,       "Signal Length", minval=1, group=g_cci)

g_smooth = "2 · Smoothing"
smoothType = input.string("EMA", "Type",
     options=["EMA", "SMA", "RMA", "WMA", "SuperSmoother", "T3", "KAMA", "JMA Approx"],
     group=g_smooth)
jmaPhase = input.int(50,    "  JMA Phase", minval=-100, maxval=100,             group=g_smooth)
jmaPower = input.float(2.0, "  JMA Power", minval=1.0, maxval=4.0, step=0.25,  group=g_smooth)

g_scale = "3 · Scale"
scaleMode     = input.string("Classic", "Mode",
     options=["Classic", "Clamp ±200", "Adaptive ±100"], group=g_scale,
     tooltip="Classic: raw CCI values (unbounded). Clamp ±200: clips to ±200. Adaptive ±100: rescales to ±100 based on recent range.")
scaleLookback = input.int(200, "Adaptive Lookback", minval=20, group=g_scale)

g_levels = "4 · Levels"
ob1 = input.float( 100, "Overbought 1",  group=g_levels)
ob2 = input.float( 200, "Overbought 2",  group=g_levels)
os1 = input.float(-100, "Oversold 1",    group=g_levels)
os2 = input.float(-200, "Oversold 2",    group=g_levels)

g_filter = "5 · Signal Filters"
useExtremeOnly  = input.bool(true, "Extreme Signals: require OB/OS zone",  group=g_filter)
lookbackExtreme = input.int(5,     "OB/OS Lookback (bars)",                 minval=1, group=g_filter)
showZeroCross   = input.bool(true, "Show Zero-Line Cross Markers",          group=g_filter)

g_col = "6 · Colors"
colBull = input.color(#00bcd4,                "Bull",         group=g_col)
colBear = input.color(#f06292,                "Bear",         group=g_col)
colZoneOB = input.color(color.new(#f06292, 90), "OB Zone Fill", group=g_col)
colZoneOS = input.color(color.new(#00bcd4, 90), "OS Zone Fill", group=g_col)

g_disp = "7 · Display"
showShadow   = input.bool(true,  "Shadow Fill (CCI vs Zero)", group=g_disp)
showFill     = input.bool(true,  "Fill CCI / Signal",         group=g_disp)
showZoneFill = input.bool(true,  "Fill OB / OS Zones",        group=g_disp)
showHist     = input.bool(true,  "Show Histogram",            group=g_disp)
showSignals  = input.bool(true,  "Show Signal Markers",       group=g_disp)

// ─────────────────────────────────────────────────────────────────────────────
// SMOOTHING FUNCTIONS
// ─────────────────────────────────────────────────────────────────────────────

f_supersmoother(series float x, simple int len) =>
    float pi = math.pi
    float a1 = math.exp(-1.414 * pi / len)
    float b1 = 2.0 * a1 * math.cos(1.414 * pi / len)
    float c2 = b1
    float c3 = -(a1 * a1)
    float c1 = 1.0 - c2 - c3
    var float ss = na
    ss := c1 * (x + nz(x[1])) / 2.0 + c2 * nz(ss[1]) + c3 * nz(ss[2])
    ss

f_t3(series float x, simple int len) =>
    float b  = 0.7
    float e1 = ta.ema(x, len)
    float e2 = ta.ema(e1, len)
    float e3 = ta.ema(e2, len)
    float e4 = ta.ema(e3, len)
    float e5 = ta.ema(e4, len)
    float e6 = ta.ema(e5, len)
    float c1 = -(b * b * b)
    float c2 =  3.0 * b * b + 3.0 * b * b * b
    float c3 = -6.0 * b * b - 3.0 * b - 3.0 * b * b * b
    float c4 =  1.0 + 3.0 * b + b * b * b + 3.0 * b * b
    c1 * e6 + c2 * e5 + c3 * e4 + c4 * e3

f_kama(series float x, simple int len) =>
    float change   = math.abs(x - x[len])
    float vol      = math.sum(math.abs(x - x[1]), len)
    float er       = vol != 0.0 ? change / vol : 0.0
    float sc       = math.pow(er * (2.0 / 3.0 - 2.0 / 31.0) + 2.0 / 31.0, 2)
    var float kama = na
    kama := nz(kama[1], x) + sc * (x - nz(kama[1], x))
    kama

f_jma(series float x, simple int len, simple int phase, simple float power) =>
    var float jma = na
    var float e0  = na
    var float e1  = na
    var float e2  = na
    float phaseRatio = phase < -100 ? 0.5 : phase > 100 ? 2.5 : phase / 100.0 + 1.5
    float beta       = 0.45 * (len - 1) / (0.45 * (len - 1) + 2.0)
    float alpha      = math.pow(beta, power)
    e0  := (1.0 - alpha) * x + alpha * nz(e0[1], x)
    e1  := (x - e0) * (1.0 - beta) + beta * nz(e1[1], 0.0)
    e2  := (e0 + phaseRatio * e1 - nz(jma[1], x)) * math.pow(1.0 - alpha, 2.0) + math.pow(alpha, 2.0) * nz(e2[1], 0.0)
    jma := nz(jma[1], x) + e2
    jma

f_smooth(series float x, simple int len, simple string mode) =>
    switch mode
        "SMA"           => ta.sma(x, len)
        "RMA"           => ta.rma(x, len)
        "WMA"           => ta.wma(x, len)
        "SuperSmoother" => f_supersmoother(x, len)
        "T3"            => f_t3(x, len)
        "KAMA"          => f_kama(x, len)
        "JMA Approx"    => f_jma(x, len, jmaPhase, jmaPower)
        =>                 ta.ema(x, len)

// ─────────────────────────────────────────────────────────────────────────────
// CCI CORE
// ─────────────────────────────────────────────────────────────────────────────

cciRaw  = ta.cci(src, cciLen)
cciLine = f_smooth(cciRaw, avgLen, smoothType)
signal  = f_smooth(cciLine, sigLen, smoothType)
hist    = cciLine - signal

// ─────────────────────────────────────────────────────────────────────────────
// SCALE
// ─────────────────────────────────────────────────────────────────────────────

float scaleAbs = ta.highest(math.max(math.abs(cciLine), math.abs(signal)), scaleLookback)

f_scale(series float x, float sharedMax) =>
    if scaleMode == "Clamp ±200"
        math.max(math.min(x, 200.0), -200.0)
    else if scaleMode == "Adaptive ±100"
        sharedMax != 0.0 ? 100.0 * x / sharedMax : 0.0
    else
        x

cciDisp = f_scale(cciLine, scaleAbs)
sigDisp = f_scale(signal,  scaleAbs)

// ─────────────────────────────────────────────────────────────────────────────
// SIGNALS (on raw / unscaled values)
// ─────────────────────────────────────────────────────────────────────────────

wasOversold   = ta.lowest(cciLine,  lookbackExtreme) <= os1
wasOverbought = ta.highest(cciLine, lookbackExtreme) >= ob1

bullCross    = ta.crossover(cciLine,  signal)
bearCross    = ta.crossunder(cciLine, signal)
bullExtreme  = bullCross and (not useExtremeOnly or wasOversold)
bearExtreme  = bearCross and (not useExtremeOnly or wasOverbought)
bullZeroCross = ta.crossover(cciLine,  0.0)
bearZeroCross = ta.crossunder(cciLine, 0.0)

// ─────────────────────────────────────────────────────────────────────────────
// COLORS
// ─────────────────────────────────────────────────────────────────────────────

color lineCol  = color.from_gradient(cciDisp, os1, ob1, colBull, colBear)
color lineCol2 = color.from_gradient(sigDisp, os1, ob1, color.new(colBull, 40), color.new(colBear, 40))

histRising = hist >= hist[1]
histColor  = hist >= 0.0
     ? (histRising     ? colBull                     : color.new(colBull, 55))
     : (not histRising ? colBear                     : color.new(colBear, 55))

// ─────────────────────────────────────────────────────────────────────────────
// HLINES + ZONE FILLS
// ─────────────────────────────────────────────────────────────────────────────

hline(0, "Zero", color=color.new(color.gray, 60), linestyle=hline.style_dotted, linewidth=1)
hOB2 = hline(ob2, "OB 2", color=color.new(color.red, 45), linestyle=hline.style_solid,  linewidth=1)
hOB1 = hline(ob1, "OB 1", color=color.new(color.red, 65), linestyle=hline.style_dashed, linewidth=1)
hOS1 = hline(os1, "OS 1", color=color.new(#00bcd4, 65),   linestyle=hline.style_dashed, linewidth=1)
hOS2 = hline(os2, "OS 2", color=color.new(#00bcd4, 45),   linestyle=hline.style_solid,  linewidth=1)

fill(hOB1, hOB2, color=showZoneFill ? colZoneOB : na, title="OB Zone")
fill(hOS2, hOS1, color=showZoneFill ? colZoneOS : na, title="OS Zone")

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────

plot(showHist ? hist : na, "Histogram", style=plot.style_columns, color=histColor)

pZero = plot(0.0, display=display.none)
pSig  = plot(sigDisp,  "CCI Signal", color=lineCol2, linewidth=1)
pCCI  = plot(cciDisp,  "CCI",        color=lineCol,  linewidth=2)

fill(pCCI, pZero, ob1,  0.0, color.new(colBear, 78), color.new(colBear, 100),
     title="Bear Shadow", display=showShadow ? display.all : display.none)
fill(pCCI, pZero, 0.0, os1,  color.new(colBull, 100), color.new(colBull, 78),
     title="Bull Shadow", display=showShadow ? display.all : display.none)

fill(pCCI, pSig,
     color=showFill ? (cciDisp >= sigDisp ? color.new(colBull, 88) : color.new(colBear, 88)) : na,
     title="CCI Fill")

// ─────────────────────────────────────────────────────────────────────────────
// SIGNAL MARKERS
// ─────────────────────────────────────────────────────────────────────────────

plotshape(showSignals and bullExtreme, "Bull Extreme",
     style=shape.triangleup, location=location.bottom,
     color=colBull, size=size.small, text="CCI↑", textcolor=colBull)

plotshape(showSignals and bearExtreme, "Bear Extreme",
     style=shape.triangledown, location=location.top,
     color=colBear, size=size.small, text="CCI↓", textcolor=colBear)

plotshape(showSignals and showZeroCross and bullZeroCross ? cciDisp : na, "Bull Zero",
     style=shape.circle, location=location.absolute,
     color=color.new(colBull, 20), size=size.tiny)

plotshape(showSignals and showZeroCross and bearZeroCross ? cciDisp : na, "Bear Zero",
     style=shape.circle, location=location.absolute,
     color=color.new(colBear, 20), size=size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────

alertcondition(bullExtreme,   "CCI Bull Signal",      "CCI bullish cross from oversold zone")
alertcondition(bearExtreme,   "CCI Bear Signal",      "CCI bearish cross from overbought zone")
alertcondition(bullZeroCross, "CCI Cross Above Zero", "CCI crossed above zero")
alertcondition(bearZeroCross, "CCI Cross Below Zero", "CCI crossed below zero")
