//@version=6
// ============================================================================
// Market Pressure Scale [WavesUnchained]
// Version: 1.2.2
// Author: WavesUnchained
// Build: 2026-06-27 00:00:00
// ============================================================================
// Two-component oscillator separating setup pressure (compression + S/R proximity)
// from impulse pressure (range expansion + volume + body + trend) with phase
// classification and directional bias.
//
// Features:
//   ✓ Setup Pressure — ATR/BB compression, S/R proximity, volume drying up
//   ✓ Impulse Pressure — range expansion, volume, body size, ADX
//   ✓ Phase classification: Coiling / Breakout Watch / Impulse Running / Sideways / Neutral
//   ✓ Directional bias via EMA + DMI
//   ✓ Range position (close relative to N-bar range)
//   ✓ Dashboard table with phase, bias, ADX, range position
//   ✓ Configurable output smoothing — EMA / RMA / SMA / WMA / HMA / JMA
//   ✓ StochRSI K/D overlay (toggleable)
//   ✓ Impulse Pressure divergence — bullish / bearish, plotted like WaveTrend
//   ✓ WaveTrend oscillator overlay (toggleable, default off) — osc + signal + divergences + crosses
//   ✓ Alerts for all four phase transitions
//   ✓ Momentum Regime Map — combined WT + StochRSI + MFI background state (Euphoric / Distribution / Accumulation / Energy Build-up)
//   ✓ Market Character Score — inter-indicator divergence diagnosis in dashboard (Conviction / Artificial Push / Divergence)
//
// ============================================================================

indicator("Market Pressure Scale [WavesUnchained]", shorttitle="MPS", overlay=false, max_labels_count=500)

// Inputs
normLen   = input.int(100,  "Normalisation",    minval=20)
atrLen    = input.int(14,   "ATR Length")
bbLen     = input.int(20,   "BB Length")
bbMult    = input.float(2.0, "BB Multiplier")
volLen    = input.int(20,   "Volume MA")
srLen     = input.int(50,   "Range / S/R Lookback")

biasGR       = "Bias"
biasType     = input.string("HMA", "Type",
     options=["EMA", "RMA", "SMA", "WMA", "HMA", "JMA"], group=biasGR)
biasFastLen  = input.int(9,  "Fast Length", minval=1, group=biasGR)
biasSlowLen  = input.int(21, "Slow Length", minval=1, group=biasGR)

smGR       = "Smoothing"
smoothLen  = input.int(3,     "Length", minval=1, maxval=50, group=smGR)
smoothType = input.string("EMA", "Type",
     options=["EMA", "RMA", "SMA", "WMA", "HMA", "JMA"], group=smGR)
jmaPhase   = input.int(50,    "  JMA Phase", minval=-100, maxval=100,            group=smGR)
jmaPower   = input.float(2.0, "  JMA Power", minval=1.0,  maxval=4.0, step=0.25, group=smGR)

dashGR    = "Dashboard"
showTable = input.bool(true, "Show Table", group=dashGR)

sigGR       = "Signal Markers"
showMarkers = input.bool(true,  "Show Markers",     group=sigGR)
showCoil    = input.bool(true,  "  Coiling Start",  group=sigGR,
              tooltip="Setup crosses above 65 with Impulse below 40 — spring loading.")
showIgnit   = input.bool(true,  "  Breakout Watch", group=sigGR,
              tooltip="Impulse crosses above 45 while Setup is still elevated — watch for breakout.")
showFailed  = input.bool(true,  "  Failed Coil",    group=sigGR,
              tooltip="Setup was high but Impulse never confirmed — stalled breakout, likely range continues.")
showNaked   = input.bool(true,  "  Naked Impulse",  group=sigGR,
              tooltip="Impulse > 70 but Setup collapses below 40 — move running without structural backing.")
showDouble  = input.bool(true,  "  Double Peak",    group=sigGR,
              tooltip="Both components simultaneously above 65 — unstable, sharp move typically imminent.")
showFade    = input.bool(true,  "  Dual Fade",      group=sigGR,
              tooltip="Both components falling from elevated levels — momentum exhausting on both sides.")

stochGR        = "StochRSI"
showStoch      = input.bool(false, "Show StochRSI",   group=stochGR)
showStochDiv   = input.bool(false, "  Divergences",   group=stochGR)
showStochCross  = input.bool(false, "  Crosses",      group=stochGR)
stochCrossLo    = input.int(25,    "    Zone Low",     minval=1, maxval=49, group=stochGR)
stochCrossHi    = input.int(75,    "    Zone High",    minval=51, maxval=99, group=stochGR)
smoothK        = input.int(3,      "K",               minval=1, group=stochGR)
smoothD    = input.int(3,      "D",               minval=1, group=stochGR)
rsiLen     = input.int(14,     "RSI Length",      minval=1, group=stochGR)
stochLen   = input.int(14,     "Stoch Length",    minval=1, group=stochGR)

wtGR         = "WaveTrend"
showWT       = input.bool(false, "Show WaveTrend",   group=wtGR)
showWTDiv    = input.bool(true,  "  Divergences",    group=wtGR)
showWTCross  = input.bool(true,  "  Crosses",        group=wtGR)
wtCrossLo    = input.int(-53,    "    Zone Low",     minval=-100, maxval=-1, group=wtGR)
wtCrossHi    = input.int(53,     "    Zone High",    minval=1,   maxval=100, group=wtGR)
wtChLen      = input.int(10,     "Channel Length",   minval=1, group=wtGR)
wtAvgLen     = input.int(21,     "Average Length",   minval=1, group=wtGR)
wtSigLen     = input.int(4,      "Signal Length",    minval=1, group=wtGR)

mfiGR       = "MFI"
showMfi     = input.bool(false, "Show MFI",          group=mfiGR,
              tooltip="Money Flow Index — RSI applied to Typical Price × Volume. Measures directional buying/selling pressure, unlike StochRSI which has no volume component.")
showMfiDiv  = input.bool(false, "  Divergences",     group=mfiGR,
              tooltip="Bullish: price makes lower low but MFI makes higher low — selling volume drying up despite price weakness.\nBearish: price makes higher high but MFI makes lower high — buying volume fading despite price strength.\nUses the same pivot lookback as Impulse divergence.")
showMfiMark = input.bool(false, "  Chart Markers",   group=mfiGR,
              tooltip="Shows MFI divergence signals as ◆ markers directly on the price chart. Active independently of whether the MFI curve is visible in the oscillator.")
mfiLen      = input.int(14,     "Length",            minval=1, group=mfiGR,
              tooltip="Lookback for MFI calculation. 14 is standard. Shorter = more reactive, more noise. Longer = smoother, fewer signals.")

regimeGR   = "Momentum Regime Map"
showRegime = input.bool(false, "Show Regime Background", group=regimeGR,
             tooltip="Optional background overlay classifying the combined WT + StochRSI + MFI state. Replaces the phase-color background when active.\nEuphoric: all three at extremes — reversal risk.\nDistribution: WT bullish but MFI fading.\nAccumulation: WT bearish but MFI recovering.\nEnergy Build-up: all three near midpoint — potential pressure buildup.")

charGR        = "Market Character"
showCharacter = input.bool(false, "Show Character in Table", group=charGR,
                tooltip="Inter-indicator divergence diagnosis in the dashboard.\nConviction: all three oscillators aligned.\nArt. Push: WT moves without MFI confirmation.\nDiv. Bull/Bear: StochRSI leads opposite to WT.")

divGR      = "Divergence"
showDiv    = input.bool(true,  "Show Divergences", group=divGR)
showBull   = input.bool(true,  "  Bullish",        group=divGR)
showBear   = input.bool(true,  "  Bearish",        group=divGR)
divLbL     = input.int(5,      "Pivot Left",      minval=1, group=divGR)
divLbR     = input.int(5,      "Pivot Right",     minval=1, group=divGR)
divRangeLo = input.int(5,      "Range Min Bars",  minval=1, group=divGR)
divRangeHi = input.int(60,     "Range Max Bars",  minval=1, group=divGR)

// Helpers
clamp(x, lo, hi) =>
    math.max(lo, math.min(hi, x))

norm100(src, len) =>
    hi = ta.highest(src, len)
    lo = ta.lowest(src, len)
    hi == lo ? 50.0 : 100.0 * (src - lo) / (hi - lo)

f_jma(src, length, phase, power) =>
    var float jma = na
    var float e0  = na
    var float e1  = na
    var float e2  = na
    _pr    = phase < -100 ? 0.5 : phase > 100 ? 2.5 : phase / 100.0 + 1.5
    _beta  = 0.45 * (length - 1) / (0.45 * (length - 1) + 2)
    _alpha = math.pow(_beta, power)
    e0    := (1 - _alpha) * src + _alpha * nz(e0[1], src)
    e1    := (src - e0) * (1 - _beta) + _beta * nz(e1[1], 0)
    e2    := (e0 + _pr * e1 - nz(jma[1], src)) * math.pow(1 - _alpha, 2) + math.pow(_alpha, 2) * nz(e2[1], 0)
    jma   := nz(jma[1], src) + e2
    jma

f_smooth(src, length, mode) =>
    switch mode
        'SMA' => ta.sma(src, length)
        'RMA' => ta.rma(src, length)
        'HMA' => ta.hma(src, length)
        'WMA' => ta.wma(src, length)
        'JMA' => f_jma(src, length, jmaPhase, jmaPower)
        =>       ta.ema(src, length)

// Base values
atr    = ta.atr(atrLen)
atrPct = atr / close

basis    = ta.sma(close, bbLen)
dev      = bbMult * ta.stdev(close, bbLen)
bbUpper  = basis + dev
bbLower  = basis - dev
bbWidth  = (bbUpper - bbLower) / basis

volRel    = volume / ta.sma(volume, volLen)
barRange  = high - low
bodySize  = math.abs(close - open)
bodyRatio = bodySize / math.max(barRange, syminfo.mintick)

_biasFast = f_smooth(close, biasFastLen, biasType)
_biasSlow = f_smooth(close, biasSlowLen, biasType)
bullBias  = _biasFast > _biasSlow
bearBias  = _biasFast < _biasSlow

// StochRSI
_rsi1          = ta.rsi(close, rsiLen)
stochK         = ta.sma(ta.stoch(_rsi1, _rsi1, _rsi1, stochLen), smoothK)
stochD         = ta.sma(stochK, smoothD)
stochBullCross = ta.crossover(stochK, stochD)  and stochK <= stochCrossLo
stochBearCross = ta.crossunder(stochK, stochD) and stochK >= stochCrossHi

// WaveTrend (double-EMA CCI-based, same formula as LazyBear)
_wtEsa  = ta.ema(hlc3, wtChLen)
_wtD    = ta.ema(math.abs(hlc3 - _wtEsa), wtChLen)
_wtCi   = (hlc3 - _wtEsa) / (0.015 * math.max(_wtD, syminfo.mintick))
wtOsc   = ta.ema(_wtCi, wtAvgLen)
wtSig   = ta.sma(wtOsc, wtSigLen)
wtBullCross = ta.crossover(wtOsc, wtSig)  and wtOsc <= wtCrossLo
wtBearCross = ta.crossunder(wtOsc, wtSig) and wtOsc >= wtCrossHi

// MFI
_mfiTypical = (high + low + close) / 3
_mfiRawMf   = _mfiTypical * volume
_mfiPosMf   = _mfiTypical > _mfiTypical[1] ? _mfiRawMf : 0.0
_mfiNegMf   = _mfiTypical < _mfiTypical[1] ? _mfiRawMf : 0.0
_mfiPosSum  = math.sum(_mfiPosMf, mfiLen)
_mfiNegSum  = math.sum(_mfiNegMf, mfiLen)
mfi         = _mfiNegSum == 0 ? 100.0 : 100.0 - 100.0 / (1.0 + _mfiPosSum / _mfiNegSum)

// Range / Support / Resistance
rangeHigh = ta.highest(high, srLen)
rangeLow  = ta.lowest(low,  srLen)
rangeSize = rangeHigh - rangeLow

nearHigh    = math.abs(rangeHigh - close) / atr
nearLow     = math.abs(close - rangeLow)  / atr
srProximity = clamp(100 - math.min(nearHigh, nearLow) * 50, 0, 100)

rangePosition = rangeSize == 0 ? 50 : 100 * (close - rangeLow) / rangeSize

// Setup Pressure — high when volatility is low, BBs tight, price near range
// extreme AND volume is drying up (a genuine squeeze, not a high-volume push)
atrCompression = 100 - norm100(atrPct, normLen)
bbCompression  = 100 - norm100(bbWidth, normLen)
compression    = (atrCompression + bbCompression) / 2
volQuiet       = 100 - norm100(volRel, normLen)

setupPressure =
     compression * 0.55 +
     srProximity * 0.30 +
     volQuiet    * 0.15

setupPressure := clamp(setupPressure, 0, 100)

// Impulse Pressure — high when range, body and volume expand
rangeExpansion = norm100(barRange / atr, normLen)
volumePressure = norm100(volRel,    normLen)
bodyPressure   = norm100(bodyRatio, normLen)

impulsePressure =
     rangeExpansion * 0.45 +
     bodyPressure   * 0.40 +
     volumePressure * 0.15

impulsePressure := clamp(impulsePressure, 0, 100)

// Smoothing
setupPressure   := f_smooth(setupPressure,   smoothLen, smoothType)
impulsePressure := f_smooth(impulsePressure, smoothLen, smoothType)

// Impulse Pressure divergence
_divInRange(cond) =>
    bars = ta.barssince(cond)
    divRangeLo <= bars and bars <= divRangeHi

_divPlFound = not na(ta.pivotlow( impulsePressure, divLbL, divLbR))
_divPhFound = not na(ta.pivothigh(impulsePressure, divLbL, divLbR))

_oscHL   = impulsePressure[divLbR] > ta.valuewhen(_divPlFound, impulsePressure[divLbR], 1) and _divInRange(_divPlFound[1])
_priceLL = low[divLbR]  < ta.valuewhen(_divPlFound, low[divLbR],  1)
bullDiv  = showDiv and showBull and _priceLL and _oscHL  and _divPlFound

_oscLH   = impulsePressure[divLbR] < ta.valuewhen(_divPhFound, impulsePressure[divLbR], 1) and _divInRange(_divPhFound[1])
_priceHH = high[divLbR] > ta.valuewhen(_divPhFound, high[divLbR], 1)
bearDiv  = showDiv and showBear and _priceHH and _oscLH  and _divPhFound

// StochRSI divergence
_stochPlFound = not na(ta.pivotlow( stochK, divLbL, divLbR))
_stochPhFound = not na(ta.pivothigh(stochK, divLbL, divLbR))

_stochHL     = stochK[divLbR] > ta.valuewhen(_stochPlFound, stochK[divLbR], 1) and _divInRange(_stochPlFound[1])
stochBullDiv = showStochDiv and _priceLL and _stochHL and _stochPlFound

_stochLH     = stochK[divLbR] < ta.valuewhen(_stochPhFound, stochK[divLbR], 1) and _divInRange(_stochPhFound[1])
stochBearDiv = showStochDiv and _priceHH and _stochLH and _stochPhFound

// WaveTrend divergence
_wtPlFound = not na(ta.pivotlow( wtOsc, divLbL, divLbR))
_wtPhFound = not na(ta.pivothigh(wtOsc, divLbL, divLbR))

_wtHL    = wtOsc[divLbR] > ta.valuewhen(_wtPlFound, wtOsc[divLbR], 1) and _divInRange(_wtPlFound[1])
wtBullDiv = showWTDiv and _priceLL and _wtHL and _wtPlFound

_wtLH    = wtOsc[divLbR] < ta.valuewhen(_wtPhFound, wtOsc[divLbR], 1) and _divInRange(_wtPhFound[1])
wtBearDiv = showWTDiv and _priceHH and _wtLH and _wtPhFound

// MFI divergence (raw — show-gates applied at plot/label level)
_mfiPlFound = not na(ta.pivotlow( mfi, divLbL, divLbR))
_mfiPhFound = not na(ta.pivothigh(mfi, divLbL, divLbR))

_mfiHL     = mfi[divLbR] > ta.valuewhen(_mfiPlFound, mfi[divLbR], 1) and _divInRange(_mfiPlFound[1])
mfiBullDiv = _priceLL and _mfiHL and _mfiPlFound

_mfiLH     = mfi[divLbR] < ta.valuewhen(_mfiPhFound, mfi[divLbR], 1) and _divInRange(_mfiPhFound[1])
mfiBearDiv = _priceHH and _mfiLH and _mfiPhFound

// Momentum Regime Map (#2): combined WT + StochRSI + MFI market state
regimeEuphorBull = wtOsc > wtCrossHi and stochK > 75 and mfi > 65
regimeEuphorBear = wtOsc < wtCrossLo and stochK < 25 and mfi < 35
regimeDistrib    = wtOsc > 20 and mfi < nz(mfi[5], mfi) and stochK < 65 and not regimeEuphorBull
regimeAccum      = wtOsc < -20 and mfi > nz(mfi[5], mfi) and stochK > 35 and not regimeEuphorBear
regimeEnergy     = math.abs(wtOsc) < 20 and math.abs(stochK - 50) < 25

color regimeBgColor = na
string regimeText   = "Neutral"
if regimeEuphorBull
    regimeBgColor := color.new(#d50000, 87)
    regimeText    := "Euphoric ↑"
else if regimeEuphorBear
    regimeBgColor := color.new(#00c853, 87)
    regimeText    := "Euphoric ↓"
else if regimeDistrib
    regimeBgColor := color.new(#ff6f00, 90)
    regimeText    := "Distribution"
else if regimeAccum
    regimeBgColor := color.new(#2196F3, 91)
    regimeText    := "Accumulation"
else if regimeEnergy
    regimeBgColor := color.new(#ffd600, 93)
    regimeText    := "Energy Build"

// Market Character Score (#5): inter-indicator divergence diagnosis
wtRising    = wtOsc  > nz(wtOsc[5],  wtOsc)
mfiRising5  = mfi    > nz(mfi[5],    mfi)

convBull  = wtOsc > 10  and mfi > 55 and stochK > 55 and wtRising and mfiRising5
convBear  = wtOsc < -10 and mfi < 45 and stochK < 45 and not wtRising and not mfiRising5
artPushUp = wtOsc > 15  and not mfiRising5 and mfi < 55 and not convBull
artPushDn = wtOsc < -15 and mfiRising5 and mfi > 45 and not convBear
divBull   = stochK > 55 and wtOsc < -10
divBear   = stochK < 45 and wtOsc > 10 and not convBull and not artPushUp

string charText     = "Mixed"
color charStateColor = color.new(color.gray, 80)
if convBull
    charText       := "Conviction ↑"
    charStateColor := color.new(#00c853, 30)
else if convBear
    charText       := "Conviction ↓"
    charStateColor := color.new(#d50000, 30)
else if artPushUp
    charText       := "Art. Push ↑"
    charStateColor := color.new(#ff6f00, 30)
else if artPushDn
    charText       := "Art. Push ↓"
    charStateColor := color.new(#ff6f00, 30)
else if divBull
    charText       := "Div. Bull"
    charStateColor := color.new(#00bcd4, 30)
else if divBear
    charText       := "Div. Bear"
    charStateColor := color.new(#9c27b0, 30)

// Signal detection
var bool inCoil      = false
var bool coilIgnited = false

coilEntry = ta.crossover(setupPressure, 65) and impulsePressure < 40
if coilEntry
    inCoil      := true
    coilIgnited := false
if inCoil and impulsePressure >= 45
    coilIgnited := true

sigCoil   = coilEntry
sigIgnit  = ta.crossover(impulsePressure, setupPressure) and setupPressure > 40
sigFailed = inCoil and not coilIgnited and ta.crossunder(setupPressure, 52)
sigNaked  = impulsePressure > 70 and ta.crossunder(setupPressure, 40)
sigDouble = setupPressure > 65 and ta.crossover(impulsePressure, 65)
_fadePrevHigh = setupPressure[1] > 60 and impulsePressure[1] > 60
_fadeBothFall = setupPressure < setupPressure[1] and impulsePressure < impulsePressure[1]
_fadeCross    = ta.crossunder(setupPressure, 55) or ta.crossunder(impulsePressure, 55)
sigFade       = _fadePrevHigh and _fadeBothFall and _fadeCross

if sigFailed or setupPressure < 40
    inCoil := false

// Phase — priority order: Impulse > Breakout Watch > Coiling > Sideways > Neutral
phase = if impulsePressure > 70
    "Impulse Running"
else if setupPressure > 55 and impulsePressure >= 45
    "Breakout Watch"
else if setupPressure > 65 and impulsePressure < 45
    "Coiling"
else if setupPressure < 40 and impulsePressure < 40
    "Sideways / Quiet"
else
    "Neutral"

biasText = bullBias ? "Bullish" : bearBias ? "Bearish" : "Flat"

// Colors
setupColor   = setupPressure   > 65 ? color.orange             : color.new(color.orange, 45)
impulseColor = impulsePressure > 70 ? color.lime               : color.new(color.lime,   45)

_nc = color.new(color.white, 100)
plot(showStoch ? stochK : na, "StochRSI K", color=color.new(#2962FF, 65), linewidth=1)
plot(showStoch ? stochD : na, "StochRSI D", color=color.new(#FF6D00, 65), linewidth=1)
plot(setupPressure,   "Setup Pressure",   color=setupColor,   linewidth=3)
plot(impulsePressure, "Impulse Pressure", color=impulseColor, linewidth=4)
plot(_divPlFound ? impulsePressure[divLbR] : na, "Bull Div", offset=-divLbR, linewidth=2, color=bullDiv ? #00c853 : _nc)
plot(_divPhFound ? impulsePressure[divLbR] : na, "Bear Div", offset=-divLbR, linewidth=2, color=bearDiv ? #d50000 : _nc)

plot(_stochPlFound and showStoch ? stochK[divLbR] : na, "StochK Bull Div", offset=-divLbR, linewidth=2, color=stochBullDiv and showStoch ? #00c853 : _nc)
plot(_stochPhFound and showStoch ? stochK[divLbR] : na, "StochK Bear Div", offset=-divLbR, linewidth=2, color=stochBearDiv and showStoch ? #d50000 : _nc)

plot(showWT ? wtOsc : na, "WT Osc",    color=color.new(#0ea5e9, 40), linewidth=1)
plot(showWT ? wtSig : na, "WT Signal", color=color.new(#f97316, 40), linewidth=1)
plot(_wtPlFound and showWT ? wtOsc[divLbR] : na, "WT Bull Div", offset=-divLbR, linewidth=2, color=wtBullDiv and showWT ? #00c853 : _nc)
plot(_wtPhFound and showWT ? wtOsc[divLbR] : na, "WT Bear Div", offset=-divLbR, linewidth=2, color=wtBearDiv and showWT ? #d50000 : _nc)

color mfiCol = #CE93D8
plot(showMfi ? mfi : na, "MFI", color=color.new(mfiCol, 65), linewidth=1)
plot(_mfiPlFound and showMfi ? mfi[divLbR] : na, "MFI Bull Div", offset=-divLbR, linewidth=2, color=showMfi and showMfiDiv and mfiBullDiv ? color.new(mfiCol, 20) : _nc)
plot(_mfiPhFound and showMfi ? mfi[divLbR] : na, "MFI Bear Div", offset=-divLbR, linewidth=2, color=showMfi and showMfiDiv and mfiBearDiv ? color.new(mfiCol, 20) : _nc)

// TF-normalised offset: 15 m = 1.0, scales down on higher timeframes
_tfFactor = math.pow(math.min(1.0, 900.0 / math.max(60, timeframe.in_seconds())), 0.65)

if showMfiMark
    if mfiBullDiv
        label.new(bar_index - divLbR, low[divLbR] - atr[divLbR] * 1.1 * _tfFactor, "◆",
             style=label.style_none, color=color.new(color.white, 100), textcolor=color.new(mfiCol, 30), size=size.small,
             force_overlay=true)
    if mfiBearDiv
        label.new(bar_index - divLbR, high[divLbR] + atr[divLbR] * 1.1 * _tfFactor, "◆",
             style=label.style_none, color=color.new(color.white, 100), textcolor=color.new(mfiCol, 30), size=size.small,
             force_overlay=true)

if showStochCross
    _crossSize = setupPressure > 65 ? size.normal : setupPressure > 40 ? size.small : size.tiny
    if stochBullCross
        label.new(bar_index, low - atr * 0.4 * _tfFactor, "●",
             style=label.style_none, color=color.new(color.white, 100), textcolor=color.new(#00c853, 40), size=_crossSize,
             force_overlay=true)
    if stochBearCross
        label.new(bar_index, high + atr * 0.4 * _tfFactor, "●",
             style=label.style_none, color=color.new(color.white, 100), textcolor=color.new(#d50000, 40), size=_crossSize,
             force_overlay=true)

if showWT and showWTCross
    _wtCrossSize = setupPressure > 65 ? size.normal : setupPressure > 40 ? size.small : size.tiny
    if wtBullCross
        label.new(bar_index, low - atr * 0.7 * _tfFactor, "◆",
             style=label.style_none, color=color.new(color.white, 100), textcolor=color.new(#0ea5e9, 40), size=_wtCrossSize,
             force_overlay=true)
    if wtBearCross
        label.new(bar_index, high + atr * 0.7 * _tfFactor, "◆",
             style=label.style_none, color=color.new(color.white, 100), textcolor=color.new(#f97316, 40), size=_wtCrossSize,
             force_overlay=true)

hline(40, "Quiet",        color=color.new(color.gray, 55), linestyle=hline.style_dashed)
hline(65, "Setup Zone",   color=color.new(color.gray, 40), linestyle=hline.style_dashed)
hline(70, "Impulse Zone", color=color.new(color.gray, 25), linestyle=hline.style_dashed)

color phaseBgC = na
if setupPressure > 65 and impulsePressure < 55
    phaseBgC := color.new(color.orange, 88)
else if impulsePressure > 70
    phaseBgC := color.new(color.green, 88)
bgcolor(showRegime and not na(regimeBgColor) ? regimeBgColor : phaseBgC)

// Signal markers
if showMarkers
    mid = (setupPressure + impulsePressure) / 2

    if showCoil and sigCoil
        label.new(bar_index, setupPressure, "▲",
             style=label.style_label_up, color=color.new(#ffd600, 15),
             textcolor=color.white, size=size.small,
             tooltip="Coiling — Setup crossed above 65, Impulse flat.\nSpring loading. Watch for Breakout Watch (Impulse ≥ 45 while Setup stays elevated).")

    if showIgnit and sigIgnit
        label.new(bar_index, mid, "ℹ",
             style=label.style_label_up, color=color.new(#ff6f00, 15),
             textcolor=color.white, size=size.small,
             tooltip="Breakout Watch — Setup and Impulse both elevated.\nCoil is releasing. Watch for directional follow-through before committing.")

    if showFailed and sigFailed
        label.new(bar_index, setupPressure, "FC",
             style=label.style_label_down, color=color.new(#d50000, 15),
             textcolor=color.white, size=size.small,
             tooltip="Failed Coil — Setup was high but Impulse never confirmed.\nBreakout attempt stalled. Expect range continuation or a full reset before the next setup forms.")

    if showNaked and sigNaked
        label.new(bar_index, impulsePressure, "NI",
             style=label.style_label_down, color=color.new(#d50000, 15),
             textcolor=color.white, size=size.small,
             tooltip="Naked Impulse — Impulse > 70 but Setup collapsed below 40.\nMove is running without structural backing. Late-entry risk — momentum may stall or reverse sharply.")

    if showDouble and sigDouble
        label.new(bar_index, math.max(setupPressure, impulsePressure), "DP",
             style=label.style_label_down, color=color.new(#aa00ff, 15),
             textcolor=color.white, size=size.small,
             tooltip="Double Peak — both components simultaneously above 65.\nUnstable and short-lived. A sharp directional move is typically imminent — direction confirmed by Bias.")

    if showFade and sigFade
        label.new(bar_index, mid, "DF",
             style=label.style_label_down, color=color.new(color.gray, 15),
             textcolor=color.white, size=size.small,
             tooltip="Dual Fade — both components falling from elevated levels.\nMomentum exhausting on both sides. Potential reversal or transition to Sideways/Quiet.")

// Table
color tc = color.new(color.gray, 20)
color hd = color.new(color.gray, 90)

setupDir   = setupPressure   > setupPressure[1]   + 0.5 ? "↑" : setupPressure   < setupPressure[1]   - 0.5 ? "↓" : "→"
impulseDir = impulsePressure > impulsePressure[1] + 0.5 ? "↑" : impulsePressure < impulsePressure[1] - 0.5 ? "↓" : "→"

var table t = table.new(position.top_right, 3, 8,
     bgcolor      = color.new(color.white, 5),
     border_color = color.new(color.gray, 60),
     border_width = 1,
     frame_color  = color.new(color.gray, 40),
     frame_width  = 1)

if barstate.islast and showTable
    phaseActive = impulsePressure > 70 or (setupPressure > 55 and impulsePressure >= 45) or setupPressure > 65
    color phaseBg = color.new(color.gray, 80)
    if impulsePressure > 70
        phaseBg := color.new(#00c853, 20)
    else if setupPressure > 55 and impulsePressure >= 45
        phaseBg := color.new(#ff6f00, 20)
    else if setupPressure > 65
        phaseBg := color.new(#ffd600, 30)
    phaseTC     = phaseActive ? color.white : tc

    table.cell(t, 0, 0, "Phase",   text_color=tc,      bgcolor=hd,      text_size=size.small)
    table.cell(t, 1, 0, phase,     text_color=phaseTC, bgcolor=phaseBg, text_size=size.small)
    table.cell(t, 2, 0, "",        bgcolor=hd,                          text_size=size.small)

    table.cell(t, 0, 1, "Setup",   text_color=tc, text_size=size.small, tooltip="How much the market is coiling: ATR/BB compression, S/R proximity, relative volume. >65 = strong setup.")
    table.cell(t, 1, 1, str.tostring(setupPressure,   "#.0") + " / 100", text_color=tc,         text_size=size.small)
    table.cell(t, 2, 1, setupDir,                                         text_color=color.new(color.orange, 0), text_size=size.small)

    table.cell(t, 0, 2, "Impulse", text_color=tc, text_size=size.small, tooltip="How much a directional move is underway: range expansion vs ATR, volume, candle body size. >70 = impulse running.")
    table.cell(t, 1, 2, str.tostring(impulsePressure, "#.0") + " / 100", text_color=tc,          text_size=size.small)
    table.cell(t, 2, 2, impulseDir,                                       text_color=color.new(#00c853, 0), text_size=size.small)

    biasTC = bullBias ? color.new(#00c853, 0) : bearBias ? color.new(#d50000, 0) : tc
    table.cell(t, 0, 3, "Bias",       text_color=tc,     text_size=size.small, tooltip="Directional bias from a fast/slow MA cross. Bullish = fast MA above slow MA.")
    table.cell(t, 1, 3, biasText,     text_color=biasTC, text_size=size.small)
    table.cell(t, 2, 3, "",           text_color=tc,     text_size=size.small)

    table.cell(t, 0, 4, "Range Pos.", text_color=tc, text_size=size.small, tooltip="Where the close sits within the N-bar high/low range. 0% = at range low, 100% = at range high.")
    table.cell(t, 1, 4, str.tostring(rangePosition, "#.0") + " %", text_color=tc, text_size=size.small)
    table.cell(t, 2, 4, "",           text_color=tc, text_size=size.small)

    // Separator
    table.cell(t, 0, 5, "", bgcolor=color.new(color.gray, 80))
    table.cell(t, 1, 5, "", bgcolor=color.new(color.gray, 80))
    table.cell(t, 2, 5, "", bgcolor=color.new(color.gray, 80))

    // Momentum Regime Map (#2)
    regimeTc2 = regimeText == "Neutral" ? tc : color.white
    color regimeCellBg = color.new(color.gray, 80)
    if regimeEuphorBull
        regimeCellBg := color.new(#d50000, 30)
    else if regimeEuphorBear
        regimeCellBg := color.new(#00c853, 30)
    else if regimeDistrib
        regimeCellBg := color.new(#ff6f00, 30)
    else if regimeAccum
        regimeCellBg := color.new(#2196F3, 30)
    else if regimeEnergy
        regimeCellBg := color.new(#ffd600, 40)
    table.cell(t, 0, 6, "Regime",   text_color=tc,       bgcolor=na,           text_size=size.small)
    table.cell(t, 1, 6, regimeText, text_color=regimeTc2, bgcolor=regimeCellBg, text_size=size.small)
    table.cell(t, 2, 6, "",         text_color=tc,        bgcolor=na,           text_size=size.small)

    // Market Character Score (#5)
    charTc2 = charText == "Mixed" ? tc : color.white
    table.cell(t, 0, 7, "Character", text_color=tc,     bgcolor=na,           text_size=size.small)
    table.cell(t, 1, 7, charText,    text_color=charTc2, bgcolor=charStateColor, text_size=size.small)
    table.cell(t, 2, 7, "",          text_color=tc,      bgcolor=na,           text_size=size.small)


// Alerts
alertcondition(setupPressure > 65 and impulsePressure < 45,               "Coiling",        "Setup Pressure high, Impulse flat — spring loaded, no release yet.")
alertcondition(setupPressure > 55 and impulsePressure >= 45 and impulsePressure <= 70, "Breakout Watch", "Setup and Impulse both active — watch for directional follow-through.")
alertcondition(impulsePressure > 70,                                       "Impulse Running", "Impulse Pressure above 70 — directional move active.")
alertcondition(setupPressure < 40 and impulsePressure < 40,                "Sideways / Quiet", "Both components below 40 — no active setup or impulse.")
alertcondition(sigCoil,   "Signal: Coiling Start",  "Setup crossed above 65 with Impulse flat — spring loading.")
alertcondition(sigIgnit,  "Signal: Breakout Watch",  "Impulse rising with Setup still elevated — watch for follow-through.")
alertcondition(sigFailed, "Signal: Failed Coil",     "Setup was high but Impulse never confirmed — breakout stalled.")
alertcondition(sigNaked,  "Signal: Naked Impulse",   "Impulse > 70 but Setup collapsed — late-entry warning.")
alertcondition(sigDouble, "Signal: Double Peak",     "Both components above 65 simultaneously — sharp move imminent.")
alertcondition(sigFade,   "Signal: Dual Fade",       "Both components falling from high — momentum exhausting.")
