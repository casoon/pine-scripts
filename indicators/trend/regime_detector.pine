// Quality Tiers
tierAConf = input.float(0.80, "Tier A: Min Confidence", minval=0.0, maxval=1.0, step=0.05, group=SIGNAL_GROUP)
tierAAgree = input.float(0.65, "Tier A: Min HTF Agreement", minval=0.0, maxval=1.0, step=0.05, group=SIGNAL_GROUP)
tierAQuality = input.float(0.70, "Tier A: Min Signal Quality", minval=0.0, maxval=1.0, step=0.05, group=SIGNAL_GROUP)

tierBConf = input.float(0.70, "Tier B: Min Confidence", minval=0.0, maxval=1.0, step=0.05, group=SIGNAL_GROUP)
