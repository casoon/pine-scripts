// Risk Management
enableRiskManagement = input.bool(true, "Risk Management (WIP)", group=WIP_GROUP, tooltip="WIP: not yet used in engine")
maxConsecutiveLosses = input.int(3, "Max Consecutive Losses (WIP)", minval=1, maxval=10, group=WIP_GROUP, tooltip="WIP: not yet used in engine")
