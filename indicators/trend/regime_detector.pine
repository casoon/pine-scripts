enableHTFDivergence = input.bool(true, "HTF Divergence Detection", group=MTF_GROUP, tooltip="Detect divergence between timeframes")

// === ADVANCED FILTERS ===
enableAdvancedFilters = input.bool(true, "Enable Advanced Filter System", group=FILTER_GROUP)

// Volatility Filter
