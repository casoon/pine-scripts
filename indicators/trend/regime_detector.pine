dataSource = input.source(close, "Data Source", group=CORE_GROUP)
enableAdaptiveEngine = input.bool(true, "Enable Adaptive Engine", group=CORE_GROUP, tooltip="Use the local adaptive engine for calculations")

// KAMA-Hybrid Parameters
erLength = input.int(20, "Efficiency Ratio Length", minval=5, maxval=100, group=CORE_GROUP, tooltip="Period for trend efficiency calculation")
alphaMin = input.float(0.03, "Alpha Minimum", minval=0.001, maxval=0.5, step=0.001, group=CORE_GROUP, tooltip="Minimum smoothing factor (slow reaction)")
alphaMax = input.float(0.30, "Alpha Maximum", minval=0.01, maxval=1.0, step=0.01, group=CORE_GROUP, tooltip="Maximum smoothing factor (fast reaction)")
gamma = input.float(1.25, "Gamma (Reaction Hardness)", minval=0.5, maxval=3.0, step=0.05, group=CORE_GROUP, tooltip="Controls non-linearity of alpha adaptation")

// ATR Bands Configuration
atrLength = input.int(14, "ATR Length", minval=2, maxval=50, group=CORE_GROUP)
entryMultiplier = input.float(1.6, "Entry Band Multiplier", minval=0.5, maxval=5.0, step=0.1, group=CORE_GROUP, tooltip="ATR factor for entry threshold")
exitMultiplier = input.float(1.2, "Exit Band Multiplier", minval=0.3, maxval=5.0, step=0.1, group=CORE_GROUP, tooltip="ATR factor for exit threshold (< Entry = Hysteresis)")

// === REGIME DETECTION SETTINGS ===
enableAdvancedRegime = input.bool(true, "Enable Advanced Regime Detection", group=REGIME_GROUP, tooltip="Use enhanced regime classification")
regimeMode = input.string("Trend + Momentum", "Regime Detection Mode", ["Trend Only", "Momentum Only", "Trend + Momentum", "Full Analysis"], group=REGIME_GROUP)

erThreshold = input.float(0.2, "ER Threshold (Trend)", minval=0.0, maxval=1.0, step=0.01, group=REGIME_GROUP, tooltip="Minimum ER value for trend regime")
erThresholdExit = input.float(0.15, "ER Exit Threshold", minval=0.0, maxval=1.0, step=0.01, group=REGIME_GROUP, tooltip="Lower ER threshold to exit regime (hysteresis)")
regimeSensitivity = input.float(0.6, "Regime Sensitivity", minval=0.1, maxval=1.0, step=0.05, group=REGIME_GROUP, tooltip="Higher = more sensitive regime detection")
regimeConfidenceMin = input.float(0.65, "Min Regime Confidence", minval=0.0, maxval=1.0, step=0.05, group=REGIME_GROUP, tooltip="Minimum confidence for regime classification")
regimeConfidenceExit = input.float(0.55, "Min Regime Confidence (Exit)", minval=0.0, maxval=1.0, step=0.05, group=REGIME_GROUP, tooltip="Lower confidence threshold to exit regime (hysteresis)")

// Machine Learning Enhancement
enableMLRegime = input.bool(true, "ML-Enhanced Classification (WIP)", group=WIP_GROUP, tooltip="WIP: not yet used in engine")
mlLookback = input.int(50, "ML Pattern Lookback (WIP)", minval=20, maxval=200, group=WIP_GROUP, tooltip="WIP: not yet used in engine")
mlConfidence = input.float(0.7, "ML Confidence Threshold (WIP)", minval=0.5, maxval=0.95, step=0.05, group=WIP_GROUP, tooltip="WIP: not yet used in engine")

// === MULTI-TIMEFRAME GATE SETTINGS ===
enableMTFGate = input.bool(true, "Enable MTF Gate", group=MTF_GROUP, tooltip="Higher timeframe must confirm trend (auto-stacked by chart TF)")

// HTF Configuration
