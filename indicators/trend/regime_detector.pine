// ============================================================================
// LOCAL ENGINE (Lite) for Regime Detector
// Minimal engine: Adaptive -> Regime -> MTF Gate -> Filters -> Signals -> Perf
// ============================================================================

// --- Helpers
f_clamp01(x) => math.max(0.0, math.min(1.0, x))

// --- JMA (CPM/Everget-style)
calculateJMA(src, length, phase, power) =>
    ph = math.max(-100.0, math.min(100.0, phase))
    pr = (ph + 100.0) / 200.0
    len = math.max(1.0, length)
    beta = 0.45 * (len - 1.0) / (0.45 * (len - 1.0) + 2.0)
    alpha = math.pow(beta, power)
    var float e0 = na
    var float e1 = na
    var float e2 = na
    var float jma = na
    e0 := (1.0 - alpha) * src + alpha * nz(e0[1], src)
    e1 := (src - e0) * (1.0 - beta) + beta * nz(e1[1], 0.0)
    e2 := (e0 + pr * e1 - nz(jma[1], src)) * math.pow(1.0 - alpha, 2.0) + math.pow(alpha, 2.0) * nz(e2[1], 0.0)
    jma := e2 + nz(jma[1], src)
    jma

// --- Adaptive Engine

type AdaptiveConfig
    bool enableAdaptiveEngine
    int erLength
    float alphaMin
    float alphaMax
    float gamma
    int atrLength
    float source

type AdaptiveState
    float line
    float atr
    float efficiencyRatio
    float currentAlpha
    float normalizedSlope

newAdaptiveConfig() =>
    AdaptiveConfig.new(true, 20, 0.03, 0.30, 1.25, 14, close)

newAdaptiveState() =>
    AdaptiveState.new(na, na, 0.0, 0.0, 0.0)

processAdaptiveEngine(AdaptiveState state, AdaptiveConfig config, int atrLen) =>
    src = config.source
    erLen = math.max(2, config.erLength)
    direction = math.abs(src - src[erLen])
    volatility = ta.sma(math.abs(src - src[1]), erLen) * erLen
    er = volatility == 0 ? 0.0 : direction / volatility

    alpha = config.alphaMin + (config.alphaMax - config.alphaMin) * math.pow(er, config.gamma)
    var float lastLine = na
    prevLine = na(lastLine) ? src : lastLine
    line = prevLine + alpha * (src - prevLine)

    atr = ta.atr(atrLen)
    slope = atr > 0 ? (line - prevLine) / atr : 0.0

    state.line := line
    state.atr := atr
    state.efficiencyRatio := er
    state.currentAlpha := alpha
    state.normalizedSlope := slope
    lastLine := line
    state

// --- Regime Detection

type RegimeConfig
    bool enableAdvancedRegime
    string regimeMode
    float erThreshold
    float erThresholdExit
    float sensitivity
    float minConfidence
    float minConfidenceExit
    bool enableMLEnhancement
    int mlLookback
    float mlConfidenceThreshold

type RegimeState
    int currentRegime
    float confidence
    float strength

newRegimeConfig() =>
    RegimeConfig.new(true, "Trend + Momentum", 0.2, 0.15, 0.6, 0.65, 0.55, false, 50, 0.7)

newRegimeState() =>
    RegimeState.new(0, 0.0, 0.0)

processRegimeDetection(RegimeState state, RegimeConfig config, AdaptiveState adaptiveState) =>
    slope = adaptiveState.normalizedSlope
    strength = f_clamp01(math.abs(slope))

    erEnterOk = adaptiveState.efficiencyRatio >= config.erThreshold
    erExitOk = adaptiveState.efficiencyRatio >= config.erThresholdExit

    baseConfEnter = erEnterOk ? f_clamp01((adaptiveState.efficiencyRatio - config.erThreshold) / math.max(1e-6, 1.0 - config.erThreshold)) : 0.0
    baseConfExit = erExitOk ? f_clamp01((adaptiveState.efficiencyRatio - config.erThresholdExit) / math.max(1e-6, 1.0 - config.erThresholdExit)) : 0.0
    confEnter = f_clamp01(baseConfEnter * config.sensitivity)
    confExit = f_clamp01(baseConfExit * config.sensitivity)

    trendEnterOk = erEnterOk
    trendExitOk = erExitOk
    momEnterOk = strength >= config.sensitivity
    momExitOk = strength >= (config.sensitivity * 0.8)

    modeEnterOk = not config.enableAdvancedRegime ? true : config.regimeMode == "Trend Only" ? trendEnterOk : config.regimeMode == "Momentum Only" ? momEnterOk : config.regimeMode == "Trend + Momentum" ? (trendEnterOk and momEnterOk) : (trendEnterOk and momEnterOk)

    modeExitOk = not config.enableAdvancedRegime ? true : config.regimeMode == "Trend Only" ? trendExitOk : config.regimeMode == "Momentum Only" ? momExitOk : config.regimeMode == "Trend + Momentum" ? (trendExitOk and momExitOk) : (trendExitOk and momExitOk)

    int prevRegime = state.currentRegime
    int regime = prevRegime

    if regime == 0
        if erEnterOk and modeEnterOk and confEnter >= config.minConfidence
            regime := slope > 0 ? 1 : slope < 0 ? -1 : 0
    else if regime == 1
        if erExitOk and modeExitOk and confExit >= config.minConfidenceExit and slope > 0
            regime := 1
        else if erEnterOk and modeEnterOk and confEnter >= config.minConfidence and slope < 0
            regime := -1
        else
            regime := 0
    else
        if erExitOk and modeExitOk and confExit >= config.minConfidenceExit and slope < 0
            regime := -1
        else if erEnterOk and modeEnterOk and confEnter >= config.minConfidence and slope > 0
            regime := 1
        else
            regime := 0

    conf = regime == 0 ? confEnter : (regime == prevRegime ? confExit : confEnter)

    state.currentRegime := regime
    state.confidence := conf
    state.strength := strength
    state

// --- MTF Gate

type MultiTimeframeConfig
    bool enableHTFGate
    bool enableDivergenceDetection
    string[] timeframes
    map<string, float> weights
    float minAgreement

type MultiTimeframeState
    bool enabled
    float agreementRatio
    int overallBias
    float divergenceStrength
    float minAgreement

newMultiTimeframeConfig() =>
    MultiTimeframeConfig.new(true, true, array.new_string(), map.new<string, float>(), 0.6)

newMultiTimeframeState() =>
    MultiTimeframeState.new(false, 1.0, 0, 0.0, 0.6)

processMultiTimeframeAnalysis(MultiTimeframeState state, MultiTimeframeConfig config, int baseRegime) =>
    state.enabled := config.enableHTFGate
    state.minAgreement := config.minAgreement

    if not config.enableHTFGate
        state.agreementRatio := 1.0
        state.overallBias := baseRegime
        state.divergenceStrength := 0.0
        state
    else
        totalW = 0.0
        agreeW = 0.0
        biasSum = 0.0

        for i = 0 to array.size(config.timeframes) - 1
            tf = array.get(config.timeframes, i)
            w = map.contains(config.weights, tf) ? map.get(config.weights, tf) : 1.0
            dir = request.security(syminfo.tickerid, tf, close > ta.ema(close, 50) ? 1 : close < ta.ema(close, 50) ? -1 : 0, barmerge.gaps_off, barmerge.lookahead_off)

            totalW += w
            biasSum += dir * w
            if baseRegime != 0 and dir == baseRegime
                agreeW += w

        agreement = totalW > 0 ? (baseRegime == 0 ? math.abs(biasSum) / totalW : agreeW / totalW) : 0.0
        overallBias = biasSum > 0 ? 1 : biasSum < 0 ? -1 : 0
        divergence = config.enableDivergenceDetection ? (1.0 - agreement) : 0.0

        state.agreementRatio := agreement
        state.overallBias := overallBias
        state.divergenceStrength := divergence
        state

// --- Filters

type FilterConfig
    bool enableAdvancedFilters
    float minATRPercent
    string volatilityMode
    bool enableVolumeFilter
    int volumeLength
    float volumeQuantile
    bool enableMarketCondition
    int marketConditionPeriod
    bool enableConfluence
    float confluenceThreshold

type FilterState
    float signalQuality
    int marketCondition

newFilterConfig() =>
    FilterConfig.new(true, 0.0007, "Adaptive", false, 50, 0.3, true, 100, true, 0.6)

newFilterState() =>
    FilterState.new(0.0, 0)

processFilterSystem(FilterState state, FilterConfig config, AdaptiveState adaptiveState, RegimeState regimeState) =>
    if not config.enableAdvancedFilters
        state.signalQuality := 1.0
        state.marketCondition := 0
        state
    else
        atrPct = close > 0 ? (adaptiveState.atr / close) : 0.0
        atrPctAvg = ta.sma(atrPct, config.marketConditionPeriod)
        atrPctThresh = config.volatilityMode == "Static" ? config.minATRPercent : config.volatilityMode == "Adaptive" ? math.max(config.minATRPercent, atrPctAvg * 0.7) : math.max(config.minATRPercent, atrPctAvg * (regimeState.currentRegime != 0 ? 0.6 : 0.85))
        volOk = atrPct >= atrPctThresh

        volAvg = ta.sma(volume, config.volumeLength)
        volGate = not config.enableVolumeFilter or (volAvg > 0 and volume >= volAvg * config.volumeQuantile)

        trendScore = ta.sma(math.abs(adaptiveState.normalizedSlope), config.marketConditionPeriod)
        erAvg = ta.sma(adaptiveState.efficiencyRatio, config.marketConditionPeriod)
        marketCond = 0
        if config.enableMarketCondition
            marketCond := trendScore > 0.35 ? 1 : erAvg < 0.15 ? -1 : 0

        quality = 0.0
        quality += volOk ? 0.5 : 0.0
        quality += volGate ? 0.3 : 0.0
        quality += trendScore > 0.2 ? 0.2 : 0.0

        if config.enableConfluence and quality < config.confluenceThreshold
            quality := quality * 0.5

        state.signalQuality := f_clamp01(quality)
        state.marketCondition := marketCond
        state

// --- Signal Engine

type SignalConfig
    int confirmBars
    bool enableSmartConfirm
    bool enableAdvancedExits
    string exitMode
    bool enableTrailingStop
    float trailingSensitivity
    bool enableRiskManagement
    int maxConsecutiveLosses
    int cooldownPeriod
    float exitMultiplier
    float tierAConf
    float tierAAgree
    float tierAQuality
    float tierBConf
    float tierBAgree
    float tierBQuality

type SignalState
    bool longEntry
    bool shortEntry
    bool exitLong
    bool exitShort
    bool lowQualityLong
    bool lowQualityShort
    int position
    int lastSignalBar

newSignalConfig() =>
    SignalConfig.new(2, true, true, "Hybrid", true, 0.7, true, 3, 5, 1.2, 0.8, 0.65, 0.7, 0.7, 0.55, 0.6)

newSignalState() =>
    SignalState.new(false, false, false, false, false, false, 0, na)

processSignalGeneration(SignalState state, SignalConfig config, AdaptiveState adaptiveState, RegimeState regimeState, MultiTimeframeState mtfState, FilterState filterState) =>
    bull = regimeState.currentRegime == 1
    bear = regimeState.currentRegime == -1

    barsOkBull = config.confirmBars <= 1 ? bull : ta.sma(bull ? 1 : 0, config.confirmBars) == 1.0
    barsOkBear = config.confirmBars <= 1 ? bear : ta.sma(bear ? 1 : 0, config.confirmBars) == 1.0

    canFire = na(state.lastSignalBar) or (bar_index - state.lastSignalBar >= config.cooldownPeriod)
    htfGateOk = not mtfState.enabled or (mtfState.agreementRatio >= mtfState.minAgreement)
    filterOk = filterState.signalQuality >= 0.5 and htfGateOk
    htfAgree = mtfState.enabled ? mtfState.agreementRatio : 1.0
    qualA = (regimeState.confidence >= config.tierAConf) and (htfAgree >= config.tierAAgree) and (filterState.signalQuality >= config.tierAQuality)
    qualB = not qualA and (regimeState.confidence >= config.tierBConf) and (htfAgree >= config.tierBAgree) and (filterState.signalQuality >= config.tierBQuality)
    allowEntry = qualA or qualB

    longCandidate = canFire and filterOk and barsOkBull and state.position != 1
    shortCandidate = canFire and filterOk and barsOkBear and state.position != -1

    longEntry = longCandidate and allowEntry
    shortEntry = shortCandidate and allowEntry
    lowQualityLong = longCandidate and not allowEntry
    lowQualityShort = shortCandidate and not allowEntry

    upperExit = adaptiveState.line + config.exitMultiplier * adaptiveState.atr
    lowerExit = adaptiveState.line - config.exitMultiplier * adaptiveState.atr

    exitByBandLong = state.position == 1 and close < lowerExit
    exitByBandShort = state.position == -1 and close > upperExit

    exitByRegimeLong = state.position == 1 and not bull
    exitByRegimeShort = state.position == -1 and not bear

    exitLong = config.enableAdvancedExits ? (config.exitMode == "Conservative" ? exitByBandLong : config.exitMode == "Aggressive" ? exitByRegimeLong : (exitByBandLong or exitByRegimeLong)) : exitByRegimeLong

    exitShort = config.enableAdvancedExits ? (config.exitMode == "Conservative" ? exitByBandShort : config.exitMode == "Aggressive" ? exitByRegimeShort : (exitByBandShort or exitByRegimeShort)) : exitByRegimeShort

    if longEntry
        state.position := 1
        state.lastSignalBar := bar_index
    else if shortEntry
        state.position := -1
        state.lastSignalBar := bar_index
    else if exitLong or exitShort
        state.position := 0

    state.longEntry := longEntry
    state.shortEntry := shortEntry
    state.exitLong := exitLong
    state.exitShort := exitShort
    state.lowQualityLong := lowQualityLong
    state.lowQualityShort := lowQualityShort
    state

// --- Performance

type PerformanceConfig
    bool enableAutoTuning
    int tuningPeriod
    float adaptationRate
    bool enablePerformanceTracking
    int trackingPeriod
    bool enableMemoryOptimization
    int maxHistoryBars

type PerformanceMetrics
    int sampleCount
    float winRate
    float profitFactor
    int wins
    int losses
    float grossProfit
    float grossLoss
    float lastEntryPrice
    int lastPosition

newPerformanceConfig() =>
    PerformanceConfig.new(true, 200, 0.02, true, 500, true, 2000)

newPerformanceMetrics() =>
    PerformanceMetrics.new(0, 0.5, 1.0, 0, 0, 0.0, 0.0, na, 0)

updatePerformanceMetrics(PerformanceMetrics metrics, PerformanceConfig config, SignalState signalState) =>
    if not config.enablePerformanceTracking
        metrics
    else
        if signalState.position != metrics.lastPosition
            if metrics.lastPosition == 0 and signalState.position != 0
                metrics.lastEntryPrice := close
            else if metrics.lastPosition != 0 and signalState.position == 0 and not na(metrics.lastEntryPrice)
                pnl = (close - metrics.lastEntryPrice) * (metrics.lastPosition == 1 ? 1 : -1)
                if pnl > 0
                    metrics.wins += 1
                    metrics.grossProfit += pnl
                else
                    metrics.losses += 1
                    metrics.grossLoss += math.abs(pnl)

                metrics.sampleCount := metrics.wins + metrics.losses
                metrics.winRate := metrics.sampleCount > 0 ? (metrics.wins / metrics.sampleCount) : 0.0
                metrics.profitFactor := metrics.grossLoss > 0 ? (metrics.grossProfit / metrics.grossLoss) : (metrics.grossProfit > 0 ? 99.0 : 0.0)

        metrics.lastPosition := signalState.position
        metrics


