//@version=6
// ============================================================================
// Williams VIX Fix Advanced [WavesUnchained]
// Version: 1.7
// Author: WavesUnchained
// Build: 2026-07-02 00:00:00
// ============================================================================
// Synthetic fear gauge (Williams VIX Fix) with dual-direction signals, StdDev
// and percentile bands, stall/absorption context, slow-WVF trend context,
// divergence wedge, and gradient coloring on a bounded 0–100 panel.
//
// Features:
//   ✓ Bullish WVF: (Highest(Close,N) − Low) / Highest(Close,N) × 100
//   ✓ Bearish WVF: (High − Lowest(Close,N)) / Lowest(Close,N) × 100
//   ✓ StdDev upper band + percentile threshold for spike detection
//   ✓ Stall/absorption: WVF surges but price barely moves (weak signal context)
//   ✓ Slow WVF context line as background fear reference
//   ✓ Fast ↔ Slow WVF divergence wedge
//   ✓ Histogram (WVF − context) showing deviation from background fear
//   ✓ Gradient coloring, shadow fills, band fills, signal markers, and alerts
//
// ============================================================================

indicator("Williams VIX Fix Advanced [WavesUnchained]", "WVFA", overlay=false, max_labels_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

g_core = "1 · Core"
wvfLen     = input.int(22, "WVF Lookback", minval=2, group=g_core)
smoothWVF  = input.bool(false, "Smooth WVF output", group=g_core,
     tooltip="Apply a smoothing filter to the raw WVF values. Reduces noise at the cost of lag.")
smoothLen  = input.int(3, "  Length", minval=1, group=g_core)
smoothType = input.string("EMA", "  Type",
     options=["EMA", "SMA", "RMA", "WMA", "SuperSmoother", "T3", "KAMA", "JMA Approx"],
     group=g_core)
jmaPhase   = input.int(50,    "  JMA Phase", minval=-100, maxval=100,             group=g_core)
jmaPower   = input.float(2.0, "  JMA Power", minval=1.0,  maxval=4.0, step=0.25, group=g_core)
showBearWVF = input.bool(true, "Show Bearish WVF (complacency / top gauge)", group=g_core)

g_levels = "2 · Reference Levels"
midLevel = input.float(3.0, "Reference Level (±)", minval=0.0, step=0.5, group=g_levels,
     tooltip="Shown as dotted lines at +N and −N as loose reference markers. Not used in signal logic.")

g_bands = "3 · Spike Bands"
bbl           = input.int(20,   "StdDev Band Length",       minval=2, group=g_bands)
mult          = input.float(2.0,"StdDev Multiplier",        minval=0.1, step=0.1, group=g_bands)
rangeLen      = input.int(100,  "Percentile Lookback",      minval=10, group=g_bands)
rangeHigh     = input.float(90, "Percentile Threshold (%)", minval=50, maxval=100, step=1, group=g_bands)
useBand       = input.bool(true, "Spike: above StdDev band",      group=g_bands)
usePercentile = input.bool(false, "Spike: above percentile level", group=g_bands)
minSpikeLevel = input.float(0.0, "Min absolute WVF level for spike", minval=0.0, step=0.5, group=g_bands,
     tooltip="Absolute minimum WVF value required for a spike signal. 0 = disabled (pure band logic). Raise to 5–10 on forex or sub-daily timeframes where WVF values are inherently small.")

g_stall = "4 · Stall / Absorption"
useStall     = input.bool(true, "Detect Stall (WVF surges, price holds)", group=g_stall,
     tooltip="Flags bars where WVF spikes sharply but price barely moves — likely a thin wick rather than genuine fear. Never changes spike detection logic.")
stallLen     = input.int(5,     "Stall Lookback (bars)", minval=1, group=g_stall)
stallFlatATR = input.float(0.5, "Max Price Move (ATR)",  minval=0.0, step=0.1, group=g_stall)
stallWVFMin  = input.float(2.0, "Min WVF Surge",         minval=0.0, step=0.5, group=g_stall)

g_ctx = "5 · Context"
useCtx = input.bool(true, "Show Context Line (EMA of WVF)", group=g_ctx,
     tooltip="EMA of the fast WVF — acts as the D-line (signal line). Histogram shows WVF deviation from this average. Rises toward 0 on slow-down, spikes positive on fear extremes.")
ctxLen = input.int(44, "Context EMA Length", minval=4, group=g_ctx)

g_div = "6 · Divergence"
showDiv = input.bool(true, "Highlight Fast ↔ Slow WVF Divergence", group=g_div,
     tooltip="Fills the wedge between fast WVF and the slow context line when they move in opposite directions.")
divLen  = input.int(4,   "Divergence Slope Lookback", minval=1, group=g_div)
divMin  = input.float(3, "Min Fast Slope",            minval=0, step=0.5, group=g_div)

g_plots = "7 · Plots"
showShadow   = input.bool(true, "Zone Fills (WVF vs zero line)",    group=g_plots)


showSignals  = input.bool(true, "Show Spike Markers",               group=g_plots)

g_col = "7 · Plots · Colors"
colCalm    = input.color(#00bcd4,                "Bull WVF (fear gauge)",         group=g_col)
colFear    = input.color(#f06292,                "Fear fills/bands",              group=g_col)
colBearWVF = input.color(#9c27b0,                "Bear WVF (complacency gauge)",  group=g_col)
colSpike   = input.color(#00c853,                "Long context marker",           group=g_col)
colWeak    = input.color(color.new(#00c853, 60), "Long context (weak)",           group=g_col)
colSpikeB  = input.color(#e53935,                "Short context marker",          group=g_col)


// ─────────────────────────────────────────────────────────────────────────────
// SMOOTHING FUNCTIONS
// ─────────────────────────────────────────────────────────────────────────────

f_supersmoother(series float x, simple int len) =>
    float pi = math.pi
    float a1 = math.exp(-1.414 * pi / len)
    float b1 = 2.0 * a1 * math.cos(1.414 * pi / len)
    float c2 = b1
    float c3 = -(a1 * a1)
    float c1 = 1.0 - c2 - c3
    var float ss = na
    ss := c1 * (x + nz(x[1])) / 2.0 + c2 * nz(ss[1]) + c3 * nz(ss[2])
    ss

f_t3(series float x, simple int len) =>
    float b  = 0.7
    float e1 = ta.ema(x, len)
    float e2 = ta.ema(e1, len)
    float e3 = ta.ema(e2, len)
    float e4 = ta.ema(e3, len)
    float e5 = ta.ema(e4, len)
    float e6 = ta.ema(e5, len)
    float c1 = -(b * b * b)
    float c2 =  3.0 * b * b + 3.0 * b * b * b
    float c3 = -6.0 * b * b - 3.0 * b - 3.0 * b * b * b
    float c4 =  1.0 + 3.0 * b + b * b * b + 3.0 * b * b
    c1 * e6 + c2 * e5 + c3 * e4 + c4 * e3

f_kama(series float x, simple int len) =>
    float change   = math.abs(x - x[len])
    float vol      = math.sum(math.abs(x - x[1]), len)
    float er       = vol != 0.0 ? change / vol : 0.0
    float sc       = math.pow(er * (2.0 / 3.0 - 2.0 / 31.0) + 2.0 / 31.0, 2)
    var float kama = na
    kama := nz(kama[1], x) + sc * (x - nz(kama[1], x))
    kama

f_jma(series float x, simple int len, simple int phase, simple float power) =>
    var float jma = na
    var float e0  = na
    var float e1  = na
    var float e2  = na
    float phaseRatio = phase < -100 ? 0.5 : phase > 100 ? 2.5 : phase / 100.0 + 1.5
    float beta       = 0.45 * (len - 1) / (0.45 * (len - 1) + 2.0)
    float alpha      = math.pow(beta, power)
    e0  := (1.0 - alpha) * x + alpha * nz(e0[1], x)
    e1  := (x - e0) * (1.0 - beta) + beta * nz(e1[1], 0.0)
    e2  := (e0 + phaseRatio * e1 - nz(jma[1], x)) * math.pow(1.0 - alpha, 2.0) + math.pow(alpha, 2.0) * nz(e2[1], 0.0)
    jma := nz(jma[1], x) + e2
    jma

f_smooth(series float x, simple int len, simple string mode) =>
    switch mode
        "SMA"           => ta.sma(x, len)
        "RMA"           => ta.rma(x, len)
        "WMA"           => ta.wma(x, len)
        "SuperSmoother" => f_supersmoother(x, len)
        "T3"            => f_t3(x, len)
        "KAMA"          => f_kama(x, len)
        "JMA Approx"    => f_jma(x, len, jmaPhase, jmaPower)
        =>                 ta.ema(x, len)

// ─────────────────────────────────────────────────────────────────────────────
// WVF CORE
// ─────────────────────────────────────────────────────────────────────────────

float hc = ta.highest(close, wvfLen)
float lc = ta.lowest(close,  wvfLen)

float wvfRaw  = hc != 0.0 ? (hc - low)  / hc * 100.0 : 0.0
float bwvfRaw = lc != 0.0 ? (high - lc) / lc * 100.0 : 0.0

float wvf  = smoothWVF ? f_smooth(wvfRaw,  smoothLen, smoothType) : wvfRaw
float bwvf = smoothWVF ? f_smooth(bwvfRaw, smoothLen, smoothType) : bwvfRaw

float ctxWVF  = ta.ema(wvf,  ctxLen)
float ctxBWVF = ta.ema(bwvf, ctxLen)

// ─────────────────────────────────────────────────────────────────────────────
// SPIKE BANDS
// ─────────────────────────────────────────────────────────────────────────────

float upperBand       = ta.sma(wvf, bbl) + mult * ta.stdev(wvf, bbl)
float wvfHigh         = ta.highest(wvf, rangeLen)
float wvfLow          = ta.lowest(wvf,  rangeLen)
float percentileLvl   = wvfLow + rangeHigh / 100.0 * (wvfHigh - wvfLow)

bool spikeRaw = ((useBand and wvf >= upperBand) or (usePercentile and wvf >= percentileLvl)) and wvf >= minSpikeLevel

float bUpperBand      = ta.sma(bwvf, bbl) + mult * ta.stdev(bwvf, bbl)
float bwvfHigh        = ta.highest(bwvf, rangeLen)
float bwvfLow         = ta.lowest(bwvf,  rangeLen)
float bPercentileLvl  = bwvfLow + rangeHigh / 100.0 * (bwvfHigh - bwvfLow)

bool bSpikeRaw = showBearWVF and ((useBand and bwvf >= bUpperBand) or (usePercentile and bwvf >= bPercentileLvl)) and bwvf >= minSpikeLevel

// ─────────────────────────────────────────────────────────────────────────────
// STALL / ABSORPTION
// ─────────────────────────────────────────────────────────────────────────────

float atrRef   = ta.atr(14)
float wvfChg   = wvf - wvf[stallLen]
float priceChg = atrRef != 0.0 ? math.abs(close - close[stallLen]) / atrRef : 0.0
bool  flatPx   = priceChg < stallFlatATR
bool  stallNow = useStall and wvfChg > stallWVFMin and flatPx

bool spikeCross  = spikeRaw  and not spikeRaw[1]
bool bSpikeCross = bSpikeRaw and not bSpikeRaw[1]

bool spikeStrong  = spikeCross  and not stallNow
bool spikeWeak    = spikeCross  and stallNow
bool bSpikeStrong = bSpikeCross and not stallNow
bool bSpikeWeak   = bSpikeCross and stallNow

// ─────────────────────────────────────────────────────────────────────────────
// DIVERGENCE (fast WVF vs slow context WVF)
// ─────────────────────────────────────────────────────────────────────────────

float fastDir = wvf    - wvf[divLen]
float slowDir = ctxWVF - ctxWVF[divLen]
bool  divBull = useCtx and showDiv and fastDir < -divMin and slowDir > 0.0
bool  divBear = useCtx and showDiv and fastDir >  divMin and slowDir < 0.0

// ─────────────────────────────────────────────────────────────────────────────
// COLORS
// ─────────────────────────────────────────────────────────────────────────────

color lineCol  = wvf  >= ctxWVF  ? colCalm    : color.new(colCalm,    65)
color lineColB = bwvf >= ctxBWVF ? colBearWVF : color.new(colBearWVF, 65)
color ctxCol   = color.new(colCalm,    70)
color ctxColB  = color.new(colBearWVF, 70)

// ─────────────────────────────────────────────────────────────────────────────
// HLINES
// ─────────────────────────────────────────────────────────────────────────────

hline(0,          "Zero",  color=color.new(color.gray, 50), linewidth=1)
hline( midLevel,  "Ref+",  color=color.new(color.gray, 78), linestyle=hline.style_dotted, linewidth=1)
hline(-midLevel,  "Ref−",  color=color.new(color.gray, 78), linestyle=hline.style_dotted, linewidth=1)

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────

pZero = plot(0, display=display.none)
plot(upperBand,                             "Bull Band",         color=color.new(colCalm,    55), linewidth=1)
plot(percentileLvl,                         "Bull Percentile",   color=color.new(colCalm,    78), linewidth=1)
plot(showBearWVF ? -bUpperBand    : na,     "Bear Band",         color=color.new(colBearWVF, 55), linewidth=1)
plot(showBearWVF ? -bPercentileLvl : na,    "Bear Percentile",   color=color.new(colBearWVF, 78), linewidth=1)

pCtx  = plot(useCtx ? ctxWVF                  : na, "WVF Context",  color=ctxCol,  linewidth=1)
pCtxB = plot(showBearWVF and useCtx ? -ctxBWVF : na, "Bear Context", color=ctxColB, linewidth=1)
pBWVF = plot(showBearWVF ? -bwvf              : na, "Bear WVF",     color=lineColB, linewidth=2)
pWVF  = plot(wvf,                                   "WVF",          color=lineCol,  linewidth=2)

fill(pWVF,  pCtx,
     color=divBull ? color.new(colCalm, 82) : divBear ? color.new(colBearWVF, 82) : na,
     title="Divergence Fill")

fill(pWVF,  pZero, color=showShadow ? color.new(lineCol,  88) : na, title="Bull Zone")
fill(pBWVF, pZero, color=showShadow and showBearWVF ? color.new(lineColB, 88) : na, title="Bear Zone")

// ─────────────────────────────────────────────────────────────────────────────
// SIGNAL MARKERS
// ─────────────────────────────────────────────────────────────────────────────

plotshape(showSignals and spikeStrong  ? 1 : na, "Bull Spike",
     style=shape.triangleup,   location=location.bottom,
     color=colSpike, size=size.small)

plotshape(showSignals and spikeWeak    ? 1 : na, "Bull Spike (absorbed)",
     style=shape.triangleup,   location=location.bottom,
     color=colWeak,  size=size.tiny)

plotshape(showSignals and bSpikeStrong ? 1 : na, "Bear Spike",
     style=shape.triangledown, location=location.top,
     color=colSpikeB, size=size.small)

plotshape(showSignals and bSpikeWeak   ? 1 : na, "Bear Spike (absorbed)",
     style=shape.triangledown, location=location.top,
     color=color.new(colSpikeB, 60), size=size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────

bool alertsOnBarClose = input.bool(true, "Alerts only on bar close (confirmed)", group="8 · Alerts")
bool alertOk = not alertsOnBarClose or barstate.isconfirmed

alertcondition(alertOk and spikeStrong,  "WVF Bull Spike",           "WVFA · SPIKE BULL · {{ticker}} {{interval}}")
alertcondition(alertOk and spikeWeak,    "WVF Bull Spike (Absorbed)", "WVFA · SPIKE BULL ABSORBED · {{ticker}} {{interval}}")
alertcondition(alertOk and bSpikeStrong, "WVF Bear Spike",           "WVFA · SPIKE BEAR · {{ticker}} {{interval}}")
alertcondition(alertOk and bSpikeWeak,   "WVF Bear Spike (Absorbed)", "WVFA · SPIKE BEAR ABSORBED · {{ticker}} {{interval}}")
alertcondition(alertOk and (spikeStrong or bSpikeStrong), "WVF Any Spike", "WVFA · SPIKE · {{ticker}} {{interval}}")
