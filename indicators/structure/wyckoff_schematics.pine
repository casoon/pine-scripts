//@version=6
// ============================================================================
// Wyckoff Schematics [WavesUnchained]
// Version: 2.0.0
// Author: WavesUnchained
// Build: 2026-05-07 00:00:00
// ============================================================================
// Volume/spread-based Wyckoff heuristics: accumulation/distribution detection, key event identification (SC, Spring, SOS, BC, UTAD, SOW), and effort-vs-result analysis
//
// Features:
//   ✓ Automatic Accumulation/Distribution phase detection
//   ✓ Key Wyckoff event identification (SC, Spring, SOS, BC, UTAD, SOW)
//   ✓ Effort vs Result analysis (Wyckoff's 3rd Law)
//   ✓ Cause and Effect calculation (Wyckoff's 2nd Law)
//   ✓ Composite Operator state (heuristic)
//   ✓ Real-time dashboard with phase and subphase
//   ✓ Alert system for phase transitions
//   ✓ Phase range visualization with color-coded boxes
//   ✓ Event labels with tooltips
//   ✓ Standalone implementation (no library dependencies)
//   ✓ Modular architecture for maintainability
//
// ============================================================================
indicator("Wyckoff Schematics [WavesUnchained]", "Wyckoff", overlay=true, max_boxes_count=50, max_labels_count=100, max_lines_count=50)

// ============================================================================
// WYCKOFF SCHEMATICS - Complete Wyckoff Method Implementation
// ============================================================================
// @description
// Volume/spread-based Wyckoff heuristics for accumulation/distribution
// detection and key event identification.
//
// Features:
//   - Automatic Accumulation/Distribution phase detection
//   - Key Wyckoff event identification (SC, Spring, SOS, BC, UTAD, SOW)
//   - Effort vs Result analysis
//   - Cause and Effect calculation
//   - Composite Operator position tracking
//   - Real-time dashboard
//
// Wyckoff Method:
//   Richard Wyckoff's method focuses on understanding institutional behavior
//   through price-volume relationships. Smart money accumulates during ranges
//   and distributes at tops, leaving footprints in the price action.
//
//   Three Laws:
//   1. Supply and Demand - Price is determined by supply/demand balance
//   2. Cause and Effect - Accumulation/Distribution creates future moves
//   3. Effort vs Result - Volume (effort) should match price (result)
//
// @author WavesUnchained
// @version 2.0.0
// ============================================================================

// NOTE: Modules will be combined by build system
// Individual module imports shown here for reference only

// ============================================================================
// INLINE MODULES (Combined at build time)
// ============================================================================

// ============================================================================
// MODULE: inputs
// ============================================================================

// ============================================================================
// USER INPUTS
// ============================================================================

var g1 = "Wyckoff Analysis"
int volumeLookback = input.int(20, "Volume Lookback", minval=10, maxval=100, group=g1)
float climaxMultiplier = input.float(2.0, "Climax Volume Multiplier", minval=1.5, maxval=5.0, group=g1)
float springThreshold = input.float(2.0, "Spring Threshold %", minval=1.0, maxval=5.0, group=g1)
float utadThreshold = input.float(2.0, "UTAD Threshold %", minval=1.0, maxval=5.0, group=g1)
float sosThreshold = input.float(3.0, "SOS Threshold %", minval=1.0, maxval=10.0, group=g1)
float sowThreshold = input.float(3.0, "SOW Threshold %", minval=1.0, maxval=10.0, group=g1)
int rangeEstablishBars = input.int(20, "Range Establish Bars (Phase A)", minval=5, maxval=100, group=g1, tooltip="Bars to establish the range after a climax. After this window, range is frozen and breakouts trigger Markup/Markdown.")
float invalidationFactor = input.float(0.5, "Range Invalidation Factor", minval=0.2, maxval=2.0, step=0.1, group=g1, tooltip="Multiplier of range width for invalidation buffer. Larger = more tolerance before phase fails.")

var g2 = "Display"
bool showPhaseRanges = input.bool(true, "Show Phase Ranges", group=g2)
bool showEventLabels = input.bool(true, "Show Event Labels", group=g2)
bool showEffortMarkers = input.bool(true, "Show Effort vs Result Markers", group=g2)
bool showDashboard = input.bool(true, "Show Dashboard", group=g2)

var g2a = "Display Lookback (per Timeframe)"
int eventLookback_5M = input.int(200, "Lookback: 5M", minval=50, maxval=500, group=g2a)
int eventLookback_15M = input.int(150, "Lookback: 15M", minval=50, maxval=500, group=g2a)
int eventLookback_1H = input.int(100, "Lookback: 1H", minval=20, maxval=300, group=g2a)
int eventLookback_4H = input.int(75, "Lookback: 4H", minval=20, maxval=200, group=g2a)
int eventLookback_D = input.int(50, "Lookback: Daily", minval=10, maxval=150, group=g2a)
int eventLookback_W = input.int(30, "Lookback: Weekly", minval=10, maxval=100, group=g2a)

// Auto-select lookback based on chart timeframe
int eventLookback = switch
    timeframe.isintraday and timeframe.multiplier <= 5 => eventLookback_5M
    timeframe.isintraday and timeframe.multiplier <= 30 => eventLookback_15M
    timeframe.isintraday => eventLookback_1H
    timeframe.isdaily => eventLookback_D
    timeframe.isweekly or timeframe.ismonthly => eventLookback_W
    => eventLookback_4H

var g2b = "Colors"
color accumColor = input.color(color.new(color.green, 70), "Accumulation", group=g2b)
color distribColor = input.color(color.new(color.red, 70), "Distribution", group=g2b)
color markupColor = input.color(color.new(color.lime, 70), "Markup", group=g2b)
color markdownColor = input.color(color.new(color.maroon, 70), "Markdown", group=g2b)


// ============================================================================
// MODULE: types
// ============================================================================

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

// @type Wyckoff phase
type WyckoffPhase
    string name
    string subphase
    int startBar
    float startPrice
    float rangeHigh
    float rangeLow
    float volumeProfile
    float confidence
    int rangeEstablishedBar

// @type Wyckoff event
type WyckoffEvent
    string eventType
    int bar
    float price
    float volume
    float volumeRatio
    float spread
    float significance
    string description
    bool labeled

// @type Effort vs Result analysis
type EffortResult
    float effort
    float result
    string relationship
    bool isPositive
    float strength

// @type Wyckoff state
type WyckoffState
    WyckoffPhase currentPhase
    WyckoffPhase previousPhase
    array<WyckoffEvent> events
    EffortResult effortResult
    string compositeOperator
    float causeBuilt
    float effectExpected
    int lastUpdateBar

// @type Wyckoff configuration
type WyckoffConfig
    int volumeLookback
    float climaxVolumeMultiplier
    float springThreshold
    float utadThreshold
    float sosThreshold
    float sowThreshold
    int minRangeBars
    int rangeEstablishBars
    float invalidationFactor


// ============================================================================
// MODULE: initialization
// ============================================================================

// ============================================================================
// INITIALIZATION FUNCTIONS
// ============================================================================

newWyckoffState() =>
    WyckoffState.new( na, na, array.new<WyckoffEvent>(), na, "NEUTRAL", 0.0, 0.0, 0 )

newWyckoffConfig() =>
    WyckoffConfig.new( volumeLookback, climaxMultiplier, springThreshold, utadThreshold, sosThreshold, sowThreshold, 10, rangeEstablishBars, invalidationFactor )

newWyckoffPhase(string name, string subphase = "") =>
    WyckoffPhase.new( name, subphase, bar_index, close, high, low, 0.0, 50.0, na )

newWyckoffEvent(string eventType, string description = "", float eventPrice = close) =>
    WyckoffEvent.new( eventType, bar_index, eventPrice, volume, 0.0, high - low, 50.0, description, false )


// ============================================================================
// MODULE: effort_result
// ============================================================================

// ============================================================================
// EFFORT VS RESULT ANALYSIS
// ============================================================================

analyzeEffortResult(float volumeCurrent, float volumeAvg, float spread, float spreadAvg) =>
    effort = volumeCurrent / volumeAvg
    result = spread / spreadAvg

    relationship = "CONFIRMATION"
    isPositive = close > open
    strength = 50.0

    if effort > 1.5 and result > 1.5
        relationship := "CONFIRMATION"
        strength := 80.0
    else if effort > 2.0 and result < 0.8
        relationship := "CLIMAX"
        strength := 90.0
    else if effort < 0.8 and result > 1.2
        relationship := "DIVERGENCE"
        strength := 70.0

    EffortResult.new(effort, result, relationship, isPositive, strength)


// ============================================================================
// MODULE: event_detection
// ============================================================================

// ============================================================================
// WYCKOFF EVENT DETECTION
// ============================================================================

detectSellingClimax(float volumeRatio, WyckoffConfig config) =>
    isHighVolume = volumeRatio >= config.climaxVolumeMultiplier
    isDownBar = close < open
    isWideSpread = (high - low) / close > 0.02
    isCloseNearLow = (close - low) / (high - low) < 0.3
    isHighVolume and isDownBar and isWideSpread and isCloseNearLow

detectBuyingClimax(float volumeRatio, WyckoffConfig config) =>
    isHighVolume = volumeRatio >= config.climaxVolumeMultiplier
    isUpBar = close > open
    isWideSpread = (high - low) / close > 0.02
    isCloseNearHigh = (high - close) / (high - low) < 0.3
    isHighVolume and isUpBar and isWideSpread and isCloseNearHigh

detectSpring(float rangeLow, WyckoffConfig config) =>
    breakdownPct = ((rangeLow - low) / rangeLow) * 100
    quickReversal = close > rangeLow
    breakdownPct >= config.springThreshold and quickReversal

detectUTAD(float rangeHigh, WyckoffConfig config) =>
    breakoutPct = ((high - rangeHigh) / rangeHigh) * 100
    quickReversal = close < rangeHigh
    breakoutPct >= config.utadThreshold and quickReversal

detectSOS(float rangeLow, float volumeRatio, WyckoffConfig config) =>
    rallyPct = ((close - rangeLow) / rangeLow) * 100
    isHighVolume = volumeRatio >= 1.5
    isUpBar = close > open
    rallyPct >= config.sosThreshold and isHighVolume and isUpBar

detectSOW(float rangeHigh, float volumeRatio, WyckoffConfig config) =>
    declinePct = ((rangeHigh - close) / rangeHigh) * 100
    isHighVolume = volumeRatio >= 1.5
    isDownBar = close < open
    declinePct >= config.sowThreshold and isHighVolume and isDownBar


// ============================================================================
// MODULE: subphase_detection
// ============================================================================

// ============================================================================
// SUB-PHASE EVENT DETECTION
// ============================================================================

detectAccumulationEvents(WyckoffState state, float volumeRatio, float prevRangeLow, WyckoffConfig config) =>
    currentPhase = state.currentPhase

    if detectSpring(prevRangeLow, config) and currentPhase.subphase != "SPRING"
        currentPhase.subphase := "SPRING"
        event = newWyckoffEvent("SPRING", "False breakdown to trap sellers", low)
        event.volumeRatio := volumeRatio
        event.significance := 85.0
        array.push(state.events, event)
        true
    else if detectSOS(currentPhase.rangeLow, volumeRatio, config) and currentPhase.subphase != "SOS"
        currentPhase.subphase := "SOS"
        event = newWyckoffEvent("SOS", "Sign of Strength - Strong rally on volume", low)
        event.volumeRatio := volumeRatio
        event.significance := 80.0
        array.push(state.events, event)
        true
    else
        false

detectDistributionEvents(WyckoffState state, float volumeRatio, float prevRangeHigh, WyckoffConfig config) =>
    currentPhase = state.currentPhase

    if detectUTAD(prevRangeHigh, config) and currentPhase.subphase != "UTAD"
        currentPhase.subphase := "UTAD"
        event = newWyckoffEvent("UTAD", "Upthrust After Distribution - False breakout", high)
        event.volumeRatio := volumeRatio
        event.significance := 85.0
        array.push(state.events, event)
        true
    else if detectSOW(currentPhase.rangeHigh, volumeRatio, config) and currentPhase.subphase != "SOW"
        currentPhase.subphase := "SOW"
        event = newWyckoffEvent("SOW", "Sign of Weakness - Sharp decline on volume", high)
        event.volumeRatio := volumeRatio
        event.significance := 80.0
        array.push(state.events, event)
        true
    else
        false


// ============================================================================
// MODULE: phase_identification
// ============================================================================

// ============================================================================
// PHASE IDENTIFICATION
// ============================================================================

identifyWyckoffPhase(WyckoffState state, float volumeAvg, float spreadAvg, WyckoffConfig config) =>
    volumeRatio = volume / volumeAvg
    spread = high - low

    state.effortResult := analyzeEffortResult(volume, volumeAvg, spread, spreadAvg)

    isSellingClimax = detectSellingClimax(volumeRatio, config)
    isBuyingClimax  = detectBuyingClimax(volumeRatio, config)

    if na(state.currentPhase)
        state.currentPhase := newWyckoffPhase("RANGING", "PS")

    prevRangeHigh = state.currentPhase.rangeHigh
    prevRangeLow  = state.currentPhase.rangeLow

    // === Climax overrides existing phase (creates fresh phase) ===
    if isSellingClimax and state.currentPhase.name != "ACCUMULATION"
        state.previousPhase := state.currentPhase
        state.currentPhase := newWyckoffPhase("ACCUMULATION", "SC")
        state.compositeOperator := "ACCUMULATING"
        scEvent = newWyckoffEvent("SC", "Selling Climax - Panic selling exhaustion", low)
        scEvent.volumeRatio := volumeRatio
        scEvent.significance := 90.0
        array.push(state.events, scEvent)
    else if isBuyingClimax and state.currentPhase.name != "DISTRIBUTION"
        state.previousPhase := state.currentPhase
        state.currentPhase := newWyckoffPhase("DISTRIBUTION", "BC")
        state.compositeOperator := "DISTRIBUTING"
        bcEvent = newWyckoffEvent("BC", "Buying Climax - Euphoric buying exhaustion", high)
        bcEvent.volumeRatio := volumeRatio
        bcEvent.significance := 90.0
        array.push(state.events, bcEvent)

    // === Phase A: Range establishment ===
    currentPhase = state.currentPhase
    phaseAge = bar_index - currentPhase.startBar
    bool rangeFrozen = not na(currentPhase.rangeEstablishedBar)
    bool isAccumOrDistrib = currentPhase.name == "ACCUMULATION" or currentPhase.name == "DISTRIBUTION"

    if not rangeFrozen
        if high > currentPhase.rangeHigh
            currentPhase.rangeHigh := high
        if low < currentPhase.rangeLow
            currentPhase.rangeLow := low
        // Freeze range after establishment window
        if isAccumOrDistrib and phaseAge >= config.rangeEstablishBars
            currentPhase.rangeEstablishedBar := bar_index
            rangeFrozen := true

    // === Phase B: Spring/UTAD/SOS/SOW detection (skip on phase-creation bar) ===
    if currentPhase.name == "ACCUMULATION" and phaseAge > 0
        detectAccumulationEvents(state, volumeRatio, prevRangeLow, config)
    else if currentPhase.name == "DISTRIBUTION" and phaseAge > 0
        detectDistributionEvents(state, volumeRatio, prevRangeHigh, config)

    // === Phase D: Breakout / invalidation from frozen range ===
    float rangeWidth = currentPhase.rangeHigh - currentPhase.rangeLow
    float invalidationBuffer = rangeWidth * config.invalidationFactor

    if currentPhase.name == "ACCUMULATION" and rangeFrozen
        if close > currentPhase.rangeHigh
            breakoutLevel = currentPhase.rangeHigh
            state.previousPhase := currentPhase
            state.currentPhase := newWyckoffPhase("MARKUP", "BU")
            state.currentPhase.rangeLow := breakoutLevel
            state.compositeOperator := "NEUTRAL"
        else if close < currentPhase.rangeLow - invalidationBuffer
            state.previousPhase := currentPhase
            state.currentPhase := newWyckoffPhase("RANGING", "FAIL")
            state.compositeOperator := "NEUTRAL"
    else if currentPhase.name == "DISTRIBUTION" and rangeFrozen
        if close < currentPhase.rangeLow
            breakdownLevel = currentPhase.rangeLow
            state.previousPhase := currentPhase
            state.currentPhase := newWyckoffPhase("MARKDOWN", "MD")
            state.currentPhase.rangeHigh := breakdownLevel
            state.compositeOperator := "NEUTRAL"
        else if close > currentPhase.rangeHigh + invalidationBuffer
            state.previousPhase := currentPhase
            state.currentPhase := newWyckoffPhase("RANGING", "FAIL")
            state.compositeOperator := "NEUTRAL"
    else if currentPhase.name == "MARKUP"
        // Markup channel grows upward; reverse close below entry-low ends the trend
        if high > currentPhase.rangeHigh
            currentPhase.rangeHigh := high
        if close < currentPhase.rangeLow
            state.previousPhase := currentPhase
            state.currentPhase := newWyckoffPhase("RANGING", "")
            state.compositeOperator := "NEUTRAL"
    else if currentPhase.name == "MARKDOWN"
        if low < currentPhase.rangeLow
            currentPhase.rangeLow := low
        if close > currentPhase.rangeHigh
            state.previousPhase := currentPhase
            state.currentPhase := newWyckoffPhase("RANGING", "")
            state.compositeOperator := "NEUTRAL"

    // === Cause / Effect ===
    finalPhase = state.currentPhase
    if finalPhase.name == "ACCUMULATION" or finalPhase.name == "DISTRIBUTION"
        finalRangeWidth = finalPhase.rangeHigh - finalPhase.rangeLow
        rangeDuration = bar_index - finalPhase.startBar
        state.causeBuilt := finalRangeWidth * rangeDuration
        state.effectExpected := finalRangeWidth * math.sqrt(rangeDuration / 100)

updateWyckoffAnalysis(WyckoffState state, float volumeAvg, float spreadAvg, WyckoffConfig config) =>
    identifyWyckoffPhase(state, volumeAvg, spreadAvg, config)
    state.lastUpdateBar := bar_index


// ============================================================================
// MODULE: query_functions
// ============================================================================

// ============================================================================
// QUERY FUNCTIONS
// ============================================================================

getCurrentWyckoffPhase(WyckoffState state) =>
    na(state.currentPhase) ? "UNKNOWN" : state.currentPhase.name

getCurrentSubphase(WyckoffState state) =>
    na(state.currentPhase) ? "" : state.currentPhase.subphase

isAccumulating(WyckoffState state) =>
    if na(state.currentPhase)
        false
    else
        state.currentPhase.name == "ACCUMULATION" or state.compositeOperator == "ACCUMULATING"

isDistributing(WyckoffState state) =>
    if na(state.currentPhase)
        false
    else
        state.currentPhase.name == "DISTRIBUTION" or state.compositeOperator == "DISTRIBUTING"

isMarkup(WyckoffState state) =>
    if na(state.currentPhase)
        false
    else
        state.currentPhase.name == "MARKUP"

isMarkdown(WyckoffState state) =>
    if na(state.currentPhase)
        false
    else
        state.currentPhase.name == "MARKDOWN"

getRecentEvents(WyckoffState state, int count = 5) =>
    events = state.events
    size = array.size(events)
    recentEvents = array.new<WyckoffEvent>()

    if size > 0
        startIdx = math.max(0, size - count)
        for i = startIdx to size - 1
            array.push(recentEvents, array.get(events, i))

    recentEvents


// ============================================================================
// MODULE: analysis
// ============================================================================

// ============================================================================
// WYCKOFF ANALYSIS ENGINE
// ============================================================================

var wyckoffState = newWyckoffState()
var wyckoffConfig = newWyckoffConfig()

float volumeAvg = ta.sma(volume, volumeLookback)
float spreadAvg = ta.sma(high - low, 20)

bool dataReady = not na(volumeAvg) and not na(spreadAvg) and volumeAvg > 0 and spreadAvg > 0 and high > low and close > 0
if dataReady
    updateWyckoffAnalysis(wyckoffState, volumeAvg, spreadAvg, wyckoffConfig)


// ============================================================================
// MODULE: visualization
// ============================================================================

// ============================================================================
// VISUALIZATION - PHASE RANGES, EVENT LABELS, EFFORT VS RESULT
// ============================================================================

// ─── PHASE RANGES ───
var box phaseBox = na
var label phaseLabel = na

bool drawPhaseBox = not na(wyckoffState.currentPhase) and wyckoffState.currentPhase.name != "RANGING"

if showPhaseRanges and not drawPhaseBox
    // Phase is RANGING (or none) — clean up any leftover box/label
    if not na(phaseBox)
        box.delete(phaseBox)
        phaseBox := na
    if not na(phaseLabel)
        label.delete(phaseLabel)
        phaseLabel := na

if showPhaseRanges and drawPhaseBox
    currentPhase = wyckoffState.currentPhase

    phaseColor = currentPhase.name == "ACCUMULATION" ? accumColor : currentPhase.name == "DISTRIBUTION" ? distribColor : currentPhase.name == "MARKUP" ? markupColor : currentPhase.name == "MARKDOWN" ? markdownColor : color.new(color.gray, 85)

    // Create new box only when phase changes
    if bar_index == currentPhase.startBar or na(phaseBox)
        // Delete old box if exists
        if not na(phaseBox)
            box.delete(phaseBox)
        if not na(phaseLabel)
            label.delete(phaseLabel)

        // Create new box
        phaseBox := box.new( currentPhase.startBar, currentPhase.rangeHigh, bar_index, currentPhase.rangeLow, border_color=phaseColor, bgcolor=phaseColor, border_width=2 )

        // Create label
        labelText = currentPhase.subphase != "" ? str.format("{0}\n{1}", currentPhase.name, currentPhase.subphase) : currentPhase.name

        phaseLabel := label.new( currentPhase.startBar, currentPhase.rangeHigh, labelText, color=color.new(color.black, 20), textcolor=color.white, style=label.style_label_down, size=size.normal )
    else
        // Update existing box
        box.set_right(phaseBox, bar_index)
        box.set_top(phaseBox, currentPhase.rangeHigh)
        box.set_bottom(phaseBox, currentPhase.rangeLow)
        box.set_border_color(phaseBox, phaseColor)
        box.set_bgcolor(phaseBox, phaseColor)
        // Update label text and position
        labelText = currentPhase.subphase != "" ? str.format("{0}\n{1}", currentPhase.name, currentPhase.subphase) : currentPhase.name
        label.set_text(phaseLabel, labelText)
        label.set_y(phaseLabel, currentPhase.rangeHigh)
        label.set_textcolor(phaseLabel, color.white)

// ─── EVENT LABELS ───
if showEventLabels
    recentEvents = getRecentEvents(wyckoffState, 20)

    if array.size(recentEvents) > 0
        for i = 0 to array.size(recentEvents) - 1
            event = array.get(recentEvents, i)

            if bar_index - event.bar <= eventLookback and not event.labeled
                eventColor = color.new(color.blue, 0)
                eventStyle = label.style_label_up

                if event.eventType == "SC"
                    eventColor := color.new(color.green, 0)
                    eventStyle := label.style_label_up
                else if event.eventType == "BC"
                    eventColor := color.new(color.red, 0)
                    eventStyle := label.style_label_down
                else if event.eventType == "SPRING"
                    eventColor := color.new(color.lime, 0)
                    eventStyle := label.style_label_up
                else if event.eventType == "UTAD"
                    eventColor := color.new(color.maroon, 0)
                    eventStyle := label.style_label_down
                else if event.eventType == "SOS"
                    eventColor := color.new(color.aqua, 0)
                    eventStyle := label.style_label_up
                else if event.eventType == "SOW"
                    eventColor := color.new(color.orange, 0)
                    eventStyle := label.style_label_down

                label.new( event.bar, event.price, event.eventType, color=eventColor, textcolor=color.white, style=eventStyle, size=size.small, tooltip=event.description )
                event.labeled := true

// ─── EFFORT VS RESULT MARKERS ───
// Small triangles at bar bottom to indicate divergences without cluttering chart
if showEffortMarkers and not na(wyckoffState.effortResult) and barstate.isconfirmed and bar_index > last_bar_index - eventLookback
    effortResult = wyckoffState.effortResult

    if effortResult.relationship == "CLIMAX" and effortResult.strength >= 70
        markerColor = effortResult.isPositive ? color.new(color.green, 0) : color.new(color.red, 0)
        label.new( bar_index, low, "⚠", color=color(na), textcolor=markerColor, style=label.style_label_up, size=size.tiny, tooltip=str.format("Climax: High effort ({0}x vol), low result ({1}x spread)", str.tostring(effortResult.effort, "#.#"), str.tostring(effortResult.result, "#.#")) )

    else if effortResult.relationship == "DIVERGENCE" and effortResult.strength >= 70
        markerColor = effortResult.isPositive ? color.new(color.lime, 0) : color.new(color.orange, 0)
        label.new( bar_index, low, "◆", color=color(na), textcolor=markerColor, style=label.style_label_up, size=size.tiny, tooltip=str.format("Divergence: Low effort ({0}x vol), high result ({1}x spread)", str.tostring(effortResult.effort, "#.#"), str.tostring(effortResult.result, "#.#")) )


// ============================================================================
// MODULE: dashboard
// ============================================================================

// ============================================================================
// DASHBOARD
// ============================================================================

if showDashboard and barstate.islast
    color tc = color.new(color.gray, 20)
    color hd = color.new(color.gray, 90)

    var table dashboard = table.new(position.top_right, 2, 12,
         bgcolor=color.new(color.white, 5),
         border_color=color.new(color.gray, 60),
         border_width=1,
         frame_color=color.new(color.gray, 40),
         frame_width=1)

    table.cell(dashboard, 0, 0, "Wyckoff",  text_color=tc, bgcolor=hd, text_size=size.small)
    table.cell(dashboard, 1, 0, "State",    text_color=tc, bgcolor=hd, text_size=size.small)

    currentPhase = wyckoffState.currentPhase

    if not na(currentPhase)
        phaseName = getCurrentWyckoffPhase(wyckoffState)
        subphase  = getCurrentSubphase(wyckoffState)
        composite = wyckoffState.compositeOperator

        phaseActive  = phaseName != "RANGING" and phaseName != "UNKNOWN"
        color phaseBg = color.new(color.gray, 80)
        if phaseName == "ACCUMULATION"
            phaseBg := color.new(#00c853, 20)
        else if phaseName == "MARKUP"
            phaseBg := color.new(#00c853, 40)
        else if phaseName == "DISTRIBUTION"
            phaseBg := color.new(#d50000, 20)
        else if phaseName == "MARKDOWN"
            phaseBg := color.new(#d50000, 40)
        phaseTextCol = phaseActive ? color.white : tc
        table.cell(dashboard, 0, 1, "Phase",   text_color=tc,           text_size=size.small)
        table.cell(dashboard, 1, 1, phaseName, text_color=phaseTextCol, text_size=size.small, bgcolor=phaseBg)

        table.cell(dashboard, 0, 2, "Event",                                text_color=tc, text_size=size.small)
        table.cell(dashboard, 1, 2, subphase != "" ? subphase : "—", text_color=tc, text_size=size.small)

        compActive  = composite == "ACCUMULATING" or composite == "DISTRIBUTING"
        color compBg = color.new(color.gray, 80)
        if composite == "ACCUMULATING"
            compBg := color.new(#00c853, 20)
        else if composite == "DISTRIBUTING"
            compBg := color.new(#d50000, 20)
        compTextCol = compActive ? color.white : tc
        table.cell(dashboard, 0, 3, "Operator", text_color=tc,          text_size=size.small)
        table.cell(dashboard, 1, 3, composite,  text_color=compTextCol, text_size=size.small, bgcolor=compBg)

        table.cell(dashboard, 0, 4, "", bgcolor=color.new(color.gray, 80))
        table.cell(dashboard, 1, 4, "", bgcolor=color.new(color.gray, 80))

        rangeBars    = bar_index - currentPhase.startBar
        rangeWidth   = currentPhase.rangeHigh - currentPhase.rangeLow
        rangeWidthPct = (rangeWidth / currentPhase.rangeLow) * 100
        table.cell(dashboard, 0, 5, "Range",  text_color=tc, text_size=size.small)
        table.cell(dashboard, 1, 5, str.tostring(rangeBars) + "b  " + str.tostring(rangeWidthPct, "#.#") + "%", text_color=tc, text_size=size.small)

        table.cell(dashboard, 0, 6, "Cause",  text_color=tc, text_size=size.small)
        table.cell(dashboard, 1, 6, str.tostring(wyckoffState.causeBuilt, "#"), text_color=tc, text_size=size.small)

        table.cell(dashboard, 0, 7, "Effect", text_color=tc, text_size=size.small)
        table.cell(dashboard, 1, 7, str.tostring(wyckoffState.effectExpected, "#.##"), text_color=tc, text_size=size.small)

        table.cell(dashboard, 0, 8, "", bgcolor=color.new(color.gray, 80))
        table.cell(dashboard, 1, 8, "", bgcolor=color.new(color.gray, 80))

        if not na(wyckoffState.effortResult)
            effortResult = wyckoffState.effortResult

            table.cell(dashboard, 0, 9,  "Effort", text_color=tc, text_size=size.small)
            table.cell(dashboard, 1, 9,  str.tostring(effortResult.effort, "#.##") + "x", text_color=tc, text_size=size.small)

            table.cell(dashboard, 0, 10, "Result", text_color=tc, text_size=size.small)
            table.cell(dashboard, 1, 10, str.tostring(effortResult.result, "#.##") + "x",  text_color=tc, text_size=size.small)

            erActive  = effortResult.relationship != "CONFIRMATION"
            color erBg = color.new(color.gray, 80)
            if effortResult.relationship == "CLIMAX"
                erBg := color.new(#d50000, 20)
            else if effortResult.relationship == "DIVERGENCE"
                erBg := color.new(#ff6f00, 20)
            erTextCol = erActive ? color.white : tc
            table.cell(dashboard, 0, 11, "E/R",                     text_color=tc,        text_size=size.small)
            table.cell(dashboard, 1, 11, effortResult.relationship,  text_color=erTextCol, text_size=size.small, bgcolor=erBg)

    else
        table.cell(dashboard, 0, 1, "Status",       text_color=tc, text_size=size.small)
        table.cell(dashboard, 1, 1, "Detecting…",   text_color=tc, text_size=size.small)


// ============================================================================
// MODULE: alerts
// ============================================================================

// ============================================================================
// ALERTS
// ============================================================================

bool accumulationStarted = isAccumulating(wyckoffState) and not isAccumulating(wyckoffState)[1]
alertcondition(accumulationStarted, "Accumulation Started", "Wyckoff: Accumulation phase started")

bool distributionStarted = isDistributing(wyckoffState) and not isDistributing(wyckoffState)[1]
alertcondition(distributionStarted, "Distribution Started", "Wyckoff: Distribution phase started")

bool markupStarted = isMarkup(wyckoffState) and not isMarkup(wyckoffState)[1]
alertcondition(markupStarted, "Markup Started", "Wyckoff: Markup phase started - Bullish move expected")

bool markdownStarted = isMarkdown(wyckoffState) and not isMarkdown(wyckoffState)[1]
alertcondition(markdownStarted, "Markdown Started", "Wyckoff: Markdown phase started - Bearish move expected")

bool climaxDetected = not na(wyckoffState.effortResult) and wyckoffState.effortResult.relationship == "CLIMAX" and wyckoffState.effortResult.strength >= 80
alertcondition(climaxDetected, "Climax Detected", "Wyckoff: Climax action - High effort, low result")


