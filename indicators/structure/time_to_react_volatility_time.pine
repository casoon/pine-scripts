//@version=6
// ============================================================================
// Time-to-React + Volatility-Time (BOS / Sweep / OB) [Scores + Candle Color] [WavesUnchained]
// Version: 1.0.0
// Author: WavesUnchained
// Build: 2025-12-20 20:22:17
// ============================================================================
// Event reaction scoring (BOS/Sweep/OB) with volatility activity and candle coloring
//
// Features:
//   ✓ Auto presets by timeframe with custom overrides
//   ✓ BOS/Sweep/OB event prioritization
//   ✓ Reaction and validation scoring
//   ✓ Volatility activity score
//   ✓ Optional chart labels and candle coloring
//
// ============================================================================
indicator("Time-to-React + Volatility-Time (BOS / Sweep / OB) [Scores + Candle Color] [WavesUnchained]", overlay=false, max_labels_count=200)

// ═══════════════════════════════════════════════════════════════════════════
// Time-to-React + Volatility-Time
// ═══════════════════════════════════════════════════════════════════════════
// Version: 1.0.0
// Author: WavesUnchained
//
// MODULES:
// - inputs.pine
// - helpers.pine
// - swings_ob.pine
// - events.pine
// - scores.pine
// - plots.pine
// ═══════════════════════════════════════════════════════════════════════════

// NOTE: Modules are combined by the build system.

// ============================================================================
// INLINE MODULES (Combined at build time)
// ============================================================================

// ============================================================================
// MODULE: inputs
// ============================================================================

//──────────────────────────────────────────────────────────────────────────────
// Inputs
//──────────────────────────────────────────────────────────────────────────────
preset = input.string("Auto", "Preset", options=["Auto","15m","1h","4h","D","M","Custom"])

customReactMin = input.int(150, "Custom: Reaction Window (min)", minval=5)
customValidMin = input.int(420, "Custom: Validation Window (min)", minval=10)

atrLen     = input.int(14, "ATR Length", minval=1)
atrBaseLen = input.int(50, "ATR Base Length (Activity)", minval=5)
activityK  = input.float(1.2, "Activity Curve Sensitivity", minval=0.1, step=0.1)

pivotLen   = input.int(3, "Swing Pivot Length (BOS/Sweep)", minval=1, maxval=20)

atrMoveMult = input.float(1.2, "B: Minimum Move (ATR Mult)", minval=0.1, step=0.1)
wA = input.float(0.6, "Validation Weight A (Break)", minval=0.0, maxval=1.0, step=0.05)
wB = input.float(0.4, "Validation Weight B (ATR Move)", minval=0.0, maxval=1.0, step=0.05)

wSpeed = input.float(0.45, "Final Weight: Speed", minval=0.0, maxval=1.0, step=0.05)
wVal   = input.float(0.55, "Final Weight: Validation", minval=0.0, maxval=1.0, step=0.05)

dispBodyATR = input.float(1.0, "OB: Displacement Body > x*ATR", minval=0.1, step=0.1)
obSearchBars = input.int(12, "OB: Search Back Bars", minval=2, maxval=50)

priority = input.string("BOS>SWEEP>OB", "Event Priority", options=["BOS>SWEEP>OB","SWEEP>BOS>OB","OB>BOS>SWEEP"])

showLabels = input.bool(true, "Show Labels on Chart")
labelAlpha = input.int(0, "Label Background Transparency (0=solid)", minval=0, maxval=90)


// ============================================================================
// MODULE: helpers
// ============================================================================

//──────────────────────────────────────────────────────────────────────────────
// Helpers
//──────────────────────────────────────────────────────────────────────────────
clamp01(x) => math.max(0.0, math.min(1.0, x))
clamp100(x) => math.max(0.0, math.min(100.0, x))

tfSec = timeframe.in_seconds(timeframe.period)
tfMin = tfSec / 60.0

// Preset resolver (minutes)
f_presets(_preset, _tfMin) =>
    float r = na
    float v = na
    float atrM = na
    float _wA = na
    float _wB = na
    float _wSpeed = na
    float _wVal = na

    r := 150
    v := 420
    atrM := 1.2
    _wA := 0.6
    _wB := 0.4
    _wSpeed := 0.45
    _wVal := 0.55

    if _preset == "15m"
        r := 150, v := 420, atrM := 1.2, _wA := 0.6, _wB := 0.4, _wSpeed := 0.45, _wVal := 0.55
    else if _preset == "1h"
        r := 480, v := 1200, atrM := 1.6, _wA := 0.7, _wB := 0.3, _wSpeed := 0.40, _wVal := 0.60
    else if _preset == "4h"
        r := 2160, v := 5760, atrM := 2.0, _wA := 0.75, _wB := 0.25, _wSpeed := 0.35, _wVal := 0.65
    else if _preset == "D"
        r := 7200, v := 17280, atrM := 2.4, _wA := 0.8, _wB := 0.2, _wSpeed := 0.30, _wVal := 0.70
    else if _preset == "M"
        r := 86400, v := 172800, atrM := 3.0, _wA := 0.85, _wB := 0.15, _wSpeed := 0.25, _wVal := 0.75
    else if _preset == "Auto"
        if _tfMin <= 20
            r := 150, v := 420, atrM := 1.2, _wA := 0.6, _wB := 0.4, _wSpeed := 0.45, _wVal := 0.55
        else if _tfMin <= 90
            r := 480, v := 1200, atrM := 1.6, _wA := 0.7, _wB := 0.3, _wSpeed := 0.40, _wVal := 0.60
        else if _tfMin <= 300
            r := 2160, v := 5760, atrM := 2.0, _wA := 0.75, _wB := 0.25, _wSpeed := 0.35, _wVal := 0.65
        else if _tfMin <= 10080
            r := 7200, v := 17280, atrM := 2.4, _wA := 0.8, _wB := 0.2, _wSpeed := 0.30, _wVal := 0.70
        else
            r := 86400, v := 172800, atrM := 3.0, _wA := 0.85, _wB := 0.15, _wSpeed := 0.25, _wVal := 0.75
    [r, v, atrM, _wA, _wB, _wSpeed, _wVal]

[pReactMin, pValidMin, pAtrMoveMult, pWA, pWB, pWSpeed, pWVal] = f_presets(preset, tfMin)

reactMin = preset == "Custom" ? customReactMin : int(pReactMin)
validMin = preset == "Custom" ? customValidMin : int(pValidMin)
atrMult  = preset == "Custom" ? atrMoveMult : pAtrMoveMult

wAeff = preset == "Custom" ? wA : pWA
wBeff = preset == "Custom" ? wB : pWB
wSpeedEff = preset == "Custom" ? wSpeed : pWSpeed
wValEff   = preset == "Custom" ? wVal   : pWVal

sumValW = math.max(0.0001, wAeff + wBeff)
wAeffN = wAeff / sumValW
wBeffN = wBeff / sumValW

sumFinalW = math.max(0.0001, wSpeedEff + wValEff)
wSpeedN = wSpeedEff / sumFinalW
wValN   = wValEff / sumFinalW

reactBars = int(math.ceil((reactMin * 60.0) / tfSec))
validBars = int(math.ceil((validMin * 60.0) / tfSec))


// ============================================================================
// MODULE: swings_ob
// ============================================================================

//──────────────────────────────────────────────────────────────────────────────
// Swings (for BOS & Sweep) + OB (simple displacement-based)
//──────────────────────────────────────────────────────────────────────────────
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low, pivotLen, pivotLen)

var float lastSwingHigh = na
var int   lastSwingHighBar = na
var float lastSwingLow = na
var int   lastSwingLowBar = na

if not na(ph)
    lastSwingHigh := ph
    lastSwingHighBar := bar_index - pivotLen

if not na(pl)
    lastSwingLow := pl
    lastSwingLowBar := bar_index - pivotLen

atr = ta.atr(atrLen)

isDispUp = (close > open) and (math.abs(close - open) > dispBodyATR * atr) and (close > high[1])
isDispDn = (close < open) and (math.abs(close - open) > dispBodyATR * atr) and (close < low[1])

var float bullObHigh = na
var float bullObLow  = na
var int   bullObBar  = na

var float bearObHigh = na
var float bearObLow  = na
var int   bearObBar  = na

if isDispUp
    float hi = na, lo = na
    int obB = na
    for i = 1 to obSearchBars
        if close[i] < open[i]
            hi := high[i]
            lo := low[i]
            obB := bar_index - i
            break
    if not na(obB)
        bullObHigh := hi
        bullObLow  := lo
        bullObBar  := obB

if isDispDn
    float hi = na, lo = na
    int obB = na
    for i = 1 to obSearchBars
        if close[i] > open[i]
            hi := high[i]
            lo := low[i]
            obB := bar_index - i
            break
    if not na(obB)
        bearObHigh := hi
        bearObLow  := lo
        bearObBar  := obB

bullObTap = not na(bullObHigh) and (low <= bullObHigh) and (high >= bullObLow)
bearObTap = not na(bearObLow)  and (high >= bearObLow) and (low <= bearObHigh)

bosUp = not na(lastSwingHigh) and bar_index > lastSwingHighBar and close > lastSwingHigh and close[1] <= lastSwingHigh
bosDn = not na(lastSwingLow)  and bar_index > lastSwingLowBar  and close < lastSwingLow  and close[1] >= lastSwingLow

sweepUp = not na(lastSwingHigh) and bar_index > lastSwingHighBar and high > lastSwingHigh and close < lastSwingHigh
sweepDn = not na(lastSwingLow)  and bar_index > lastSwingLowBar  and low < lastSwingLow  and close > lastSwingLow


// ============================================================================
// MODULE: events
// ============================================================================

//──────────────────────────────────────────────────────────────────────────────
// Event engine (single active event with priority)
//──────────────────────────────────────────────────────────────────────────────
var bool  eventActive = false
var string eventType = ""
var int   eventDir = 0
var int   eventBar = na
var float eventRef = na
var float eventAtr = na

var bool  reacFound = false
var int   reacBar = na
var float reacHi = na
var float reacLo = na

var bool  valA = false
var float valBProgress = 0.0

var float speedScore = na
var float valScore = na
var float reactionScore = na

f_reset() =>
    eventActive := false
    eventType := ""
    eventDir := 0
    eventBar := na
    eventRef := na
    eventAtr := na
    reacFound := false
    reacBar := na
    reacHi := na
    reacLo := na
    valA := false
    valBProgress := 0.0
    speedScore := na
    valScore := na
    reactionScore := na

f_pickEvent() =>
    bool fire = false
    string t = ""
    int d = 0
    float ref = na

    bool cBOS = (bosUp or bosDn)
    bool cSWP = (sweepUp or sweepDn)
    bool cOB  = (bullObTap or bearObTap)

    setBOS() =>
        fire := true
        t := "BOS"
        d := bosUp ? 1 : -1
        ref := bosUp ? lastSwingHigh : lastSwingLow

    setSWP() =>
        fire := true
        t := "SWEEP"
        d := sweepDn ? 1 : -1
        ref := sweepDn ? lastSwingLow : lastSwingHigh

    setOB() =>
        fire := true
        t := "OB"
        d := bullObTap ? 1 : -1
        ref := bullObTap ? bullObHigh : bearObLow

    if priority == "BOS>SWEEP>OB"
        if cBOS
            setBOS()
        else if cSWP
            setSWP()
        else if cOB
            setOB()
    else if priority == "SWEEP>BOS>OB"
        if cSWP
            setSWP()
        else if cBOS
            setBOS()
        else if cOB
            setOB()
    else
        if cOB
            setOB()
        else if cBOS
            setBOS()
        else if cSWP
            setSWP()

    [fire, t, d, ref]

[fireEvt, tEvt, dEvt, refEvt] = f_pickEvent()
if not eventActive and fireEvt
    eventActive := true
    eventType := tEvt
    eventDir := dEvt
    eventBar := bar_index
    eventRef := refEvt
    eventAtr := atr

    if showLabels
        colBg = eventDir == 1 ? color.new(color.lime, labelAlpha) : color.new(color.red, labelAlpha)
        label.new(bar_index, close, text=eventType + (eventDir == 1 ? " ↑" : " ↓"),
          style=label.style_label_up, textcolor=color.white, color=colBg, size=size.normal)

if eventActive
    ageBars = bar_index - eventBar

    if not reacFound
        bullReac = (close > open) or (low >= low[1])
        bearReac = (close < open) or (high <= high[1])

        if (eventDir == 1 and bullReac)
            reacFound := true
            reacBar := bar_index
            reacHi := high
            reacLo := low
            if showLabels
                label.new(bar_index, high, text="Reac", style=label.style_label_down,
                  textcolor=color.black, color=color.new(color.yellow, labelAlpha), size=size.normal)

        if (eventDir == -1 and bearReac)
            reacFound := true
            reacBar := bar_index
            reacHi := high
            reacLo := low
            if showLabels
                label.new(bar_index, low, text="Reac", style=label.style_label_up,
                  textcolor=color.black, color=color.new(color.yellow, labelAlpha), size=size.normal)

    if reacFound and na(speedScore)
        barsToReact = reacBar - eventBar
        speedScore := 100.0 * clamp01(1.0 - (barsToReact / math.max(1.0, reactBars)))

    if reacFound
        barsSinceReac = bar_index - reacBar
        inValidWindow = barsSinceReac <= validBars

        if not valA and inValidWindow
            if eventDir == 1
                valA := close > reacHi
            else
                valA := close < reacLo

        moveTarget = atrMult * eventAtr
        moveNow = eventDir == 1 ? (high - eventRef) : (eventRef - low)
        valBProgress := clamp01(moveTarget > 0 ? (moveNow / moveTarget) : 0)

        valScore := 100.0 * (wAeffN * (valA ? 1.0 : 0.0) + wBeffN * valBProgress)
        reactionScore := clamp100(wSpeedN * speedScore + wValN * valScore)

        if barsSinceReac > validBars
            eventActive := false

    if not reacFound and ageBars > reactBars
        speedScore := 0
        valScore := 0
        reactionScore := 0
        eventActive := false


// ============================================================================
// MODULE: scores
// ============================================================================

//──────────────────────────────────────────────────────────────────────────────
// Scores
//──────────────────────────────────────────────────────────────────────────────
plotScore = eventActive or (not na(reactionScore) and (bar_index - nz(reacBar, bar_index)) <= 3) ? reactionScore : na

atrBase = ta.sma(atr, atrBaseLen)
ratio = atrBase > 0 ? (atr / atrBase) : 1.0
activityScore = 50.0 + 50.0 * math.tanh((ratio - 1.0) * activityK)
activityScore := clamp100(activityScore)


// ============================================================================
// MODULE: plots
// ============================================================================

//──────────────────────────────────────────────────────────────────────────────
// Plots (panel) + candle coloring
//──────────────────────────────────────────────────────────────────────────────
hline(50, "Mid (50)", color=color.new(color.gray, 65))
hline(70, "Strong (70)", color=color.new(color.gray, 75))
hline(30, "Weak (30)", color=color.new(color.gray, 75))

reacCol = not na(plotScore) ? color.from_gradient(plotScore, 0, 100, color.red, color.lime) : color.new(color.gray, 90)
plot(plotScore, "ReactionScore (0-100)", color=reacCol, linewidth=3)

actCol = color.from_gradient(activityScore, 0, 100, color.new(color.gray, 10), color.aqua)
plot(activityScore, "ActivityScore (0-100)", color=actCol, linewidth=2, style=plot.style_line)

barCol = na
if eventActive and not na(reactionScore)
    base = eventDir == 1 ? color.lime : color.red
    barCol := color.from_gradient(reactionScore, 0, 100, color.new(base, 70), color.new(base, 0))

barcolor(barCol)


