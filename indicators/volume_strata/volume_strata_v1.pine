//@version=6
// ============================================================================
// Volume Strata [WavesUnchained]
// Version: 1.2
// Author: WavesUnchained
// Build: 2026-04-27 00:00:00
// ============================================================================
// Fixed-range volume profile anchored to the right, with POC, VAH/VAL,
// HVN/LVN markers, context table, and alerts.
//
// Features:
//   ✓ Right-anchored bars — profile grows left into the candle range
//   ✓ Up / down volume split per row, value area highlighted
//   ✓ Point of Control (POC) – dashed line with right-side price label
//   ✓ Value Area High / Low (VAH / VAL) – dotted lines with labels
//   ✓ High Volume Node (HVN) – rows exceeding mean + 1σ
//   ✓ Low Volume Node (LVN) – local minima below mean − 1σ
//   ✓ Info table – levels, up-vol %, VA state, Virgin POC, developing POC, POC distance
//   ✓ Alerts – POC cross, VA entry/exit, VAH/VAL touch
//   ✓ Show Profile toggle – hide bars to display levels only
//
// ============================================================================

indicator('Volume Strata [WavesUnchained]', overlay=true, max_boxes_count=500, max_bars_back=501)

// ── Inputs ────────────────────────────────────────────────────────────────────
var string G_RANGE   = 'Range'
var string G_COLORS  = 'Colors'
var string G_DISPLAY = 'Display'

bbars       = input.int  (150,  'Lookback Bars',             minval=1,  maxval=500,  group=G_RANGE)
cnum        = input.int  (24,   'Rows',                      minval=5,  maxval=100,  group=G_RANGE)
va_pct      = input.float(70.,  'Value Area %',              minval=0., maxval=100., group=G_RANGE)
prof_offset = input.int  (150,  'Profile Offset (bars right)', minval=0, maxval=500, group=G_RANGE)

poc_color   = input.color(#e53935,                    'POC',           inline='poc', group=G_COLORS)
poc_width   = input.int  (2,                          'Width',         inline='poc', group=G_COLORS, minval=1, maxval=5)
va_color    = input.color(color.new(#9e9e9e, 0),      'VAH / VAL',                  group=G_COLORS)
hvn_color   = input.color(#ffd600,                    'HVN',                        group=G_COLORS)
lvn_color   = input.color(#4dd0e1,                    'LVN',                        group=G_COLORS)
vup_color   = input.color(color.new(color.blue,   30),'Value Area Up',              group=G_COLORS)
vdown_color = input.color(color.new(color.orange, 30),'Value Area Down',            group=G_COLORS)
up_color    = input.color(color.new(color.blue,   75),'Outside Up',                 group=G_COLORS)
down_color  = input.color(color.new(color.orange, 75),'Outside Down',               group=G_COLORS)

show_profile = input.bool(true, 'Show profile bars', group=G_DISPLAY)
show_poc     = input.bool(true, 'POC label',         group=G_DISPLAY)
show_va      = input.bool(true, 'VAH / VAL',         group=G_DISPLAY)
show_hvn     = input.bool(true, 'HVN markers',       group=G_DISPLAY)
show_lvn     = input.bool(true, 'LVN markers',       group=G_DISPLAY)
show_table   = input.bool(true, 'Info table',        group=G_DISPLAY)

// ── Persistent drawing objects ────────────────────────────────────────────────
var vol_bars = array.new_box(cnum * 2, na)
var hvn_bars = array.new_box(cnum,     na)
var lvn_bars = array.new_box(cnum,     na)
var line  poc_line = na
var label poc_lbl  = na
var line  vah_line = na
var line  val_line = na
var label vah_lbl  = na
var label val_lbl  = na

// Persisted levels (updated on barstate.islast, used by alertcondition)
var float poc_lvl_p  = na
var float vah_lvl_p  = na
var float val_lvl_p  = na
var float prev_poc_lvl = na

color TC = color.new(color.gray, 20)
color HD = color.new(color.gray, 90)
color SEP = color.new(color.gray, 80)
var table info_tbl = table.new(position.top_right, 2, 10,
     bgcolor=color.new(color.white, 5),
     border_color=color.new(color.gray, 60), border_width=1,
     frame_color=color.new(color.gray, 40), frame_width=1)

// ── ATR (runs every bar for alert and table use) ───────────────────────────────
atr_14 = ta.atr(14)

// ── Level grid ────────────────────────────────────────────────────────────────
top  = ta.highest(bbars)
bot  = ta.lowest (bbars)
rng  = math.max(top - bot, syminfo.mintick)
dist = rng / 500
step = rng / cnum

levels = array.new_float(cnum + 1)
for x = 0 to cnum
    array.set(levels, x, bot + step * x)

// ── Volume intersection helper ─────────────────────────────────────────────────
get_vol(y11, y12, y21, y22, height, vol) =>
    height > 0 ? nz(math.max(math.min(math.max(y11, y12), math.max(y21, y22)) -
                              math.max(math.min(y11, y12), math.min(y21, y22)), 0) * vol / height) : 0.

if barstate.islast
    // ── Accumulate volume per row ──────────────────────────────────────────────
    volumes = array.new_float(cnum * 2, 0.)
    for bars = 0 to bbars - 1
        body_top = math.max(close[bars], open[bars])
        body_bot = math.min(close[bars], open[bars])
        itsgreen = close[bars] >= open[bars]
        tw    = high[bars] - body_top
        bw    = body_bot   - low[bars]
        bd    = body_top   - body_bot
        denom = math.max(2 * tw + 2 * bw + bd, syminfo.mintick)
        bvol  = bd * volume[bars] / denom
        twvol = 2 * tw * volume[bars] / denom
        bwvol = 2 * bw * volume[bars] / denom
        for x = 0 to cnum - 1
            lx  = array.get(levels, x)
            lx1 = array.get(levels, x + 1)
            upv = (itsgreen ? get_vol(lx, lx1, body_bot, body_top, bd, bvol) : 0.) +
                  get_vol(lx, lx1, body_top, high[bars], tw, twvol) / 2 +
                  get_vol(lx, lx1, body_bot, low[bars],  bw, bwvol) / 2
            dnv = (itsgreen ? 0. : get_vol(lx, lx1, body_bot, body_top, bd, bvol)) +
                  get_vol(lx, lx1, body_top, high[bars], tw, twvol) / 2 +
                  get_vol(lx, lx1, body_bot, low[bars],  bw, bwvol) / 2
            array.set(volumes, x,        array.get(volumes, x)        + upv)
            array.set(volumes, x + cnum, array.get(volumes, x + cnum) + dnv)

    // ── Total per row, POC, and stats ──────────────────────────────────────────
    totalvols = array.new_float(cnum, 0.)
    total_up  = 0.
    for x = 0 to cnum - 1
        tv = array.get(volumes, x) + array.get(volumes, x + cnum)
        array.set(totalvols, x, tv)
        total_up += array.get(volumes, x)

    total_all = array.sum(totalvols)
    up_pct    = total_all > 0 ? total_up / total_all * 100 : 50.
    int poc   = array.indexof(totalvols, array.max(totalvols))

    // HVN / LVN thresholds
    vol_mean   = array.avg(totalvols)
    vol_stdev  = array.stdev(totalvols)
    hvn_thresh = vol_mean + vol_stdev
    lvn_thresh = math.max(0., vol_mean - vol_stdev)

    // ── Value area ─────────────────────────────────────────────────────────────
    totalmax = total_all * va_pct / 100.
    va_total = array.get(totalvols, poc)
    int va_up   = poc
    int va_down = poc
    for x = 0 to cnum - 1
        if va_total >= totalmax
            break
        uppervol = va_up   < cnum - 1 ? array.get(totalvols, va_up   + 1) : 0.
        lowervol = va_down > 0         ? array.get(totalvols, va_down - 1) : 0.
        if uppervol == 0. and lowervol == 0.
            break
        if uppervol >= lowervol
            va_total += uppervol
            va_up    += 1
        else
            va_total += lowervol
            va_down  -= 1

    // ── Scale volumes to bar widths ────────────────────────────────────────────
    maxvol = math.max(array.max(totalvols), 1)
    for x = 0 to cnum * 2 - 1
        array.set(volumes, x, array.get(volumes, x) * bbars / (3 * maxvol))

    // ── Key levels ─────────────────────────────────────────────────────────────
    poc_lvl = (array.get(levels, poc) + array.get(levels, poc + 1)) / 2
    vah_lvl = array.get(levels, va_up   + 1)
    val_lvl = array.get(levels, va_down)

    // ── Context: Virgin POC (not touched in last 5 bars) ───────────────────────
    poc_virgin = true
    for t = 0 to 4
        if high[t] >= poc_lvl and low[t] <= poc_lvl
            poc_virgin := false
            break
    vpoc_str = poc_virgin ? 'Virgin' : 'Touched'
    vpoc_col = poc_virgin ? #00c853 : TC

    // ── Context: Developing POC direction ──────────────────────────────────────
    poc_trend_str = na(prev_poc_lvl) ? '—' : poc_lvl > prev_poc_lvl ? '↑ Rising' : poc_lvl < prev_poc_lvl ? '↓ Falling' : '— Stable'
    poc_trend_col = na(prev_poc_lvl) ? TC : poc_lvl > prev_poc_lvl ? #00c853 : poc_lvl < prev_poc_lvl ? #d50000 : TC
    prev_poc_lvl := poc_lvl

    // ── Context: Value Area State ───────────────────────────────────────────────
    va_state     = close > vah_lvl ? 'Above VA' : close < val_lvl ? 'Below VA' : 'Inside VA'
    va_state_col = close > vah_lvl ? #00c853 : close < val_lvl ? #d50000 : TC

    // ── Context: POC Distance in ATR ───────────────────────────────────────────
    poc_dist_raw = atr_14 > 0 ? (close - poc_lvl) / atr_14 : 0.
    poc_dist_str = (poc_dist_raw >= 0 ? '+' : '') + str.tostring(math.round(poc_dist_raw, 2)) + ' ATR'
    poc_dist_col = poc_dist_raw >= 0 ? #00c853 : #d50000

    // Persist levels for alert conditions
    poc_lvl_p := poc_lvl
    vah_lvl_p := vah_lvl
    val_lvl_p := val_lvl

    // ── Volume bars (right-anchored, growing left) ─────────────────────────────
    for x = 0 to cnum - 1
        box.delete(array.get(vol_bars, x))
        box.delete(array.get(vol_bars, x + cnum))
        if show_profile
            in_va   = x >= va_down and x <= va_up
            up_w    = math.round(array.get(volumes, x))
            dn_w    = math.round(array.get(volumes, x + cnum))
            lev_top = array.get(levels, x + 1) - dist
            lev_bot = array.get(levels, x)     + dist
            // up-volume on the right (innermost)
            array.set(vol_bars, x, box.new(
                 bar_index + prof_offset - up_w, lev_top, bar_index + prof_offset, lev_bot,
                 border_width=0, bgcolor=in_va ? vup_color : up_color))
            // down-volume extends further left
            array.set(vol_bars, x + cnum, box.new(
                 bar_index + prof_offset - up_w - dn_w, lev_top, bar_index + prof_offset - up_w, lev_bot,
                 border_width=0, bgcolor=in_va ? vdown_color : down_color))

    // ── HVN markers ────────────────────────────────────────────────────────────
    for x = 0 to cnum - 1
        box.delete(array.get(hvn_bars, x))
        lev_top = array.get(levels, x + 1) - dist
        lev_bot = array.get(levels, x)     + dist
        if show_hvn and array.get(totalvols, x) >= hvn_thresh
            array.set(hvn_bars, x, box.new(
                 bar_index + prof_offset + 1, lev_top, bar_index + prof_offset + 3, lev_bot,
                 border_width=0, bgcolor=color.new(hvn_color, 20)))
        else
            array.set(hvn_bars, x, na)

    // ── LVN markers (local minima below mean − 1σ only) ────────────────────────
    for x = 0 to cnum - 1
        box.delete(array.get(lvn_bars, x))
        lev_top = array.get(levels, x + 1) - dist
        lev_bot = array.get(levels, x)     + dist
        vol_x   = array.get(totalvols, x)
        is_local_min = x > 0 and x < cnum - 1 and
                       vol_x < array.get(totalvols, x - 1) and
                       vol_x < array.get(totalvols, x + 1)
        if show_lvn and is_local_min and vol_x <= lvn_thresh
            array.set(lvn_bars, x, box.new(
                 bar_index + prof_offset + 1, lev_top, bar_index + prof_offset + 3, lev_bot,
                 border_width=0, bgcolor=color.new(lvn_color, 20)))
        else
            array.set(lvn_bars, x, na)

    // ── POC ────────────────────────────────────────────────────────────────────
    line.delete(poc_line)
    poc_line := line.new(bar_index - bbars + 1, poc_lvl, bar_index, poc_lvl,
                         extend=extend.right, color=poc_color, width=poc_width,
                         style=line.style_dashed)
    label.delete(poc_lbl)
    if show_poc
        poc_lbl := label.new(bar_index + prof_offset + (show_hvn or show_lvn ? 5 : 2), poc_lvl,
                             text='POC  ' + str.tostring(math.round_to_mintick(poc_lvl)),
                             style=label.style_label_left,
                             color=poc_color, textcolor=color.white, size=size.small)

    // ── VAH / VAL ──────────────────────────────────────────────────────────────
    line.delete(vah_line)
    line.delete(val_line)
    label.delete(vah_lbl)
    label.delete(val_lbl)
    if show_va
        vah_line := line.new(bar_index - bbars + 1, vah_lvl, bar_index, vah_lvl,
                             extend=extend.right, color=va_color, width=1,
                             style=line.style_dotted)
        val_line := line.new(bar_index - bbars + 1, val_lvl, bar_index, val_lvl,
                             extend=extend.right, color=va_color, width=1,
                             style=line.style_dotted)
        int lbl_x = bar_index + prof_offset + (show_hvn or show_lvn ? 5 : 2)
        vah_lbl := label.new(lbl_x, vah_lvl,
                             text='VAH  ' + str.tostring(math.round_to_mintick(vah_lvl)),
                             style=label.style_label_left,
                             color=va_color, textcolor=color.white, size=size.tiny)
        val_lbl := label.new(lbl_x, val_lvl,
                             text='VAL  ' + str.tostring(math.round_to_mintick(val_lvl)),
                             style=label.style_label_left,
                             color=va_color, textcolor=color.white, size=size.tiny)

    // ── Info table ─────────────────────────────────────────────────────────────
    if show_table
        up_col = up_pct >= 55 ? #00c853 : up_pct <= 45 ? #d50000 : TC
        // Header
        table.cell(info_tbl, 0, 0, 'VOLUME STRATA', text_color=TC, bgcolor=HD, text_size=size.small)
        table.cell(info_tbl, 1, 0, '',               text_color=TC, bgcolor=HD, text_size=size.small)
        // Key levels
        table.cell(info_tbl, 0, 1, 'POC',    text_color=TC,       text_size=size.small)
        table.cell(info_tbl, 1, 1, str.tostring(math.round_to_mintick(poc_lvl)),
                   text_color=poc_color, text_size=size.small)
        table.cell(info_tbl, 0, 2, 'VAH',    text_color=TC,       text_size=size.small)
        table.cell(info_tbl, 1, 2, str.tostring(math.round_to_mintick(vah_lvl)),
                   text_color=TC, text_size=size.small)
        table.cell(info_tbl, 0, 3, 'VAL',    text_color=TC,       text_size=size.small)
        table.cell(info_tbl, 1, 3, str.tostring(math.round_to_mintick(val_lvl)),
                   text_color=TC, text_size=size.small)
        table.cell(info_tbl, 0, 4, 'Up Vol', text_color=TC,       text_size=size.small)
        table.cell(info_tbl, 1, 4, str.tostring(math.round(up_pct, 1)) + '%',
                   text_color=up_col, text_size=size.small)
        // Separator
        table.cell(info_tbl, 0, 5, '', bgcolor=SEP, text_size=size.tiny)
        table.cell(info_tbl, 1, 5, '', bgcolor=SEP, text_size=size.tiny)
        // Context
        table.cell(info_tbl, 0, 6, 'VA State', text_color=TC,           text_size=size.small)
        table.cell(info_tbl, 1, 6, va_state,   text_color=va_state_col, text_size=size.small)
        table.cell(info_tbl, 0, 7, 'POC',      text_color=TC,           text_size=size.small)
        table.cell(info_tbl, 1, 7, vpoc_str,   text_color=vpoc_col,     text_size=size.small)
        table.cell(info_tbl, 0, 8, 'Dev POC',  text_color=TC,           text_size=size.small)
        table.cell(info_tbl, 1, 8, poc_trend_str, text_color=poc_trend_col, text_size=size.small)
        table.cell(info_tbl, 0, 9, 'POC Dist', text_color=TC,           text_size=size.small)
        table.cell(info_tbl, 1, 9, poc_dist_str, text_color=poc_dist_col, text_size=size.small)
    else
        table.clear(info_tbl, 0, 0, 1, 9)

// ── Alert conditions ──────────────────────────────────────────────────────────
alertcondition(ta.cross(close, poc_lvl_p),
     'VS: POC Cross', 'Price crossed POC')
alertcondition(close > vah_lvl_p and close[1] <= vah_lvl_p[1],
     'VS: Exit VA (above)', 'Price broke above VAH — out of value')
alertcondition(close < val_lvl_p and close[1] >= val_lvl_p[1],
     'VS: Exit VA (below)', 'Price broke below VAL — out of value')
alertcondition(close <= vah_lvl_p and close[1] > vah_lvl_p[1],
     'VS: Enter VA (from above)', 'Price re-entered value area from above')
alertcondition(close >= val_lvl_p and close[1] < val_lvl_p[1],
     'VS: Enter VA (from below)', 'Price re-entered value area from below')
alertcondition(high >= vah_lvl_p and low < vah_lvl_p and not (high[1] >= vah_lvl_p[1] and low[1] < vah_lvl_p[1]),
     'VS: VAH Touch', 'Price touched VAH')
alertcondition(high > val_lvl_p and low <= val_lvl_p and not (high[1] > val_lvl_p[1] and low[1] <= val_lvl_p[1]),
     'VS: VAL Touch', 'Price touched VAL')
