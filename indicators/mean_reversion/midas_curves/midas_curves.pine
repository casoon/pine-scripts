//@version=6
// ============================================================================
// MIDAS 2.0 [WavesUnchained]
// Version: 2.3
// Author: WavesUnchained
// Build: 2026-06-28 19:40:00
// ============================================================================
// Anchored MIDAS support/resistance curve (launch-anchored volume-weighted price)
// with a true topfinder / bottomfinder accelerated curve that forecasts trend
// exhaustion. Location + Exhaustion sensor: it reports where price sits relative
// to the MIDAS curve/bands and how far the launched move has run toward its
// projected end. Context markers are Setup-level evidence, not hard entries.
//
// Features:
//   ✓ MIDAS curve anchored at manual time, daily open, or auto swing (last / low / high)
//   ✓ Volume-weighted σ bands, ATR bands, or Hybrid (avg) at two configurable multiples
//   ✓ Topfinder / bottomfinder accelerated curve with closed-form auto-fit
//   ✓ 4-stage exhaustion read (no fit / running / late / expired) from d/D progress
//   ✓ Stretched-from-value and reclaim-after-stretch context markers (no BUY/SELL)
//   ✓ Element | Value | Read dashboard with a TF-aware plain-language conclusion
//   ✓ Light-theme dashboard, alerts, debug log
//
// ============================================================================

indicator("MIDAS 2.0 [WavesUnchained]", "MIDAS 2.0", overlay=true, max_labels_count=500, max_lines_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

g_anchor = "1 · Anchor"
anchorMode = input.string("Auto Last Swing", "Anchor on",
     options=["Manual Time", "Daily Open", "Auto Last Swing", "Auto Swing Low", "Auto Swing High"], group=g_anchor,
     tooltip="Auto Last Swing anchors on the most recent significant swing of either side and sets the TBF direction from it (low → topfinder, high → bottomfinder). Auto Swing Low/High force a side.")
anchorTime = input.time(timestamp("01 Jan 2026 00:00 +0000"), "Manual Anchor", group=g_anchor)
anchorLeft  = input.int(20, "Anchor Swing Left",  minval=1, group=g_anchor)
anchorRight = input.int(20, "Anchor Swing Right", minval=1, group=g_anchor,
     tooltip="Degree of the swing that defines an anchor. Larger = only significant pivots launch a new MIDAS curve, so it tracks the current leg origin rather than every minor wiggle. Re-seeded from the real pivot bar (anchorRight back).")
src         = input.source(hlc3, "Price Source", group=g_anchor)

g_bands = "2 · Bands"
showBands = input.bool(true, "Show Bands", group=g_bands)
bandMode  = input.string("VW StDev", "Band Mode", options=["VW StDev", "ATR", "Hybrid"], group=g_bands,
     tooltip="VW StDev widens with the anchored move (can dull in long trends); ATR is more reactive short-term; Hybrid averages the two.")
bandMult1 = input.float(1.0, "Band 1 Mult", minval=0.0, step=0.25, group=g_bands)
bandMult2 = input.float(2.0, "Band 2 Mult", minval=0.0, step=0.25, group=g_bands)
atrLen    = input.int(14, "ATR Length", minval=1, group=g_bands)

g_tbf = "3 · Topfinder / Bottomfinder"
enableTBF = input.bool(true, "Enable TBF Exhaustion Curve", group=g_tbf,
     tooltip="Accelerated MIDAS curve auto-fitted to the most recent same-direction swing after the launch. Catches up to price and forecasts the end of the launched move.")
warnThresh = input.float(0.85, "Exhaustion Warn (d/D)", minval=0.5, maxval=0.99, step=0.05, group=g_tbf,
     tooltip="When cumulative volume since launch reaches this fraction of the fitted projection D, flag the move as nearing exhaustion.")
fitLeft    = input.int(5, "Fit Swing Left",  minval=1, group=g_tbf)
fitRight   = input.int(5, "Fit Swing Right", minval=1, group=g_tbf,
     tooltip="Degree of the pullback swings (smaller than the anchor) the topfinder/bottomfinder is fitted to within the current leg.")

g_bias = "4 · Bias"
curveBias = input.string("Auto EMA", "Trend Bias", options=["Auto EMA", "Up", "Down"], group=g_bias,
     tooltip="Colours the context markers and selects topfinder vs bottomfinder for Manual/Daily anchors. For Auto modes the TBF direction follows the anchor side (low → topfinder, high → bottomfinder). Auto EMA = price vs EMA.")
emaLen    = input.int(55, "Auto Bias EMA", minval=5, group=g_bias)

g_disp = "5 · Display"
showMarkers = input.bool(true, "Show context markers", group=g_disp,
     tooltip="Stretched-from-value and MIDAS-reclaim markers. Setup-level context, not hard entries.")
reclaimLook = input.int(10, "Reclaim: stretch lookback", minval=1, group=g_disp,
     tooltip="A MIDAS reclaim only fires if price was stretched past the inner band within this many bars before reclaiming the curve.")
showTable   = input.bool(true, "Show dashboard", group=g_disp)
tablePos    = input.string("Top Right", "Dashboard position",
     options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=g_disp)
showAnchor  = input.bool(true, "Show anchor markers", group=g_disp)
dbg         = input.bool(false, "Debug log", group=g_disp)

g_col = "6 · Colors"
colMidas = input.color(#ff6f00, "MIDAS curve", group=g_col)
colTBF   = input.color(#7b1fa2, "TBF curve",   group=g_col)
colUp    = input.color(#00c853, "Bullish",     group=g_col)
colDn    = input.color(#d50000, "Bearish",     group=g_col)

// ─────────────────────────────────────────────────────────────────────────────
// ANCHOR
// ─────────────────────────────────────────────────────────────────────────────
vol = na(volume) or volume <= 0 ? 1.0 : volume

manualPulse = time >= anchorTime and time[1] < anchorTime
dailyPulse  = ta.change(time("D")) != 0
// Anchor pivots (significant degree) — define a new leg origin
anchLowConf  = not na(ta.pivotlow(low,  anchorLeft, anchorRight))
anchHighConf = not na(ta.pivothigh(high, anchorLeft, anchorRight))
// Fit pivots (smaller degree) — pullbacks the topfinder/bottomfinder is fitted to
fitLowConf   = not na(ta.pivotlow(low,  fitLeft, fitRight))
fitHighConf  = not na(ta.pivothigh(high, fitLeft, fitRight))

bool isPivotMode = anchorMode == "Auto Swing Low" or anchorMode == "Auto Swing High" or anchorMode == "Auto Last Swing"

// Auto modes re-anchor on the most recent significant swing — the origin of the
// current leg. Larger anchor degree keeps the curve on the current move, not on
// every minor wiggle (and not pinned to the all-time extreme).
bool anchorPulse = false
if anchorMode == "Manual Time"
    anchorPulse := manualPulse
else if anchorMode == "Daily Open"
    anchorPulse := dailyPulse
else if anchorMode == "Auto Swing Low"
    anchorPulse := anchLowConf
else if anchorMode == "Auto Swing High"
    anchorPulse := anchHighConf
else   // Auto Last Swing — most recent significant swing of either side
    anchorPulse := anchLowConf or anchHighConf

// Side of the active auto-anchor (used by Auto Last Swing for the TBF direction)
var bool anchorIsLow = true
if anchorPulse and isPivotMode
    anchorIsLow := anchLowConf   // prefer the low if both confirm on the same bar

// ─────────────────────────────────────────────────────────────────────────────
// MIDAS CUMULATIVE SUMS  (A=ΣpV, C=ΣV, P2=Σp²V, B=ΣpVd, E=ΣVd ; d = running ΣV)
// ─────────────────────────────────────────────────────────────────────────────
var float cumPV  = na   // A
var float cumV   = na   // C  (= d, cumulative volume since launch)
var float cumP2V = na   // Σ p² V  (for VW variance)
var float cumPVd = na   // B
var float cumVd  = na   // E
var int   age    = na

if anchorPulse or na(cumPV)
    cumPV  := 0.0
    cumV   := 0.0
    cumP2V := 0.0
    cumPVd := 0.0
    cumVd  := 0.0
    if isPivotMode and anchorPulse
        // re-seed from the real pivot bar (anchorRight back), so value accrues
        // from the actual swing rather than the lagging confirmation bar
        for i = anchorRight to 0
            float p = nz(src[i], src)
            float v = nz(volume[i])
            v := v <= 0 ? 1.0 : v
            cumV   := cumV + v          // running cumulative volume d
            cumPV  := cumPV + p * v
            cumP2V := cumP2V + p * p * v
            cumPVd := cumPVd + p * v * cumV
            cumVd  := cumVd + v * cumV
        age := anchorRight + 1
    else
        cumPV  := src * vol
        cumV   := vol
        cumP2V := src * src * vol
        cumPVd := src * vol * vol
        cumVd  := vol * vol
        age    := 1
else
    float dj = cumV + vol          // running cumulative volume after this bar
    cumPVd += src * vol * dj
    cumVd  += vol * dj
    cumPV  += src * vol
    cumV   := dj
    cumP2V += src * src * vol
    age    += 1

midas = cumV > 0 ? cumPV / cumV : na

// Bands
vwVar  = math.max(cumP2V / cumV - midas * midas, 0)
vwDev  = math.sqrt(vwVar)
devATR = ta.atr(atrLen)
dev    = bandMode == "VW StDev" ? vwDev : bandMode == "ATR" ? devATR : math.avg(vwDev, devATR)

upper1 = midas + dev * bandMult1
lower1 = midas - dev * bandMult1
upper2 = midas + dev * bandMult2
lower2 = midas - dev * bandMult2

// ─────────────────────────────────────────────────────────────────────────────
// BIAS  (Trend role — colour + TBF direction only, never a hard gate)
// ─────────────────────────────────────────────────────────────────────────────
ema = ta.ema(close, emaLen)
int bias = 0
if curveBias == "Up"
    bias := 1
else if curveBias == "Down"
    bias := -1
else
    bias := close >= ema ? 1 : -1
// TBF direction follows the anchor type (low → topfinder, high → bottomfinder)
// so the accelerated curve is coherent with the launch; bias only decides for
// manual / daily anchors.
bool tbfTop = anchorMode == "Auto Swing Low" ? true : anchorMode == "Auto Swing High" ? false : anchorMode == "Auto Last Swing" ? anchorIsLow : bias == 1

// ─────────────────────────────────────────────────────────────────────────────
// TOPFINDER / BOTTOMFINDER  (Exhaustion role)
//   TBF_j = (A·D − B) / (C·D − E),  weights w_i = 1 − d_i/D
//   Fit at a same-direction swing after launch:  D = (B − T·E)/(A − T·C)
// ─────────────────────────────────────────────────────────────────────────────
var float tbfD = na   // fitted projected total volume D

if anchorPulse
    tbfD := na

// Re-fit on a confirmed same-direction swing that sits after the launch
float fitT  = na
bool  doFit = false
if enableTBF and not na(cumPV)
    if tbfTop and fitLowConf and age >= fitRight + 1
        fitT  := low[fitRight]
        doFit := true
    else if (not tbfTop) and fitHighConf and age >= fitRight + 1
        fitT  := high[fitRight]
        doFit := true

if doFit
    float Af = cumPV[fitRight]
    float Bf = cumPVd[fitRight]
    float Cf = cumV[fitRight]
    float Ef = cumVd[fitRight]
    float den = Af - fitT * Cf
    float Dcand = den != 0 ? (Bf - fitT * Ef) / den : na
    // valid only if it still projects forward FROM NOW (D > volume already accumulated
    // at the current bar) — not just at the fit bar, else the projected end is in the past
    bool ok = not na(Dcand) and Dcand > cumV and Dcand < cumV * 50
    if ok
        tbfD := Dcand
    else if dbg and barstate.isconfirmed
        // why the fit was rejected — distinguishes "already passed / no acceleration" from "degenerate"
        string why = na(Dcand) ? "den=0" : Dcand <= cumV ? "D<=d (already passed / no acceleration)" : "D>50·d (degenerate)"
        log.info("MIDAS TBF FIT REJECTED dir={0} reason={1} D={2} d={3} T={4}",
             tbfTop ? "top" : "bot", why, str.tostring(Dcand, "0"), str.tostring(cumV, "0"), str.tostring(fitT, format.mintick))

// TBF curve value + 4-stage state (no fit → running → late → expired)
float progress = (not enableTBF or na(tbfD)) ? na : cumV / tbfD
float tbf = na
// `not anchorPulse` forces a one-bar gap on every re-anchor so separate projection
// episodes never bridge into one straight line on long-history views
if enableTBF and not na(tbfD) and tbfD > cumV and not anchorPulse
    float denom = cumV * tbfD - cumVd
    tbf := denom != 0 ? (cumPV * tbfD - cumPVd) / denom : na

// "late" = far through the projection (advanced move), NOT a confirmed turn.
// "expired" = the move ran past its projected end (d ≥ D).
string tbfState = not enableTBF ? "off" : na(progress) ? "no fit" : progress >= 1.0 ? "expired" : progress >= warnThresh ? "late" : "running"
bool tbfWarn    = tbfState == "late"
bool tbfLateNew = tbfWarn and not tbfWarn[1]

// ─────────────────────────────────────────────────────────────────────────────
// LOCATION + CONTEXT MARKERS  (Setup-level evidence, §7/§9 — not BUY/SELL)
// ─────────────────────────────────────────────────────────────────────────────
distSigma = not na(midas) and dev > 0 ? (close - midas) / dev : na

// Reclaim only counts after a genuine stretch past the inner band (not on small dips)
stretchedLowRecently  = ta.barssince(not na(lower1) and close < lower1) <= reclaimLook
stretchedHighRecently = ta.barssince(not na(upper1) and close > upper1) <= reclaimLook

stretchUp = bias == 1  and not na(upper2) and high > upper2 and close < upper2   // rejected at upper band in up-bias
stretchDn = bias == -1 and not na(lower2) and low  < lower2 and close > lower2   // rejected at lower band in down-bias
reclaimUp = bias == 1  and stretchedLowRecently  and ta.crossover(close, midas)  // value reclaimed after a stretch below
reclaimDn = bias == -1 and stretchedHighRecently and ta.crossunder(close, midas) // value lost after a stretch above

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────
plot(midas, "MIDAS curve", color=color.new(colMidas, 0), linewidth=2)
plot(showBands ? upper1 : na, "Upper 1", color=color.new(colUp, 60))
plot(showBands ? lower1 : na, "Lower 1", color=color.new(colDn, 60))
plot(showBands ? upper2 : na, "Upper 2", color=color.new(colUp, 30))
plot(showBands ? lower2 : na, "Lower 2", color=color.new(colDn, 30))
plot(tbf, "TBF curve", color=color.new(colTBF, tbfWarn ? 0 : 35), linewidth=2, style=plot.style_line)

// Anchor marker — pivot modes mark the real pivot bar (offset back), time/daily mark the current bar
plotshape(showAnchor and anchorPulse and isPivotMode ? src[anchorRight] : na, "Anchor (pivot)",
     style=shape.circle, location=location.absolute, offset=-anchorRight,
     color=color.new(colMidas, 0), size=size.tiny)
plotshape(showAnchor and anchorPulse and not isPivotMode ? src : na, "Anchor",
     style=shape.circle, location=location.absolute,
     color=color.new(colMidas, 0), size=size.tiny)

plotshape(showMarkers and stretchUp, "Stretched above value", style=shape.triangledown, location=location.abovebar,
     color=color.new(colDn, 20), size=size.tiny)
plotshape(showMarkers and stretchDn, "Stretched below value", style=shape.triangleup, location=location.belowbar,
     color=color.new(colUp, 20), size=size.tiny)
plotshape(showMarkers and reclaimUp, "MIDAS reclaim ▲", style=shape.diamond, location=location.belowbar,
     color=color.new(colUp, 0), size=size.tiny)
plotshape(showMarkers and reclaimDn, "MIDAS reclaim ▼", style=shape.diamond, location=location.abovebar,
     color=color.new(colDn, 0), size=size.tiny)
plotshape(tbfLateNew and tbfTop, "TBF late move (top)", style=shape.xcross, location=location.abovebar,
     color=color.new(colTBF, 0), text="LATE", textcolor=color.white, size=size.tiny)
plotshape(tbfLateNew and not tbfTop, "TBF late move (bottom)", style=shape.xcross, location=location.belowbar,
     color=color.new(colTBF, 0), text="LATE", textcolor=color.white, size=size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
// INTERPRETATION  (verbalises the role outputs; thresholds & read are TF-aware)
// ─────────────────────────────────────────────────────────────────────────────
tfMin    = timeframe.in_seconds() / 60.0
tfBucket = tfMin < 240 ? "Intraday" : tfMin < 1440 ? "Swing" : "Position"
higherTf = tfMin >= 240                       // Swing / Position lean on Location & reversion
locMid   = higherTf ? 1.0 : 1.5               // intraday is noisier → a wider stretch bar
locHi    = higherTf ? 2.0 : 2.5

absD       = na(distSigma) ? na : math.abs(distSigma)
locUnit    = bandMode == "VW StDev" ? " σ" : bandMode == "ATR" ? " atr" : " ×"
locStr     = na(distSigma) ? "n/a" : str.tostring(distSigma, "0.00") + locUnit
dirWord    = na(distSigma) ? "" : distSigma > 0 ? " up" : " down"
locRead    = na(distSigma) ? "n/a" : absD >= locHi ? "overextended" + dirWord : absD >= locMid ? "stretched" + dirWord : "at value"

zone       = na(midas) ? "n/a" : close > upper2 ? "above U2" : close > upper1 ? "U1–U2" : close > lower1 ? "inside" : close > lower2 ? "L1–L2" : "below L2"
zoneRead   = na(midas) ? "n/a" : zone == "inside" ? "normal" : (zone == "above U2" or zone == "below L2") ? "extreme" : "stretched"

midasSlope = na(midas) ? na : midas - midas[3]
trendVal   = na(midas) ? "n/a" : (close > midas ? "above" : "below") + " value" + (na(midasSlope) ? "" : midasSlope > 0 ? " ↑" : midasSlope < 0 ? " ↓" : " →")
trendRead  = na(midas) ? "n/a" : close > midas ? "buyers since launch" : "sellers since launch"

tbfStr     = not enableTBF ? "off" : na(progress) ? "no fit" : tbfState + " " + str.tostring(progress * 100, "0") + "%"
tbfRead    = not enableTBF ? "off" : tbfState == "no fit" ? "no accel" : tbfState == "running" ? "move running" : tbfState == "late" ? "don't chase" : "overrun"

ageRead    = na(age) ? "n/a" : age < 2 * anchorRight ? "fresh (thin)" : "established"

flat = not na(dev) and dev > 0 and not na(midasSlope) and math.abs(midasSlope) < dev * 0.15

// TF-aware headline conclusion + tone
string headline = "—"
string tone     = "neutral"
if na(distSigma) or na(midas)
    headline := "warming up"
else if (tbfState == "late" or tbfState == "expired") and absD >= locMid
    headline := higherTf ? "Overextended + late move → reversion risk, don't chase" : "Late + stretched — intraday noisy, fade only on a trigger"
    tone := "warn"
else if absD >= locHi
    headline := higherTf ? "Overextended from value → mean-reversion to MIDAS likely" : "Stretched — intraday, fade only on a trigger"
    tone := "warn"
else if zone == "inside" and flat
    headline := "At value / range → fade the bands, no chase"
    tone := "neutral"
else if close > midas and (na(midasSlope) or midasSlope > 0)
    headline := "Trend above value → pullbacks to MIDAS = support"
    tone := "bull"
else if close < midas and (na(midasSlope) or midasSlope < 0)
    headline := "Below value, falling → MIDAS = resistance"
    tone := "bear"
else
    headline := "Neutral / building"
    tone := "neutral"
headlineCol = tone == "warn" ? #ff6f00 : tone == "bull" ? colUp : tone == "bear" ? colDn : color.new(color.gray, 20)

// ─────────────────────────────────────────────────────────────────────────────
// DASHBOARD  (light theme — see CLAUDE.md) :  Element | Value | Read
// ─────────────────────────────────────────────────────────────────────────────
color tc = color.new(color.gray, 20)
color hd = color.new(color.gray, 90)
posSel = tablePos == "Top Right" ? position.top_right : tablePos == "Top Left" ? position.top_left : tablePos == "Bottom Right" ? position.bottom_right : position.bottom_left

if showTable and barstate.islast
    var table t = table.new(posSel, 3, 8,
         bgcolor=color.new(color.white, 5),
         border_color=color.new(color.gray, 60),
         border_width=1,
         frame_color=color.new(color.gray, 40),
         frame_width=1)

    // Header
    table.cell(t, 0, 0, "MIDAS 2.0", text_color=tc, text_size=size.normal, bgcolor=hd)
    table.cell(t, 1, 0, tfBucket,    text_color=tc, text_size=size.normal, bgcolor=hd)
    table.cell(t, 2, 0, bias == 1 ? "Bull" : "Bear", text_color=bias == 1 ? colUp : colDn, text_size=size.normal, bgcolor=hd)

    // Location
    table.cell(t, 0, 1, "Location", text_color=tc, text_size=size.small)
    table.cell(t, 1, 1, locStr, text_color=na(distSigma) ? tc : (distSigma > 0 ? colUp : colDn), text_size=size.small)
    table.cell(t, 2, 1, locRead, text_color=tc, text_size=size.small)

    // Band zone
    table.cell(t, 0, 2, "Band zone", text_color=tc, text_size=size.small)
    table.cell(t, 1, 2, zone, text_color=tc, text_size=size.small)
    table.cell(t, 2, 2, zoneRead, text_color=tc, text_size=size.small)

    // TBF
    tbfActive = tbfState == "late" or tbfState == "expired"
    table.cell(t, 0, 3, tbfTop ? "Topfinder" : "Bottomfinder", text_color=tc, text_size=size.small)
    table.cell(t, 1, 3, tbfStr, text_color=tbfActive ? color.white : tc, bgcolor=tbfActive ? color.new(colTBF, 0) : na, text_size=size.small)
    table.cell(t, 2, 3, tbfRead, text_color=tbfActive ? colTBF : tc, text_size=size.small)

    // Trend (price vs value)
    table.cell(t, 0, 4, "Trend", text_color=tc, text_size=size.small)
    table.cell(t, 1, 4, trendVal, text_color=na(midas) ? tc : (close > midas ? colUp : colDn), text_size=size.small)
    table.cell(t, 2, 4, trendRead, text_color=tc, text_size=size.small)

    // Anchor maturity
    table.cell(t, 0, 5, "Anchor", text_color=tc, text_size=size.small)
    table.cell(t, 1, 5, na(age) ? "n/a" : str.tostring(age) + " bars", text_color=tc, text_size=size.small)
    table.cell(t, 2, 5, ageRead, text_color=tc, text_size=size.small)

    // Separator
    table.cell(t, 0, 6, "", bgcolor=color.new(color.gray, 80))
    table.cell(t, 1, 6, "", bgcolor=color.new(color.gray, 80))
    table.cell(t, 2, 6, "", bgcolor=color.new(color.gray, 80))

    // TF-aware read (headline conclusion)
    table.cell(t, 0, 7, "Read", text_color=tc, text_size=size.normal, bgcolor=hd)
    table.cell(t, 1, 7, headline, text_color=headlineCol, text_size=size.normal, bgcolor=hd)
    table.cell(t, 2, 7, "", text_color=tc, text_size=size.normal, bgcolor=hd)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(stretchUp, "Stretched above value", "Price rejected the upper MIDAS band in bullish bias.")
alertcondition(stretchDn, "Stretched below value", "Price rejected the lower MIDAS band in bearish bias.")
alertcondition(reclaimUp, "MIDAS bullish reclaim", "Price reclaimed the MIDAS curve in bullish context after a stretch below.")
alertcondition(reclaimDn, "MIDAS bearish reclaim", "Price lost the MIDAS curve in bearish context after a stretch above.")
alertcondition(tbfLateNew, "TBF late move", "Launched move is far through its topfinder/bottomfinder projection (advanced move, not a confirmed turn).")

// ─────────────────────────────────────────────────────────────────────────────
// DEBUG
// ─────────────────────────────────────────────────────────────────────────────
if dbg and barstate.isconfirmed
    if anchorPulse
        log.info("MIDAS ANCHOR mode={0} price={1}", anchorMode, str.tostring(src, format.mintick))
    if doFit and not na(tbfD)
        log.info("MIDAS TBF FIT dir={0} D={1} d={2} T={3}", tbfTop ? "top" : "bot", str.tostring(tbfD, "0"), str.tostring(cumV, "0"), str.tostring(fitT, format.mintick))
    if tbfLateNew
        log.info("MIDAS TBF LATE progress={0} midas={1} close={2}", str.tostring(progress, "0.00"), str.tostring(midas, format.mintick), str.tostring(close, format.mintick))
