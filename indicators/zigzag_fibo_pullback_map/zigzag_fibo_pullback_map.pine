//@version=6
// ============================================================================
// ZigZag Fibo Pullback Map [WavesUnchained]
// Version: 1.2.0
// Author: WavesUnchained
// Build: 2026-04-14 22:40:00
// ============================================================================
// Confirmed ZigZag pivots with pullback-to-fibo labeling and active fib fan.
//
// Features:
//   ✓ Confirmed ZigZag pivot engine based on symmetric pivot detection
//   ✓ Pullback-to-fibo labeling directly at completed ZigZag turning points
//   ✓ Standard-fibo color coding for 0.236 / 0.382 / 0.500 / 0.618 / 0.786
//   ✓ Live active swing projection with fib fan on the current unfinished leg
//   ✓ Visual verification workflow without entry or signal clutter
//   ✓ Depth regime, timing, efficiency and reaction tracking for pullbacks
//   ✓ Optional zone bands, current-zone state and pullback summary table
//   ✓ Pullback zone engine with confluence and continuation/failure outlook
// ============================================================================
indicator("ZigZag Fibo Pullback Map [WavesUnchained]", shorttitle="ZZ Fibo Map", overlay=true, max_bars_back=5000, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

groupZigZag = "ZigZag"
pivotLen = input.int(8, "Pivot Length", minval=2, group=groupZigZag)
maxPivots = input.int(80, "Max Stored Pivots", minval=20, maxval=200, group=groupZigZag)
drawLookbackBars = input.int(1500, "Draw Lookback Bars", minval=200, maxval=5000, group=groupZigZag)
showZigZag = input.bool(true, "Draw ZigZag", group=groupZigZag)
zigZagWidth = input.int(2, "ZigZag Width", minval=1, maxval=4, group=groupZigZag)
upColor = input.color(color.lime, "Up Leg Color", group=groupZigZag, inline="zzc")
downColor = input.color(color.red, "Down Leg Color", group=groupZigZag, inline="zzc")
confirmedLineOpacity = input.int(0, "Confirmed Opacity", minval=0, maxval=90, group=groupZigZag, inline="zzo")
liveLineOpacity = input.int(15, "Live Opacity", minval=0, maxval=90, group=groupZigZag, inline="zzo")

groupPB = "Pullback Labels"
showPullbackLabels = input.bool(true, "Show Pullback Labels", group=groupPB)
pullbackMaxRatio = input.float(1.0, "Max Ratio Counted as Pullback", minval=0.236, maxval=1.272, step=0.001, group=groupPB)
matchTolerance = input.float(0.03, "Standard Fibo Match Tolerance", minval=0.001, maxval=0.100, step=0.001, group=groupPB)
showActualRatio = input.bool(true, "Append Actual Retracement", group=groupPB)
neutralPullbackColor = input.color(color.gray, "Non-Standard Label Color", group=groupPB)
pullbackLabelSize = input.string("Normal", "Pullback Label Size", options=["Small", "Normal", "Large"], group=groupPB)
labelMode = input.string("Standard + Reached", "Pullback Label Mode", options=["All", "Standard + Reached", "Standard Only"], group=groupPB)
showClusterTag = input.bool(true, "Show Cluster Tag", group=groupPB)
showDepthRegime = input.bool(true, "Show Depth Regime", group=groupPB)
showTimeStats = input.bool(true, "Show Pullback Bars", group=groupPB)
showEfficiency = input.bool(true, "Show Efficiency", group=groupPB)
showReactionTracking = input.bool(true, "Show Reaction Tracking", group=groupPB)

groupFan = "Active Fan"
showActiveFan = input.bool(true, "Show Active Fib Fan", group=groupFan)
activeFibDisplayMode = input.string("Key Levels", "Active Fib Display", options=["Auto", "Current Zone", "Key Levels", "Full Ladder"], group=groupFan)
fanLabelSide = input.string("Right", "Fan Label Side", options=["Left", "Right"], group=groupFan)
fanLabelOffset = input.int(20, "Fan Label Offset", minval=2, maxval=80, group=groupFan)
fanLineWidth = input.int(1, "Fan Line Width", minval=1, maxval=3, group=groupFan)
extendPastPivot = input.bool(true, "Draw One Level Beyond Latest Pivot", group=groupFan)
showExtensions = input.bool(true, "Include Extensions", group=groupFan)
fanLabelSize = input.string("Normal", "Fan Label Size", options=["Small", "Normal", "Large"], group=groupFan)
showLiveRetracementLabel = input.bool(true, "Show Live Retracement Label", group=groupFan)
showLiveOriginMarker = input.bool(true, "Show Live Origin Marker", group=groupFan)
showCurrentZone = input.bool(true, "Show Current Zone", group=groupFan)
showZoneBands = input.bool(true, "Show Standard Fib Bands", group=groupFan)
zoneBandAtrMult = input.float(0.20, "Zone Band Height (ATR)", minval=0.05, maxval=1.0, step=0.05, group=groupFan)

groupZone = "Zone Engine"
showConfluenceZone = input.bool(true, "Show Confluence Zone", group=groupZone)
showOutlookLabel = input.bool(true, "Show Continuation/Failure Outlook", group=groupZone)
confluenceLookback = input.int(5, "Confluence Swing Count", minval=2, maxval=12, group=groupZone)
confluenceToleranceAtr = input.float(0.35, "Confluence Tolerance (ATR)", minval=0.05, maxval=2.0, step=0.05, group=groupZone)

groupFilter = "Filters"
atrLen = input.int(14, "ATR Length", minval=2, group=groupFilter)
minLegAtr = input.float(0.30, "Min Leg Size (ATR)", minval=0.0, maxval=10.0, step=0.05, group=groupFilter)
minLegPercent = input.float(0.10, "Min Leg Size (%)", minval=0.0, maxval=10.0, step=0.05, group=groupFilter)

groupStats = "Stats"
showStatsTable = input.bool(true, "Show Pullback Table", group=groupStats)
statsTablePosition = input.string("top_right", "Table Position", options=["top_left", "top_right", "bottom_left", "bottom_right"], group=groupStats)
statsRows = input.int(10, "Rows", minval=3, maxval=15, group=groupStats)
showZoneMemory = input.bool(true, "Show Zone Memory", group=groupStats)
showMemoryLabels = input.bool(true, "Show Memory Labels", group=groupStats)
memoryZoneStyle = input.string("Border Only", "Memory Zone Style", options=["Border Only", "Soft Fill"], group=groupStats)

groupStyle = "Style"
displayPreset = input.string("Balanced", "Display Preset", options=["Minimal", "Balanced", "Full"], group=groupStyle)
textColor = input.color(color.white, "Text Color", group=groupStyle)
fanExtensionColor = input.color(color.silver, "Extension Color", group=groupStyle)
activeLegColor = input.color(color.rgb(244, 67, 54), "Active Leg Dashed Color", group=groupStyle)
memoryColor = input.color(color.rgb(156, 39, 176), "Zone Memory Color", group=groupStyle)
supportMemoryColor = input.color(color.rgb(0, 200, 83), "Support Memory Color", group=groupStyle)
riskMemoryColor = input.color(color.rgb(213, 0, 0), "Risk Memory Color", group=groupStyle)

var float[] standardRatios = array.from(0.236, 0.382, 0.500, 0.618, 0.786)
var float[] fanRatios = array.new_float()

var float[] pivPrices = array.new_float()
var int[] pivIndexes = array.new_int()
var int[] pivTypes = array.new_int()  // 1 = high, -1 = low

var line[] zigZagLines = array.new_line()
var label[] pullbackPivotLabels = array.new_label()
var line[] activeFanLines = array.new_line()
var label[] activeFanLabels = array.new_label()
var label[] activeStateLabels = array.new_label()
var label[] activeOriginLabels = array.new_label()
var label[] outlookLabels = array.new_label()
var label[] memoryLabels = array.new_label()
var label[] reactionLabels = array.new_label()
var box[] activeZoneBoxes = array.new_box()
var box[] memoryZoneBoxes = array.new_box()
var box[] confluenceZoneBoxes = array.new_box()
var table statsTable = na
var int statsTableCols = 0
var int statsTableRows = 0
var string statsTablePosCurrent = ""
var string[] statsId = array.new_string()
var string[] statsDir = array.new_string()
var string[] statsBar = array.new_string()
var string[] statsPrice = array.new_string()
var string[] statsFib = array.new_string()
var string[] statsDepth = array.new_string()
var string[] statsBars = array.new_string()
var string[] statsEff = array.new_string()
var string[] statsReact = array.new_string()

atr = ta.atr(atrLen)

max_bars_back(high, 5000)
max_bars_back(low, 5000)

// Force sufficient history allocation for dynamic active-leg lookbacks.
float _highHistoryAnchor = high[4999]
float _lowHistoryAnchor = low[4999]

f_table_position(string pos) =>
    pos == "top_left" ? position.top_left : pos == "bottom_left" ? position.bottom_left : pos == "bottom_right" ? position.bottom_right : position.top_right

f_is_minimal() =>
    displayPreset == "Minimal"

f_is_balanced() =>
    displayPreset == "Balanced"

f_is_full() =>
    displayPreset == "Full"

if barstate.isfirst
    statsTableCols := f_is_full() ? 7 : 5
    statsTableRows := 2
    statsTablePosCurrent := statsTablePosition
    statsTable := table.new(f_table_position(statsTablePosition), statsTableCols, statsTableRows, bgcolor=color.new(color.white, 5), border_color=color.new(color.gray, 60), border_width=1, frame_color=color.new(color.gray, 40), frame_width=1)
    array.push(fanRatios, 0.000)
    for i = 0 to array.size(standardRatios) - 1
        array.push(fanRatios, array.get(standardRatios, i))
    if showExtensions
        array.push(fanRatios, 1.000)
        array.push(fanRatios, 1.272)
        array.push(fanRatios, 1.414)
        array.push(fanRatios, 1.618)
        array.push(fanRatios, 2.000)
        array.push(fanRatios, 2.272)
        array.push(fanRatios, 2.618)

f_clear_lines(line[] arr) =>
    while array.size(arr) > 0
        line.delete(array.pop(arr))

f_clear_labels(label[] arr) =>
    while array.size(arr) > 0
        label.delete(array.pop(arr))

f_clear_boxes(box[] arr) =>
    while array.size(arr) > 0
        box.delete(array.pop(arr))

f_trim_pivots() =>
    while array.size(pivPrices) > maxPivots
        array.shift(pivPrices)
        array.shift(pivIndexes)
        array.shift(pivTypes)

f_level_color(float ratio) =>
    if math.abs(ratio - 0.236) < 0.0005
        color.rgb(0, 191, 165)
    else if math.abs(ratio - 0.382) < 0.0005
        color.rgb(33, 150, 243)
    else if math.abs(ratio - 0.500) < 0.0005
        color.rgb(76, 175, 80)
    else if math.abs(ratio - 0.618) < 0.0005
        color.rgb(255, 193, 7)
    else if math.abs(ratio - 0.786) < 0.0005
        color.rgb(255, 87, 34)
    else
        fanExtensionColor

f_text_on_color(color bg) =>
    float luminance = color.r(bg) * 0.299 + color.g(bg) * 0.587 + color.b(bg) * 0.114
    luminance > 160 ? color.black : color.white

f_label_size(string sizeName) =>
    sizeName == "Large" ? size.large : sizeName == "Normal" ? size.normal : size.small

f_depth_regime(float ratio) =>
    ratio < 0.382 ? "Shallow" : ratio <= 0.618 ? "Normal" : ratio <= 0.786 ? "Deep" : "Extreme"

f_zone_bounds(float ratio) =>
    float zoneLoRatio = ratio < 0.236 ? 0.000 : ratio < 0.382 ? 0.236 : ratio < 0.500 ? 0.382 : ratio < 0.618 ? 0.500 : ratio < 0.786 ? 0.618 : ratio < 1.000 ? 0.786 : 1.000
    float zoneHiRatio = ratio < 0.236 ? 0.236 : ratio < 0.382 ? 0.382 : ratio < 0.500 ? 0.500 : ratio < 0.618 ? 0.618 : ratio < 0.786 ? 0.786 : ratio < 1.000 ? 1.000 : 1.272
    [zoneLoRatio, zoneHiRatio]

f_outlook_score(float ratio, int pullbackBars, float efficiency, string reaction) =>
    float score = 0.0
    score += ratio <= 0.382 ? 2.0 : ratio <= 0.618 ? 1.0 : ratio <= 0.786 ? -0.5 : -2.0
    score += pullbackBars <= 5 ? 1.0 : pullbackBars <= 10 ? 0.0 : -1.0
    score += not na(efficiency) ? (efficiency >= 1.2 ? 1.5 : efficiency >= 0.9 ? 0.5 : efficiency >= 0.6 ? -0.5 : -1.5) : 0.0
    score += reaction == "HH" or reaction == "LL" ? 1.5 : reaction == "Weak" ? -0.5 : reaction == "Break" ? -2.0 : 0.0
    score

f_outlook_text(float score) =>
    score >= 3.0 ? "Continuation Likely" : score >= 1.0 ? "Balanced Continuation" : score > -1.0 ? "Fragile Continuation" : "Failure Risk"

f_zone_bias(string outlook) =>
    outlook == "Failure Risk" ? "risk" : outlook == "Fragile Continuation" ? "fragile" : "supportive"

f_outlook_color(string outlook) =>
    outlook == "Continuation Likely" ? color.rgb(0, 200, 83) : outlook == "Balanced Continuation" ? color.rgb(76, 175, 80) : outlook == "Fragile Continuation" ? color.rgb(255, 152, 0) : color.rgb(213, 0, 0)

f_confluence_candidate(bool relevant, float ratio, int pullbackBars, float efficiency, string reaction) =>
    if not relevant
        false
    else
        float score = f_outlook_score(ratio, pullbackBars, efficiency, reaction)
        ratio >= 0.236 and ratio <= 0.786 and pullbackBars <= 16 and (na(efficiency) or efficiency >= 0.55) and reaction != "Break" and score >= -0.5

f_reaction_text(bool impulseUp, float b, float c, float d) =>
    impulseUp ? (d > b ? "HH" : d < c ? "Break" : "Weak") : (d < b ? "LL" : d > c ? "Break" : "Weak")

f_outcome_text(string reaction) =>
    reaction == "HH" ? "HH formed" : reaction == "LL" ? "LL formed" : reaction == "Break" ? "Structure Break" : reaction == "Weak" ? "Weak follow-through" : "Pending"

f_efficiency(float distanceA, int barsA, float distanceB, int barsB) =>
    float aRate = barsA > 0 ? distanceA / barsA : na
    float bRate = barsB > 0 ? distanceB / barsB : na
    not na(aRate) and not na(bRate) and bRate > 0 ? aRate / bRate : na

f_zone_text(float ratio) =>
    if ratio < 0.236
        "Below 0.236"
    else if ratio < 0.382
        "0.236-0.382"
    else if ratio < 0.500
        "0.382-0.500"
    else if ratio < 0.618
        "0.500-0.618"
    else if ratio < 0.786
        "0.618-0.786"
    else if ratio <= 1.000
        "0.786-1.000"
    else
        "> 1.000"

f_is_relevant(float matchedStandard, float reachedStandard) =>
    labelMode == "All" ? true : labelMode == "Standard Only" ? not na(matchedStandard) : not na(matchedStandard) or not na(reachedStandard)

f_is_standard(float ratio) =>
    bool found = false
    for i = 0 to array.size(standardRatios) - 1
        found := found or math.abs(array.get(standardRatios, i) - ratio) < 0.0005
    found

f_nearest_standard(float ratio, float tolerance) =>
    float best = na
    float bestDist = 10.0
    for i = 0 to array.size(standardRatios) - 1
        float candidate = array.get(standardRatios, i)
        float dist = math.abs(candidate - ratio)
        if dist < bestDist
            best := candidate
            bestDist := dist
    bestDist <= tolerance ? best : na

f_reached_standard(float ratio) =>
    float reached = na
    for i = 0 to array.size(standardRatios) - 1
        float candidate = array.get(standardRatios, i)
        if ratio >= candidate
            reached := candidate
    reached

f_pullback_text(float ratio, float matchedStandard, float reachedStandard) =>
    string actual = str.tostring(ratio, "#.###")
    if not na(matchedStandard)
        showActualRatio ? "PB " + str.tostring(matchedStandard, "#.###") + " | " + actual : "PB " + str.tostring(matchedStandard, "#.###")
    else if not na(reachedStandard)
        showActualRatio ? "PB " + str.tostring(reachedStandard, "#.###") + "+ | " + actual : "PB " + str.tostring(reachedStandard, "#.###") + "+"
    else
        "PB " + actual

f_table_cell(int col, int row, string txt, color bg, color fg) =>
    table.cell(statsTable, col, row, txt, bgcolor=bg, text_color=fg)

f_push_pivot(int pIndex, float pPrice, int pType) =>
    bool changed = false
    int n = array.size(pivTypes)
    if n > 0 and array.get(pivTypes, n - 1) == pType
        float lastPrice = array.get(pivPrices, n - 1)
        bool replace = pType == 1 ? pPrice > lastPrice : pPrice < lastPrice
        if replace
            array.set(pivPrices, n - 1, pPrice)
            array.set(pivIndexes, n - 1, pIndex)
            changed := true
    else
        array.push(pivPrices, pPrice)
        array.push(pivIndexes, pIndex)
        array.push(pivTypes, pType)
        f_trim_pivots()
        changed := true
    changed

float ph = ta.pivothigh(high, pivotLen, pivotLen)
float pl = ta.pivotlow(low, pivotLen, pivotLen)

if not na(ph) or not na(pl)
    int pBar = bar_index - pivotLen
    if not na(ph) and not na(pl)
        int lastType = array.size(pivTypes) > 0 ? array.get(pivTypes, array.size(pivTypes) - 1) : 0
        if lastType == 1
            f_push_pivot(pBar, pl, -1)
            f_push_pivot(pBar, ph, 1)
        else
            f_push_pivot(pBar, ph, 1)
            f_push_pivot(pBar, pl, -1)
    else if not na(ph)
        f_push_pivot(pBar, ph, 1)
    else
        f_push_pivot(pBar, pl, -1)

if barstate.islast
    bool presetMinimal = f_is_minimal()
    bool presetBalanced = f_is_balanced()
    bool presetFull = f_is_full()
    bool useCompactLabels = presetMinimal or presetBalanced
    bool renderDepthInLabel = showDepthRegime and (presetBalanced or presetFull)
    bool renderTimeInLabel = showTimeStats and presetFull
    bool renderEfficiencyInLabel = showEfficiency and presetFull
    bool renderClusterInLabel = showClusterTag and (presetBalanced or presetFull)
    bool renderReactionMarkers = showReactionTracking and presetFull
    bool renderStatsTable = showStatsTable and not presetMinimal
    bool renderZoneMemory = showZoneMemory and presetFull
    bool renderZoneBands = showZoneBands and not presetMinimal
    bool renderCurrentZoneBox = showCurrentZone and not presetMinimal
    bool renderConfluenceZone = showConfluenceZone and not presetMinimal
    bool renderOutlookLabel = showOutlookLabel
    bool renderAllFanLabels = presetFull
    bool renderOnlyKeyFanLabels = presetBalanced
    int memoryKeepCount = presetFull ? 6 : presetBalanced ? 3 : 0
    int compactTableCols = presetFull ? 7 : 5
    int liveLabelOpacity = presetFull ? 8 : presetBalanced ? 12 : 20
    int weakLiveLabelOpacity = presetFull ? 35 : presetBalanced ? 55 : 72
    string activeDisplayMode = activeFibDisplayMode == "Auto" ? (presetMinimal ? "Current Zone" : presetBalanced ? "Key Levels" : "Full Ladder") : activeFibDisplayMode

    f_clear_lines(zigZagLines)
    f_clear_labels(pullbackPivotLabels)
    f_clear_lines(activeFanLines)
    f_clear_labels(activeFanLabels)
    f_clear_labels(activeStateLabels)
    f_clear_labels(activeOriginLabels)
    f_clear_labels(outlookLabels)
    f_clear_labels(memoryLabels)
    f_clear_labels(reactionLabels)
    f_clear_boxes(activeZoneBoxes)
    f_clear_boxes(confluenceZoneBoxes)
    f_clear_boxes(memoryZoneBoxes)
    array.clear(statsId)
    array.clear(statsDir)
    array.clear(statsBar)
    array.clear(statsPrice)
    array.clear(statsFib)
    array.clear(statsDepth)
    array.clear(statsBars)
    array.clear(statsEff)
    array.clear(statsReact)

    int desiredTableCols = presetFull ? 7 : 5
    if na(statsTable) or desiredTableCols != statsTableCols or statsTablePosCurrent != statsTablePosition
        if not na(statsTable)
            table.delete(statsTable)
        statsTableCols := desiredTableCols
        statsTableRows := 2
        statsTablePosCurrent := statsTablePosition
        statsTable := table.new(f_table_position(statsTablePosition), statsTableCols, statsTableRows, bgcolor=color.new(color.white, 5), border_color=color.new(color.gray, 60), border_width=1, frame_color=color.new(color.gray, 40), frame_width=1)

    int pivotCount = array.size(pivPrices)
    int minDrawIndex = math.max(0, bar_index - drawLookbackBars)
    float bandHalf = atr * zoneBandAtrMult * 0.5
    float priorClusterFib = na
    int clusterCount = 0
    float[] confLevels = array.new_float()
    int[] confIndices = array.new_int()
    string[] confOutlooks = array.new_string()

    if showZigZag and pivotCount >= 2
        for i = 1 to pivotCount - 1
            int x1 = array.get(pivIndexes, i - 1)
            float y1 = array.get(pivPrices, i - 1)
            int x2 = array.get(pivIndexes, i)
            float y2 = array.get(pivPrices, i)
            if x1 >= minDrawIndex and x2 >= minDrawIndex
                color segmentColor = y2 >= y1 ? upColor : downColor
                array.push(zigZagLines, line.new(x1, y1, x2, y2, xloc=xloc.bar_index, color=color.new(segmentColor, confirmedLineOpacity), width=zigZagWidth))

    // Only lock a pullback pivot once the next opposite pivot exists.
    // This prevents labels on provisional pullback ends that later get invalidated by a deeper extension.
    if (showPullbackLabels or renderStatsTable or renderZoneMemory or renderReactionMarkers or renderConfluenceZone or renderOutlookLabel) and pivotCount >= 4
        for i = 2 to pivotCount - 2
            float a = array.get(pivPrices, i - 2)
            float b = array.get(pivPrices, i - 1)
            float c = array.get(pivPrices, i)
            int aIndex = array.get(pivIndexes, i - 2)
            int bIndex = array.get(pivIndexes, i - 1)
            int cIndex = array.get(pivIndexes, i)
            int cType = array.get(pivTypes, i)
            bool impulseUp = b > a
            float legSize = math.abs(b - a)
            float pullbackSize = math.abs(c - b)
            int impulseBars = math.max(1, bIndex - aIndex)
            int pullbackBars = math.max(1, cIndex - bIndex)
            float ratio = legSize > 0.0 ? pullbackSize / legSize : na
            float legPercent = b != 0.0 ? legSize / math.abs(b) * 100.0 : 0.0
            bool legQualified = legSize >= atr * minLegAtr and legPercent >= minLegPercent

            if not na(ratio) and ratio >= array.get(standardRatios, 0) and ratio <= pullbackMaxRatio and legQualified
                float matched = f_nearest_standard(ratio, matchTolerance)
                float reached = f_reached_standard(ratio)
                float dominantFib = not na(matched) ? matched : reached
                bool relevant = f_is_relevant(matched, reached)
                string depth = f_depth_regime(ratio)
                float efficiency = f_efficiency(legSize, impulseBars, pullbackSize, pullbackBars)
                string efficiencyText = showEfficiency and not na(efficiency) ? str.tostring(efficiency, "#.##") + "x" : ""
                string fibText = not na(matched) ? str.tostring(matched, "#.###") : not na(reached) ? str.tostring(reached, "#.###") + "+" : str.tostring(ratio, "#.###")
                string reaction = "Pending"
                int reactionIndex = na
                float reactionPrice = na

                if not na(dominantFib) and not na(priorClusterFib) and math.abs(dominantFib - priorClusterFib) < 0.0005
                    clusterCount += 1
                else
                    clusterCount := 1
                priorClusterFib := dominantFib

                reactionPrice := array.get(pivPrices, i + 1)
                reactionIndex := array.get(pivIndexes, i + 1)
                reaction := f_reaction_text(impulseUp, b, c, reactionPrice)
                string outcome = f_outcome_text(reaction)

                float outlookScore = f_outlook_score(ratio, pullbackBars, efficiency, reaction)
                string outlook = f_outlook_text(outlookScore)
                string zoneBias = f_zone_bias(outlook)

                if (renderConfluenceZone or renderOutlookLabel) and f_confluence_candidate(relevant, ratio, pullbackBars, efficiency, reaction) and not na(dominantFib)
                    float confLevel = b + (a - b) * dominantFib
                    array.push(confLevels, confLevel)
                    array.push(confIndices, cIndex)
                    array.push(confOutlooks, zoneBias + "|" + outlook)
                    while array.size(confLevels) > confluenceLookback
                        array.shift(confLevels)
                        array.shift(confIndices)
                        array.shift(confOutlooks)

                if showPullbackLabels and relevant and cIndex >= minDrawIndex
                    string pullbackId = "#" + str.tostring(array.size(statsId) + 1)
                    string txt = useCompactLabels ? (not na(matched) ? "PB " + str.tostring(matched, "#.###") : not na(reached) ? "PB " + str.tostring(reached, "#.###") + "+" : "PB " + str.tostring(ratio, "#.###")) : f_pullback_text(ratio, matched, reached)
                    txt := pullbackId + " " + txt
                    txt := renderDepthInLabel ? txt + "\n" + depth : txt
                    txt := renderTimeInLabel ? txt + "\n" + str.tostring(pullbackBars) + " bars" : txt
                    txt := renderEfficiencyInLabel and efficiencyText != "" ? txt + "\nEff " + efficiencyText : txt
                    txt := renderClusterInLabel and clusterCount >= 2 and not na(dominantFib) ? txt + " x" + str.tostring(clusterCount) : txt
                    color labelColor = not na(matched) ? f_level_color(matched) : not na(reached) ? f_level_color(reached) : neutralPullbackColor
                    color labelTextColor = f_text_on_color(labelColor)
                    string structureText = impulseUp ? "Impulse up -> pullback down" : "Impulse down -> pullback up"
                    string tooltip = "Pullback pivot\n" +
                         "Structure: " + structureText + "\n" +
                         "Pivot index: " + str.tostring(cIndex) + "\n" +
                         "Pivot price: " + str.tostring(c, format.mintick) + "\n" +
                         "Reference leg: " + str.tostring(a, format.mintick) + " -> " + str.tostring(b, format.mintick) + "\n" +
                         "Pullback size: " + str.tostring(pullbackSize, format.mintick) + "\n" +
                         "Retracement: " + str.tostring(ratio, "#.###") + "\n" +
                         "Depth regime: " + depth +
                         (showTimeStats ? "\nImpulse bars: " + str.tostring(impulseBars) + "\nPullback bars: " + str.tostring(pullbackBars) : "") +
                         (showEfficiency and efficiencyText != "" ? "\nEfficiency: " + efficiencyText : "") + "\n" +
                         "Outlook: " + outlook + "\n" +
                         "Outcome: " + outcome +
                         (not na(matched) ? "\nMatched standard fib: " + str.tostring(matched, "#.###") : not na(reached) ? "\nDeepest reached standard fib: " + str.tostring(reached, "#.###") : "\nNo standard fib match") +
                         (showClusterTag and clusterCount >= 2 and not na(dominantFib) ? "\nCluster count: " + str.tostring(clusterCount) : "")
                    array.push(
                         pullbackPivotLabels,
                         label.new(
                             cIndex,
                             c,
                             txt,
                             xloc=xloc.bar_index,
                             style=cType == 1 ? label.style_label_down : label.style_label_up,
                             color=color.new(labelColor, 0),
                             textcolor=labelTextColor,
                             size=useCompactLabels and pullbackLabelSize == "Large" ? size.normal : f_label_size(pullbackLabelSize),
                             tooltip=tooltip))

                    if renderStatsTable
                        array.push(statsId, pullbackId)
                        array.push(statsDir, impulseUp ? "Up" : "Down")
                        array.push(statsBar, str.tostring(cIndex))
                        array.push(statsPrice, str.tostring(c, format.mintick))
                        array.push(statsFib, fibText)
                        array.push(statsDepth, depth)
                        array.push(statsBars, showTimeStats ? str.tostring(pullbackBars) : "")
                        array.push(statsEff, efficiencyText)
                        array.push(statsReact, outcome)
                        while array.size(statsDir) > statsRows
                            array.shift(statsId)
                            array.shift(statsDir)
                            array.shift(statsBar)
                            array.shift(statsPrice)
                            array.shift(statsFib)
                            array.shift(statsDepth)
                            array.shift(statsBars)
                            array.shift(statsEff)
                            array.shift(statsReact)

                if renderZoneMemory and relevant and cIndex >= minDrawIndex and not na(dominantFib)
                    float memLevel = b + (a - b) * dominantFib
                    color memZoneColor = zoneBias == "risk" ? riskMemoryColor : zoneBias == "fragile" ? color.rgb(255, 152, 0) : supportMemoryColor
                    string memLabelText = zoneBias == "risk" ? "Risk Memory" : zoneBias == "fragile" ? "Fragile Memory" : "Support Memory"
                    int memBgAlpha = memoryZoneStyle == "Border Only" ? 100 : zoneBias == "supportive" ? 95 : 93
                    int memBorderAlpha = zoneBias == "supportive" ? 72 : 55
                    array.push(memoryZoneBoxes, box.new(left=cIndex, top=memLevel + bandHalf, right=bar_index, bottom=memLevel - bandHalf, xloc=xloc.bar_index, bgcolor=color.new(memZoneColor, memBgAlpha), border_color=color.new(memZoneColor, memBorderAlpha)))
                    if showMemoryLabels
                        array.push(memoryLabels, label.new(cIndex, memLevel, presetMinimal ? "M" : memLabelText, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(memZoneColor, 16), textcolor=f_text_on_color(memZoneColor), size=presetBalanced ? size.tiny : size.small, tooltip="Historical memory zone\nType: " + memLabelText + "\nLevel: " + str.tostring(memLevel, format.mintick) + "\nDerived from confirmed pullback at bar " + str.tostring(cIndex)))
                    while array.size(memoryZoneBoxes) > memoryKeepCount
                        box.delete(array.shift(memoryZoneBoxes))
                    while array.size(memoryLabels) > memoryKeepCount
                        label.delete(array.shift(memoryLabels))

                if renderReactionMarkers and reaction != "Pending" and not na(reactionIndex) and reactionIndex >= minDrawIndex
                    color reactionColor = reaction == "HH" or reaction == "LL" ? color.new(color.lime, 0) : reaction == "Break" ? color.new(color.red, 0) : color.new(color.orange, 0)
                    string reactionText = "R " + reaction
                    array.push(reactionLabels, label.new(reactionIndex, reactionPrice, reactionText, xloc=xloc.bar_index, style=impulseUp ? label.style_label_down : label.style_label_up, color=color.new(reactionColor, 8), textcolor=f_text_on_color(reactionColor), size=size.tiny))

        if renderConfluenceZone and array.size(confLevels) >= 2
            float avgLevel = 0.0
            for j = 0 to array.size(confLevels) - 1
                avgLevel += array.get(confLevels, j)
            avgLevel := avgLevel / array.size(confLevels)

            int clusterHits = 0
            for j = 0 to array.size(confLevels) - 1
                if math.abs(array.get(confLevels, j) - avgLevel) <= atr * confluenceToleranceAtr
                    clusterHits += 1

            if clusterHits >= 2
                int leftIndex = array.get(confIndices, 0)
                float tol = atr * confluenceToleranceAtr
                array.push(confluenceZoneBoxes, box.new(left=leftIndex, top=avgLevel + tol, right=bar_index, bottom=avgLevel - tol, xloc=xloc.bar_index, bgcolor=color.new(color.rgb(63, 81, 181), 94), border_color=color.new(color.rgb(63, 81, 181), 52)))
                if renderOutlookLabel
                    string confMeta = array.get(confOutlooks, array.size(confOutlooks) - 1)
                    string recentBias = str.contains(confMeta, "|") ? str.substring(confMeta, 0, str.pos(confMeta, "|")) : "supportive"
                    string recentOutlook = str.contains(confMeta, "|") ? str.substring(confMeta, str.pos(confMeta, "|") + 1, str.length(confMeta)) : confMeta
                    color outlookColor = f_outlook_color(recentOutlook)
                    color zoneColor = recentBias == "risk" ? color.rgb(213, 0, 0) : recentBias == "fragile" ? color.rgb(255, 152, 0) : color.rgb(0, 200, 83)
                    string outlookText = presetMinimal ? recentOutlook : "Confluence\n" + recentOutlook + "\nx" + str.tostring(clusterHits)
                    string outlookTooltip = "Confluence zone\n" +
                         "Average level: " + str.tostring(avgLevel, format.mintick) + "\n" +
                         "Tolerance: " + str.tostring(tol, format.mintick) + "\n" +
                         "Zone bias: " + recentBias + "\n" +
                         "Cluster hits: " + str.tostring(clusterHits) + "\n" +
                         "Current outlook: " + recentOutlook
                    box.set_bgcolor(array.get(confluenceZoneBoxes, array.size(confluenceZoneBoxes) - 1), color.new(zoneColor, 94))
                    box.set_border_color(array.get(confluenceZoneBoxes, array.size(confluenceZoneBoxes) - 1), color.new(zoneColor, 52))
                    array.push(outlookLabels, label.new(bar_index, avgLevel, outlookText, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(outlookColor, presetBalanced ? 22 : 10), textcolor=f_text_on_color(outlookColor), size=presetMinimal ? size.tiny : size.small, tooltip=outlookTooltip))

    if showActiveFan and pivotCount >= 3
        float base0 = array.get(pivPrices, pivotCount - 2)
        float base1 = array.get(pivPrices, pivotCount - 1)
        int baseIndex = array.get(pivIndexes, pivotCount - 1)
        int lastConfirmedType = array.get(pivTypes, pivotCount - 1)
        int activeLookback = math.min(bar_index - baseIndex + 1, drawLookbackBars)

        if baseIndex >= minDrawIndex and activeLookback > 0
            float lastPivot = base1
            int activeOffset = 0
            if lastConfirmedType == -1
                for k = 0 to activeLookback - 1
                    if high[k] > lastPivot
                        lastPivot    := high[k]
                        activeOffset := k
            else
                for k = 0 to activeLookback - 1
                    if low[k] < lastPivot
                        lastPivot    := low[k]
                        activeOffset := k
            int activeIndex = bar_index - activeOffset
            float diff = base0 - base1
            bool moveUp = lastPivot > base1
            bool alreadyBeyondLatest = false
            float activeMove = math.abs(lastPivot - base1)
            float referenceMove = math.abs(base0 - base1)
            float liveRatio = referenceMove > 0.0 ? activeMove / referenceMove : na
            float liveMatched = not na(liveRatio) ? f_nearest_standard(liveRatio, matchTolerance) : na
            float liveReached = not na(liveRatio) ? f_reached_standard(liveRatio) : na
            string liveZone = not na(liveRatio) ? f_zone_text(liveRatio) : "na"
            float zoneLoRatio = 0.000
            float zoneHiRatio = 0.236
            if not na(liveRatio)
                [zoneLoRatio, zoneHiRatio] = f_zone_bounds(liveRatio)
            float nextFib = na
            for j = 0 to array.size(standardRatios) - 1
                float candidate = array.get(standardRatios, j)
                if candidate > liveRatio
                    nextFib := candidate
                    break

            if showZigZag and activeIndex > baseIndex and lastPivot != base1
                array.push(zigZagLines, line.new(baseIndex, base1, activeIndex, lastPivot, xloc=xloc.bar_index, color=color.new(activeLegColor, liveLineOpacity), width=zigZagWidth, style=line.style_dashed))

            if showLiveOriginMarker and baseIndex >= minDrawIndex
                string originText = presetMinimal ? "O" : "Origin"
                string originTooltip = "Live pullback origin\n" +
                     "This is the last confirmed pivot from which the current unfinished pullback is measured.\n" +
                     "Origin price: " + str.tostring(base1, format.mintick) + "\n" +
                     "Origin bar: " + str.tostring(baseIndex)
                array.push(activeOriginLabels, label.new(baseIndex, base1, originText, xloc=xloc.bar_index, style=moveUp ? label.style_label_up : label.style_label_down, color=color.new(color.gray, 18), textcolor=color.white, size=presetMinimal ? size.tiny : size.small, tooltip=originTooltip))

            if showLiveRetracementLabel and activeIndex > baseIndex and not na(liveRatio)
                color liveBg = not na(liveMatched) ? f_level_color(liveMatched) : not na(liveReached) ? f_level_color(liveReached) : neutralPullbackColor
                color liveText = f_text_on_color(liveBg)
                string fibState = not na(liveMatched) ? "Matched " + str.tostring(liveMatched, "#.###") : not na(liveReached) ? "Reached " + str.tostring(liveReached, "#.###") : "Below 0.236"
                bool liveRelevant = liveRatio >= 0.236
                string liveTextLabel = presetMinimal ? (liveRelevant ? "LIVE " + str.tostring(liveRatio, "#.###") : "LIVE") : "LIVE " + str.tostring(liveRatio, "#.###") + "\n" + fibState + (showCurrentZone and liveRelevant ? "\nZone " + liveZone : "")
                string liveTooltip = "Active unfinished leg\n" +
                     "Active leg: " + (moveUp ? "Up" : "Down") + "\n" +
                     "Last confirmed pivot: " + (lastConfirmedType == 1 ? "High" : "Low") + "\n" +
                     "Base anchor: " + str.tostring(base1, format.mintick) + "\n" +
                     "Reference swing: " + str.tostring(base0, format.mintick) + " -> " + str.tostring(base1, format.mintick) + "\n" +
                     "Current extreme: " + str.tostring(lastPivot, format.mintick) + "\n" +
                     "Current retracement ratio: " + str.tostring(liveRatio, "#.###") + "\n" +
                     "Current zone: " + liveZone + "\n" +
                     "State: " + fibState + "\n" +
                     "This leg is live and can still extend until a pivot confirms."
                array.push(activeStateLabels, label.new(bar_index + 1, close, liveTextLabel, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(liveBg, liveRelevant ? liveLabelOpacity : weakLiveLabelOpacity), textcolor=liveText, size=presetMinimal ? size.small : f_label_size(fanLabelSize), tooltip=liveTooltip))

            if renderCurrentZoneBox and not na(liveRatio) and liveRatio >= 0.236
                float zoneTop = base1 + diff * zoneHiRatio
                float zoneBottom = base1 + diff * zoneLoRatio
                color zoneColor = not na(liveMatched) ? f_level_color(liveMatched) : not na(liveReached) ? f_level_color(liveReached) : neutralPullbackColor
                array.push(activeZoneBoxes, box.new(left=baseIndex, top=math.max(zoneTop, zoneBottom), right=bar_index, bottom=math.min(zoneTop, zoneBottom), xloc=xloc.bar_index, bgcolor=color.new(zoneColor, presetBalanced ? 88 : 82), border_color=color.new(zoneColor, presetBalanced ? 45 : 20)))

                if renderOutlookLabel
                    string liveDepth = f_depth_regime(liveRatio)
                    float liveOutlookScore = f_outlook_score(liveRatio, activeLookback, na, "Pending")
                    string liveOutlook = f_outlook_text(liveOutlookScore)
                    color liveOutlookColor = f_outlook_color(liveOutlook)
                    string liveOutlookText = presetMinimal ? liveOutlook : "Current Zone\n" + liveOutlook
                    string liveOutlookTooltip = "Current pullback zone\n" +
                         "Active leg: " + (moveUp ? "Up" : "Down") + "\n" +
                         "Last confirmed pivot: " + (lastConfirmedType == 1 ? "High" : "Low") + "\n" +
                         "Zone: " + liveZone + "\n" +
                         "Retracement: " + str.tostring(liveRatio, "#.###") + "\n" +
                         "Depth: " + liveDepth + "\n" +
                         "Score: " + str.tostring(liveOutlookScore, "#.##") + "\n" +
                         "Outlook: " + liveOutlook
                    array.push(outlookLabels, label.new(bar_index, math.avg(zoneTop, zoneBottom), liveOutlookText, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(liveOutlookColor, presetBalanced ? 24 : 12), textcolor=f_text_on_color(liveOutlookColor), size=presetMinimal ? size.tiny : size.small, tooltip=liveOutlookTooltip))

            for i = 0 to array.size(fanRatios) - 1
                float ratio = array.get(fanRatios, i)
                float level = base1 + diff * ratio
                bool beyondLatest = moveUp ? level > lastPivot : level < lastPivot

                if beyondLatest and alreadyBeyondLatest and extendPastPivot
                    break
                if beyondLatest and not extendPastPivot
                    break

                color lineColor = f_is_standard(ratio) ? f_level_color(ratio) : fanExtensionColor
                bool keyFanLevel = ratio == 0.236 or ratio == 0.382 or ratio == 0.500 or ratio == 0.618 or ratio == 0.786 or ratio == 1.000
                bool zoneBoundary = math.abs(ratio - zoneLoRatio) < 0.0005 or math.abs(ratio - zoneHiRatio) < 0.0005
                bool reachedBoundary = not na(liveReached) and math.abs(ratio - liveReached) < 0.0005
                bool nextBoundary = not na(nextFib) and math.abs(ratio - nextFib) < 0.0005
                bool drawThisLevel = activeDisplayMode == "Full Ladder" ? true : activeDisplayMode == "Current Zone" ? zoneBoundary : zoneBoundary or reachedBoundary or nextBoundary
                bool drawFanLabel = activeDisplayMode == "Full Ladder" ? (renderAllFanLabels or (renderOnlyKeyFanLabels and keyFanLevel)) : drawThisLevel

                if drawThisLevel and renderZoneBands and f_is_standard(ratio)
                    array.push(activeZoneBoxes, box.new(left=baseIndex, top=level + bandHalf, right=bar_index, bottom=level - bandHalf, xloc=xloc.bar_index, bgcolor=color.new(lineColor, presetBalanced ? 88 : 82), border_color=color.new(lineColor, presetBalanced ? 75 : 55)))
                else if drawThisLevel
                    array.push(activeFanLines, line.new(baseIndex, level, bar_index, level, xloc=xloc.bar_index, extend=extend.right, color=color.new(lineColor, 0), width=fanLineWidth))

                if drawFanLabel
                    int labelX = fanLabelSide == "Left" ? baseIndex - 1 : bar_index + fanLabelOffset
                    string ratioText = str.tostring(ratio, "#.###")
                    string levelRole = zoneBoundary ? " zone" : reachedBoundary ? " reached" : nextBoundary ? " next" : ""
                    string labelText = activeDisplayMode == "Full Ladder" ? (presetBalanced ? ratioText : ratioText + " (" + str.tostring(level, format.mintick) + ")") : ratioText + levelRole
                    string fanTooltip = "Active fib level\n" +
                         "Ratio: " + ratioText + "\n" +
                         "Level price: " + str.tostring(level, format.mintick) + "\n" +
                         "Base leg anchor: " + str.tostring(base0, format.mintick) + " -> " + str.tostring(base1, format.mintick) + "\n" +
                         "Active extreme: " + str.tostring(lastPivot, format.mintick) + " at bar " + str.tostring(activeIndex) + "\n" +
                         "Dashed leg direction: " + (moveUp ? "up" : "down") + "\n" +
                         "Role: " + (zoneBoundary ? "current zone boundary" : reachedBoundary ? "deepest reached standard fib" : nextBoundary ? "next standard fib" : "active fib level") + "\n" +
                         "Current zone: " + liveZone + "\n" +
                         "Beyond current extreme: " + (beyondLatest ? "yes" : "no")
                    label fanLabel = label.new(labelX, level, labelText, xloc=xloc.bar_index, style=fanLabelSide == "Left" ? label.style_label_left : label.style_label_right, color=color.new(lineColor, activeDisplayMode == "Full Ladder" ? (presetBalanced ? 72 : 58) : 38), textcolor=f_text_on_color(lineColor), size=activeDisplayMode == "Full Ladder" ? (presetBalanced ? size.small : f_label_size(fanLabelSize)) : size.small, tooltip=fanTooltip)
                    array.push(activeFanLabels, fanLabel)

                if beyondLatest
                    alreadyBeyondLatest := true

    int rowsToShow = math.min(statsRows, array.size(statsId))
    int requiredRows = renderStatsTable ? math.max(2, rowsToShow + 1) : 2
    if requiredRows != statsTableRows
        if not na(statsTable)
            table.delete(statsTable)
        statsTableRows := requiredRows
        statsTable := table.new(f_table_position(statsTablePosition), statsTableCols, statsTableRows, bgcolor=color.new(color.white, 5), border_color=color.new(color.gray, 60), border_width=1, frame_color=color.new(color.gray, 40), frame_width=1)

    if renderStatsTable
        color tc = color.new(color.gray, 10)
        color lc = color.new(color.gray, 20)
        f_table_cell(0, 0, "ID", color.new(color.gray, 90), lc)
        f_table_cell(1, 0, "Impulse", color.new(color.gray, 90), lc)
        f_table_cell(2, 0, "Bar", color.new(color.gray, 90), lc)
        f_table_cell(3, 0, "Price", color.new(color.gray, 90), lc)
        f_table_cell(4, 0, "Fib", color.new(color.gray, 90), color.rgb(33, 150, 243))
        if compactTableCols == 7
            f_table_cell(5, 0, "Depth", color.new(color.gray, 90), lc)
            f_table_cell(6, 0, "Outcome", color.new(color.gray, 90), lc)
        for row = 0 to rowsToShow - 1
            int idx = array.size(statsId) - 1 - row
            string idVal = array.get(statsId, idx)
            string dirVal = array.get(statsDir, idx)
            string barVal = array.get(statsBar, idx)
            string priceVal = array.get(statsPrice, idx)
            string fibVal = array.get(statsFib, idx)
            string depthVal = array.get(statsDepth, idx)
            string reactVal = array.get(statsReact, idx)
            color dirBg = dirVal == "Up" ? color.new(#00c853, 72) : color.new(#d50000, 72)
            color fibBg = str.contains(fibVal, "0.618") ? color.new(#ffd600, 50) : str.contains(fibVal, "0.786") ? color.new(#ff6f00, 45) : str.contains(fibVal, "0.382") ? color.new(#2196f3, 45) : str.contains(fibVal, "0.5") ? color.new(#4caf50, 45) : color.new(color.gray, 70)
            color reactBg = str.contains(reactVal, "LL formed") or str.contains(reactVal, "HH formed") ? color.new(#00c853, 55) : str.contains(reactVal, "Break") ? color.new(#d50000, 45) : str.contains(reactVal, "Weak") ? color.new(#ff6f00, 45) : color.new(color.gray, 75)
            f_table_cell(0, row + 1, idVal, color.new(color.white, 5), tc)
            f_table_cell(1, row + 1, dirVal, dirBg, color.white)
            f_table_cell(2, row + 1, barVal, color.new(color.white, 5), tc)
            f_table_cell(3, row + 1, priceVal, color.new(color.white, 5), tc)
            if compactTableCols == 7
                f_table_cell(4, row + 1, fibVal, fibBg, f_text_on_color(fibBg))
                f_table_cell(5, row + 1, depthVal, color.new(color.white, 5), tc)
                f_table_cell(6, row + 1, reactVal, reactBg, f_text_on_color(reactBg))
            else
                f_table_cell(4, row + 1, reactVal, reactBg, f_text_on_color(reactBg))
    else
        for row = 0 to statsTableRows - 1
            for col = 0 to statsTableCols - 1
                f_table_cell(col, row, "", color.new(color.white, 100), color.new(color.gray, 100))
