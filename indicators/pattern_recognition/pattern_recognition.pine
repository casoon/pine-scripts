// ============================================================================
// MODULE: types
// ============================================================================

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

// Pattern Types
type PatternType
    string name
    bool isBullish
    bool isBearish
    bool isNeutral

// Triangle Pattern
type TrianglePattern
    int startBar
    int endBar
    float upperLine_y1
    float upperLine_y2
    float lowerLine_y1
    float lowerLine_y2
    int upperTouches
    int lowerTouches
    string triangleType
    float confidence
    bool active
    line upperLine
    line lowerLine
    label patternLabel

// Wedge Pattern
type WedgePattern
    int startBar
    int endBar
    float upperLine_y1
    float upperLine_y2
    float lowerLine_y1
    float lowerLine_y2
    int upperTouches
    int lowerTouches
    string wedgeType
    bool hasRSIDivergence
    bool hasStochDivergence
    float confidence
    bool active
    line upperLine
    line lowerLine
    label patternLabel

// Channel Pattern
type ChannelPattern
    int startBar
    int endBar
    float upperLine_y1
    float upperLine_y2
    float lowerLine_y1
    float lowerLine_y2
    int upperTouches
    int lowerTouches
    string channelType
    bool isParallel
    float confidence
    bool active
    line upperLine
    line lowerLine
    line midLine
    label patternLabel

// Technical Indicators State
type TechnicalState
    float rsi
    float stochK
    float stochD
    bool stochCrossUp
    bool stochCrossDown
    bool inOverbought
    bool inOversold
    float volumeRatio

// Divergence Detection
type Divergence
    bool regularBullish
    bool regularBearish
    bool hiddenBullish
    bool hiddenBearish
    int pivotIndex
    float strength


