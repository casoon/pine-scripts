//@version=6
// ============================================================================
// Modern Trend Regime [WavesUnchained]
// Version: 1.3.1
// Author: WavesUnchained
// Build: 2026-07-14 20:00:00
// ============================================================================
// Vereinfachtes Trend- und Range-System ohne Ichimoku-Begriffe.
//
// Features:
//   ✓ Marktmodus-Erkennung: Trend / Range / Übergang mit Score- statt AND-Logik
//   ✓ Übergang wird bei Strukturverlust sofort aktiv, neue Modi werden bestätigt
//   ✓ Trendbestätigung an der Regime-Änderung selbst, nicht am rohen Cross
//   ✓ Echte Range-Struktur mit eingefrorenen Grenzen (nicht nur ATR-Band)
//   ✓ Einmalig scharfgeschaltete Range-Ausbrüche, entprellte Range-Reaktionen
//   ✓ Sechs abgestimmte Presets + Benutzerdefiniert
//   ✓ Mehrere moderne Visualisierungsmodi
// ============================================================================

indicator(
     "Modern Trend Regime [WavesUnchained]",
     shorttitle = "MTR",
     overlay = true,
     max_labels_count = 500
)

// ─────────────────────────────────────────────────────────────────────────────
// PRESET
// ─────────────────────────────────────────────────────────────────────────────

groupPreset = "Voreinstellung"

preset = input.string(
     "Standard",
     "Preset",
     options = [
         "Standard",
         "Schnell",
         "Ruhig",
         "Trendfolge",
         "Range Trading",
         "Ausbruch",
         "Benutzerdefiniert"
     ],
     group = groupPreset,
     tooltip = "Wählt eine abgestimmte Grundeinstellung. Benutzerdefiniert verwendet die Werte aus den '– Benutzerdefiniert'-Gruppen."
)

// ─────────────────────────────────────────────────────────────────────────────
// BERECHNUNG
// ─────────────────────────────────────────────────────────────────────────────

groupCalculation = "Berechnung"

calculationMode = input.string(
     "Preisspanne",
     "Berechnungsmethode",
     options = ["Preisspanne", "EMA", "WMA", "SMA"],
     group = groupCalculation
)

priceSource = input.source(
     close,
     "Preisquelle",
     group = groupCalculation
)

groupCalculationCustom = "Berechnung – Benutzerdefiniert"

customFastLength = input.int(
     9,
     "Fast Trend Länge",
     minval = 2,
     group = groupCalculationCustom
)

customBaseLength = input.int(
     26,
     "Trend Basis Länge",
     minval = 2,
     group = groupCalculationCustom
)

customSlowLength = input.int(
     52,
     "Langfristige Struktur",
     minval = 3,
     group = groupCalculationCustom
)

// ─────────────────────────────────────────────────────────────────────────────
// MARKTMODUS
// ─────────────────────────────────────────────────────────────────────────────

groupRegimeCustom = "Marktmodus – Benutzerdefiniert"

customRegimeLength = input.int(
     20,
     "Analysezeitraum",
     minval = 5,
     group = groupRegimeCustom
)

customAdxLength = input.int(
     14,
     "Trendstärke Zeitraum",
     minval = 3,
     group = groupRegimeCustom
)

customRangeAdxThreshold = input.float(
     18.0,
     "Seitwärts unter Trendstärke",
     minval = 5,
     maxval = 40,
     step = 0.5,
     group = groupRegimeCustom,
     tooltip = "Niedrige Werte erkennen nur sehr ruhige Seitwärtsphasen."
)

customTrendAdxThreshold = input.float(
     23.0,
     "Trend über Trendstärke",
     minval = 5,
     maxval = 50,
     step = 0.5,
     group = groupRegimeCustom
)

customRangeEfficiencyThreshold = input.float(
     0.28,
     "Seitwärts unter Richtungseffizienz",
     minval = 0.05,
     maxval = 0.8,
     step = 0.01,
     group = groupRegimeCustom
)

customTrendEfficiencyThreshold = input.float(
     0.42,
     "Trend über Richtungseffizienz",
     minval = 0.05,
     maxval = 1.0,
     step = 0.01,
     group = groupRegimeCustom
)

customRangeSlopeThreshold = input.float(
     0.025,
     "Maximale Basis-Steigung (ATR/Kerze)",
     minval = 0.0,
     step = 0.005,
     group = groupRegimeCustom,
     tooltip = "Durchschnittliche Steigung der Trend Basis pro Kerze, normalisiert auf ATR."
)

customCompressionThreshold = input.float(
     0.45,
     "Maximale Strukturbreite in ATR",
     minval = 0.05,
     step = 0.05,
     group = groupRegimeCustom
)

customRegimeConfirmationBars = input.int(
     3,
     "Bestätigungskerzen",
     minval = 1,
     maxval = 10,
     group = groupRegimeCustom,
     tooltip = "Der neue Marktmodus muss mehrere Kerzen bestehen bleiben."
)

// ─────────────────────────────────────────────────────────────────────────────
// RANGE-MODUS
// ─────────────────────────────────────────────────────────────────────────────

groupRange = "Seitwärtsmodus"

groupRangeCustom = "Seitwärtsmodus – Benutzerdefiniert"

customBreakoutBufferAtr = input.float(
     0.10,
     "Ausbruchspuffer in ATR",
     minval = 0,
     step = 0.05,
     group = groupRangeCustom
)

showRangeReactions = input.bool(
     true,
     "Range-Reaktionen anzeigen",
     group = groupRange
)

showRangeBreakouts = input.bool(
     true,
     "Range-Ausbrüche anzeigen",
     group = groupRange
)

rangeReactionNeedsCandle = input.bool(
     true,
     "Reaktionskerze verlangen",
     group = groupRange,
     tooltip = "Long benötigt eine positive, Short eine negative Kerze."
)

// ─────────────────────────────────────────────────────────────────────────────
// TRENDSIGNALE
// ─────────────────────────────────────────────────────────────────────────────

groupSignals = "Trendmodus"

showTrendFlips = input.bool(
     true,
     "Trend-Bestätigung anzeigen",
     group = groupSignals,
     tooltip = "Markiert, wenn die State Machine tatsächlich in einen neuen Trend wechselt (nicht jeder Fast/Base-Cross)."
)

confirmOnClose = input.bool(
     true,
     "Nur bestätigte Kerzen",
     group = groupSignals
)

// ─────────────────────────────────────────────────────────────────────────────
// VISUALISIERUNG
// ─────────────────────────────────────────────────────────────────────────────

groupDisplay = "Visualisierung"

visualMode = input.string(
     "Trendband",
     "Darstellungsmodus",
     options = [
         "Trendband",
         "Range-Korridor",
         "Regime-Leiste",
         "Minimal",
         "Alles"
     ],
     group = groupDisplay
)

showFastTrend = input.bool(
     false,
     "Fast Trend anzeigen",
     group = groupDisplay
)

showTrendBase = input.bool(
     true,
     "Trend Basis anzeigen",
     group = groupDisplay
)

colorBars = input.bool(
     true,
     "Kerzen nach Marktmodus färben",
     group = groupDisplay
)

showTransitionBackground = input.bool(
     false,
     "Übergangsphasen hinterlegen",
     group = groupDisplay
)

bandWidthAtr = input.float(
     0.22,
     "Trendband Breite in ATR",
     minval = 0.05,
     step = 0.01,
     group = groupDisplay
)

structurePreviewEnabled = input.bool(
     true,
     "Strukturvorschau anzeigen",
     group = groupDisplay,
     tooltip = "Verschiebt die aktuell berechnete Struktur optisch nach rechts. Es handelt sich nicht um eine Kursprognose."
)

structurePreviewOffset = input.int(
     26,
     "Strukturvorschau-Verschiebung",
     minval = 1,
     maxval = 200,
     group = groupDisplay
)

// ─────────────────────────────────────────────────────────────────────────────
// FARBEN
// ─────────────────────────────────────────────────────────────────────────────

bullColor = color.rgb(38, 166, 154)
bearColor = color.rgb(239, 83, 80)
rangeColor = color.rgb(126, 87, 194)
transitionColor = color.rgb(120, 123, 134)

fastColor = color.rgb(255, 167, 38)
baseColor = color.rgb(66, 165, 245)

// ─────────────────────────────────────────────────────────────────────────────
// GEMEINSAM
// ─────────────────────────────────────────────────────────────────────────────

barConfirmed = not confirmOnClose or barstate.isconfirmed

// ─────────────────────────────────────────────────────────────────────────────
// PRESET-WERTE
// ─────────────────────────────────────────────────────────────────────────────

fastLength = switch preset
    "Schnell"           => 7
    "Ruhig"             => 12
    "Trendfolge"        => 10
    "Range Trading"     => 8
    "Ausbruch"          => 10
    "Benutzerdefiniert" => customFastLength
    => 9

baseLength = switch preset
    "Schnell"           => 18
    "Ruhig"             => 30
    "Trendfolge"        => 28
    "Range Trading"     => 22
    "Ausbruch"          => 26
    "Benutzerdefiniert" => customBaseLength
    => 26

slowLength = switch preset
    "Schnell"           => 36
    "Ruhig"             => 60
    "Trendfolge"        => 65
    "Range Trading"     => 44
    "Ausbruch"          => 52
    "Benutzerdefiniert" => customSlowLength
    => 52

regimeLength = switch preset
    "Schnell"           => 14
    "Ruhig"             => 30
    "Trendfolge"        => 25
    "Range Trading"     => 18
    "Ausbruch"          => 20
    "Benutzerdefiniert" => customRegimeLength
    => 20

adxLength = switch preset
    "Schnell"           => 10
    "Ruhig"             => 18
    "Trendfolge"        => 14
    "Range Trading"     => 12
    "Ausbruch"          => 14
    "Benutzerdefiniert" => customAdxLength
    => 14

rangeAdxThreshold = switch preset
    "Schnell"           => 17.0
    "Ruhig"             => 19.0
    "Trendfolge"        => 16.0
    "Range Trading"     => 21.0
    "Ausbruch"          => 20.0
    "Benutzerdefiniert" => customRangeAdxThreshold
    => 18.0

trendAdxThreshold = switch preset
    "Schnell"           => 21.0
    "Ruhig"             => 25.0
    "Trendfolge"        => 27.0
    "Range Trading"     => 24.0
    "Ausbruch"          => 25.0
    "Benutzerdefiniert" => customTrendAdxThreshold
    => 23.0

rangeEfficiencyThreshold = switch preset
    "Schnell"           => 0.25
    "Ruhig"             => 0.30
    "Trendfolge"        => 0.22
    "Range Trading"     => 0.34
    "Ausbruch"          => 0.30
    "Benutzerdefiniert" => customRangeEfficiencyThreshold
    => 0.28

trendEfficiencyThreshold = switch preset
    "Schnell"           => 0.38
    "Ruhig"             => 0.46
    "Trendfolge"        => 0.50
    "Range Trading"     => 0.44
    "Ausbruch"          => 0.48
    "Benutzerdefiniert" => customTrendEfficiencyThreshold
    => 0.42

rangeSlopeThreshold = switch preset
    "Schnell"           => 0.035
    "Ruhig"             => 0.020
    "Trendfolge"        => 0.018
    "Range Trading"     => 0.040
    "Ausbruch"          => 0.025
    "Benutzerdefiniert" => customRangeSlopeThreshold
    => 0.025

compressionThreshold = switch preset
    "Schnell"           => 0.50
    "Ruhig"             => 0.40
    "Trendfolge"        => 0.35
    "Range Trading"     => 0.60
    "Ausbruch"          => 0.38
    "Benutzerdefiniert" => customCompressionThreshold
    => 0.45

regimeConfirmationBars = switch preset
    "Schnell"           => 2
    "Ruhig"             => 5
    "Trendfolge"        => 4
    "Range Trading"     => 2
    "Ausbruch"          => 3
    "Benutzerdefiniert" => customRegimeConfirmationBars
    => 3

breakoutBufferAtr = switch preset
    "Schnell"           => 0.05
    "Ruhig"             => 0.15
    "Trendfolge"        => 0.15
    "Range Trading"     => 0.10
    "Ausbruch"          => 0.20
    "Benutzerdefiniert" => customBreakoutBufferAtr
    => 0.10

// ─────────────────────────────────────────────────────────────────────────────
// FUNKTIONEN
// ─────────────────────────────────────────────────────────────────────────────

f_midpoint(int length) =>
    (ta.highest(high, length) + ta.lowest(low, length)) / 2.0

f_line(float source, int length, string mode) =>
    switch mode
        "EMA" => ta.ema(source, length)
        "WMA" => ta.wma(source, length)
        "SMA" => ta.sma(source, length)
        => f_midpoint(length)

// ─────────────────────────────────────────────────────────────────────────────
// BASISSTRUKTUR
// ─────────────────────────────────────────────────────────────────────────────

fastTrend = f_line(priceSource, fastLength, calculationMode)
trendBase = f_line(priceSource, baseLength, calculationMode)
slowTrend = f_line(priceSource, slowLength, calculationMode)

atr = ta.atr(14)

structureFast = (fastTrend + trendBase) / 2.0
structureUpper = math.max(structureFast, slowTrend)
structureLower = math.min(structureFast, slowTrend)
structureWidth = structureUpper - structureLower

// ─────────────────────────────────────────────────────────────────────────────
// TRENDSTÄRKE
// ─────────────────────────────────────────────────────────────────────────────

[plusDi, minusDi, adx] = ta.dmi(adxLength, adxLength)

directionalMove = math.abs(close - close[regimeLength])

totalMovement = math.sum(
     math.abs(close - close[1]),
     regimeLength
)

efficiencyRatio =
     totalMovement > 0
         ? directionalMove / totalMovement
         : 0.0

baseSlopeAtr =
     atr > 0 and regimeLength > 0
         ? math.abs(trendBase - trendBase[regimeLength]) / (atr * regimeLength)
         : 0.0

structureWidthAtr =
     atr > 0
         ? structureWidth / atr
         : 0.0

// ─────────────────────────────────────────────────────────────────────────────
// MARKTMODUS-KANDIDATEN
// ─────────────────────────────────────────────────────────────────────────────

rangeScore =
     (adx < rangeAdxThreshold ? 1 : 0) +
     (efficiencyRatio < rangeEfficiencyThreshold ? 1 : 0) +
     (baseSlopeAtr < rangeSlopeThreshold ? 1 : 0) +
     (structureWidthAtr < compressionThreshold ? 1 : 0)

requiredRangeScore = preset == "Range Trading" ? 3 : 4

rangeCandidate = rangeScore >= requiredRangeScore

// Geteilte Stärke (ADX, Efficiency Ratio) + drei Richtungsfaktoren (DI, Stack,
// Preis) als Score statt harter 5er-AND-Kette — sonst reißt ein einzelner
// schwacher Faktor (typischerweise Efficiency Ratio bei volatilen Instrumenten
// wie NatGas) die Trendbestätigung praktisch permanent ab.
sharedTrendScore =
     (adx > trendAdxThreshold ? 1 : 0) +
     (efficiencyRatio > trendEfficiencyThreshold ? 1 : 0)

bullDirectionScore =
     (plusDi > minusDi ? 1 : 0) +
     (fastTrend > trendBase and trendBase > slowTrend ? 1 : 0) +
     (close > trendBase ? 1 : 0)

bearDirectionScore =
     (minusDi > plusDi ? 1 : 0) +
     (fastTrend < trendBase and trendBase < slowTrend ? 1 : 0) +
     (close < trendBase ? 1 : 0)

bullScore = sharedTrendScore + bullDirectionScore
bearScore = sharedTrendScore + bearDirectionScore

// Mit Schwelle 4 von 5 kann Richtung allein (max. 3 Punkte) nie ausreichen —
// mindestens ADX oder Efficiency Ratio muss immer mitspielen.
requiredTrendScore = preset == "Range Trading" ? 5 : 4

bullCandidate = bullScore >= requiredTrendScore
bearCandidate = bearScore >= requiredTrendScore

// Marktmodus:
//  1 = Aufwärtstrend
// -1 = Abwärtstrend
//  2 = Seitwärtsphase
//  0 = Übergang

candidateRegime =
     bullCandidate ? 1 :
     bearCandidate ? -1 :
     rangeCandidate ? 2 :
     0

var int candidateState = 0
var int candidateCount = 0
var int marketRegime = 0

if candidateRegime == 0
    // Verlust einer eindeutigen Struktur sofort anzeigen, statt den alten Modus zu halten.
    marketRegime := 0
    candidateState := 0
    candidateCount := 0
else
    if candidateRegime == candidateState
        candidateCount += 1
    else
        candidateState := candidateRegime
        candidateCount := 1

    if candidateCount >= regimeConfirmationBars
        marketRegime := candidateState

isBullTrend = marketRegime == 1
isBearTrend = marketRegime == -1
isRange = marketRegime == 2
isTransition = marketRegime == 0

// ─────────────────────────────────────────────────────────────────────────────
// RANGE-STRUKTUR
// ─────────────────────────────────────────────────────────────────────────────
// Grenzen werden beim Range-Eintritt aus dem Swing-High/Low eingefroren, statt
// einem beweglichen ATR-Band um die Trend Basis zu folgen — sonst laufen die
// "Range"-Grenzen dem Kurs hinterher und Reaktionen/Ausbrüche bedeuten etwas
// anderes als ihr Name verspricht.

var float activeRangeHigh = na
var float activeRangeLow = na
var bool rangeInitialized = false

rangeStarted = isRange and not isRange[1]
rangeEnded = not isRange and isRange[1]

if rangeStarted
    activeRangeHigh := ta.highest(high[1], regimeLength)
    activeRangeLow := ta.lowest(low[1], regimeLength)
    rangeInitialized := true

if rangeEnded
    rangeInitialized := false

if isRange and rangeInitialized
    activeRangeHigh := math.max(activeRangeHigh, high)
    activeRangeLow := math.min(activeRangeLow, low)

// ─────────────────────────────────────────────────────────────────────────────
// RANGE-REAKTIONEN
// ─────────────────────────────────────────────────────────────────────────────

bullishCandle = close > open
bearishCandle = close < open

lowerZoneTouched =
     rangeInitialized and
     low <= activeRangeLow and
     close > activeRangeLow

upperZoneTouched =
     rangeInitialized and
     high >= activeRangeHigh and
     close < activeRangeHigh

rawRangeLongReaction =
     isRange and
     lowerZoneTouched and
     (
         not rangeReactionNeedsCandle or
         bullishCandle
     )

rawRangeShortReaction =
     isRange and
     upperZoneTouched and
     (
         not rangeReactionNeedsCandle or
         bearishCandle
     )

// Nur die erste Kerze einer Berührung zählt — sonst feuert ein mehrtägiger
// Grenztest an jeder einzelnen Kerze erneut.
rangeLongReaction =
     rawRangeLongReaction and
     not rawRangeLongReaction[1] and
     barConfirmed

rangeShortReaction =
     rawRangeShortReaction and
     not rawRangeShortReaction[1] and
     barConfirmed

// ─────────────────────────────────────────────────────────────────────────────
// RANGE-AUSBRÜCHE
// ─────────────────────────────────────────────────────────────────────────────
// Scharf/entschärft statt Zeitfenster: einmal in der Range "armed", feuert der
// erste Ausbruch danach genau einmal und wird erst durch die nächste Range
// wieder scharfgeschaltet.

var bool breakoutArmed = false

if isRange
    breakoutArmed := true

bullRangeBreakout =
     breakoutArmed and
     not isRange and
     not na(activeRangeHigh[1]) and
     close > activeRangeHigh[1] + atr * breakoutBufferAtr and
     barConfirmed

bearRangeBreakout =
     breakoutArmed and
     not isRange and
     not na(activeRangeLow[1]) and
     close < activeRangeLow[1] - atr * breakoutBufferAtr and
     barConfirmed

if bullRangeBreakout or bearRangeBreakout
    breakoutArmed := false

// ─────────────────────────────────────────────────────────────────────────────
// TREND-BESTÄTIGUNG
// ─────────────────────────────────────────────────────────────────────────────
// Der rohe Fast/Base-Cross feuert auf jeden Wackler, auch mitten in einer
// Seitwärtsphase, die (noch) nicht als Range bestätigt ist. Das Signal wird
// deshalb an die Regime-Änderung selbst gekoppelt: es feuert genau einmal,
// wenn die State Machine (Score-Range, DI-Richtung, Preisbestätigung,
// Bestätigungskerzen) tatsächlich in einen neuen Trend wechselt.

bullFlip =
     isBullTrend and
     not isBullTrend[1] and
     barConfirmed

bearFlip =
     isBearTrend and
     not isBearTrend[1] and
     barConfirmed

// ─────────────────────────────────────────────────────────────────────────────
// DARSTELLUNGSMODI
// ─────────────────────────────────────────────────────────────────────────────

showBand =
     visualMode == "Trendband" or
     visualMode == "Alles"

showRangeCorridor =
     visualMode == "Range-Korridor" or
     visualMode == "Alles"

showRegimeRail =
     visualMode == "Regime-Leiste" or
     visualMode == "Alles"

showMinimal =
     visualMode == "Minimal"

// ─────────────────────────────────────────────────────────────────────────────
// BASISLINIEN
// ─────────────────────────────────────────────────────────────────────────────

plot(
     showFastTrend and not showMinimal
         ? fastTrend
         : na,
     "Fast Trend",
     color = fastColor,
     linewidth = 1
)

plot(
     showTrendBase
         ? trendBase
         : na,
     "Trend Basis",
     color = isBullTrend
         ? bullColor
         : isBearTrend
         ? bearColor
         : isRange
         ? rangeColor
         : baseColor,
     linewidth = 2
)

// ─────────────────────────────────────────────────────────────────────────────
// TRENDBAND
// ─────────────────────────────────────────────────────────────────────────────

trendBandUpper =
     trendBase + atr * bandWidthAtr

trendBandLower =
     trendBase - atr * bandWidthAtr

bandUpperPlot = plot(
     showBand and not isRange
         ? trendBandUpper
         : na,
     "Trendband oben",
     color = color.new(
         isBullTrend ? bullColor :
         isBearTrend ? bearColor :
         transitionColor,
         70
     )
)

bandLowerPlot = plot(
     showBand and not isRange
         ? trendBandLower
         : na,
     "Trendband unten",
     color = color.new(
         isBullTrend ? bullColor :
         isBearTrend ? bearColor :
         transitionColor,
         70
     )
)

fill(
     bandUpperPlot,
     bandLowerPlot,
     color = color.new(
         isBullTrend ? bullColor :
         isBearTrend ? bearColor :
         transitionColor,
         88
     ),
     title = "Trendband"
)

// ─────────────────────────────────────────────────────────────────────────────
// RANGE-KORRIDOR
// ─────────────────────────────────────────────────────────────────────────────

rangeUpperPlot = plot(
     showRangeCorridor and isRange and rangeInitialized
         ? activeRangeHigh
         : na,
     "Range oben",
     color = color.new(rangeColor, 25),
     linewidth = 2,
     style = plot.style_linebr
)

rangeLowerPlot = plot(
     showRangeCorridor and isRange and rangeInitialized
         ? activeRangeLow
         : na,
     "Range unten",
     color = color.new(rangeColor, 25),
     linewidth = 2,
     style = plot.style_linebr
)

fill(
     rangeUpperPlot,
     rangeLowerPlot,
     color = color.new(rangeColor, 91),
     title = "Range-Korridor"
)

// ─────────────────────────────────────────────────────────────────────────────
// STRUKTURVORSCHAU
// ─────────────────────────────────────────────────────────────────────────────
// Verschiebt die aktuell berechnete Struktur optisch nach rechts — keine
// Kursprognose, nur eine besser lesbare Darstellung des Ist-Zustands.

previewUpper = plot(
     structurePreviewEnabled
         ? structureUpper
         : na,
     "Strukturvorschau oben",
     color = color.new(
         structureFast > slowTrend ? bullColor : bearColor,
         65
     ),
     offset = structurePreviewOffset
)

previewLower = plot(
     structurePreviewEnabled
         ? structureLower
         : na,
     "Strukturvorschau unten",
     color = color.new(
         structureFast > slowTrend ? bullColor : bearColor,
         65
     ),
     offset = structurePreviewOffset
)

fill(
     previewUpper,
     previewLower,
     color = structurePreviewEnabled
         ? color.new(
             structureFast > slowTrend ? bullColor : bearColor,
             93
         )
         : na,
     title = "Strukturvorschau"
)

// ─────────────────────────────────────────────────────────────────────────────
// REGIME-LEISTE
// ─────────────────────────────────────────────────────────────────────────────

regimeColor =
     isBullTrend ? bullColor :
     isBearTrend ? bearColor :
     isRange ? rangeColor :
     transitionColor

plotshape(
     showRegimeRail,
     title = "Marktmodus-Leiste",
     style = shape.square,
     location = location.bottom,
     color = color.new(regimeColor, 10),
     size = size.tiny
)

// ─────────────────────────────────────────────────────────────────────────────
// SIGNALMARKER
// ─────────────────────────────────────────────────────────────────────────────

if showTrendFlips and bullFlip
    label.new(
         bar_index,
         low,
         text = "",
         yloc = yloc.belowbar,
         style = label.style_triangleup,
         color = bullColor,
         size = size.tiny,
         tooltip = "Aufwärtstrend bestätigt"
    )

if showTrendFlips and bearFlip
    label.new(
         bar_index,
         high,
         text = "",
         yloc = yloc.abovebar,
         style = label.style_triangledown,
         color = bearColor,
         size = size.tiny,
         tooltip = "Abwärtstrend bestätigt"
    )

plotshape(
     showRangeReactions and rangeLongReaction,
     title = "Range-Reaktion Long",
     style = shape.circle,
     location = location.belowbar,
     color = rangeColor,
     size = size.tiny,
     text = "R"
)

plotshape(
     showRangeReactions and rangeShortReaction,
     title = "Range-Reaktion Short",
     style = shape.circle,
     location = location.abovebar,
     color = rangeColor,
     size = size.tiny,
     text = "R"
)

plotshape(
     showRangeBreakouts and bullRangeBreakout,
     title = "Range-Ausbruch Long",
     style = shape.labelup,
     location = location.belowbar,
     color = bullColor,
     textcolor = color.white,
     text = "BREAK",
     size = size.tiny
)

plotshape(
     showRangeBreakouts and bearRangeBreakout,
     title = "Range-Ausbruch Short",
     style = shape.labeldown,
     location = location.abovebar,
     color = bearColor,
     textcolor = color.white,
     text = "BREAK",
     size = size.tiny
)

// ─────────────────────────────────────────────────────────────────────────────
// KERZEN UND HINTERGRUND
// ─────────────────────────────────────────────────────────────────────────────

barcolor(
     colorBars
         ? color.new(regimeColor, isTransition ? 65 : 20)
         : na
)

bgcolor(
     showTransitionBackground and isTransition
         ? color.new(transitionColor, 94)
         : na,
     title = "Übergangsphase"
)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────

alertcondition(
     bullFlip,
     "Aufwärtstrend bestätigt",
     "Modern Trend Regime: Aufwärtstrend bestätigt bei {{ticker}} auf {{interval}}."
)

alertcondition(
     bearFlip,
     "Abwärtstrend bestätigt",
     "Modern Trend Regime: Abwärtstrend bestätigt bei {{ticker}} auf {{interval}}."
)

alertcondition(
     rangeLongReaction,
     "Range-Reaktion Long",
     "Modern Trend Regime: Bullische Reaktion an der unteren Range-Grenze bei {{ticker}}."
)

alertcondition(
     rangeShortReaction,
     "Range-Reaktion Short",
     "Modern Trend Regime: Bärische Reaktion an der oberen Range-Grenze bei {{ticker}}."
)

alertcondition(
     bullRangeBreakout,
     "Bullischer Range-Ausbruch",
     "Modern Trend Regime: Bullischer Ausbruch aus einer Seitwärtsphase bei {{ticker}}."
)

alertcondition(
     bearRangeBreakout,
     "Bärischer Range-Ausbruch",
     "Modern Trend Regime: Bärischer Ausbruch aus einer Seitwärtsphase bei {{ticker}}."
)
