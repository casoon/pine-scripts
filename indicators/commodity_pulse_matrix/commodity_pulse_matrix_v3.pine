// ==== ENTRY ENGINE ====

bool useNewEntryEngine = input.bool(true, "Enable New Entry Engine", group="Entry Engine", tooltip="Use new lightweight entry system (Chart-TF only, no request.security)")

string entryDensity = input.string("Moderate", "Signal Density", options=["Few (Top Signals)", "Moderate", "Many (Scalper)"], group="Entry Engine", tooltip="Few: Only highest quality setups | Moderate: Balanced | Many: More signals for scalping")

bool useBreakoutEntries = input.bool(true, "Enable Breakout Entries", group="Entry Engine", tooltip="Trigger on level breaks with momentum confirmation")
