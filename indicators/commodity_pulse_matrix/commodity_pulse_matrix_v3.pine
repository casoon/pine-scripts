bool allowCounterTrendEntries = input.bool(true, "Allow Counter-Trend Entries", group="Entry Engine", tooltip="Allow entries against trend (requires 1.5x stronger momentum)")

bool showVolatilityStop = input.bool(true, "Show Volatility Stop Lines", group="Entry Engine", tooltip="Display ATR-based trend bias lines on chart")
