float qualityATRExpandThresh = input.float(1.2, "ATR Expand Threshold", minval=1.0, maxval=2.0, step=0.05, group="Signal Quality", tooltip="Above this = Expanding volatility, ideal for trends")
float qualityVolLowThresh = input.float(0.7, "Volume Low Threshold", minval=0.3, maxval=1.0, step=0.05, group="Signal Quality", tooltip="Below this = Low volume, skip entries (Vol/Vol_SMA)")
float qualityVolHighThresh = input.float(1.2, "Volume High Threshold", minval=1.0, maxval=2.0, step=0.05, group="Signal Quality", tooltip="Above this = High volume confirmation")
bool qualityBlockLowVol = input.bool(true, "Block Entries on Low Volume", group="Signal Quality", tooltip="Prevent entries when volume is below threshold")
bool qualityBlockRange = input.bool(true, "Block Trend Signals in Range", group="Signal Quality", tooltip="Prevent trend signals when ATR is contracting (range market)")
bool qualityAllowMeanReversion = input.bool(true, "Allow Mean-Reversion in Range", group="Signal Quality", tooltip="In range markets, allow signals near S/R zones (mean-reversion)")

