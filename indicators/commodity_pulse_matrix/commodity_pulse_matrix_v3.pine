// ===========================================================================
// DIAMOND ZONE BOXES
// ===========================================================================

// Memory management for Diamond Zone boxes
var box[] diamondZoneBoxes = array.new_box(0)
int MAX_ZONE_BOXES = 20  // REDUCED from 50

plotDiamondZones(zones, bool enabled = true) =>
    if enabled and not na(zones.supportZone) and zones.supportZone.isValid
        // Cleanup old boxes if at limit
        if array.size(diamondZoneBoxes) >= MAX_ZONE_BOXES
            box oldBox = array.shift(diamondZoneBoxes)
            box.delete(oldBox)

        // Support zone box (NO TEXT - just colored box)
        box supportBox = box.new(bar_index - zones.supportZone.barsAgo, zones.supportZone.upper, bar_index, zones.supportZone.lower, border_color=getSupportZoneColor(zones.supportZone), bgcolor=getSupportZoneColor(zones.supportZone))
        array.push(diamondZoneBoxes, supportBox)

    if enabled and not na(zones.resistanceZone) and zones.resistanceZone.isValid
        // Cleanup old boxes if at limit
        if array.size(diamondZoneBoxes) >= MAX_ZONE_BOXES
            box oldBox = array.shift(diamondZoneBoxes)
            box.delete(oldBox)

        // Resistance zone box (NO TEXT - just colored box)
        box resistBox = box.new(bar_index - zones.resistanceZone.barsAgo, zones.resistanceZone.upper, bar_index, zones.resistanceZone.lower, border_color=getResistanceZoneColor(zones.resistanceZone), bgcolor=getResistanceZoneColor(zones.resistanceZone))
        array.push(diamondZoneBoxes, resistBox)

// ===========================================================================
// PIVOT LABELS (S/R)
// ===========================================================================
// Displays "S" and "R" labels at pivot points WITHOUT horizontal lines
// Memory-efficient: Uses array with max limit (50 labels) to prevent accumulation

var label[] pivotLabelsArray = array.new_label(0)
int MAX_PIVOT_LABELS = 20  // REDUCED from 50

plotPivotLabels(int pivotLabelLength = 10, bool enabled = true) =>
    // Extract ta.pivothigh/ta.pivotlow for consistency
    float pivotHigh = ta.pivothigh(high, pivotLabelLength, pivotLabelLength)
    float pivotLow = ta.pivotlow(low, pivotLabelLength, pivotLabelLength)

    if enabled
        // Detect pivot highs (resistance)
        if not na(pivotHigh)
            // Delete oldest label if array full
            if array.size(pivotLabelsArray) >= MAX_PIVOT_LABELS
                label oldLabel = array.shift(pivotLabelsArray)
                label.delete(oldLabel)

            // Add "R" label at resistance pivot
            label newLabel = label.new(bar_index - pivotLabelLength, pivotHigh, "R",
                                       style=label.style_label_down, color=color.new(#FF5252, 30),
                                       textcolor=color.white, size=size.small,
                                       tooltip="Resistance: " + str.tostring(pivotHigh, format.mintick))
            array.push(pivotLabelsArray, newLabel)

        // Detect pivot lows (support)
        if not na(pivotLow)
            // Delete oldest label if array full
            if array.size(pivotLabelsArray) >= MAX_PIVOT_LABELS
                label oldLabel = array.shift(pivotLabelsArray)
                label.delete(oldLabel)

            // Add "S" label at support pivot
            label newLabel = label.new(bar_index - pivotLabelLength, pivotLow, "S",
                                       style=label.style_label_up, color=color.new(#00E676, 30),
                                       textcolor=color.white, size=size.small,
                                       tooltip="Support: " + str.tostring(pivotLow, format.mintick))
            array.push(pivotLabelsArray, newLabel)


// ============================================================================
// MARKET STRUCTURE STATE (Global - must be outside functions)
// ============================================================================

var StructureState structureState = na

if na(structureState)
    structureState := newStructureState()

// ============================================================================
// MEMORY MANAGEMENT - Drawing Object Arrays
// ============================================================================
// All visualization objects tracked in arrays with auto-cleanup to prevent memory leaks

var array<label> signalLabels = array.new<label>()      // Line 245 signal labels
var array<label> debugLabelArray = array.new<label>()   // Line 256, 552 debug labels (renamed to avoid conflict)
var array<label> confluenceLabels = array.new<label>()  // Line 350 confluence labels
var array<label> dualScoreLabels = array.new<label>()   // Line 262 dual-score labels
var array<label> chartLabels = array.new<label>()       // Line 583 chart debug labels
int MAX_ENTRY_OBJECTS = 30     // Limit for entry engine labels
int MAX_LABEL_OBJECTS = 20     // Limit for other labels (REDUCED from 100 - we have 5 arrays!)

// ============================================================================
// COOLDOWN & FLIP MODE STATE (Global - must be at script level)
// ============================================================================
var int g_lastSignalBar = na
var string g_lastSignalType = "NONE"
var string g_currentPosition = "FLAT"  // "LONG", "SHORT", "FLAT"

// ============================================================================
// MAIN CALCULATION PIPELINE
// ============================================================================

// === STEP 1: CALCULATE MULTI-TIMEFRAME SCORES ===
// Chart TF ENABLED: Now safe with hardcoded TF hierarchy (4 timeframes total)
// WCM DISABLED: Memory optimization for 2H+ timeframes
// HARDCODED TFs: Parameters ignored, actual TFs selected via getSmartTF1/2/3() in scoring_engine
// WEIGHTS: Using Swing weights (balanced approach, hardcoded in scoring_engine)
MultiTimeframeScores mtfScores = calculateAll("", "", "", true)

// ============================================================================
// === CONSOLIDATED TA CALCULATIONS (Memory Optimization) ===
// All ta.* calls in ONE place to avoid duplicate calculations
// Using JMA instead of EMA for better responsiveness and less lag
float jma20 = calculateJMA(close, 20)
float jma50 = calculateJMA(close, 50)
float jma100 = calculateJMA(close, 100)
float jma200 = calculateJMA(close, 200)
float atr = ta.atr(14)
float atrSMA = ta.sma(atr, 20)
float rsi = ta.rsi(close, 14)
float stochRSI = ta.stoch(rsi, rsi, rsi, 14)
[macdLine, signalLine, macdHist] = ta.macd(close, 12, 26, 9)
float volumeSMA = ta.sma(volume, 20)
float recentHigh5 = ta.highest(high[1], 5)
float recentLow5 = ta.lowest(low[1], 5)
float swingHigh20 = ta.highest(high, 20)
float swingLow20 = ta.lowest(low, 20)

// === STEP 2: DETECT MARKET REGIME (Standalone) ===
MarketRegime regime = analyzeMarketStructure(structureState, jma20, jma50, jma200, atr)

// === STEP 3: CALCULATE HEAT SCORE ===
HeatScoreBreakdown heatBreakdown = getHeatScoreBreakdown(mtfScores.tf1.totalScore, mtfScores.tf2.totalScore, mtfScores.tf3.totalScore, mtfScores.chartTF.isValid ? mtfScores.chartTF.totalScore : 0.0, false, "BUILDING SETUP", stochRSI, macdHist, atr, atrSMA, mtfScores.tf1.flowScore, mtfScores.tf1.momentumScore, mtfScores.tf1.trendScore, mtfScores.tf1.volatilityScore, mtfScores.tf1.structureScore, mtfScores.tf1.divergenceScore)

// === STEP 4: CALCULATE MV CONFLUENCE ===
// WCM REMOVED: Using RSI-based momentum for MV Confluence
MVInterpretation mvInterp = analyzeMVConfluence(rsi, volume, 20)

// === STEP 5: DETECT EXHAUSTION ===
ExhaustionResult exhaust = detectExhaustion(3, 14, 14, 20)

// === STEP 6: DETECT DIAMOND ZONES ===
// proximityThreshold increased to 1.5% for better zone detection by Entry Engine
DiamondZoneResult zones = detectDiamondZonesWithConfluence(5, 5, 14, 0.3, 0.015, exhaust.bullWatch or exhaust.bullConfirmed, exhaust.bearWatch or exhaust.bearConfirmed, exhaust.bullWatch or exhaust.bullConfirmed, exhaust.bearWatch or exhaust.bearConfirmed)

// === STEP 6.5: DETECT DIVERGENCE ZONES (NEW - Phase 1) ===
// RSI-Price Divergence with smaller lookbacks for earlier detection
// NOTE: Reusing 'rsi' from consolidated TA calculations
DivergenceZonesResult divZones = analyzeDivergenceZones(rsi, 2, 2, 5, 100, 1.0, color.new(color.lime, 0), color.new(color.red, 0))

// === STEP 6.6: NEW ENTRY ENGINE (Chart-TF Only, No MTF) ===
// Lightweight entry signals using only chart timeframe data
// NO request.security() calls - memory efficient for all timeframes

// Expanded S/R detection: Diamond Zones + Swing Levels + Recent Highs/Lows

// Near support: Diamond zone OR price near 20-bar swing low (within 0.5 ATR)
bool nearSwingLow = math.abs(low - swingLow20) < atr * 0.5
bool nearSupportForEntry = zones.nearSupport or zones.atSupport or nearSwingLow

// Near resistance: Diamond zone OR price near 20-bar swing high (within 0.5 ATR)
bool nearSwingHigh = math.abs(high - swingHigh20) < atr * 0.5
bool nearResistanceForEntry = zones.nearResistance or zones.atResistance or nearSwingHigh

// Old entry_engine.pine removed - using Entry Engine V2 only

// === ENTRY ENGINE V2 (Chart-TF Only, Event-Based) ===
// Build market context
MarketContext marketCtx = buildMarketContext(
    entryJMAFast,
    entryJMASlow,
    14,  // ATR length
    50,  // ATR SMA length
    0.7, // ATR compress threshold
    volStopATRMult
)

// Extract values for visualization
float volStopLongLine = useNewEntryEngine ? marketCtx.volStopLong : na
float volStopShortLine = useNewEntryEngine ? marketCtx.volStopShort : na
bool isRangingMarket = useNewEntryEngine ? marketCtx.isRanging : false

// Calculate strength
StrengthScore strengthScoreRaw = calculateStrength(
    marketCtx,
    (rsi - 50) / 50,  // Normalized momentum
    nearSupportForEntry,
    nearResistanceForEntry
)

// === SIGNAL BOOST: RSI + WT1 Extreme Conditions ===
// Apply boosts based on extreme indicator values
// WT1 is calculated here for boost check (mrSignal not yet available)
float wt1ForBoost = ta.ema(ta.ema((hlc3 - ta.ema(hlc3, 12)) / (0.015 * ta.ema(math.abs(hlc3 - ta.ema(hlc3, 12)), 12)), 21), 4)

// RSI Extreme Boost: RSI < threshold (oversold) or RSI > 100-threshold (overbought)
bool rsiOversold = rsi < rsiBoostThreshold
bool rsiOverbought = rsi > (100 - rsiBoostThreshold)
float rsiBoostLong = useRSIBoost and rsiOversold ? rsiBoostAmount : 0.0
float rsiBoostShort = useRSIBoost and rsiOverbought ? rsiBoostAmount : 0.0

// WT1 Extreme Boost: WT1 < -threshold (oversold) or WT1 > threshold (overbought)
bool wt1Oversold = wt1ForBoost < -wt1BoostThreshold
bool wt1Overbought = wt1ForBoost > wt1BoostThreshold
float wt1BoostLong = useWT1Boost and wt1Oversold ? wt1BoostAmount : 0.0
float wt1BoostShort = useWT1Boost and wt1Overbought ? wt1BoostAmount : 0.0

// Apply boosts to strength scores
float boostedLongStrength = strengthScoreRaw.longStrength + rsiBoostLong + wt1BoostLong
float boostedShortStrength = strengthScoreRaw.shortStrength + rsiBoostShort + wt1BoostShort

// Create boosted StrengthScore
StrengthScore strengthScore = StrengthScore.new(
    boostedLongStrength,
    boostedShortStrength,
    strengthScoreRaw.momentum,
    strengthScoreRaw.trendAlign,
    strengthScoreRaw.zoneBoost
)

// Generate entry signals (two levels)
// Pass configurable threshold (strengthThreshold from inputs)
EntrySignal entryV2 = generateEntries(
    entryDensity,
    marketCtx,
    strengthScore,
    nearSupportForEntry,
    nearResistanceForEntry,
    useBreakoutEntries,
    usePullbackEntries,
    useContinuationEntries,
    allowCounterTrendEntries,
    8,  // lookback for breakout/continuation
    calculateJMA(close, entryJMAFast),
    calculateJMA(close, entryJMASlow),
    strengthThreshold  // Custom threshold from inputs
)

// === INDEPENDENT WARNING SYSTEM (Chart-TF, no signal dependencies) ===
// Detects market weakness/exhaustion BEFORE entries trigger
// Uses 4-criteria system: (A) Rejection, (B) Momentum Decay, (C) Failure, (D) VolSpike
WarningSignal independentWarning = detectMarketWeakness(
    nearSupportForEntry,
    zones.atSupport,
    nearResistanceForEntry,
    zones.atResistance,
    rsi,
    calculateJMA(close, entryJMAFast),
    8  // lookback for failure detection
)

// Warning confirmation counter (reduces false positives)
// Warnings must persist for 2 bars before emission
var WarningConfirmation warningConfirm = newWarningConfirmation(2, 8)  // 2 bars confirm, 8 bar cooldown
[emitBull, emitBear, newWarningConfirm] = confirmWarning(independentWarning, warningConfirm)
warningConfirm := newWarningConfirm

// Combined emit flag for visualization
bool shouldEmit = emitBull or emitBear

// State machine for entry deduplication (warnings handled separately above)
var EntryState entryState = newEntryState()
[entryEvent, newEntryState] = updateEntryStateMachine(
    entryState,
    entryV2.finalLong,
    entryV2.finalShort,
    entryV2.finalLongStrength,
    entryV2.finalShortStrength,
    false,  // warnings now handled independently
    false,  // warnings now handled independently
    5,         // entry cooldown (hardcoded, previously from Master Control)
    8,         // warning cooldown (unused, kept for compatibility)
    0.35       // upgrade delta
)
entryState := newEntryState

// === STEP 7: DETECT PIVOTS (for Strategy C) ===
[isPivotHigh, pivotHighPrice] = detectPivotHigh(5, 5)
[isPivotLow, pivotLowPrice] = detectPivotLow(5, 5)

// === STEP 7.1: CONTINUATION ENTRY TRACKING ===
// Track last pivot type for pullback entry visualization
// Green dot: Pivot Low AFTER Pivot High + bullish confluence = Long entry
// Red dot: Pivot High AFTER Pivot Low + bearish confluence = Short entry
var string lastPivotType = "NONE"  // "HIGH", "LOW", or "NONE"
var int lastPivotBar = na
var float lastPivotPrice = na

// Update last pivot on new pivot detection
if isPivotHigh
    lastPivotType := "HIGH"
    lastPivotBar := bar_index - 5  // Pivot occurs 5 bars back (pivotLabelLength)
    lastPivotPrice := pivotHighPrice

if isPivotLow
    lastPivotType := "LOW"
    lastPivotBar := bar_index - 5
    lastPivotPrice := pivotLowPrice

// === STEP 7.6: CALCULATE CONFLUENCE (Phase 4 - FULL SYSTEM) ===
// 3-Factor Confluence: Momentum + Flow + ZoneContext
// Quality: STRONG (3/3), OK (2/3), INVALID (<2)

// Guard against NaN values when chartTF is not valid
float chartMomentum = mtfScores.chartTF.isValid ? mtfScores.chartTF.momentumScore : 0.0
float chartFlow = mtfScores.chartTF.isValid ? mtfScores.chartTF.flowScore : 0.0

// Calculate for bullish signals
ConfluenceFactors bullConfluence = calculateConfluence(chartMomentum, chartFlow, divZones.nearBullZone, divZones.nearBearZone, zones.nearSupport, zones.nearResistance, true, 0.3, 0.2)

// Calculate for bearish signals
ConfluenceFactors bearConfluence = calculateConfluence(chartMomentum, chartFlow, divZones.nearBullZone, divZones.nearBearZone, zones.nearSupport, zones.nearResistance, false, 0.3, 0.2)

// === PREDICTIVE SIGNALS REMOVED ===
// Old SignalStage system removed - replaced with Entry Engine V2

// === STEP 8: GENERATE SIGNALS ===
// (rsi already calculated in STEP 3)

// Get scores from each hierarchy level
// Entry TF: Fast TF for precise entry timing
// Bias TF: Chart TF for directional bias (already calculated as chartTF)
// Trend TF: Higher TF for trend confirmation

// Calculate signal score (Chart TF only)
TimeframeScores chartTF = mtfScores.chartTF

float signalOptimizedScore = (chartTF.flowScore * 0.40) + (chartTF.momentumScore * 0.40) + (chartTF.trendScore * 0.10) + (chartTF.volatilityScore * 0.05) + (chartTF.structureScore * 0.05)
string chartDirection = signalOptimizedScore > 0 ? "BULLISH" : signalOptimizedScore < 0 ? "BEARISH" : "NEUTRAL"
MultiTimeframeScores chartOnlyScores = MultiTimeframeScores.new(mtfScores.tf1, mtfScores.tf2, mtfScores.tf3, chartTF, signalOptimizedScore, chartDirection, 1, 1)

string activeStrategy = "Strategy A (Balanced)"
bool useHeatFilter    = false
float threshStrong    = 0.75
float threshModerate  = 0.45
bool  diamondEnabled  = true
int   cooldown        = 5

SignalResult signal = generateSignals(activeStrategy, chartOnlyScores, rsi, isPivotHigh, isPivotLow, zones, heatBreakdown, mvInterp, exhaust, regime, threshStrong, threshModerate, diamondEnabled, useHeatFilter, 0.3, false, false, 0.3, cooldown)

// === STEP 8.5: ENTRY TIMING FILTER (Break-Pullback-Continuation) ===
// NOTE: Reusing consolidated TA values (jma20, jma50, atr, recentHigh5, recentLow5, volumeSMA)
// Analyze BPC state with precomputed values
float bpcMinPullback = 0.3
float bpcMaxPullback = 0.7
int   bpcPullbackWait = 5
int   bpcContWait    = 3
bool  bpcVolConfirm  = true
float bpcVolMult     = 1.2
EntryTimingResult bpcResult = analyzeEntryTiming(jma20, jma50, atr, recentHigh5, recentLow5, volumeSMA, bpcMinPullback, bpcMaxPullback, bpcPullbackWait, bpcContWait, bpcVolConfirm, bpcVolMult)

// Apply BPC filter based on mode
bool   entryTimingEnabled    = true
string entryTimingModeValue  = "Strict"
SignalResult bpcFilteredSignal = signal

if entryTimingEnabled and entryTimingModeValue != "Disabled"
    bool isBuySignal = signal.strongBuy or signal.moderateBuy
    bool isSellSignal = signal.strongSell or signal.moderateSell

    if entryTimingModeValue == "Strict"
        // Strict mode: Only allow signals when BPC gives entry
        bool bpcAllowsBuy = strictBPCFilter(isBuySignal, true, bpcResult)
        bool bpcAllowsSell = strictBPCFilter(isSellSignal, false, bpcResult)

        if not bpcAllowsBuy
            bpcFilteredSignal.strongBuy := false
            bpcFilteredSignal.moderateBuy := false
        if not bpcAllowsSell
            bpcFilteredSignal.strongSell := false
            bpcFilteredSignal.moderateSell := false

    else  // Filter mode (default)
        // Filter mode: Gate signals with BPC (allow when no active setup OR BPC confirms)
        bool bpcAllowsBuy = filterSignalWithBPC(isBuySignal, true, bpcResult)
        bool bpcAllowsSell = filterSignalWithBPC(isSellSignal, false, bpcResult)

        if not bpcAllowsBuy
            bpcFilteredSignal.strongBuy := false
            bpcFilteredSignal.moderateBuy := false
        if not bpcAllowsSell
            bpcFilteredSignal.strongSell := false
            bpcFilteredSignal.moderateSell := false

// Use BPC-filtered signal for further processing
signal := bpcFilteredSignal

// === STEP 8.6: SIGNAL QUALITY GATE (ATR + Volume) ===
// NOTE: Reusing consolidated TA values (atr, atrSMA, volumeSMA)
MarketQuality marketQuality = analyzeMarketQuality(atr, atrSMA, volume, volumeSMA, qualityATRContractThresh, qualityATRExpandThresh, qualityVolLowThresh, qualityVolHighThresh)

// Apply Quality Gate filter
SignalResult qualityFilteredSignal = signal

if useQualityGate
    bool isBuySignal = signal.strongBuy or signal.moderateBuy
    bool isSellSignal = signal.strongSell or signal.moderateSell
    bool isStrongSignal = signal.strongBuy or signal.strongSell

    // Check if near S/R for mean-reversion allowance
    bool nearSR = zones.nearSupport or zones.nearResistance or zones.atSupport or zones.atResistance

    // Rule 1: Block entries on low volume
    if qualityBlockLowVol and not marketQuality.allowEntries
        qualityFilteredSignal.strongBuy := false
        qualityFilteredSignal.strongSell := false
        qualityFilteredSignal.moderateBuy := false
        qualityFilteredSignal.moderateSell := false

    // Rule 2: Block trend signals in range (unless mean-reversion near S/R)
    else if qualityBlockRange and not marketQuality.allowTrendSignals
        if qualityAllowMeanReversion and nearSR
            // Allow mean-reversion signals near S/R, but downgrade strong to moderate
            if isStrongSignal
                qualityFilteredSignal.strongBuy := false
                qualityFilteredSignal.strongSell := false
                qualityFilteredSignal.moderateBuy := isBuySignal
                qualityFilteredSignal.moderateSell := isSellSignal
        else
            // Block all signals in range without S/R context
            qualityFilteredSignal.strongBuy := false
            qualityFilteredSignal.strongSell := false
            qualityFilteredSignal.moderateBuy := false
            qualityFilteredSignal.moderateSell := false

    // Rule 3: Downgrade strong signals in FAIR/POOR quality
    else if isStrongSignal and (marketQuality.qualitySeal == "FAIR" or marketQuality.qualitySeal == "POOR")
        qualityFilteredSignal.strongBuy := false
        qualityFilteredSignal.strongSell := false
        qualityFilteredSignal.moderateBuy := isBuySignal
        qualityFilteredSignal.moderateSell := isSellSignal

signal := qualityFilteredSignal

// === TIMEFRAME-AWARE ADJUSTMENTS ===
// Daily (1440 min) and higher TFs need relaxed filters
float tfMinutes = timeframe.in_seconds(timeframe.period) / 60
bool isDailyOrHigher = tfMinutes >= 1440

// Reduce cooldown for Daily (5 bars = 5 days is too long)
int effectiveCooldown = isDailyOrHigher ? math.min(cooldown, 1) : cooldown

// Daily: Relax confidence requirements (scores fluctuate less on higher TFs)
if isDailyOrHigher
    // Re-enable signals that were blocked by confidence gate in generateSignals()
    // Daily often has lower confidence due to slower score movement
    float dailyConfMin = 0.35  // Lower than normal 0.45
    if signal.confidence >= dailyConfMin
        // If we have bullish confluence but signal was blocked, try to recover
        float chartScore = (mtfScores.chartTF.flowScore * 0.35) + (mtfScores.chartTF.momentumScore * 0.50) + (mtfScores.chartTF.trendScore * 0.15)
        if chartScore > 0.02 and not signal.strongBuy and not signal.moderateBuy
            signal.moderateBuy := true
        else if chartScore < -0.02 and not signal.strongSell and not signal.moderateSell
            signal.moderateSell := true

// === COOLDOWN FILTER (Applied at script level for proper var state) ===
// Check cooldown using global state
bool inCooldown = not na(g_lastSignalBar) and (bar_index - g_lastSignalBar) < effectiveCooldown
int barsSinceSignal = na(g_lastSignalBar) ? 10000 : (bar_index - g_lastSignalBar)

// Directional cooldown: Only block same-direction signals
bool lastWasBuy = g_lastSignalType == "STRONG_BUY" or g_lastSignalType == "MODERATE_BUY"
bool lastWasSell = g_lastSignalType == "STRONG_SELL" or g_lastSignalType == "MODERATE_SELL"
bool sameDirCooldown = (lastWasBuy and (signal.strongBuy or signal.moderateBuy)) or
                       (lastWasSell and (signal.strongSell or signal.moderateSell))

if inCooldown and sameDirCooldown
    signal.strongBuy := false
    signal.moderateBuy := false
    signal.strongSell := false
    signal.moderateSell := false

// === STRUCTURE FILTER FOR SHORTS (Enhanced) ===
// Block shorts in clearly bullish structure (prevents counter-trend traps)
bool bullStructure = close > jma50 and jma20 > jma50 and jma50 > jma200
bool bearStructure = close < jma50 and jma20 < jma50

// Enhanced bull trend detection: EMA stack + flow/momentum agreement + HH/HL pattern
float flowScore = mtfScores.chartTF.flowScore
float momScore = mtfScores.chartTF.momentumScore
bool bullTrend = jma20 > jma50 and jma50 > jma200 and close > jma50 and flowScore > 0 and momScore > 0
bool bullHHHL = high > high[2] and low > low[2]

if (signal.strongSell or signal.moderateSell)
    // Only allow shorts if NOT in strong bull trend, OR structure is flipping
    bool allowShort = not bullTrend or regime.isRanging or (bearStructure and not bullHHHL)
    if not allowShort
        signal.strongSell := false
        signal.moderateSell := false

// === CANDLE QUALITY FILTER FOR LONGS ===
// Only allow longs on strong bullish candles with follow-through
// NOTE: Relaxed for Daily TF (daily candles are often dojis/indecision)
float candleRange = high - low + syminfo.mintick
float candleBody = math.abs(close - open)
bool strongBullCandle = close > open and (candleBody / candleRange) > 0.5
bool closeNearHigh = close > high - (0.3 * candleRange)
bool followThrough = close > high[1]

if (signal.strongBuy or signal.moderateBuy) and not isDailyOrHigher
    // Require decent candle quality (not doji/spinning top) - SKIP for Daily
    bool allowLongCandle = strongBullCandle or closeNearHigh or followThrough
    if not allowLongCandle
        // Downgrade strong to moderate, block moderate entirely
        if signal.strongBuy
            signal.strongBuy := false
            signal.moderateBuy := true
        else
            signal.moderateBuy := false

// Update cooldown state if signal triggered
bool anySignal = signal.strongBuy or signal.strongSell or signal.moderateBuy or signal.moderateSell
if anySignal
    g_lastSignalBar := bar_index
    g_lastSignalType := signal.strongBuy ? "STRONG_BUY" : signal.strongSell ? "STRONG_SELL" : signal.moderateBuy ? "MODERATE_BUY" : "MODERATE_SELL"

// ============================================================================
// A-SETUP DETECTION (Premium Quality Signals)
// ============================================================================
// A-Setups are the highest quality signals - clear trend + high heat + momentum
// Now based on Entry Engine V2 when enabled, otherwise legacy finalSignal

bool isASetupLong = false
bool isASetupShort = false

if useNewEntryEngine
    // Entry Engine V2 based A-Setup: Final entry + high heat + strong strength + trending
    float momentumNorm = (rsi - 50) / 50  // -1 to +1
    isASetupLong := entryV2.finalLong and heatBreakdown.overall >= 0.65 and strengthScore.longStrength >= 0.70 and regime.isTrending and close > jma50 and jma20 > jma50
    isASetupShort := entryV2.finalShort and heatBreakdown.overall >= 0.65 and strengthScore.shortStrength >= 0.70 and regime.isTrending and close < jma50 and jma20 < jma50
else
    // Legacy: finalSignal based (when Entry Engine disabled)
    isASetupLong := signal.strongBuy and heatBreakdown.overall >= 0.65 and signal.confidence >= 0.60 and regime.isTrending and close > jma50 and jma20 > jma50 and jma50 > jma200
    isASetupShort := signal.strongSell and heatBreakdown.overall >= 0.65 and signal.confidence >= 0.60 and regime.isTrending and close < jma50 and jma20 < jma50 and jma50 < jma200

// Regime Label for Matrix
string regimeLabel = regime.isTrending and flowScore > 0 and momScore > 0 ? "TRENDING UP" : regime.isTrending and flowScore < 0 and momScore < 0 ? "TRENDING DOWN" : regime.isRanging ? "RANGE" : "MIXED"

// ============================================================================
// VISUALIZATION
// ============================================================================

// === MATRIX TABLE ===
if showMatrix
    // Use regime label instead of generic "BUILDING SETUP"
    string matrixStatus = isASetupLong ? "★ A-SETUP LONG" : isASetupShort ? "★ A-SETUP SHORT" : regimeLabel
    drawMatrixTable(mtfScores, signal, heatBreakdown, mvInterp, exhaust, matrixStatus, compactMode, matrixPos)

// === SIGNAL LABELS ===
// Check if there's an active signal
bool hasActiveSignal = signal.strongBuy or signal.strongSell or signal.moderateBuy or signal.moderateSell

// === A-SETUP MARKERS (Premium Signals) ===
// Show special marker for A-grade setups
var array<label> aSetupLabels = array.new<label>()
int MAX_ASETUP_LABELS = 10

if isASetupLong or isASetupShort
    // Memory management
    if array.size(aSetupLabels) >= MAX_ASETUP_LABELS
        label oldLabel = array.shift(aSetupLabels)
        label.delete(oldLabel)

    bool isLong = isASetupLong
    float labelY = isLong ? low - (atr * 0.3) : high + (atr * 0.3)
    color aColor = isLong ? color.new(#00E676, 0) : color.new(#FF1744, 0)
    string aTooltip = "A-SETUP " + (isLong ? "LONG" : "SHORT") + "\nHeat: " + str.tostring(heatBreakdown.overall, "#.00") + "\nConf: " + str.tostring(signal.confidence, "#.00") + "\nRegime: " + regimeLabel

    label aLabel = label.new(bar_index, labelY, "★", style=isLong ? label.style_label_up : label.style_label_down, color=aColor, textcolor=color.white, size=size.normal, tooltip=aTooltip)
    array.push(aSetupLabels, aLabel)

// ============================================================================
// LEGACY SIGNAL VISUALIZATION (Removed - use Entry Engine V2)
// ============================================================================

// === PREDICTIVE SIGNAL VISUALIZATION (Additional Processing) ===
// Use the existing predictiveSignal from above

// REVERSAL SIGNAL LOGIC - Buy at Support, Sell at Resistance
// Requirements for LONG (Buy at Support):
// 1. Price NEAR support zone
// 2. Bearish exhaustion confirmed (sellers exhausted)
// 3. Good confluence (2/3 or better)
// 4. Rejection candle (optional, helps but not required)

bool nearSupportZone = zones.nearSupport or zones.atSupport
bool nearResistanceZone = zones.nearResistance or zones.atResistance

// Confluence check
bool goodConfluenceBull = bullConfluence.totalCount >= 2
bool goodConfluenceBear = bearConfluence.totalCount >= 2

// ============================================================================
// CONTINUATION ENTRY DOTS (Legacy - Only when New Entry Engine is DISABLED)
// ============================================================================
// Green dot: After Pivot High, when Pivot Low forms + bullish confluence = Long entry point
// Red dot: After Pivot Low, when Pivot High forms + bearish confluence = Short entry point
// Only ONE dot shown at a time (current/relevant)
// NOTE: These are DISABLED when New Entry Engine is active (use triangles instead)

var array<label> entryDotLabels = array.new<label>()
int MAX_ENTRY_DOT_LABELS = 1  // Only show ONE dot at a time

// LONG ENTRY: Good bullish confluence + (Pivot Low after PH OR near Diamond Support)
bool pivotLongEntry = isPivotLow and lastPivotType == "HIGH"
bool diamondLongEntry = zones.nearSupport or zones.atSupport
bool longEntryDot = goodConfluenceBull and (pivotLongEntry or diamondLongEntry)

// SHORT ENTRY: Good bearish confluence + (Pivot High after PL OR near Diamond Resistance)
bool pivotShortEntry = isPivotHigh and lastPivotType == "LOW"
bool diamondShortEntry = zones.nearResistance or zones.atResistance
bool shortEntryDot = goodConfluenceBear and (pivotShortEntry or diamondShortEntry)

// Draw entry dots ONLY when New Entry Engine is DISABLED (legacy mode)
if (longEntryDot or shortEntryDot) and not useNewEntryEngine
    // Clear previous dot (only ONE visible at a time)
    if array.size(entryDotLabels) > 0
        label oldDot = array.shift(entryDotLabels)
        label.delete(oldDot)

    bool isLongEntry = longEntryDot
    float dotY = isLongEntry ? pivotLowPrice : pivotHighPrice
    int dotBar = bar_index - 5  // Pivot occurs 5 bars back
    color dotColor = isLongEntry ? color.new(#00E676, 0) : color.new(#FF1744, 0)  // Green / Red
    string entryReason = isLongEntry ? (pivotLongEntry ? "Pullback Low after PH" : "Diamond Support Zone") : (pivotShortEntry ? "Pullback High after PL" : "Diamond Resistance Zone")
    string confInfo = isLongEntry ? str.tostring(bullConfluence.totalCount) + "/3 (" + bullConfluence.quality + ")" : str.tostring(bearConfluence.totalCount) + "/3 (" + bearConfluence.quality + ")"
    string dotTooltip = (isLongEntry ? "LONG" : "SHORT") + " Entry | " + entryReason + " | Confluence: " + confInfo

    label entryDot = label.new(dotBar, dotY, "●", style=isLongEntry ? label.style_label_up : label.style_label_down, color=color.new(color.white, 100), textcolor=dotColor, size=size.normal, tooltip=dotTooltip)
    array.push(entryDotLabels, entryDot)

// finalSignal already filtered by Exhaustion + MV in generateSignals()
bool hasFinalBuySignal = signal.strongBuy or signal.moderateBuy
bool hasFinalSellSignal = signal.strongSell or signal.moderateSell

// BPC Filter for Predictive Signals: Only allow setup when BPC confirms OR BPC is disabled
bool bpcAllowsLong = not entryTimingEnabled or entryTimingModeValue == "Disabled" or bpcResult.longEntry or (not bpcResult.inSetup)
bool bpcAllowsShort = not entryTimingEnabled or entryTimingModeValue == "Disabled" or bpcResult.shortEntry or (not bpcResult.inSetup)

// In Strict mode: Only allow when BPC gives explicit entry signal
if entryTimingEnabled and entryTimingModeValue == "Strict"
    bpcAllowsLong := bpcResult.longEntry
    bpcAllowsShort := bpcResult.shortEntry

// LONG Setup: Support + Confluence + finalSignal (already filtered) + BPC
bool longSetup = nearSupportZone and goodConfluenceBull and hasFinalBuySignal and bpcAllowsLong

// SHORT Setup: Resistance + Confluence + finalSignal (already filtered) + BPC
bool shortSetup = nearResistanceZone and goodConfluenceBear and hasFinalSellSignal and bpcAllowsShort

// ============================================================================
// SIGNAL DEBUG LABELS (Removed)
// ============================================================================



// === JMA GRADIENT FILL (Global scope - Pine v6 requirement) ===
// NOTE: jma100 already calculated in consolidated TA section
p1 = plot(close, display=display.none)
p2 = plot(jma20, display=display.none)
p3 = plot(jma50, display=display.none)
p4 = plot(jma100, display=display.none)
p5 = plot(jma200, display=display.none)
fill(p1, p2, color=showJMAGradient ? (close > jma20 ? color.new(#00E676, 95) : color.new(#FF1744, 95)) : na, title="Fill: Price/JMA20")
fill(p2, p3, color=showJMAGradient ? (jma20 > jma50 ? color.new(#4CAF50, 93) : color.new(#F44336, 93)) : na, title="Fill: JMA20/50")
fill(p3, p4, color=showJMAGradient ? (jma50 > jma100 ? color.new(#81C784, 91) : color.new(#E57373, 91)) : na, title="Fill: JMA50/100")
fill(p4, p5, color=showJMAGradient ? (jma100 > jma200 ? color.new(#A5D6A7, 90) : color.new(#FFCDD2, 90)) : na, title="Fill: JMA100/200")

// === DIAMOND ZONES ===
if diamondEnabled and showDiamondBoxes
    plotDiamondZones(zones, true)

// === PIVOT LABELS (S/R) ===
if showPivotLabels
    plotPivotLabels(pivotLabelLength, showPivotLabels)

// HTF Midline removed from here - now plotted at global scope at end of file

// === JMA LINES (optional) ===
bool showJMAs = showJMALines  // Controlled via input
plot(showJMAs ? jma20 : na, "JMA 20", color=color.new(#2196F3, 0), linewidth=1)
plot(showJMAs ? jma50 : na, "JMA 50", color=color.new(#FF9800, 0), linewidth=1)
plot(showJMAs ? jma200 : na, "JMA 200", color=color.new(#9C27B0, 0), linewidth=2)

// ============================================================================
// NEW ENTRY ENGINE VISUALIZATION + SIGNAL STATE MACHINE
// ============================================================================
// Event-based signals: First Signal → Upgrades → Weakness Warnings → Reversals
// NO repeated signals - only meaningful events get visualized

// Volatility Stop Lines (trend bias indicator)
plot(useNewEntryEngine and showVolatilityStop ? volStopLongLine : na,
    "VolStop Long", color=color.new(#4CAF50, 60), linewidth=1, style=plot.style_linebr)
plot(useNewEntryEngine and showVolatilityStop ? volStopShortLine : na,
    "VolStop Short", color=color.new(#F44336, 60), linewidth=1, style=plot.style_linebr)

// OLD Signal State Machine removed - now using Entry Engine V2 only

// Range market indicator (optional background when market is ranging)
bgcolor(useNewEntryEngine and isRangingMarket ? color.new(#9E9E9E, 95) : na, title="Ranging Market BG")

// === ENTRY ENGINE V2 VISUALIZATION ===
// BPC Filtered signals (early, transparent)
bool showBpcLong = useNewEntryEngine and entryV2.bpcLong and not entryV2.finalLong
bool showBpcShort = useNewEntryEngine and entryV2.bpcShort and not entryV2.finalShort
plotshape(showBpcLong, "BPC Long", shape.circle, location.belowbar, color.new(#4CAF50, 60), size=size.tiny)
plotshape(showBpcShort, "BPC Short", shape.circle, location.abovebar, color.new(#F44336, 60), size=size.tiny)

// ============================================================================
// MEAN REVERSION CALCULATION (must be before unified labels)
// ============================================================================
var MeanReversionState mrState = newMeanReversionState()

[mrSignal, newMrState] = calculateMeanReversion(
    hlc3,                    // Source: HLC3 for balanced price representation
    mrWTLength1,                // WT Smooth Length 1 (default: 12)
    mrWTLength2,                // WT Smooth Length 2 (default: 21)
    mrSignalLength,                // Signal Line Length (default: 4)
    mrZoneLookback,                // Zone Lookback (default: 180)
    mrZoneMultiplier,              // Zone Multiplier (default: 2.0)
    mrCooldown,          // Cooldown (default: 20)
    mrState
)
mrState := newMrState

// ============================================================================
// S/R PIVOT LOGGING
// ============================================================================
// Log signal values AT the pivot point (pivotLabelLength bars ago)
// This helps analyze why signals don't align with optimal S/R entry points
float srPivotHigh = ta.pivothigh(high, pivotLabelLength, pivotLabelLength)
float srPivotLow = ta.pivotlow(low, pivotLabelLength, pivotLabelLength)

// Extract values for logging (Pine doesn't allow UDT fields directly in log.info)
float logMom = strengthScore.momentum * 100
float logLongStr = strengthScore.longStrength * 100
float logShortStr = strengthScore.shortStrength * 100
float logTrendAlign = strengthScore.trendAlign * 100
float logZoneBoost = strengthScore.zoneBoost * 100
bool logTrendUp = marketCtx.trendUp
bool logTrendDn = marketCtx.trendDown
bool logLongBias = marketCtx.longBias
bool logShortBias = marketCtx.shortBias
bool logRanging = marketCtx.isRanging
float logWT1 = mrSignal.wt1
bool logInOB = mrSignal.inOverbought
bool logInOS = mrSignal.inOversold
bool logFinalLong = entryV2.finalLong
bool logFinalShort = entryV2.finalShort
bool logBpcLong = entryV2.bpcLong
bool logBpcShort = entryV2.bpcShort
string logEntryType = entryV2.entryType

// Log at Resistance (Pivot High) - potential SHORT entry point
if not na(srPivotHigh)
    log.info("=== RESISTANCE PIVOT (bar {0}) ===", bar_index - pivotLabelLength)
    log.info("Price: {0,number,#.####} | RSI: {1,number,#.#} | Mom: {2,number,#.##}%",
        srPivotHigh, rsi[pivotLabelLength], logMom)
    log.info("LongStr: {0,number,#.#}% | ShortStr: {1,number,#.#}% | TrendAlign: {2,number,#.#}% | ZoneBoost: {3,number,#.#}%",
        logLongStr, logShortStr, logTrendAlign, logZoneBoost)
    log.info("TrendUp: {0} | TrendDn: {1} | LongBias: {2} | ShortBias: {3} | Ranging: {4}",
        logTrendUp, logTrendDn, logLongBias, logShortBias, logRanging)
    log.info("nearSup: {0} | nearRes: {1} | WT1: {2,number,#.#} | MR inOB: {3} | MR inOS: {4}",
        nearSupportForEntry, nearResistanceForEntry, logWT1, logInOB, logInOS)
    log.info("EntryV2 finalShort: {0} | bpcShort: {1} | Type: {2}",
        logFinalShort, logBpcShort, logEntryType)

// Log at Support (Pivot Low) - potential LONG entry point
if not na(srPivotLow)
    log.info("=== SUPPORT PIVOT (bar {0}) ===", bar_index - pivotLabelLength)
    log.info("Price: {0,number,#.####} | RSI: {1,number,#.#} | Mom: {2,number,#.##}%",
        srPivotLow, rsi[pivotLabelLength], logMom)
    log.info("LongStr: {0,number,#.#}% | ShortStr: {1,number,#.#}% | TrendAlign: {2,number,#.#}% | ZoneBoost: {3,number,#.#}%",
        logLongStr, logShortStr, logTrendAlign, logZoneBoost)
    log.info("TrendUp: {0} | TrendDn: {1} | LongBias: {2} | ShortBias: {3} | Ranging: {4}",
        logTrendUp, logTrendDn, logLongBias, logShortBias, logRanging)
    log.info("nearSup: {0} | nearRes: {1} | WT1: {2,number,#.#} | MR inOB: {3} | MR inOS: {4}",
        nearSupportForEntry, nearResistanceForEntry, logWT1, logInOB, logInOS)
    log.info("EntryV2 finalLong: {0} | bpcLong: {1} | Type: {2}",
        logFinalLong, logBpcLong, logEntryType)

// ============================================================================
// UNIFIED SIGNAL LABELS (Trend + Mean Reversion consolidated)
// ============================================================================
// All signals shown as LONG or SHORT with origin suffix:
// [T] = Trend (Breakout, Pullback, Continuation)
// [MR] = Mean Reversion (Oversold Bounce, Overbought Fade)

var array<label> unifiedLabels = array.new<label>()
int MAX_UNIFIED_LABELS = 30

// Determine signal source and create unified labels
bool hasTrendLong = useNewEntryEngine and entryEvent.emitEntry and entryV2.finalLong
bool hasTrendShort = useNewEntryEngine and entryEvent.emitEntry and entryV2.finalShort
bool hasMRLong = useMeanReversion and mrSignal.longSignal
bool hasMRShort = useMeanReversion and mrSignal.shortSignal

// LONG signals (Trend or Mean Reversion)
if hasTrendLong or hasMRLong
    // Prefer Mean Reversion if both trigger (counter-trend in extreme = stronger signal)
    bool isMR = hasMRLong
    string origin = isMR ? "MR" : "T"
    float strength = isMR ? (mrSignal.signalStrength == "STRONG" ? 0.9 : mrSignal.signalStrength == "MODERATE" ? 0.7 : 0.5) : entryEvent.strength
    string entryType = isMR ? "Oversold Bounce" : entryV2.entryType

    // Color intensity based on strength: STRONG = full color, MODERATE = 30% transparent, WEAK = 50% transparent
    int transparency = strength >= 0.8 ? 0 : strength >= 0.6 ? 30 : 50
    color baseCol = isMR ? mrLongColor : #00E676
    color labelCol = color.new(baseCol, transparency)

    string labelText = "LONG [" + origin + "]"
    string tooltipText = "LONG SIGNAL\nType: " + entryType + "\nStrength: " + str.tostring(strength * 100, "#") + "%"
    if isMR
        tooltipText := tooltipText + "\nWT1: " + str.tostring(mrSignal.wt1, "#.#") + " | Zone: " + str.tostring(mrSignal.lowerZone, "#.#")

    label lbl = label.new(bar_index, low, labelText,
        style=label.style_label_up, color=labelCol, textcolor=color.white, size=size.small,
        tooltip=tooltipText)
    array.push(unifiedLabels, lbl)
    if array.size(unifiedLabels) > MAX_UNIFIED_LABELS
        label.delete(array.shift(unifiedLabels))

// SHORT signals (Trend or Mean Reversion)
if hasTrendShort or hasMRShort
    // Prefer Mean Reversion if both trigger
    bool isMR = hasMRShort
    string origin = isMR ? "MR" : "T"
    float strength = isMR ? (mrSignal.signalStrength == "STRONG" ? 0.9 : mrSignal.signalStrength == "MODERATE" ? 0.7 : 0.5) : entryEvent.strength
    string entryType = isMR ? "Overbought Fade" : entryV2.entryType

    // Color intensity based on strength: STRONG = full color, MODERATE = 30% transparent, WEAK = 50% transparent
    int transparency = strength >= 0.8 ? 0 : strength >= 0.6 ? 30 : 50
    color baseCol = isMR ? mrShortColor : #FF1744
    color labelCol = color.new(baseCol, transparency)

    string labelText = "SHORT [" + origin + "]"
    string tooltipText = "SHORT SIGNAL\nType: " + entryType + "\nStrength: " + str.tostring(strength * 100, "#") + "%"
    if isMR
        tooltipText := tooltipText + "\nWT1: " + str.tostring(mrSignal.wt1, "#.#") + " | Zone: " + str.tostring(mrSignal.upperZone, "#.#")

    label lbl = label.new(bar_index, high, labelText,
        style=label.style_label_down, color=labelCol, textcolor=color.white, size=size.small,
        tooltip=tooltipText)
    array.push(unifiedLabels, lbl)
    if array.size(unifiedLabels) > MAX_UNIFIED_LABELS
        label.delete(array.shift(unifiedLabels))

// ============================================================================
// UNIFIED EXIT LABELS (Weakness + TP consolidated)
// ============================================================================
// All exit signals shown as "EXIT" with source in tooltip:
// - Weakness: Market showing signs of exhaustion/reversal
// - TP: Mean reversion target reached

var array<label> exitLabels = array.new<label>()
int MAX_EXIT_LABELS = 30

// Exit cooldown state (prevent spam)
var int lastExitLongBar = na
var int lastExitShortBar = na
int EXIT_COOLDOWN = 10  // Minimum bars between exit signals

// Determine exit sources
bool hasWeaknessBull = useNewEntryEngine and shouldEmit and independentWarning.warningBull
bool hasWeaknessBear = useNewEntryEngine and shouldEmit and independentWarning.warningBear
bool hasMRExitLong = useMeanReversion and mrShowExits and mrSignal.longExit
bool hasMRExitShort = useMeanReversion and mrShowExits and mrSignal.shortExit

// Check cooldowns
bool exitLongCooldownOK = na(lastExitLongBar) or (bar_index - lastExitLongBar) >= EXIT_COOLDOWN
bool exitShortCooldownOK = na(lastExitShortBar) or (bar_index - lastExitShortBar) >= EXIT_COOLDOWN

// EXIT for longs (close long position) - triggered by Bear Weakness or MR Long Exit
if (hasWeaknessBear or hasMRExitLong) and exitLongCooldownOK
    string reason = hasMRExitLong ? "Mean Reversion TP" : "Weakness: " + independentWarning.reason
    color exitCol = hasMRExitLong ? color.new(mrLongColor, 40) : color.new(#FF6F00, 0)

    label lbl = label.new(bar_index, high, "EXIT",
        style=label.style_label_down, color=exitCol, textcolor=color.white, size=size.tiny,
        tooltip="EXIT LONG\n" + reason)
    array.push(exitLabels, lbl)
    if array.size(exitLabels) > MAX_EXIT_LABELS
        label.delete(array.shift(exitLabels))
    lastExitLongBar := bar_index

// EXIT for shorts (close short position) - triggered by Bull Weakness or MR Short Exit
if (hasWeaknessBull or hasMRExitShort) and exitShortCooldownOK
    string reason = hasMRExitShort ? "Mean Reversion TP" : "Weakness: " + independentWarning.reason
    color exitCol = hasMRExitShort ? color.new(mrShortColor, 40) : color.new(#FFB300, 0)

    label lbl = label.new(bar_index, low, "EXIT",
        style=label.style_label_up, color=exitCol, textcolor=color.white, size=size.tiny,
        tooltip="EXIT SHORT\n" + reason)
    array.push(exitLabels, lbl)
    if array.size(exitLabels) > MAX_EXIT_LABELS
        label.delete(array.shift(exitLabels))
    lastExitShortBar := bar_index

// VolStop lines
plot(useNewEntryEngine and showVolatilityStop ? marketCtx.volStopLong : na, "VolStop Long", color.new(#00E676, 70), 1)
plot(useNewEntryEngine and showVolatilityStop ? marketCtx.volStopShort : na, "VolStop Short", color.new(#FF1744, 70), 1)

// ============================================================================
// DEBUG LABELS (Entry Engine Score Components)
// ============================================================================
// Shows strength score breakdown every 10 bars when enabled
// Helps understand why signals are/aren't triggering

var array<label> entryDebugLabels = array.new<label>()
int MAX_DEBUG_LABELS = 15

if useNewEntryEngine and showEntryDebug and (bar_index % 10 == 0)
    // Memory management
    if array.size(entryDebugLabels) >= MAX_DEBUG_LABELS
        label.delete(array.shift(entryDebugLabels))

    // Build debug text showing all score components
    string debugText = "--- Entry Debug ---\n"
    debugText += "Long Str: " + str.tostring(strengthScore.longStrength * 100, "#.0") + "%\n"
    debugText += "Short Str: " + str.tostring(strengthScore.shortStrength * 100, "#.0") + "%\n"
    debugText += "Mom: " + str.tostring(strengthScore.momentum * 100, "#.0") + "%\n"
    debugText += "Trend: " + str.tostring(strengthScore.trendAlign * 100, "#.0") + "%\n"
    debugText += "Zone: " + str.tostring(strengthScore.zoneBoost * 100, "#.0") + "%\n"
    debugText += "---\n"
    debugText += "TrendUp: " + (marketCtx.trendUp ? "Y" : "N") + " | LongBias: " + (marketCtx.longBias ? "Y" : "N") + "\n"
    debugText += "TrendDn: " + (marketCtx.trendDown ? "Y" : "N") + " | ShortBias: " + (marketCtx.shortBias ? "Y" : "N") + "\n"
    debugText += "Ranging: " + (marketCtx.isRanging ? "Y" : "N") + "\n"
    debugText += "nearSup: " + (nearSupportForEntry ? "Y" : "N") + " | nearRes: " + (nearResistanceForEntry ? "Y" : "N") + "\n"
    debugText += "---\n"
    debugText += "BPC L/S: " + (entryV2.bpcLong ? "Y" : "N") + "/" + (entryV2.bpcShort ? "Y" : "N") + "\n"
    debugText += "Final L/S: " + (entryV2.finalLong ? "Y" : "N") + "/" + (entryV2.finalShort ? "Y" : "N") + "\n"
    debugText += "Type: " + entryV2.entryType

    label debugLbl = label.new(bar_index, high + (atr * 0.5), debugText,
        style=label.style_label_down, color=color.new(#2196F3, 20), textcolor=color.white, size=size.small)
    array.push(entryDebugLabels, debugLbl)

// === MEAN REVERSION EXIT SIGNALS ===
// Now integrated into unified EXIT labels above

// === MEAN REVERSION ZONE BANDS ===
// Shows dynamic overbought/oversold zones as horizontal bands
// Zones adapt based on WaveTrend amplitude

// Zone visualization requires converting WT levels to price levels
// We use ATR-scaled projection from current price

// Plot zone indicators as background color when in extreme zones
bgcolor(useMeanReversion and mrShowZones and mrSignal.inOverbought ? color.new(mrShortColor, 90) : na, title="MR Overbought Zone")
bgcolor(useMeanReversion and mrShowZones and mrSignal.inOversold ? color.new(mrLongColor, 90) : na, title="MR Oversold Zone")

// ============================================================================
// ALERTS
// ============================================================================

// Strong Buy Alert
alertcondition(signal.strongBuy, title="Strong Buy Signal", message="CPM v3: STRONG BUY - Score: {{plot_0}}, Confidence: {{plot_1}}")

// Strong Sell Alert
alertcondition(signal.strongSell, title="Strong Sell Signal", message="CPM v3: STRONG SELL - Score: {{plot_0}}, Confidence: {{plot_1}}")

// Moderate Buy Alert
alertcondition(signal.moderateBuy, title="Moderate Buy Signal", message="CPM v3: Moderate Buy - Score: {{plot_0}}, Confidence: {{plot_1}}")

// Moderate Sell Alert
alertcondition(signal.moderateSell, title="Moderate Sell Signal", message="CPM v3: Moderate Sell - Score: {{plot_0}}, Confidence: {{plot_1}}")

// High Heat Score Alert
alertcondition(heatBreakdown.overall >= 0.7, title="High Quality Setup", message="CPM v3: HIGH HEAT SCORE ({{plot_2}}) - Quality setup detected")

// Entry Engine V2 Alerts - event-based (only emit on state machine events)
alertcondition(useNewEntryEngine and entryEvent.emitEntry and entryV2.finalLong, title="Entry V2 Long", message="CPM v3: ENTRY V2 LONG signal detected")
alertcondition(useNewEntryEngine and entryEvent.emitEntry and entryV2.finalShort, title="Entry V2 Short", message="CPM v3: ENTRY V2 SHORT signal detected")

// Independent Warning Alerts (NOT tied to entries - separate cooldown)
alertcondition(useNewEntryEngine and shouldEmit and independentWarning.warningBull, title="Weakness Bull", message="CPM v3: BULL WEAKNESS - potential reversal up")
alertcondition(useNewEntryEngine and shouldEmit and independentWarning.warningBear, title="Weakness Bear", message="CPM v3: BEAR WEAKNESS - potential reversal down")

// Exhaustion Alert
alertcondition(exhaust.bullConfirmed or exhaust.bearConfirmed, title="Exhaustion Confirmed", message="CPM v3: EXHAUSTION CONFIRMED - Potential reversal")

// Mean Reversion Alerts
alertcondition(useMeanReversion and mrSignal.longSignal, title="Mean Rev Long", message="CPM v3: MEAN REVERSION LONG - Oversold reversal confirmed")
alertcondition(useMeanReversion and mrSignal.shortSignal, title="Mean Rev Short", message="CPM v3: MEAN REVERSION SHORT - Overbought reversal confirmed")
alertcondition(useMeanReversion and mrSignal.longExit, title="Mean Rev Long Exit", message="CPM v3: MR Long Exit - Take profit")
alertcondition(useMeanReversion and mrSignal.shortExit, title="Mean Rev Short Exit", message="CPM v3: MR Short Exit - Take profit")

// ============================================================================
// SIGNAL AGE TRACKER
// ============================================================================
// Shows when signal becomes stale (helps identify signal invalidation)

var int lastSignalBar = na
var string lastSignalType = ""
var float lastSignalPrice = na

// Update on new signal
if signal.strongBuy or signal.moderateBuy or signal.strongSell or signal.moderateSell
    lastSignalBar := bar_index
    lastSignalType := signal.strongBuy ? "Strong Buy" : signal.moderateBuy ? "Moderate Buy" : signal.strongSell ? "Strong Sell" : "Moderate Sell"
    lastSignalPrice := close

// ============================================================================
// MARKET BIAS BAND (ATR-Based Bounded Fill - Optimized)
// ============================================================================
// Shows market bias as a bounded band between two ATR-based lines
// Green = bullish bias, Red = bearish bias
// Features: Smoothed bias, dynamic band width, hysteresis, intensity by strength

// Calculate Market Bias Score from Chart-TF categories (-1 to +1)
float biasScoreRaw = (
    mtfScores.chartTF.flowScore * 0.20 +          // Flow/Volume Profile bias
    mtfScores.chartTF.momentumScore * 0.25 +      // Momentum oscillators bias (higher weight)
    mtfScores.chartTF.trendScore * 0.25 +         // Trend direction bias (higher weight)
    mtfScores.chartTF.volatilityScore * 0.10 +    // Volatility regime bias
    mtfScores.chartTF.structureScore * 0.10 +     // Support/Resistance bias
    mtfScores.chartTF.divergenceScore * 0.10      // Divergence bias
) // Result: -1 (max bearish) to +1 (max bullish)

// Smooth bias score with JMA to reduce noise (lower lag than EMA)
float biasScore = calculateJMA(biasScoreRaw, 5)
float biasStrength = math.abs(biasScore)  // 0 to 1

// ATR-based bias band calculation
float biasATR = ta.atr(14)
float biasBasis = calculateJMA(close, 20)  // JMA basis for consistency

// Dynamic band width: Narrower when bias is strong, wider when weak
// Strong bias (0.5+) = 1.0 ATR, Weak bias (0) = 2.0 ATR
float biasFactor = 2.0 - (biasStrength * 1.0)  // Range: 1.0 to 2.0

// Calculate upper and lower bands
float biasUp = biasBasis - (biasFactor * biasATR)
float biasDn = biasBasis + (biasFactor * biasATR)
float biasUpExt = biasBasis - (biasFactor * 1.5 * biasATR)
float biasDnExt = biasBasis + (biasFactor * 1.5 * biasATR)

// Trailing logic for adaptive bands
var float biasTUp = na
var float biasTDown = na

biasTUp := close[1] > nz(biasTUp[1], biasUp) ? math.max(biasUp, nz(biasTUp[1], biasUp)) : biasUp
biasTDown := close[1] < nz(biasTDown[1], biasDn) ? math.min(biasDn, nz(biasTDown[1], biasDn)) : biasDn

// Hysteresis thresholds to prevent rapid switching
// Entry threshold higher than exit threshold
float biasEntryThresh = 0.15   // Need stronger signal to switch
float biasExitThresh = 0.05    // Can stay in trend with weaker signal

// Determine trend direction with hysteresis
var int biasTrend = 0
if biasTrend == 0
    // Neutral: need strong signal to enter
    if biasScore > biasEntryThresh and close > biasTDown[1]
        biasTrend := 1
    else if biasScore < -biasEntryThresh and close < biasTUp[1]
        biasTrend := -1
else if biasTrend == 1
    // Bullish: exit only if bias flips significantly
    if biasScore < -biasExitThresh or close < biasTUp
        biasTrend := biasScore < -biasEntryThresh ? -1 : 0
else if biasTrend == -1
    // Bearish: exit only if bias flips significantly
    if biasScore > biasExitThresh or close > biasTDown
        biasTrend := biasScore > biasEntryThresh ? 1 : 0

// Select which lines to show based on trend
float biasLine1 = biasTrend == 1 ? biasTUp : biasTrend == -1 ? biasTDown : na
float biasLine2 = biasTrend == 1 ? biasTDown : biasTrend == -1 ? biasTUp : na

// Dynamic color intensity based on bias strength
// Strong bias = more opaque (less transparency)
int lineTransp = int(50 - (biasStrength * 30))   // Range: 20-50
int fillTransp = int(90 - (biasStrength * 20))   // Range: 70-90

color biasLineColor = biasTrend == 1 ? color.new(#00E676, lineTransp) : biasTrend == -1 ? color.new(#FF1744, lineTransp) : color.new(#9E9E9E, 50)
color biasFillColor = biasTrend == 1 ? color.new(#00E676, fillTransp) : biasTrend == -1 ? color.new(#FF1744, fillTransp) : na

// Plot bias band (only when enabled) - need plot references for fill()
biasBandPlot1 = plot(showSignalAgeBg ? biasLine1 : na, "Bias Band 1", color=biasLineColor, linewidth=1, style=plot.style_line)
biasBandPlot2 = plot(showSignalAgeBg ? biasLine2 : na, "Bias Band 2", color=biasLineColor, linewidth=1, style=plot.style_line)

// Fill between the two lines (bounded area)
fill(biasBandPlot1, biasBandPlot2, color=biasFillColor, title="Bias Band Fill")

// Extended guard rails (dashed-look using circles)
color biasExtColor = biasTrend == 1 ? color.new(#00E676, 70) : biasTrend == -1 ? color.new(#FF1744, 70) : color.new(#9E9E9E, 70)
plot(showSignalAgeBg ? biasUpExt : na, "Bias Band Upper Guard", color=biasExtColor, linewidth=1, style=plot.style_circles)
plot(showSignalAgeBg ? biasDnExt : na, "Bias Band Lower Guard", color=biasExtColor, linewidth=1, style=plot.style_circles)

// ============================================================================
// DEBUG PLOTS (invisible, for alert messages)
// ============================================================================

plot(mtfScores.consensusScore, "Consensus Score", display=display.none)
plot(signal.confidence, "Signal Confidence", display=display.none)
plot(heatBreakdown.overall, "Heat Score", display=display.none)

// ============================================================================
// BOTTOM AREA INDICATOR (Multi-Mode)
// ============================================================================
// Continuous cyan area fill with transparency gradient at chart bottom
// 3 modes available: Trend Strength, Signal Quality, Risk Level
// Dark cyan = strong/high, Light cyan = weak/low

// Calculate indicator value based on selected mode
float indicatorValue = 0.0
string indicatorTitle = ""

if bottomAreaMode == "Trend Strength"
    // Mode 1: Trend Strength (0-100)
    // Uses absolute trend score - shows how strong trend is regardless of direction
    indicatorValue := math.abs(mtfScores.chartTF.trendScore) * 100  // -1/+1 → 0-100
    indicatorTitle := "Trend Strength"

else if bottomAreaMode == "Signal Quality"
    // Mode 2: Signal Quality (0-100)
    // Combines all 6 category scores to show overall setup quality
    float avgScore = (
        math.abs(mtfScores.chartTF.flowScore) +
        math.abs(mtfScores.chartTF.momentumScore) +
        math.abs(mtfScores.chartTF.trendScore) +
        math.abs(mtfScores.chartTF.volatilityScore) +
        math.abs(mtfScores.chartTF.structureScore) +
        math.abs(mtfScores.chartTF.divergenceScore)
    ) / 6  // Average of all 6 categories (0-1)
    indicatorValue := avgScore * 100  // 0-100
    indicatorTitle := "Signal Quality"

else if bottomAreaMode == "Risk Level"
    // Mode 3: Risk Level (0-100)
    // Combines volatility score and regime uncertainty
    float volatility = math.abs(mtfScores.chartTF.volatilityScore)  // High ATR = high value
    float regimeUncertainty = 1.0 - math.abs(mtfScores.chartTF.trendScore)  // Ranging = high uncertainty
    indicatorValue := ((volatility + regimeUncertainty) / 2) * 100  // 0-100
    indicatorTitle := "Risk Level"

// Calculate transparency based on indicator value
// Formula: Higher value = lower transparency = darker color
// Scale: 10% (strong) to 95% (weak)
int areaTransparency = int(math.max(10, math.min(95, 95 - (indicatorValue * 0.85))))

// Show area only if enabled and mode is not "Off"
bool showArea = showSignalStatus and bottomAreaMode != "Off"
color areaColor = showArea ? color.new(#00BCD4, areaTransparency) : na

// Position at bottom of chart (fixed offset from low)
float chartBottom = low - (atr * 2)
float areaHeight = atr * 0.8  // Height of the area

// Draw continuous area fill at chart bottom (using two plots + fill())
bottomPlotBase = plot(showArea ? chartBottom : na,
                      title="Bottom Area Base",
                      color=color.new(#00BCD4, 100),
                      display=display.none)

bottomPlotTop = plot(showArea ? chartBottom + areaHeight : na,
                     title="Bottom Area Top",
                     color=color.new(#00BCD4, 100),
                     display=display.none)

fill(bottomPlotBase, bottomPlotTop, color=areaColor, title="Bottom Area Indicator")

// ============================================================================
// DEBUG CHART LABELS (Removed)
// ============================================================================

// ============================================================================
// HTF MIDLINE
// ============================================================================
// Higher timeframe equilibrium line with multiple calculation modes

// Dynamic TF selection based on chart TF
getDynamicHTF() =>
    string currentTF = timeframe.period
    switch currentTF
        "1"   => "60"    // 1M → 1H
        "3"   => "60"    // 3M → 1H
        "5"   => "60"    // 5M → 1H
        "15"  => "240"   // 15M → 4H
        "30"  => "240"   // 30M → 4H
        "60"  => "D"     // 1H → Daily
        "120" => "D"     // 2H → Daily
        "240" => "D"     // 4H → Daily
        "D"   => "W"     // Daily → Weekly
        "W"   => "M"     // Weekly → Monthly
        => "D"           // Default: Daily

// Determine which TF to use
string htfToUse = str.contains(htfMidlineMode, "Dynamic") ? getDynamicHTF() : htfMidlineRes

// Calculate HTF Midline based on mode
float htfMidline = na
if showHTFMidline
    if htfMidlineMode == "Simple (OC/2)"
        htfMidline := request.security(syminfo.tickerid, htfToUse, (open + close) / 2, lookahead=barmerge.lookahead_off)
    else if htfMidlineMode == "OHLC4" or htfMidlineMode == "Dynamic + OHLC4"
        htfMidline := request.security(syminfo.tickerid, htfToUse, ohlc4, lookahead=barmerge.lookahead_off)
    else if htfMidlineMode == "VWAP" or htfMidlineMode == "Dynamic + VWAP"
        htfMidline := request.security(syminfo.tickerid, htfToUse, ta.vwap, lookahead=barmerge.lookahead_off)

// Plot HTF Midline (GLOBAL SCOPE - outside all if blocks)
plot(htfMidline, title="HTF Midline", color=htfMidlineColor, linewidth=2, style=plot.style_line)
