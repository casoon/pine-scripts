float tpATRMultSimple = input.float(1.5, "Simple TP: ATR ×", minval=0.5, maxval=5.0, step=0.1, group="Take-Profit", tooltip="ATR multiplier for Simple mode (REDUCED from 2.0 for more realistic targets)")
float tp1ATRMult = input.float(1.0, "TP1: ATR × (Quick Profit)", minval=0.5, maxval=2.0, step=0.1, group="Take-Profit", tooltip="First target - quick profit taking (default: 1.0 ATR)")
float tp3ATRMult = input.float(2.0, "TP3: ATR × (Extended)", minval=1.0, maxval=4.0, step=0.1, group="Take-Profit", tooltip="Third target - extended move, only in trends (default: 2.0 ATR)")
