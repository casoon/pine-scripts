int entryJMAFast = input.int(50, "Trend JMA Fast", minval=10, maxval=100, group="Entry Engine", tooltip="Fast JMA for trend bias (default: 50) - lower lag than EMA")
int entryJMASlow = input.int(100, "Trend JMA Slow", minval=50, maxval=200, group="Entry Engine", tooltip="Slow JMA for trend bias (default: 100) - lower lag than EMA")

bool showEntryDebug = input.bool(false, "Show Entry Debug Labels", group="Entry Engine", tooltip="Display strength score components every 10 bars for debugging signal generation")

// ==== SIGNAL BOOST (Extreme Conditions) ====
bool useRSIBoost = input.bool(true, "RSI Extreme Boost", group="Signal Boost", tooltip="Boost signal strength when RSI is in extreme zones (<25 or >75)")
float rsiBoostThreshold = input.float(25.0, "RSI Extreme Threshold", minval=15.0, maxval=35.0, step=1.0, group="Signal Boost", tooltip="RSI below this (oversold) or above 100-this (overbought) triggers boost")
float rsiBoostAmount = input.float(0.15, "RSI Boost Amount", minval=0.05, maxval=0.30, step=0.01, group="Signal Boost", tooltip="Strength added when RSI is extreme (0.15 = 15%)")

bool useWT1Boost = input.bool(true, "WaveTrend Extreme Boost", group="Signal Boost", tooltip="Boost signal strength when WT1 is in extreme zones")
float wt1BoostThreshold = input.float(60.0, "WT1 Extreme Threshold", minval=40.0, maxval=80.0, step=5.0, group="Signal Boost", tooltip="WT1 above this or below -this triggers boost")
float wt1BoostAmount = input.float(0.10, "WT1 Boost Amount", minval=0.05, maxval=0.25, step=0.01, group="Signal Boost", tooltip="Strength added when WT1 is extreme (0.10 = 10%)")

float strengthThreshold = input.float(0.40, "Strength Threshold", minval=0.20, maxval=0.70, step=0.05, group="Signal Boost", tooltip="Minimum strength required for final signal (lower = more signals)")

// ==== SIGNAL QUALITY GATE ====
bool useQualityGate = input.bool(true, "Enable Quality Gate", group="Signal Quality", tooltip="Filter signals based on ATR + Volume conditions")
int qualityATRLen = input.int(14, "ATR Length", minval=5, maxval=50, group="Signal Quality", tooltip="ATR period for quality assessment")
int qualityVolLen = input.int(20, "Volume SMA Length", minval=10, maxval=50, group="Signal Quality", tooltip="Volume average period for comparison")
