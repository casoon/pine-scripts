enableAlerts = input.bool(true, "Enable Alerts", group=groupFilter)

// Zone Management Settings
groupZones = "🏗️ Zone Management (Pro)"
useZoneManagement = input.bool(true, "Enable Zone Management", group=groupZones, tooltip="Advanced multi-timeframe zone detection and ranking")
zoneSource = input.string("Orderblock", "Zone Source", options=["Orderblock","Pivots"], group=groupZones)

htfTimeframe = input.timeframe("60", "HTF Timeframe", group=groupZones, tooltip="Higher timeframe for zone detection")

maxZonesPerSide = input.int(5, "Max Zones per Side", minval=1, maxval=10, group=groupZones, tooltip="Maximum number of bull/bear zones to track")

rankFavorHTF = input.bool(true, "Rank Favor HTF Zones", group=groupZones)
rankFavorFVG = input.bool(true, "Rank Favor FVG Overlap", group=groupZones)
rankFavorFresh = input.bool(true, "Rank Favor Fresh Zones", group=groupZones)

// Bias & Targets
groupBias = "📊 Bias & Targets"
biasLength = input.int(50, "Bias Analysis Length", minval=10, maxval=200, group=groupBias)
biasBandMult = input.float(1.5, "Bias Band Multiplier", minval=0.5, step=0.1, group=groupBias)

targetMode = input.string("ATR", "Target Mode", options=["ATR", "SIGMA", "LIQUIDITY"], group=groupBias)
atrSteps = input.string("0.5,1,1.5,2", "ATR Target Steps", group=groupBias)
sigmaSteps = input.string("1,1.5,2", "Sigma Target Steps", group=groupBias)

// Entry logic
groupEntries = "🔔 Entries"
entryStyle = input.string("Conservative", "Entry Style", options=["Conservative","Aggressive"], group=groupEntries)
useVWAPEntries = input.bool(true, "Use VWAP Retest Entries", group=groupEntries)
useZoneEntries = input.bool(true, "Use Zone Retest Entries", group=groupEntries)
minBarsBetweenEntries = input.int(30, "Min Bars Between Entries", minval=5, group=groupEntries)

// Zone Confirmations
groupConfirm = "✅ Zone Confirmations"
confirmMidline = input.bool(true, "Require Midline Cross", group=groupConfirm)
confirmBreak = input.bool(true, "Require Zone Break", group=groupConfirm)
requireBias = input.bool(true, "Require Bias Alignment", group=groupConfirm)

// Volume Profile Settings (Pro)
groupVolume = "📊 Volume Profile (Pro)"
useVolumeProfile = input.bool(true, "Enable Volume Profile", group=groupVolume, tooltip="Advanced volume profile analysis with POC, VA, HVN/LVN")

volumeProfileMode = input.string("ROLLING", "Profile Mode", options=["FIXED", "ROLLING", "SESSIONS"], group=groupVolume)

rollingLength = input.int(250, "Rolling Length", minval=50, maxval=1000, group=groupVolume)
binCount = input.int(64, "Bin Count", minval=24, maxval=200, group=groupVolume)
valueAreaPercent = input.float(0.70, "Value Area %", minval=0.5, maxval=0.99, step=0.01, group=groupVolume)

// Volume filters
groupVolumeFilters = "🔍 Volume Filters"
enableLVNSignals = input.bool(true, "LVN Break & Retest Signals", group=groupVolumeFilters)
enableVASignals = input.bool(true, "Value Area Re-entry Signals", group=groupVolumeFilters)
retestDistanceATR = input.float(0.25, "Max Retest Distance (ATR)", minval=0.0, step=0.05, group=groupVolumeFilters)

// Volume trend filters
useEMAFilter = input.bool(true, "EMA Trend Filter (50/200)", group=groupVolumeFilters)
useSupertrendFilter = input.bool(true, "Supertrend Filter", group=groupVolumeFilters)
useMOSTFilter = input.bool(true, "MOST Filter (ATR Trailing)", group=groupVolumeFilters)

// HTF Stack Panel Settings (Pro)
groupHTFStack = "📊 HTF Stack Panel (Pro)"
useHTFStack = input.bool(true, "Enable HTF Stack Panel", group=groupHTFStack, tooltip="Advanced multi-timeframe trend confluence analysis")

htfStackMethod = input.string("EMA", "Trend Detection Method", options=["EMA", "SUPERTREND", "MOST"], group=groupHTFStack)

htfStackPosition = input.string("top_left", "Panel Position", options=["top_left", "top_right", "bottom_left", "bottom_right"], group=groupHTFStack)

autotunVolumeProfile = input.bool(true, "Auto-tune Volume Profile", group=groupHTFStack, tooltip="Automatically adjust volume profile parameters based on market conditions")

htfStackThreshold = input.float(0.7, "Stack Alignment Threshold", minval=0.5, maxval=1.0, step=0.05, group=groupHTFStack, tooltip="Minimum confluence required for stack signal confirmation")

showChoppiness = input.bool(true, "Show Choppiness Index", group=groupHTFStack, tooltip="Display current market choppiness level")

// ============================================================================


// ============================================================================
// MODULE: core
// ============================================================================

// WUC VWAP DETECTION SETUP (Replaces all modules)
// ============================================================================

// Create WUC VWAP Configuration
vwapConfig = newVwapConfig()
vwapConfig.pivotLeftBars := vwapPivotL
vwapConfig.pivotRightBars := vwapPivotR
vwapConfig.clusterTolerancePercent := clusterPct
vwapConfig.minBarsBetweenSignals := minBarsLabel
vwapConfig.enableThrottling := true
vwapConfig.detectClusters := true

// Initialize VWAP anchors storage (persistent across bars)
var vwapAnchors = newVwapAnchors()

// Initialize Zone Management (Pro Feature)
var zoneState = newZoneState()
zoneConfig = newZoneConfig()

// Configure Zone Management
if useZoneManagement
    zoneConfig.htfTimeframe := htfTimeframe
    zoneConfig.useHTF := true
    zoneConfig.maxZonesPerSide := maxZonesPerSide
    zoneConfig.rankFavorHTF := rankFavorHTF
    zoneConfig.rankFavorFVG := rankFavorFVG
    zoneConfig.rankFavorFresh := rankFavorFresh
    zoneConfig.biasLength := biasLength
    zoneConfig.biasBandMultiplier := biasBandMult
    zoneConfig.targetMode := targetMode
    zoneConfig.atrSteps := atrSteps
    zoneConfig.sigmaSteps := sigmaSteps
    zoneConfig.confirmMidline := confirmMidline
    zoneConfig.confirmBreak := confirmBreak
    zoneConfig.requireBias := requireBias

// Initialize Volume Profile (Pro Feature)
var volumeState = newVolumeState()
volumeConfig = newVolumeConfig()

// Configure Volume Profile
if useVolumeProfile
    volumeConfig.profileMode := volumeProfileMode
    volumeConfig.rollingLength := rollingLength
    volumeConfig.binCount := binCount
    volumeConfig.valueAreaPercent := valueAreaPercent
    volumeConfig.useHLC3 := true
    volumeConfig.enableLVNSignals := enableLVNSignals
    volumeConfig.enableVASignals := enableVASignals
    volumeConfig.maxRetestDistanceATR := retestDistanceATR
    volumeConfig.useEMAFilter := useEMAFilter
    volumeConfig.useSupertrendFilter := useSupertrendFilter
    volumeConfig.useMOSTFilter := useMOSTFilter
    volumeConfig.showPOC := true
    volumeConfig.showValueArea := true
    volumeConfig.showNodes := true

    // Auto-tuning configuration
    volumeConfig.enableAutoTuning := autotunVolumeProfile
    volumeConfig.useMarketRegime := true

// Initialize HTF Stack Panel (Pro Feature)
var htfStackState = newHTFStackState()
htfConfig = newHTFConfig()

// Configure HTF Stack Panel
if useHTFStack
    htfConfig.trendMethod := htfStackMethod
    htfConfig.showStackPanel := true
    htfConfig.panelPosition := htfStackPosition
    htfConfig.stackThreshold := htfStackThreshold
    htfConfig.enableAutoTuning := autotunVolumeProfile
    htfConfig.autoSelectTFs := true
    htfConfig.maxTimeframes := 4

// ============================================================================
// CORE VWAP PROCESSING (Powered by WUC)
// ============================================================================

// Process all VWAP detection using WUC Engine
[vwapState, updatedAnchors] = processVwapDetection(vwapAnchors, vwapConfig)
vwapAnchors := updatedAnchors

// Generate VWAP signals
vwapSignals = generateVwapSignals(vwapState)

// Get VWAP bias analysis
[vwapBias, biasTrend] = getVwapBias(vwapState)

// Get confluence metrics
[confluenceCount, avgConfluenceStrength] = getVwapConfluence(vwapState)

// Process Zone Management (Pro Feature - Enhanced)
if useZoneManagement
    // Multi-source zone creation with VWAP integration
    if barstate.isconfirmed
        // Method 1: Zone source (Orderblock-like vs Pivot-based)
        if zoneSource == "Pivots"
            if vwapState.hasAnchoredHigh and vwapState.hasAnchoredLow
                // Current timeframe zones based on VWAP structures
                zonePivotHigh = ta.pivothigh(high, vwapPivotL, vwapPivotR)
                zonePivotLow = ta.pivotlow(low, vwapPivotL, vwapPivotR)

                if not na(zonePivotHigh)
                    // Enhanced bearish zone with VWAP bias
                    zoneTop = ta.highest(high, 15)
                    zoneBottom = ta.lowest(low, 8)

                    // Apply VWAP context for zone quality
                    vwapDistance = math.abs(zoneTop - vwapState.sessionVwap)
                    isNearVWAP = vwapDistance < (ta.atr(14) * 2.0)

                    if isNearVWAP or vwapState.crossStrength > 60.0
                        newZone = createZone(zoneTop, zoneBottom, false, false)
                        array.unshift(zoneState.zonesTF, newZone)

                if not na(zonePivotLow)
                    // Enhanced bullish zone with VWAP bias
                    zoneTop = ta.highest(high, 8)
                    zoneBottom = ta.lowest(low, 15)

                    // Apply VWAP context for zone quality
                    vwapDistance = math.abs(zoneBottom - vwapState.sessionVwap)
                    isNearVWAP = vwapDistance < (ta.atr(14) * 2.0)

                    if isNearVWAP or vwapState.crossStrength > 60.0
                        newZone = createZone(zoneTop, zoneBottom, true, false)
                        array.unshift(zoneState.zonesTF, newZone)
        else
            // Orderblock-like zones: last opposite candle before impulse
            atrNow = ta.atr(14)
            impulsUp = close > open and (close - open) > atrNow * 0.5
            impulsDn = close < open and (open - close) > atrNow * 0.5

            bullOB = impulsUp and close[1] < open[1]
            bearOB = impulsDn and close[1] > open[1]

            if bullOB
                obTop = open[1]
                obBot = low[1]
                newZone = createZone(obTop, obBot, true, false)
                array.unshift(zoneState.zonesTF, newZone)

            if bearOB
                obTop = high[1]
                obBot = open[1]
                newZone = createZone(obTop, obBot, false, false)
                array.unshift(zoneState.zonesTF, newZone)

        // Method 2: VWAP Confluence Zones (New)
        if vwapState.isClusterActive and vwapState.clusterStrength > 70.0
            // Create zones around VWAP cluster areas
            clusterCenter = vwapState.sessionVwap
            clusterRange = ta.atr(14) * 1.5

            // Bullish cluster zone
            bullZoneTop = clusterCenter + (clusterRange * 0.3)
            bullZoneBottom = clusterCenter - (clusterRange * 0.7)
            bullZone = createZone(bullZoneTop, bullZoneBottom, true, false)
            array.unshift(zoneState.zonesTF, bullZone)

            // Bearish cluster zone
            bearZoneTop = clusterCenter + (clusterRange * 0.7)
            bearZoneBottom = clusterCenter - (clusterRange * 0.3)
            bearZone = createZone(bearZoneTop, bearZoneBottom, false, false)
            array.unshift(zoneState.zonesTF, bearZone)

        // Method 3: HTF VWAP Zones with Enhanced Logic
        htfPivotHigh = request.security(syminfo.tickerid, htfTimeframe, ta.pivothigh(high, vwapPivotL, vwapPivotR))
        htfPivotLow = request.security(syminfo.tickerid, htfTimeframe, ta.pivotlow(low, vwapPivotL, vwapPivotR))
        htfVwap = request.security(syminfo.tickerid, htfTimeframe, ta.vwap(close))
        htfAtr = request.security(syminfo.tickerid, htfTimeframe, ta.atr(14))

        if not na(htfPivotHigh) and not na(htfVwap)
            htfHigh = request.security(syminfo.tickerid, htfTimeframe, ta.highest(high, 12))
            htfLow = request.security(syminfo.tickerid, htfTimeframe, ta.lowest(low, 6))

            // Enhanced HTF zone quality check
            htfVwapDistance = math.abs(htfHigh - htfVwap)
            htfIsQuality = htfVwapDistance < (htfAtr * 3.0)

            if htfIsQuality
                htfZone = createZone(htfHigh, htfLow, false, true)
                array.unshift(zoneState.zonesHTF, htfZone)

        if not na(htfPivotLow) and not na(htfVwap)
            htfHigh = request.security(syminfo.tickerid, htfTimeframe, ta.highest(high, 6))
            htfLow = request.security(syminfo.tickerid, htfTimeframe, ta.lowest(low, 12))

            // Enhanced HTF zone quality check
            htfVwapDistance = math.abs(htfLow - htfVwap)
            htfIsQuality = htfVwapDistance < (htfAtr * 3.0)

            if htfIsQuality
                htfZone = createZone(htfHigh, htfLow, true, true)
                array.unshift(zoneState.zonesHTF, htfZone)

        // Method 4: FVG-VWAP Confluence Zones (Advanced)
        // Detect Fair Value Gaps near VWAP levels
        fvgUp = low[2] > high and vwapState.sessionVwap >= high and vwapState.sessionVwap <= low[2]
        fvgDown = high[2] < low and vwapState.sessionVwap >= high[2] and vwapState.sessionVwap <= low

        if fvgUp and vwapState.crossStrength > 50.0
            fvgZone = createZone(high, low[2], true, false)
            fvgZone.hasFVG := true  // Mark as FVG zone
            array.unshift(zoneState.zonesTF, fvgZone)

        if fvgDown and vwapState.crossStrength > 50.0
            fvgZone = createZone(high[2], low, false, false)
            fvgZone.hasFVG := true  // Mark as FVG zone
            array.unshift(zoneState.zonesTF, fvgZone)

    // Enhanced Zone Processing with VWAP Integration
    zoneState := processZoneManagement(zoneState, zoneConfig)
    zoneState := findNearestZones(zoneState)

    // VWAP-Zone Confluence Analysis
    vwapZoneConfluence = 0.0
    if not na(zoneState.nearestBullZone) and zoneState.nearestBullZone.isActive
        distanceToVWAP = math.abs(zoneState.nearestBullZone.mid - vwapState.sessionVwap)
        maxDistance = ta.atr(14) * 1.0
        if distanceToVWAP < maxDistance
            vwapZoneConfluence += (1.0 - (distanceToVWAP / maxDistance)) * 30.0

    if not na(zoneState.nearestBearZone) and zoneState.nearestBearZone.isActive
        distanceToVWAP = math.abs(zoneState.nearestBearZone.mid - vwapState.sessionVwap)
        maxDistance = ta.atr(14) * 1.0
        if distanceToVWAP < maxDistance
            vwapZoneConfluence += (1.0 - (distanceToVWAP / maxDistance)) * 30.0

    // Update zone state with VWAP confluence
    if not na(zoneState.biasScore)
        zoneState.biasScore := zoneState.biasScore + vwapZoneConfluence

// Process Volume Profile (Pro Feature)
if useVolumeProfile
    volumeState := processVolumeProfile(volumeState, volumeConfig)

// Process HTF Stack Panel (Pro Feature)
var htfStackStatePrev = na
if useHTFStack
    htfStackState := processHTFStack(htfStackState, htfConfig)
    htfStackState := processHTFStackSignals(htfStackState, htfStackStatePrev, htfConfig)
    htfStackStatePrev := htfStackState

// ============================================================================
// SIGNAL FILTERING AND DISPLAY LOGIC
// ============================================================================

// Check display mode settings
bool isPriceMode = vwapMode == "Smart" or vwapMode == "Price Only"
bool isSmartMode = vwapMode == "Smart"
bool isClusterMode = vwapMode == "Smart" or vwapMode == "Cluster Only"

// Apply strength filtering
bool showPriceCrossUp = isPriceMode and vwapState.priceCrossUp and vwapState.canShowPriceCross and
                       vwapState.crossStrength >= minSignalStrength

bool showPriceCrossDown = isPriceMode and vwapState.priceCrossDown and vwapState.canShowPriceCross and
                         vwapState.crossStrength >= minSignalStrength

bool showStructureCrossUp = isSmartMode and vwapState.structureCrossUp and vwapState.canShowStructureCross and
                           vwapState.structureStrength >= minSignalStrength

bool showStructureCrossDown = isSmartMode and vwapState.structureCrossDown and vwapState.canShowStructureCross and
                             vwapState.structureStrength >= minSignalStrength

bool showCluster = isClusterMode and vwapState.isClusterActive and vwapState.canShowCluster and
                   vwapState.clusterStrength >= minSignalStrength

// Zone signals (Pro Feature)
bool showZoneLong = false
bool showZoneShort = false

if useZoneManagement
    showZoneLong := zoneState.longSignal
    showZoneShort := zoneState.shortSignal

// Volume Profile signals (Pro Feature)
bool showVolumeLong = false
bool showVolumeShort = false

if useVolumeProfile
    showVolumeLong := volumeState.longLVNSignal or volumeState.longVASignal
    showVolumeShort := volumeState.shortLVNSignal or volumeState.shortVASignal

// Entry triggers (retest + reject)
f_rejectUp(level, style) =>
    reenter = low <= level
    wickReject = low < level and close > level
    closeConfirm = close > level and close > open
    style == "Aggressive" ? (reenter and wickReject) : (reenter and wickReject and closeConfirm)

f_rejectDown(level, style) =>
    reenter = high >= level
    wickReject = high > level and close < level
    closeConfirm = close < level and close < open
    style == "Aggressive" ? (reenter and wickReject) : (reenter and wickReject and closeConfirm)

vwapEntryLong = useVWAPEntries and f_rejectUp(vwapState.sessionVwap, entryStyle)
vwapEntryShort = useVWAPEntries and f_rejectDown(vwapState.sessionVwap, entryStyle)

zoneEntryLong = false
zoneEntryShort = false
if useZoneManagement and useZoneEntries
    if not na(zoneState.nearestBullZone) and zoneState.nearestBullZone.isActive
        zoneEntryLong := f_rejectUp(zoneState.nearestBullZone.top, entryStyle)
    if not na(zoneState.nearestBearZone) and zoneState.nearestBearZone.isActive
        zoneEntryShort := f_rejectDown(zoneState.nearestBearZone.bottom, entryStyle)

biasOkLong = biasTrend == "BULLISH" or (useZoneManagement and zoneState.biasRegime == "BULL")
biasOkShort = biasTrend == "BEARISH" or (useZoneManagement and zoneState.biasRegime == "BEAR")
needBias = entryStyle == "Conservative"

entryLongRaw = (vwapEntryLong or zoneEntryLong) and (not needBias or biasOkLong)
entryShortRaw = (vwapEntryShort or zoneEntryShort) and (not needBias or biasOkShort)

var int lastEntryBar = na
entryCooldownOk = na(lastEntryBar) or (bar_index - lastEntryBar >= minBarsBetweenEntries)

entryLong = entryCooldownOk and entryLongRaw
entryShort = entryCooldownOk and entryShortRaw

if entryLong or entryShort
    lastEntryBar := bar_index

// HTF Stack signals (Pro Feature)
bool showHTFLong = false
bool showHTFShort = false
bool showHTFBreak = false

if useHTFStack
    showHTFLong := htfStackState.bullStackSignal
    showHTFShort := htfStackState.bearStackSignal
    showHTFBreak := htfStackState.stackBreakSignal

// ============================================================================
// COLOR SCHEME (Dynamic Based on Strength)
// ============================================================================

getSignalColor(float strength, bool isBullish) =>
    if not showStrengthColors
        isBullish ? color.new(color.lime, 0) : color.new(color.red, 0)
    else
        // Color intensity based on strength
        transparency = strength >= 80.0 ? 0 : strength >= 60.0 ? 20 : 40

        if isBullish
            strength >= 80.0 ? color.new(color.green, transparency) : strength >= 60.0 ? color.new(color.lime, transparency) :
            color.new(color.yellow, transparency)
        else
            strength >= 80.0 ? color.new(color.red, transparency) : strength >= 60.0 ? color.new(color.orange, transparency) :
            color.new(color.gray, transparency)

// VWAP line colors
COL_VWAP = color.new(color.blue, 0)
COL_AVWAP_H = color.new(color.purple, 0)
COL_AVWAP_L = color.new(color.orange, 0)

// ============================================================================


// ============================================================================
// MODULE: visualization
// ============================================================================

// VISUAL RENDERING
// ============================================================================

var line[] bullTargetLines = array.new_line()
var line[] bearTargetLines = array.new_line()
int maxTargets = 4

f_updateTargetLines(line[] linesArr, float[] levels, color baseCol) =>
    for i = 0 to maxTargets - 1
        line ln = array.size(linesArr) > i ? array.get(linesArr, i) : na
        float lvl = array.size(levels) > i ? array.get(levels, i) : na
        if not na(lvl)
            int alpha = i == 0 ? 40 : i == 1 ? 60 : i == 2 ? 80 : 90
            if na(ln)
                ln := line.new(bar_index - 1, lvl, bar_index, lvl, xloc=xloc.bar_index, extend=extend.right, color=color.new(baseCol, alpha), width=1)
                if array.size(linesArr) <= i
                    array.push(linesArr, ln)
                else
                    array.set(linesArr, i, ln)
            else
                line.set_xy1(ln, bar_index - 1, lvl)
                line.set_xy2(ln, bar_index, lvl)
                line.set_color(ln, color.new(baseCol, alpha))
        else if not na(ln)
            line.delete(ln)
            if array.size(linesArr) > i
                array.set(linesArr, i, na)

// Plot VWAP Lines
plot(showVWAPLines ? vwapState.sessionVwap : na,
     title="Session VWAP", color=COL_VWAP, linewidth=2)

plot(showVWAPLines and vwapState.hasAnchoredHigh ? vwapState.anchoredVwapHigh : na,
     title="Anchored VWAP High", color=COL_AVWAP_H, linewidth=1)

plot(showVWAPLines and vwapState.hasAnchoredLow ? vwapState.anchoredVwapLow : na,
     title="Anchored VWAP Low", color=COL_AVWAP_L, linewidth=1)

// Plot bias bands and target levels (Pro Feature - Enhanced)
if useZoneManagement
    // Bias bands with dynamic coloring based on regime
    biasUpperColor = zoneState.biasRegime == "BULL" ? color.new(color.green, 60) : zoneState.biasRegime == "BEAR" ? color.new(color.red, 60) : color.new(color.blue, 70)
    biasLowerColor = zoneState.biasRegime == "BULL" ? color.new(color.green, 60) : zoneState.biasRegime == "BEAR" ? color.new(color.red, 60) : color.new(color.blue, 70)

    plot(zoneState.bandUpper, title="Bias Upper", color=biasUpperColor, linewidth=1)
    plot(zoneState.bandLower, title="Bias Lower", color=biasLowerColor, linewidth=1)
    plot(zoneState.vwapLevel, title="VWAP Bias",
         color=zoneState.biasRegime == "BULL" ? color.new(color.green, 0) : zoneState.biasRegime == "BEAR" ? color.new(color.red, 0) : color.new(color.blue, 0),
         linewidth=2)

    // Dynamic target levels (lines, no plot-in-loop)
    if not na(zoneState.nearestBullZone) and zoneState.nearestBullZone.isActive
        bullTargetBase = zoneState.nearestBullZone.top
        float[] bullTargets = targetMode == "ATR" ? calculateTargetsATR(bullTargetBase, atrSteps, 14) : calculateTargetsSigma(bullTargetBase, sigmaSteps, 100)
        f_updateTargetLines(bullTargetLines, bullTargets, color.lime)
    else
        f_updateTargetLines(bullTargetLines, array.new_float(), color.lime)

    if not na(zoneState.nearestBearZone) and zoneState.nearestBearZone.isActive
        bearTargetBase = zoneState.nearestBearZone.bottom
        float[] bearTargets = targetMode == "ATR" ? calculateTargetsATR(bearTargetBase, atrSteps, 14) : calculateTargetsSigma(bearTargetBase, sigmaSteps, 100)
        for i = 0 to array.size(bearTargets) - 1
            float v = array.get(bearTargets, i)
            array.set(bearTargets, i, bearTargetBase - (v - bearTargetBase))
        f_updateTargetLines(bearTargetLines, bearTargets, color.red)
    else
        f_updateTargetLines(bearTargetLines, array.new_float(), color.red)

    // Zone strength visualization background
    zoneStrengthColor = zoneState.avgZoneScore > 5.0 ? color.new(color.yellow, 97) : zoneState.avgZoneScore > 3.0 ? color.new(color.orange, 98) : na
    bgcolor(zoneStrengthColor, title="Zone Strength Background")

// Plot Volume Profile levels (Pro Feature)
if useVolumeProfile
    plot(volumeState.currentProfile.pocPrice, title="POC",
         color=color.new(color.purple, 0), linewidth=3)
    plot(volumeState.currentProfile.valueAreaHigh, title="VAH",
         color=color.new(color.gray, 50), linewidth=1)
    plot(volumeState.currentProfile.valueAreaLow, title="VAL",
         color=color.new(color.gray, 50), linewidth=1)

// SIGNAL 1: Price × VWAP Cross
plotshape(showPriceCrossUp,
         title="Price x VWAP Up",
         style=shape.triangleup,
         location=location.belowbar,
         color=getSignalColor(vwapState.crossStrength, true),
         size=size.tiny,
         text="P")

plotshape(showPriceCrossDown,
         title="Price x VWAP Down",
         style=shape.triangledown,
         location=location.abovebar,
         color=getSignalColor(vwapState.crossStrength, false),
         size=size.tiny,
         text="P")

// SIGNAL 2: VWAP Structure Cross
plotshape(showStructureCrossUp,
         title="VWAP Structure Up",
         style=shape.diamond,
         location=location.bottom,
         color=color.new(color.aqua, 0),
         size=size.tiny,
         text="S")

plotshape(showStructureCrossDown,
         title="VWAP Structure Down",
         style=shape.diamond,
         location=location.top,
         color=color.new(color.orange, 0),
         size=size.tiny,
         text="S")

// SIGNAL 3: Multi-VWAP Cluster
plotshape(showCluster,
         title="VWAP Cluster",
         style=shape.circle,
         location=location.absolute,
         color=getSignalColor(vwapState.clusterStrength, true),
         size=size.small,
         text="C")

// ZONE SIGNALS (Pro)
plotshape(useZoneManagement and showZoneLong, title="Zone Long", style=shape.triangleup,
         location=location.belowbar, color=color.new(color.lime, 0), size=size.tiny, text="ZL")
plotshape(useZoneManagement and showZoneShort, title="Zone Short", style=shape.triangledown,
         location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="ZS")

// ENTRY SIGNALS (Context + Setup)
plotshape(entryLong, title="Entry Long", style=shape.triangleup,
         location=location.belowbar, color=color.new(color.lime, 0), size=size.tiny, text="L")
plotshape(entryShort, title="Entry Short", style=shape.triangledown,
         location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="S")

// VOLUME PROFILE SIGNALS (Pro)
plotshape(useVolumeProfile and showVolumeLong, title="Volume Long", style=shape.arrowup,
         location=location.belowbar, color=color.new(color.purple, 0), size=size.tiny, text="VL")
plotshape(useVolumeProfile and showVolumeShort, title="Volume Short", style=shape.arrowdown,
         location=location.abovebar, color=color.new(color.purple, 0), size=size.tiny, text="VS")

// HTF STACK SIGNALS (Pro)
plotshape(useHTFStack and showHTFLong, title="HTF Stack Long", style=shape.labelup,
         location=location.belowbar, color=color.new(color.blue, 0), size=size.small, text="HTF↑")
plotshape(useHTFStack and showHTFShort, title="HTF Stack Short", style=shape.labeldown,
         location=location.abovebar, color=color.new(color.blue, 0), size=size.small, text="HTF↓")
plotshape(useHTFStack and showHTFBreak, title="HTF Stack Break", style=shape.xcross,
         location=location.absolute, color=color.new(color.orange, 0), size=size.small, text="BREAK")

// Cluster zone background (subtle)
bgcolor(vwapState.vwapsInCluster ? color.new(color.yellow, 93) : na,
       title="VWAP Cluster Zone")

// ============================================================================
// INFORMATION PANEL
// ============================================================================

if showLegend and barstate.islast
    tableRows = 8
    if useZoneManagement
        tableRows += 4
    if useVolumeProfile
        tableRows += 4
    if useHTFStack
        tableRows += 5
    var table legend = table.new(position.top_right, 2, tableRows,
                                 frame_color=color.new(color.gray, 80),
                                 border_width=1)

    // Header
    table.cell(legend, 0, 0, "VWAP Cross Visuals",
               text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(legend, 1, 0, "WUC Powered",
               text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)

    // Signal legend
    table.cell(legend, 0, 1, "▲/▼ P",
               text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(legend, 1, 1, "Price × VWAP",
               text_color=color.white, bgcolor=color.new(color.gray, 70))

    table.cell(legend, 0, 2, "◆ S",
               text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(legend, 1, 2, "Structure Cross",
               text_color=color.white, bgcolor=color.new(color.gray, 70))

    table.cell(legend, 0, 3, "● C",
               text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(legend, 1, 3, "VWAP Cluster",
               text_color=color.white, bgcolor=color.new(color.gray, 70))

    // Current mode
    table.cell(legend, 0, 4, "Mode:",
               text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(legend, 1, 4, vwapMode,
               text_color=color.yellow, bgcolor=color.new(color.gray, 70))

    // VWAP Bias
    biasColor = biasTrend == "BULLISH" ? color.green : biasTrend == "BEARISH" ? color.red : color.gray
    table.cell(legend, 0, 5, "Bias:",
               text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(legend, 1, 5, biasTrend,
               text_color=biasColor, bgcolor=color.new(color.gray, 70))

    // Confluence
    table.cell(legend, 0, 6, "Confluence:",
               text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(legend, 1, 6, str.tostring(confluenceCount) + "/3",
               text_color=color.white, bgcolor=color.new(color.gray, 70))

    // Avg Strength
    table.cell(legend, 0, 7, "Strength:",
               text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(legend, 1, 7, str.tostring(avgConfluenceStrength, "#") + "%",
               text_color=color.white, bgcolor=color.new(color.gray, 70))

    // Zone Management Info (Pro)
    if useZoneManagement
        // Zone Bias
        biasColor = zoneState.biasRegime == "BULL" ? color.green : zoneState.biasRegime == "BEAR" ? color.red : color.gray
        table.cell(legend, 0, 8, "Zone Bias:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, 8, zoneState.biasRegime,
                   text_color=biasColor, bgcolor=color.new(color.gray, 70))

        // Active Zones
        table.cell(legend, 0, 9, "Zones:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, 9, str.tostring(zoneState.activeBullZones) + "/" + str.tostring(zoneState.activeBearZones),
                   text_color=color.white, bgcolor=color.new(color.gray, 70))

        // Zone Signals
        zoneSignalText = showZoneLong ? "LONG" : showZoneShort ? "SHORT" : "-"
        zoneSignalColor = showZoneLong ? color.green : showZoneShort ? color.red : color.gray
        table.cell(legend, 0, 10, "Zone Signal:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, 10, zoneSignalText,
                   text_color=zoneSignalColor, bgcolor=color.new(color.gray, 70))

        // Zone Score
        nextRow = 11
        table.cell(legend, 0, nextRow, "Avg Zone Score:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, nextRow, str.tostring(zoneState.avgZoneScore, "#.#"),
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        nextRow += 1
    else
        nextRow = 8

    // Volume Profile Info (Pro)
    if useVolumeProfile
        // POC Price
        table.cell(legend, 0, nextRow, "POC:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, nextRow, str.tostring(volumeState.currentProfile.pocPrice, format.mintick),
                   text_color=color.purple, bgcolor=color.new(color.gray, 70))
        nextRow += 1

        // Value Area
        table.cell(legend, 0, nextRow, "VA Range:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        vaRange = str.tostring(volumeState.currentProfile.valueAreaHigh, format.mintick) +
                 " - " + str.tostring(volumeState.currentProfile.valueAreaLow, format.mintick)
        table.cell(legend, 1, nextRow, vaRange,
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        nextRow += 1

        // Volume Signal
        volumeSignalText = showVolumeLong ? "LONG" : showVolumeShort ? "SHORT" : "-"
        volumeSignalColor = showVolumeLong ? color.green : showVolumeShort ? color.red : color.gray
        table.cell(legend, 0, nextRow, "Volume Signal:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, nextRow, volumeSignalText,
                   text_color=volumeSignalColor, bgcolor=color.new(color.gray, 70))
        nextRow += 1

        // Volume Score
        table.cell(legend, 0, nextRow, "Volume Score:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, nextRow, str.tostring(volumeState.volumeScore, "#.#") + "/10",
                   text_color=volumeState.passFilter ? color.green : color.gray, bgcolor=color.new(color.gray, 70))
        nextRow += 1
    else
        nextRow := na(nextRow) ? 8 : nextRow

    // HTF Stack Panel Info (Pro)
    if useHTFStack
        if na(nextRow)
            nextRow := 8

        // Stack Bias
        stackBiasColor = htfStackState.stackBias == "BULL" ? color.green : htfStackState.stackBias == "BEAR" ? color.red : htfStackState.stackBias == "CHOPPY" ? color.orange : color.gray

        table.cell(legend, 0, nextRow, "HTF Bias:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, nextRow, htfStackState.stackBias,
                   text_color=stackBiasColor, bgcolor=color.new(color.gray, 70))
        nextRow += 1

        // Stack Strength
        table.cell(legend, 0, nextRow, "HTF Strength:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, nextRow, str.tostring(htfStackState.stackStrength, "#") + "%",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        nextRow += 1

        // Choppiness
        if showChoppiness
            choppinessColor = htfStackState.choppiness > 61.8 ? color.orange : htfStackState.choppiness < 38.2 ? color.green : color.gray

            table.cell(legend, 0, nextRow, "Choppiness:",
                       text_color=color.white, bgcolor=color.new(color.gray, 70))
            table.cell(legend, 1, nextRow, str.tostring(htfStackState.choppiness, "#.#"),
                       text_color=choppinessColor, bgcolor=color.new(color.gray, 70))
            nextRow += 1

        // Market Regime
        regimeColor = htfStackState.marketRegime == "TRENDING" ? color.green : htfStackState.marketRegime == "RANGING" ? color.orange : color.gray

        table.cell(legend, 0, nextRow, "Market Regime:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, nextRow, htfStackState.marketRegime,
                   text_color=regimeColor, bgcolor=color.new(color.gray, 70))
        nextRow += 1

        // HTF Signal Status
        htfSignalText = showHTFLong ? "LONG" : showHTFShort ? "SHORT" : showHTFBreak ? "BREAK" : "-"
        htfSignalColor = showHTFLong ? color.green : showHTFShort ? color.red : showHTFBreak ? color.orange : color.gray

        table.cell(legend, 0, nextRow, "HTF Signal:",
                   text_color=color.white, bgcolor=color.new(color.gray, 70))
        table.cell(legend, 1, nextRow, htfSignalText,
                   text_color=htfSignalColor, bgcolor=color.new(color.gray, 70))

// ============================================================================
// ALERTS (Enhanced with WUC)
// ============================================================================

if enableAlerts
    // Price cross alerts
    if showPriceCrossUp
        alert("VWAP: Price crosses above VWAP (Strength: " + str.tostring(vwapState.crossStrength, "#") + "%)",
              alert.freq_once_per_bar)

    if showPriceCrossDown
        alert("VWAP: Price crosses below VWAP (Strength: " + str.tostring(vwapState.crossStrength, "#") + "%)",
              alert.freq_once_per_bar)

    // Structure cross alerts
    if showStructureCrossUp
        alert("VWAP: Structure breaks higher (Strength: " + str.tostring(vwapState.structureStrength, "#") + "%)",
              alert.freq_once_per_bar)

    if showStructureCrossDown
        alert("VWAP: Structure breaks lower (Strength: " + str.tostring(vwapState.structureStrength, "#") + "%)",
              alert.freq_once_per_bar)

    // Cluster alerts
    if showCluster
        alert("VWAP: Multi-VWAP confluence zone (Strength: " + str.tostring(vwapState.clusterStrength, "#") + "%)",
              alert.freq_once_per_bar)

    // High confluence alerts
    if confluenceCount >= 2 and avgConfluenceStrength >= 70.0
        alert("VWAP: HIGH CONFLUENCE - " + str.tostring(confluenceCount) + " signals align (" +
              str.tostring(avgConfluenceStrength, "#") + "% strength)", alert.freq_once_per_bar)

    // Zone alerts (Pro Feature - Enhanced)
    if useZoneManagement
        if showZoneLong
            zoneDetails = ""
            if not na(zoneState.nearestBullZone)
                zoneDetails += " | HTF: " + (zoneState.nearestBullZone.isHTF ? "YES" : "NO")
                zoneDetails += " | FVG: " + (zoneState.nearestBullZone.hasFVG ? "YES" : "NO")
                zoneDetails += " | Score: " + str.tostring(zoneState.nearestBullZone.score, "#.##")

            alert("🟢 ZONE LONG: " + zoneState.biasRegime + " bias" + zoneDetails +
                  " | VWAP Confluence: " + str.tostring(vwapZoneConfluence, "#.#") + "%",
                  alert.freq_once_per_bar)

        if showZoneShort
            zoneDetails = ""
            if not na(zoneState.nearestBearZone)
                zoneDetails += " | HTF: " + (zoneState.nearestBearZone.isHTF ? "YES" : "NO")
                zoneDetails += " | FVG: " + (zoneState.nearestBearZone.hasFVG ? "YES" : "NO")
                zoneDetails += " | Score: " + str.tostring(zoneState.nearestBearZone.score, "#.##")

            alert("🔴 ZONE SHORT: " + zoneState.biasRegime + " bias" + zoneDetails +
                  " | VWAP Confluence: " + str.tostring(vwapZoneConfluence, "#.#") + "%",
                  alert.freq_once_per_bar)

        // High-quality zone alerts
        if showZoneLong and zoneState.avgZoneScore > 4.0 and vwapZoneConfluence > 20.0
            alert("⭐ HIGH QUALITY ZONE LONG: Score " + str.tostring(zoneState.avgZoneScore, "#.#") +
                  " | VWAP Confluence: " + str.tostring(vwapZoneConfluence, "#.#") + "%",
                  alert.freq_once_per_bar)

        if showZoneShort and zoneState.avgZoneScore > 4.0 and vwapZoneConfluence > 20.0
            alert("⭐ HIGH QUALITY ZONE SHORT: Score " + str.tostring(zoneState.avgZoneScore, "#.#") +
                  " | VWAP Confluence: " + str.tostring(vwapZoneConfluence, "#.#") + "%",
                  alert.freq_once_per_bar)

        // Target level alerts
        if targetMode == "ATR" and not na(zoneState.nearestBullZone)
            bullTargetBase = zoneState.nearestBullZone.top
            atrTargets = calculateTargetsATR(bullTargetBase, atrSteps, 14)
            if array.size(atrTargets) > 0
                target1 = array.get(atrTargets, 0)
                if close >= target1 and close[1] < target1
                    alert("🎯 BULL TARGET 1 REACHED: " + str.tostring(target1, format.mintick), alert.freq_once_per_bar)

        if targetMode == "ATR" and not na(zoneState.nearestBearZone)
            bearTargetBase = zoneState.nearestBearZone.bottom
            atrTargets = calculateTargetsATR(bearTargetBase, atrSteps, 14)
            if array.size(atrTargets) > 0
                target1 = bearTargetBase - (array.get(atrTargets, 0) - bearTargetBase)
                if close <= target1 and close[1] > target1
                    alert("🎯 BEAR TARGET 1 REACHED: " + str.tostring(target1, format.mintick), alert.freq_once_per_bar)

        // Multi-signal confluence with enhanced zones
        totalSignals = (showPriceCrossUp or showPriceCrossDown ? 1 : 0) +
                      (showStructureCrossUp or showStructureCrossDown ? 1 : 0) +
                      (showCluster ? 1 : 0) +
                      (showZoneLong or showZoneShort ? 1 : 0)

        confluenceStrength = avgConfluenceStrength + vwapZoneConfluence +
                           (zoneState.avgZoneScore * 10.0)

        if totalSignals >= 3 and confluenceStrength > 150.0
            alert("🚀 MEGA CONFLUENCE: " + str.tostring(totalSignals) + " signals | " +
                  "Total Strength: " + str.tostring(confluenceStrength, "#") + "%!",
                  alert.freq_once_per_bar)

        // FVG Zone alerts
        fvgZoneAlert = false
        if array.size(zoneState.zonesTF) > 0
            for i = 0 to array.size(zoneState.zonesTF) - 1
                zone = array.get(zoneState.zonesTF, i)
                if zone.hasFVG and zone.touched and not zone.violated
                    fvgZoneAlert := true
                    break

        if fvgZoneAlert
            alert("📦 FVG-VWAP CONFLUENCE: Fair Value Gap zone interaction detected!", alert.freq_once_per_bar)

    // HTF Stack alerts (Pro Feature)
    if useHTFStack
        if showHTFLong
            alert("📊 HTF STACK LONG: " + htfStackState.stackBias + " bias | " +
                  "Strength: " + str.tostring(htfStackState.stackStrength, "#") + "% | " +
                  "Regime: " + htfStackState.marketRegime, alert.freq_once_per_bar)

        if showHTFShort
            alert("📊 HTF STACK SHORT: " + htfStackState.stackBias + " bias | " +
                  "Strength: " + str.tostring(htfStackState.stackStrength, "#") + "% | " +
                  "Regime: " + htfStackState.marketRegime, alert.freq_once_per_bar)

        if showHTFBreak
            alert("⚠️ HTF STACK BREAK: Multi-timeframe confluence breakdown detected!", alert.freq_once_per_bar)

        // High confluence alerts with HTF
        if htfStackState.stackStrength > 80.0 and htfStackState.marketRegime == "TRENDING"
            alert("🚀 HIGH CONFLUENCE HTF: Strong trending environment detected! (" +
                  str.tostring(htfStackState.stackStrength, "#") + "% strength)", alert.freq_once_per_bar)

    // Volume Profile alerts (Pro Feature)
    if useVolumeProfile
        if showVolumeLong
            volumeAlertText = "VOLUME: Long Signal"
            if volumeState.longLVNSignal
                volumeAlertText += " (LVN Break & Retest)"
            if volumeState.longVASignal
                volumeAlertText += " (VA Re-entry)"
            volumeAlertText += " - Score: " + str.tostring(volumeState.volumeScore, "#.#") + "/10"
            alert(volumeAlertText, alert.freq_once_per_bar)

        if showVolumeShort
            volumeAlertText = "VOLUME: Short Signal"
            if volumeState.shortLVNSignal
                volumeAlertText += " (LVN Break & Retest)"
            if volumeState.shortVASignal
                volumeAlertText += " (VA Re-entry)"
            volumeAlertText += " - Score: " + str.tostring(volumeState.volumeScore, "#.#") + "/10"
            alert(volumeAlertText, alert.freq_once_per_bar)

        // Ultimate confluence alert (all systems)
        megaSignals = (showPriceCrossUp or showPriceCrossDown ? 1 : 0) +
                     (showStructureCrossUp or showStructureCrossDown ? 1 : 0) +
                     (showCluster ? 1 : 0) +
                     (showZoneLong or showZoneShort ? 1 : 0) +
                     (showVolumeLong or showVolumeShort ? 1 : 0)

        if megaSignals >= 4
            alert("🚀 ULTIMATE CONFLUENCE: " + str.tostring(megaSignals) + " signal systems align!", alert.freq_once_per_bar)

// Standard Pine Script alert conditions for external systems
alertcondition(showPriceCrossUp, "VWAP Price Cross Up", "Price crosses above VWAP")
alertcondition(showPriceCrossDown, "VWAP Price Cross Down", "Price crosses below VWAP")
alertcondition(showStructureCrossUp, "VWAP Structure Up", "VWAP structure breaks higher")
alertcondition(showStructureCrossDown, "VWAP Structure Down", "VWAP structure breaks lower")
alertcondition(showCluster, "VWAP Cluster", "Multi-VWAP confluence zone")

// High confidence signals
alertcondition(showPriceCrossUp and vwapState.crossStrength >= 80.0,
              "VWAP High Confidence Up", "High confidence bullish VWAP signal")
alertcondition(showPriceCrossDown and vwapState.crossStrength >= 80.0,
              "VWAP High Confidence Down", "High confidence bearish VWAP signal")

// Zone alert conditions (Pro)
if useZoneManagement
    alertcondition(showZoneLong, "Zone Long Signal", "Zone-based long signal")
    alertcondition(showZoneShort, "Zone Short Signal", "Zone-based short signal")
    alertcondition(zoneState.biasRegime == "BULL" and showZoneLong, "Zone Bull Bias Long", "Zone long with bullish bias")
    alertcondition(zoneState.biasRegime == "BEAR" and showZoneShort, "Zone Bear Bias Short", "Zone short with bearish bias")

// Volume Profile alert conditions (Pro)
if useVolumeProfile
    alertcondition(showVolumeLong, "Volume Long Signal", "Volume-based long signal")
    alertcondition(showVolumeShort, "Volume Short Signal", "Volume-based short signal")
    alertcondition(volumeState.longLVNSignal, "LVN Long", "LVN break and retest long")
    alertcondition(volumeState.shortLVNSignal, "LVN Short", "LVN break and retest short")
    alertcondition(volumeState.longVASignal, "VA Long", "Value area re-entry long")
    alertcondition(volumeState.shortVASignal, "VA Short", "Value area re-entry short")
    alertcondition(volumeState.passFilter, "Volume Filter Pass", "Volume score >= 6.0")

// ============================================================================
// EXPORT PLOTS FOR EXTERNAL ACCESS
// ============================================================================

// Trading signals for external strategies
longSignal = showPriceCrossUp or showStructureCrossUp or
            (useZoneManagement and showZoneLong) or
            (useVolumeProfile and showVolumeLong) or
            (useHTFStack and showHTFLong)
shortSignal = showPriceCrossDown or showStructureCrossDown or
             (useZoneManagement and showZoneShort) or
             (useVolumeProfile and showVolumeShort) or
             (useHTFStack and showHTFShort)

plot(longSignal ? 1 : 0, title="VWAP_Long_Signal", display=display.none)
plot(shortSignal ? 1 : 0, title="VWAP_Short_Signal", display=display.none)

// VWAP values for external access
plot(vwapState.sessionVwap, title="VWAP_Session", display=display.none)
plot(vwapState.hasAnchoredHigh ? vwapState.anchoredVwapHigh : na,
     title="VWAP_Anchored_High", display=display.none)
plot(vwapState.hasAnchoredLow ? vwapState.anchoredVwapLow : na,
     title="VWAP_Anchored_Low", display=display.none)

// Bias and confluence for external access
plot(vwapBias, title="VWAP_Bias_Score", display=display.none)
plot(confluenceCount, title="VWAP_Confluence_Count", display=display.none)

// Zone data for external access (Pro)
if useZoneManagement
    plot(zoneState.bias, title="Zone_Bias", display=display.none)
    plot(zoneState.biasScore, title="Zone_Bias_Score", display=display.none)
    plot(zoneState.activeBullZones, title="Zone_Bull_Count", display=display.none)
    plot(zoneState.activeBearZones, title="Zone_Bear_Count", display=display.none)
    plot(zoneState.avgZoneScore, title="Zone_Avg_Score", display=display.none)
    plot(showZoneLong ? 1 : 0, title="Zone_Long_Signal", display=display.none)
    plot(showZoneShort ? 1 : 0, title="Zone_Short_Signal", display=display.none)

// Volume Profile data for external access (Pro)
if useVolumeProfile
    plot(volumeState.currentProfile.pocPrice, title="Volume_POC", display=display.none)
    plot(volumeState.currentProfile.valueAreaHigh, title="Volume_VAH", display=display.none)
    plot(volumeState.currentProfile.valueAreaLow, title="Volume_VAL", display=display.none)
    plot(volumeState.currentProfile.nearestLVN, title="Volume_Nearest_LVN", display=display.none)
    plot(volumeState.currentProfile.nearestHVN, title="Volume_Nearest_HVN", display=display.none)
    plot(volumeState.volumeScore, title="Volume_Score", display=display.none)
    plot(volumeState.passFilter ? 1 : 0, title="Volume_Filter_Pass", display=display.none)
    plot(showVolumeLong ? 1 : 0, title="Volume_Long_Signal", display=display.none)
    plot(showVolumeShort ? 1 : 0, title="Volume_Short_Signal", display=display.none)
    plot(volumeState.longLVNSignal ? 1 : 0, title="Volume_LVN_Long", display=display.none)
    plot(volumeState.shortLVNSignal ? 1 : 0, title="Volume_LVN_Short", display=display.none)
    plot(volumeState.longVASignal ? 1 : 0, title="Volume_VA_Long", display=display.none)
    plot(volumeState.shortVASignal ? 1 : 0, title="Volume_VA_Short", display=display.none)

// HTF Stack Panel data for external access (Pro)
if useHTFStack
    plot(htfStackState.stackStrength, title="HTF_Stack_Strength", display=display.none)
    plot(htfStackState.bullConfluence, title="HTF_Bull_Confluence", display=display.none)
    plot(htfStackState.bearConfluence, title="HTF_Bear_Confluence", display=display.none)
    plot(htfStackState.choppiness, title="HTF_Choppiness", display=display.none)
    plot(showHTFLong ? 1 : 0, title="HTF_Long_Signal", display=display.none)
    plot(showHTFShort ? 1 : 0, title="HTF_Short_Signal", display=display.none)
    plot(showHTFBreak ? 1 : 0, title="HTF_Break_Signal", display=display.none)
    plot(htfStackState.isChoppy ? 1 : 0, title="HTF_Is_Choppy", display=display.none)
    plot(htfStackState.isTrending ? 1 : 0, title="HTF_Is_Trending", display=display.none)
    plot(htfStackState.vaPct_eff, title="HTF_Auto_VA_Percent", display=display.none)
    plot(htfStackState.epsATR_eff, title="HTF_Auto_Epsilon_ATR", display=display.none)


