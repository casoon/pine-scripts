vwapPivotL = input.int(5, "VWAP Pivot Left", minval=1, maxval=20, group=groupVwap, tooltip="Left bars for pivot detection")

vwapPivotR = input.int(5, "VWAP Pivot Right", minval=1, maxval=20, group=groupVwap, tooltip="Right bars for pivot detection")

minBarsLabel = input.int(50, "Min Bars Between Signals", minval=10, maxval=200, group=groupVwap, tooltip="Throttle: minimum distance between visual markers")

// Visual Settings
