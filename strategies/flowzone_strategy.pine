//@version=6

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// FlowZone - Strategy Wrapper
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// @description Trading strategy wrapper that uses FlowZone system for execution
// @author RTA
// @build 2025-10-14 15:15:41
// @version 1.0.0

strategy("FlowZone Strategy", "FZ_S", overlay=true, max_bars_back=5000,
         default_qty_type=strategy.percent_of_equity, default_qty_value=100,
         calc_on_every_tick=false, process_orders_on_close=true,
         max_labels_count=100, max_lines_count=100)

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// STRATEGY CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════

// Core Strategy Settings
strategyMode = input.string("Professional", "Strategy Mode", 
                          options=["Aggressive", "Conservative", "Professional", "Scalping"], 
                          group="🎯 Core Settings")

enableStrategy = input.bool(true, "Enable Strategy Execution", group="🎯 Core Settings")
confluenceThreshold = input.float(7.0, "Confluence Threshold", minval=5.0, maxval=10.0, step=0.1, group="🎯 Core Settings")

// Risk Management
riskPerTrade = input.float(2.0, "Risk Per Trade %", minval=0.1, maxval=10.0, step=0.1, 
                          tooltip="Risk per trade as % of account", group="⚖️ Risk Management")

useStopLoss = input.bool(true, "Use Stop Loss", group="⚖️ Risk Management")
stopLossATR = input.float(2.0, "Stop Loss ATR Multiplier", minval=0.5, maxval=5.0, step=0.1, group="⚖️ Risk Management")

useTrailingStop = input.bool(false, "Use Trailing Stop", group="⚖️ Risk Management")
trailingATR = input.float(1.5, "Trailing Stop ATR", minval=0.5, maxval=3.0, step=0.1, group="⚖️ Risk Management")

// Take Profit Settings
useTakeProfit = input.bool(true, "Use Take Profit Levels", group="💰 Take Profit")
tp1Ratio = input.float(1.5, "TP1 Risk:Reward Ratio", minval=0.5, maxval=5.0, step=0.1, group="💰 Take Profit")
tp2Ratio = input.float(2.5, "TP2 Risk:Reward Ratio", minval=0.5, maxval=5.0, step=0.1, group="💰 Take Profit")
tp3Ratio = input.float(3.5, "TP3 Risk:Reward Ratio", minval=0.5, maxval=5.0, step=0.1, group="💰 Take Profit")

tp1Percent = input.int(33, "TP1 Position %", minval=10, maxval=50, group="💰 Take Profit")
tp2Percent = input.int(33, "TP2 Position %", minval=10, maxval=50, group="💰 Take Profit")

// Position Management
maxPositions = input.int(1, "Max Concurrent Positions", minval=1, maxval=3, group="📊 Position Management")
enableBreakEven = input.bool(true, "Enable Break Even", group="📊 Position Management")
breakEvenATR = input.float(1.0, "Break Even Trigger ATR", minval=0.5, maxval=3.0, step=0.1, group="📊 Position Management")

// Time Filters
useTimeFilter = input.bool(false, "Use Time Filter", group="⏰ Time Management")
startHour = input.int(9, "Start Hour", minval=0, maxval=23, group="⏰ Time Management")
endHour = input.int(17, "End Hour", minval=0, maxval=23, group="⏰ Time Management")

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// INDICATOR LOGIC INTEGRATION (MOCK - WILL BE REPLACED BY BUILD)
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════

// This section will be replaced by the build system with actual FlowZone indicator logic
// For now, using simplified EMA crossover system as placeholder

// Calculate confluence score (placeholder)
confluenceScore = 7.5  // Will be replaced by actual confluence calculation

// Generate signals (placeholder) 
ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)

longCondition = ta.crossover(ema20, ema50) and close > ema200 and confluenceScore >= confluenceThreshold
shortCondition = ta.crossunder(ema20, ema50) and close < ema200 and confluenceScore >= confluenceThreshold

// Time filter
timeFilter = not useTimeFilter or (hour >= startHour and hour <= endHour)

// Final signals
longSignal = enableStrategy and longCondition and timeFilter and strategy.position_size == 0
shortSignal = enableStrategy and shortCondition and timeFilter and strategy.position_size == 0

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// POSITION SIZING & RISK CALCULATION  
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════

// ATR for stop loss calculation
atr = ta.atr(14)

// Calculate position size based on risk
var float entryPrice = na
var float stopPrice = na
var float positionSize = na

if longSignal
    entryPrice := close
    stopPrice := useStopLoss ? close - (atr * stopLossATR) : na
    
    if useStopLoss and not na(stopPrice)
        riskAmount = strategy.equity * (riskPerTrade / 100)
        stopDistance = entryPrice - stopPrice
        positionSize := riskAmount / stopDistance
    else
        positionSize := strategy.equity * 0.95 / close

if shortSignal
    entryPrice := close  
    stopPrice := useStopLoss ? close + (atr * stopLossATR) : na
    
    if useStopLoss and not na(stopPrice)
        riskAmount = strategy.equity * (riskPerTrade / 100)
        stopDistance = stopPrice - entryPrice
        positionSize := riskAmount / stopDistance
    else
        positionSize := strategy.equity * 0.95 / close

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════

// Long Entry
if longSignal
    strategy.entry("LONG", strategy.long, qty=positionSize, comment="FZ Long @ " + str.tostring(close, "#.##"))
    
    // Set stop loss
    if useStopLoss and not na(stopPrice)
        strategy.exit("SL_LONG", "LONG", stop=stopPrice, comment="Stop Loss")
    
    // Set take profit levels
    if useTakeProfit
        tp1Price = entryPrice + ((entryPrice - stopPrice) * tp1Ratio)
        tp2Price = entryPrice + ((entryPrice - stopPrice) * tp2Ratio)  
        tp3Price = entryPrice + ((entryPrice - stopPrice) * tp3Ratio)
        
        strategy.exit("TP1_LONG", "LONG", limit=tp1Price, qty_percent=tp1Percent, comment="TP1")
        strategy.exit("TP2_LONG", "LONG", limit=tp2Price, qty_percent=tp2Percent, comment="TP2") 
        strategy.exit("TP3_LONG", "LONG", limit=tp3Price, comment="TP3")

// Short Entry  
if shortSignal
    strategy.entry("SHORT", strategy.short, qty=positionSize, comment="FZ Short @ " + str.tostring(close, "#.##"))
    
    // Set stop loss
    if useStopLoss and not na(stopPrice)
        strategy.exit("SL_SHORT", "SHORT", stop=stopPrice, comment="Stop Loss")
    
    // Set take profit levels
    if useTakeProfit
        tp1Price = entryPrice - ((stopPrice - entryPrice) * tp1Ratio)
        tp2Price = entryPrice - ((stopPrice - entryPrice) * tp2Ratio)
        tp3Price = entryPrice - ((stopPrice - entryPrice) * tp3Ratio)
        
        strategy.exit("TP1_SHORT", "SHORT", limit=tp1Price, qty_percent=tp1Percent, comment="TP1")
        strategy.exit("TP2_SHORT", "SHORT", limit=tp2Price, qty_percent=tp2Percent, comment="TP2")
        strategy.exit("TP3_SHORT", "SHORT", limit=tp3Price, comment="TP3")

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// BREAK EVEN MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════

if enableBreakEven and strategy.position_size != 0
    if strategy.position_size > 0 and close >= strategy.position_avg_price + (atr * breakEvenATR)
        strategy.exit("BE_LONG", "LONG", stop=strategy.position_avg_price + 0.01, comment="Break Even")
    
    if strategy.position_size < 0 and close <= strategy.position_avg_price - (atr * breakEvenATR)
        strategy.exit("BE_SHORT", "SHORT", stop=strategy.position_avg_price - 0.01, comment="Break Even")

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// TRAILING STOP MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════

if useTrailingStop and strategy.position_size != 0
    if strategy.position_size > 0
        trailStop = close - (atr * trailingATR)
        strategy.exit("TRAIL_LONG", "LONG", trail_price=close, trail_offset=atr * trailingATR, comment="Trailing Stop")
    
    if strategy.position_size < 0
        trailStop = close + (atr * trailingATR)
        strategy.exit("TRAIL_SHORT", "SHORT", trail_price=close, trail_offset=atr * trailingATR, comment="Trailing Stop")

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// VISUALIZATION
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════

// Plot EMAs
plot(ema20, "EMA 20", color.new(color.lime, 0), linewidth=2)
plot(ema50, "EMA 50", color.new(color.blue, 0), linewidth=2)
plot(ema200, "EMA 200", color.new(color.red, 0), linewidth=3)

// Signal Arrows
plotshape(longSignal, "Long Entry", shape.triangleup, location.belowbar, 
         color.new(color.lime, 0), size=size.normal, text="LONG")
plotshape(shortSignal, "Short Entry", shape.triangledown, location.abovebar, 
         color.new(color.orange, 0), size=size.normal, text="SHORT")

// Position Info Panel
if barstate.islast and strategy.position_size != 0
    infoTable = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 85), 
                         border_width=1, border_color=color.new(color.gray, 0))
    
    // Header
    table.cell(infoTable, 0, 0, "FlowZone Strategy v2.0", 
              text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 0))
    table.cell(infoTable, 1, 0, strategyMode + " Mode", 
              text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 0))
    
    // Position Info
    positionSide = strategy.position_size > 0 ? "LONG" : "SHORT"
    positionColor = strategy.position_size > 0 ? color.new(color.green, 0) : color.new(color.red, 0)
    table.cell(infoTable, 0, 1, "Position", text_color=color.gray)
    table.cell(infoTable, 1, 1, positionSide, text_color=positionColor)
    
    // P&L
    pnl = strategy.position_size > 0 ? (close - strategy.position_avg_price) / strategy.position_avg_price * 100 :
          (strategy.position_avg_price - close) / strategy.position_avg_price * 100
    pnlColor = pnl >= 0 ? color.new(color.green, 0) : color.new(color.red, 0)
    table.cell(infoTable, 0, 2, "P&L", text_color=color.gray)
    table.cell(infoTable, 1, 2, str.tostring(pnl, "#.1") + "%", text_color=pnlColor)
    
    // Size
    table.cell(infoTable, 0, 3, "Size", text_color=color.gray)
    table.cell(infoTable, 1, 3, str.tostring(math.abs(strategy.position_size), "#"), text_color=color.white)
    
    // Entry
    table.cell(infoTable, 0, 4, "Entry", text_color=color.gray)
    table.cell(infoTable, 1, 4, str.tostring(strategy.position_avg_price, "#.##"), text_color=color.white)
    
    // Confluence
    confColor = confluenceScore >= 7.5 ? color.new(color.green, 0) : 
               confluenceScore >= 6.5 ? color.new(color.blue, 0) : color.new(color.red, 0)
    table.cell(infoTable, 0, 5, "Confluence", text_color=color.gray)
    table.cell(infoTable, 1, 5, str.tostring(confluenceScore, "#.1") + "/10", text_color=confColor)

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// PERFORMANCE TRACKING
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════

// Output key performance metrics to data window
if barstate.islast
    totalTrades = strategy.closedtrades
    winRate = totalTrades > 0 ? strategy.wintrades / totalTrades * 100 : 0
    profitFactor = strategy.grossloss != 0 ? math.abs(strategy.grossprofit / strategy.grossloss) : 0
    
    plotchar(totalTrades, "Total Trades", "", location.top, display=display.data_window)
    plotchar(winRate, "Win Rate %", "", location.top, display=display.data_window)
    plotchar(profitFactor, "Profit Factor", "", location.top, display=display.data_window)
    plotchar(strategy.netprofit, "Net Profit", "", location.top, display=display.data_window)
    plotchar(confluenceScore, "Confluence Score", "", location.top, display=display.data_window)

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════

// Entry Alerts
if longSignal
    alert("FlowZone Ultimate v2.0 Strategy | LONG ENTRY\\nPrice: " + str.tostring(close, "#.##") + 
          "\\nConfluence: " + str.tostring(confluenceScore, "#.1") + "/10\\nMode: " + strategyMode, 
          alert.freq_once_per_bar)

if shortSignal  
    alert("FlowZone Ultimate v2.0 Strategy | SHORT ENTRY\\nPrice: " + str.tostring(close, "#.##") +
          "\\nConfluence: " + str.tostring(confluenceScore, "#.1") + "/10\\nMode: " + strategyMode, 
          alert.freq_once_per_bar)

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════
// VERSION INFO
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════

// Strategy Wrapper Information:
// Version: 2.0.0
// Base: FlowZone Ultimate v2.0 Indicator
// Features: Multi-TP, Risk Management, Break Even, Trailing Stops
// Risk Management: Position Sizing, ATR-based Stops
// Performance: Professional Strategy Execution