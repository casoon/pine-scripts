//@version=6
// ============================================================================
// Oscillator Divergence Zones [WavesUnchained] — Strategy (generated)
// Version: 1.1
// Author: WavesUnchained
// Build: 2026-04-29 00:00:00
// ============================================================================
// Detects regular and hidden divergences for RSI, CCI, or MFI.
//
// Features:
//   ✓ Oscillator selector: RSI (default), CCI, MFI
//   ✓ Regular divergence: price/oscillator structural opposition at pivots
//   ✓ Hidden divergence: trend-continuation counterpart (toggle separately)
//   ✓ OB/OS filter: suppress signals outside meaningful oscillator territory
//   ✓ StdDev filter: optional statistical overextension gate for regular divergences
//   ✓ ATR-based zone width: band height locked to creation-time volatility
//   ✓ Configurable break trigger: full-candle (default) or close-based
//   ✓ Zone retest counter: touch count displayed at zone right edge
//   ✓ Dual-pane visualization: oscillator pane markers and chart overlay
//   ✓ Alert conditions for all four divergence types
//
// ============================================================================

strategy("Oscillator Divergence Zones [WavesUnchained] — Strategy", overlay=false,
     format=format.price,
     precision=2,
     max_lines_count=500,
     max_labels_count=500,
     max_boxes_count=500,
     default_qty_type=strategy.percent_of_equity, default_qty_value=10,
     commission_type=strategy.commission.percent, commission_value=0.02,
     slippage=1, max_bars_back=500)

// ─── Inputs ──────────────────────────────────────────────────────────────────
g_osc    = "Oscillator"
oscType  = input.string("RSI", "Type", options=["RSI", "CCI", "MFI"], group=g_osc)
oscSrc   = input.source(close, "Source",                     group=g_osc)
oscLen   = input.int(14,       "Length",       minval=2,     group=g_osc)
autoLevels = input.bool(true,  "Auto OB/OS per Oscillator", group=g_osc,
     tooltip="Automatically applies standard OB/OS levels per oscillator: RSI 70/30 · CCI 100/−100 · MFI 80/20. Disable to set custom values below.")
obLevel  = input.int(70,       "Overbought",  minval=-500, maxval=500, group=g_osc,
     tooltip="Used only when Auto OB/OS is disabled. RSI: 70 · CCI: 100 · MFI: 80")
osLevel  = input.int(30,       "Oversold",    minval=-500, maxval=500, group=g_osc,
     tooltip="Used only when Auto OB/OS is disabled. RSI: 30 · CCI: −100 · MFI: 20")

g_div         = "Divergence"
pivLeft       = input.int(7,   "Pivot Left Bars",           minval=1, group=g_div)
pivRight      = input.int(7,   "Pivot Right Bars",          minval=1, group=g_div)
minRange      = input.int(10,  "Min Bars Between Pivots",   minval=1, group=g_div)
maxRange      = input.int(100, "Max Bars Between Pivots",   minval=5, group=g_div)
showHidden    = input.bool(false, "Show Hidden Divergence",            group=g_div)
oscFilter      = input.bool(true, "Filter by Oscillator Level",        group=g_div)
bullFilterPct  = input.int(75,  "Max for Bull (%)", minval=0, maxval=100, group=g_div,
     tooltip="Upper limit for bullish signals as % of the OB–OS range (auto-scales across oscillators). 75% ≈ RSI 60 · CCI 50 · MFI 65")
bearFilterPct  = input.int(25,  "Min for Bear (%)", minval=0, maxval=100, group=g_div,
     tooltip="Lower limit for bearish signals as % of the OB–OS range (auto-scales across oscillators). 25% ≈ RSI 40 · CCI −50 · MFI 35")

g_std        = "StdDev Filter"
useStdFilter = input.bool(false,  "Statistical Overextension Filter", group=g_std,
     tooltip="Only fire regular divergences when the oscillator is outside its rolling mean ± N×StdDev band at the pivot. Reduces false signals in flat/choppy markets. Does not apply to hidden divergences.")
stdPeriod    = input.int(100,  "Lookback Period", minval=10,               group=g_std)
stdMult      = input.float(1.5, "StdDev Multiplier", minval=0.5, step=0.1, group=g_std)

g_zone       = "Zones"
showZones    = input.bool(true,  "Show Zones on Chart",             group=g_zone)
maxZones     = input.int(10,     "Max Active Zones", minval=1, maxval=50, group=g_zone)
zoneExtend   = input.int(15,     "Zone Lookahead (bars)", minval=1,   group=g_zone)
atrLen       = input.int(14,     "ATR Length (zone width)", minval=1, group=g_zone)
zoneFactor   = input.float(0.25, "Zone Width (ATR×)", minval=0.05, maxval=3.0, step=0.05, group=g_zone)
breakOnClose = input.bool(false, "Break on Close",                   group=g_zone)
showTouches  = input.bool(true,  "Show Retest Count",                group=g_zone)

g_col   = "Colors"
bullCol = input.color(#26a69a, "Bullish", group=g_col)
bearCol = input.color(#ef5350, "Bearish", group=g_col)

g_debug    = "Debug"
showPivots = input.bool(false, "Show All Pivots", group=g_debug,
     tooltip="Marks every detected price pivot as a small circle — helps diagnose why a divergence was not triggered. Filled = passed all filters. Semi-transparent = pivot detected but no divergence signal.")

// ─── Types ───────────────────────────────────────────────────────────────────
type Zone
    line  edge
    box   area
    int   touches
    label info
    float halfW
    bool  bull

// ─── State ───────────────────────────────────────────────────────────────────
var array<Zone> bullZones    = array.new<Zone>()
var array<Zone> bearZones    = array.new<Zone>()
var array<Zone> hidBullZones = array.new<Zone>()
var array<Zone> hidBearZones = array.new<Zone>()

var int   prevBullBar    = na
var float prevBullOsc    = na
var int   prevBearBar    = na
var float prevBearOsc    = na
var int   prevHidBullBar = na
var float prevHidBullOsc = na
var int   prevHidBearBar = na
var float prevHidBearOsc = na

// ─── Oscillator ──────────────────────────────────────────────────────────────
atr         = ta.atr(atrLen)
rsiSeries = ta.rsi(oscSrc, oscLen)
cciSeries = ta.cci(oscSrc, oscLen)
mfiSeries = ta.mfi(oscSrc, oscLen)

oscVal = oscType == "CCI" ? cciSeries :
         oscType == "MFI" ? mfiSeries : rsiSeries

// CCI is centered on 0; all others on 50
midLevel   = oscType == "CCI" ? 0 : 50
oscAtPiv   = oscVal[pivRight]

effectiveOB = autoLevels ? (oscType == "CCI" ? 100 : oscType == "MFI" ? 80 : 70)  : obLevel
effectiveOS = autoLevels ? (oscType == "CCI" ? -100 : oscType == "MFI" ? 20 : 30) : osLevel

// ─── Pivots on price ─────────────────────────────────────────────────────────
foundPL = not na(ta.pivotlow(low,   pivLeft, pivRight))
foundPH = not na(ta.pivothigh(high, pivLeft, pivRight))

pivBarIdx = bar_index - pivRight

bullFilterLvl = effectiveOS + bullFilterPct / 100.0 * (effectiveOB - effectiveOS)
bearFilterLvl = effectiveOS + bearFilterPct / 100.0 * (effectiveOB - effectiveOS)
bullOk = not oscFilter or oscAtPiv < bullFilterLvl
bearOk = not oscFilter or oscAtPiv > bearFilterLvl

// StdDev overextension filter (regular divergences only)
_oscMean  = ta.sma(oscVal, stdPeriod)
_oscStd   = ta.stdev(oscVal, stdPeriod)
_oscUpper = _oscMean + stdMult * _oscStd
_oscLower = _oscMean - stdMult * _oscStd
stdBullOk = not useStdFilter or oscAtPiv < _oscLower[pivRight]
stdBearOk = not useStdFilter or oscAtPiv > _oscUpper[pivRight]

// Check divergence against one of the last 3 preceding pivots so that
// intermediate pivots do not prevent detection of the structurally relevant pair.
_bullDivWith(n) =>
    prevP = ta.valuewhen(foundPL, low[pivRight],  n)
    prevO = ta.valuewhen(foundPL, oscAtPiv,        n)
    dist  = pivBarIdx - ta.valuewhen(foundPL, pivBarIdx, n)
    not na(prevP) and dist >= minRange and dist <= maxRange and low[pivRight] < prevP and oscAtPiv > prevO

_bearDivWith(n) =>
    prevP = ta.valuewhen(foundPH, high[pivRight], n)
    prevO = ta.valuewhen(foundPH, oscAtPiv,       n)
    dist  = pivBarIdx - ta.valuewhen(foundPH, pivBarIdx, n)
    not na(prevP) and dist >= minRange and dist <= maxRange and high[pivRight] > prevP and oscAtPiv < prevO

_bullHidWith(n) =>
    prevP = ta.valuewhen(foundPL, low[pivRight],  n)
    prevO = ta.valuewhen(foundPL, oscAtPiv,        n)
    dist  = pivBarIdx - ta.valuewhen(foundPL, pivBarIdx, n)
    not na(prevP) and dist >= minRange and dist <= maxRange and low[pivRight] > prevP and oscAtPiv < prevO

_bearHidWith(n) =>
    prevP = ta.valuewhen(foundPH, high[pivRight], n)
    prevO = ta.valuewhen(foundPH, oscAtPiv,       n)
    dist  = pivBarIdx - ta.valuewhen(foundPH, pivBarIdx, n)
    not na(prevP) and dist >= minRange and dist <= maxRange and high[pivRight] < prevP and oscAtPiv > prevO

// Regular: price/oscillator oppose → reversal signal
bullDiv    = foundPL and bullOk and stdBullOk and (_bullDivWith(1) or _bullDivWith(2) or _bullDivWith(3))
bearDiv    = foundPH and bearOk and stdBearOk and (_bearDivWith(1) or _bearDivWith(2) or _bearDivWith(3))

// Hidden: price/oscillator diverge in trend direction → continuation signal
// Always calculated so strategy/alerts can use them; display gated by showHidden
bullHidDiv = foundPL and bullOk and (_bullHidWith(1) or _bullHidWith(2) or _bullHidWith(3))
bearHidDiv = foundPH and bearOk and (_bearHidWith(1) or _bearHidWith(2) or _bearHidWith(3))

// ─── Zone functions ───────────────────────────────────────────────────────────
_addZone(arr, col, priceLevel, isHidden, isBull) =>
    halfW    = atr * zoneFactor / 2
    x1       = bar_index - pivRight
    x2       = bar_index + zoneExtend
    // Label sits outside the zone box — below for bull, above for bear
    labelY   = isBull ? priceLevel - halfW : priceLevel + halfW
    edgeLine = line.new(x1, priceLevel, x2, priceLevel,
         color=col, width=1,
         style=isHidden ? line.style_dashed : line.style_solid,
         force_overlay=true)
    areaBox  = box.new(x1, priceLevel + halfW, x2, priceLevel - halfW,
         border_color=color.new(col, 60),
         bgcolor=isHidden ? color.new(col, 100) : color.new(col, 90),
         force_overlay=true)
    infoLbl  = label.new(x2, labelY, "",
         xloc=xloc.bar_index, style=label.style_label_left,
         color=color.new(col, 20), textcolor=color.white, size=size.small,
         tooltip="Retest count: how many times price re-entered this zone without breaking it.",
         force_overlay=true)
    arr.push(Zone.new(edgeLine, areaBox, 0, infoLbl, halfW, isBull))
    while arr.size() > maxZones
        old = arr.shift()
        old.edge.delete()
        old.area.delete()
        old.info.delete()

_updateZones(arr, isBull) =>
    if arr.size() > 0
        toRemove = array.new<int>()
        for i = 0 to arr.size() - 1
            z       = arr.get(i)
            lvl     = z.edge.get_y1()
            broken  = breakOnClose ? (isBull ? close < lvl : close > lvl) : (isBull ? high <= lvl : low >= lvl)
            touched = not broken and (isBull ? low <= lvl + z.halfW : high >= lvl - z.halfW)
            if broken
                z.edge.set_x2(bar_index)
                z.edge.set_style(line.style_dotted)
                z.area.set_right(bar_index)
                z.area.set_bgcolor(color.new(color.gray, 94))
                z.area.set_border_color(color.new(color.gray, 88))
                z.info.delete()
                toRemove.unshift(i)
            else
                z.edge.set_x2(bar_index + zoneExtend)
                z.area.set_right(bar_index + zoneExtend)
                if touched
                    z.touches += 1
                if showTouches and z.touches > 0
                    z.info.set_x(bar_index + zoneExtend)
                    z.info.set_text("×" + str.tostring(z.touches))
        if toRemove.size() > 0
            for j = 0 to toRemove.size() - 1
                arr.remove(toRemove.get(j))

// ─── Execute ─────────────────────────────────────────────────────────────────
_updateZones(bullZones,    true)
_updateZones(bearZones,    false)
_updateZones(hidBullZones, true)
_updateZones(hidBearZones, false)

if showZones
    if bullDiv
        _addZone(bullZones,    bullCol, low[pivRight],  false, true)
    if bearDiv
        _addZone(bearZones,    bearCol, high[pivRight], false, false)
    if showHidden and bullHidDiv
        _addZone(hidBullZones, bullCol, low[pivRight],  true,  true)
    if showHidden and bearHidDiv
        _addZone(hidBearZones, bearCol, high[pivRight], true,  false)

// Regular connector lines: dotted, full opacity
if bullDiv
    currBar = bar_index - pivRight
    if not na(prevBullBar)
        line.new(prevBullBar, prevBullOsc, currBar, oscAtPiv,
             color=color.new(bullCol, 20), style=line.style_dotted, width=2)
    prevBullBar := currBar
    prevBullOsc := oscAtPiv

if bearDiv
    currBar = bar_index - pivRight
    if not na(prevBearBar)
        line.new(prevBearBar, prevBearOsc, currBar, oscAtPiv,
             color=color.new(bearCol, 20), style=line.style_dotted, width=2)
    prevBearBar := currBar
    prevBearOsc := oscAtPiv

// Hidden connector lines: dashed, reduced opacity
if showHidden and bullHidDiv
    currBar = bar_index - pivRight
    if not na(prevHidBullBar)
        line.new(prevHidBullBar, prevHidBullOsc, currBar, oscAtPiv,
             color=color.new(bullCol, 55), style=line.style_dashed, width=1)
    prevHidBullBar := currBar
    prevHidBullOsc := oscAtPiv

if showHidden and bearHidDiv
    currBar = bar_index - pivRight
    if not na(prevHidBearBar)
        line.new(prevHidBearBar, prevHidBearOsc, currBar, oscAtPiv,
             color=color.new(bearCol, 55), style=line.style_dashed, width=1)
    prevHidBearBar := currBar
    prevHidBearOsc := oscAtPiv

// ─── Oscillator pane plots ───────────────────────────────────────────────────
noneCol = color.new(color.white, 100)

p_ob  = plot(effectiveOB, "OB",  color=color.new(bearCol, 50))
p_os  = plot(effectiveOS, "OS",  color=color.new(bullCol, 50))
p_mid = plot(midLevel, "Mid", color=color.new(color.gray, 70))
p_osc = plot(oscVal, "Oscillator",
     color=color.from_gradient(oscVal, effectiveOS, effectiveOB, bullCol, bearCol),
     linewidth=2)

fill(p_osc, p_mid, effectiveOB, effectiveOS, color.new(bearCol, 85), na)
fill(p_osc, p_mid, effectiveOB, effectiveOS, na, color.new(bullCol, 85))

plotshape(bullDiv ? oscAtPiv : na, offset=-pivRight,
     title="Bull (pane)", style=shape.labelup, location=location.absolute,
     color=bullCol, textcolor=color.white, text="▲", size=size.small)

plotshape(bearDiv ? oscAtPiv : na, offset=-pivRight,
     title="Bear (pane)", style=shape.labeldown, location=location.absolute,
     color=bearCol, textcolor=color.white, text="▼", size=size.small)

_hidDist = (effectiveOB - effectiveOS) * 0.08
plotshape(showHidden and bullHidDiv ? oscAtPiv - _hidDist : na, offset=-pivRight,
     title="Bull hidden (pane)", style=shape.triangleup, location=location.absolute,
     color=color.new(bullCol, 40), size=size.small)

plotshape(showHidden and bearHidDiv ? oscAtPiv + _hidDist : na, offset=-pivRight,
     title="Bear hidden (pane)", style=shape.triangledown, location=location.absolute,
     color=color.new(bearCol, 40), size=size.small)

// ─── Chart overlay shapes ────────────────────────────────────────────────────
plotshape(bullDiv ? low[pivRight] : na, offset=-pivRight,
     title="Bull reversal (chart)", style=shape.labelup, location=location.absolute,
     color=noneCol, textcolor=bullCol, text="▲\nReversal", force_overlay=true)

plotshape(bearDiv ? high[pivRight] : na, offset=-pivRight,
     title="Bear reversal (chart)", style=shape.labeldown, location=location.absolute,
     color=noneCol, textcolor=bearCol, text="Reversal\n▼", force_overlay=true)

plotshape(showHidden and bullHidDiv ? low[pivRight] : na, offset=-pivRight,
     title="Bull continuation (chart)", style=shape.labelup, location=location.absolute,
     color=noneCol, textcolor=color.new(bullCol, 35), text="▲\nCont.", force_overlay=true)

plotshape(showHidden and bearHidDiv ? high[pivRight] : na, offset=-pivRight,
     title="Bear continuation (chart)", style=shape.labeldown, location=location.absolute,
     color=noneCol, textcolor=color.new(bearCol, 35), text="Cont.\n▼", force_overlay=true)

// ─── Debug: all detected pivots ──────────────────────────────────────────────
// Semi-transparent circles on every pivot — bull pivots teal, bear pivots red.
// A circle without a divergence label means a filter blocked the signal.
plotshape(showPivots and foundPL ? oscAtPiv : na, offset=-pivRight,
     title="Debug: Pivot Low (pane)", style=shape.circle, location=location.absolute,
     color=color.new(bullCol, 60), size=size.tiny)
plotshape(showPivots and foundPH ? oscAtPiv : na, offset=-pivRight,
     title="Debug: Pivot High (pane)", style=shape.circle, location=location.absolute,
     color=color.new(bearCol, 60), size=size.tiny)
plotshape(showPivots and foundPL ? low[pivRight] : na, offset=-pivRight,
     title="Debug: Pivot Low (chart)", style=shape.circle, location=location.absolute,
     color=color.new(bullCol, 60), size=size.tiny, force_overlay=true)
plotshape(showPivots and foundPH ? high[pivRight] : na, offset=-pivRight,
     title="Debug: Pivot High (chart)", style=shape.circle, location=location.absolute,
     color=color.new(bearCol, 60), size=size.tiny, force_overlay=true)

// ─── Alerts ──────────────────────────────────────────────────────────────────
// alertcondition: named alerts, require one setup per condition in the Alert dialog
// alert(): all signals through a single "any alert() call" setup on the indicator
_ticker = syminfo.tickerid + " (" + timeframe.period + ")"
if bullDiv
    alert("Bullish Divergence — " + _ticker + " | " + oscType, alert.freq_once_per_bar)
if bearDiv
    alert("Bearish Divergence — " + _ticker + " | " + oscType, alert.freq_once_per_bar)
if bullHidDiv
    alert("Bullish Hidden Divergence — " + _ticker + " | " + oscType, alert.freq_once_per_bar)
if bearHidDiv
    alert("Bearish Hidden Divergence — " + _ticker + " | " + oscType, alert.freq_once_per_bar)
// ─── Strategy inputs (generated) ─────────────────────────────────────────────
g_strat       = "Strategy"
tradeDirInput = input.string("Both", "Trade Direction",
     options=["Both", "Long Only", "Short Only"], group=g_strat,
     tooltip="Filter entries by direction. Useful for asymmetric instruments.")
confirmClose  = input.bool(true,  "Entries on Confirmed Bar Only", group=g_strat,
     tooltip="Only trigger entries on closed bars. Prevents repainting in live trading.")
cooldownBars  = input.int(0,     "Cooldown Bars After Exit", minval=0, group=g_strat,
     tooltip="Block new entries for N bars after a position closes. Set 0 to disable.")
enableBE      = input.bool(false, "Break-Even Stop", group=g_strat,
     tooltip="Move SL to entry price once the trade is N×ATR in profit.")
beATRInput    = input.float(1.0,  "Break-Even Trigger (ATR×)", minval=0.1, step=0.1, group=g_strat,
     tooltip="ATR distance from entry that triggers the break-even move.")

var int _lastExitBar = na
_justClosed = strategy.closedtrades > 0 and strategy.closedtrades.exit_bar_index(0) == bar_index
if _justClosed
    _lastExitBar := bar_index
_inCooldown = cooldownBars > 0 and not na(_lastExitBar) and (bar_index - _lastExitBar) < cooldownBars
_canEntry   = not _inCooldown and (not confirmClose or barstate.isconfirmed)
slBufInput = input.float(0.5, "SL ATR Buffer (×)", minval=0.1, step=0.1, group=g_strat,
     tooltip="ATR distance beyond the divergence pivot for the stop loss.")
tpRRInput  = input.float(2.0, "TP R:R Ratio",      minval=0.5, step=0.5, group=g_strat,
     tooltip="Take profit at this R:R multiple of the SL distance from entry.")

// ─── Strategy execution (generated) ──────────────────────────────────────────
_canLong  = tradeDirInput != "Short Only"
_canShort = tradeDirInput != "Long Only"

var float _sl = na
var float _tp = na

if (bullDiv) and _canLong and _canEntry
    _atr    = ta.atr(14)
    _sl    := low[pivRight] - _atr * slBufInput
    _slDist = math.max(close - _sl, syminfo.mintick)
    _tp    := close + _slDist * tpRRInput
    strategy.entry("Long", strategy.long)

if (bearHidDiv) and _canShort and _canEntry
    _atr    = ta.atr(14)
    _sl    := high[pivRight] + _atr * slBufInput
    _slDist = math.max(_sl - close, syminfo.mintick)
    _tp    := close - _slDist * tpRRInput
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    strategy.exit("Long Exit", "Long", stop=_sl, limit=_tp)
if strategy.position_size < 0
    strategy.exit("Short Exit", "Short", stop=_sl, limit=_tp)

// ─── Break-even management (generated) ────────────────────────────────────────
if enableBE
    _beAtr = ta.atr(14) * beATRInput
    if strategy.position_size > 0 and close >= strategy.position_avg_price + _beAtr
        strategy.exit("Long BE", "Long", stop=strategy.position_avg_price)
    if strategy.position_size < 0 and close <= strategy.position_avg_price - _beAtr
        strategy.exit("Short BE", "Short", stop=strategy.position_avg_price)
