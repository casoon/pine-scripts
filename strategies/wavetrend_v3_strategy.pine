         + ' | SETUP: ok={9} loc={10} rangeLoc={11} swingLoc={12} roomOk={13} volOk={14}'
         + ' | PB: pbOk={15} pbTrend={16} pbLoc={17}',
         str.tostring(bar_index), str.tostring(longContextScoreRR, '#.#'), str.tostring(maxContextScoreRR, '#.#'), str.tostring(_effMinScore, '#.#'), profileMode,
         str.tostring(mtfLongOkRR), str.tostring(structureLongOk), str.tostring(pocReclaimRecent), str.tostring(bullVolSpike),
         str.tostring(longRangeReversalSetupOk), str.tostring(longLocationOk), str.tostring(longRangeLocationOk), str.tostring(longSwingLocationOk), str.tostring(longRoomOk), str.tostring(longSetupVolumeOkRR),
         str.tostring(longPullbackSetupOk), str.tostring(longPullbackTrendOk), str.tostring(longPullbackLocationOk)) + _regimeStr)

if debugMode and pbTriggerLong and not longPBSignal
    log.info(str.format('WT3 LONG BLOCKED | family=pullback_continuation | type=pullback_continuation | bar={0} | ctxScore={1}/{2} min={3} | profile={4}'
         + ' | mtfOk={5} STRUCT={6} POC={7} VOL={8}'
         + ' | SETUP: ok={9} loc={10} rangeLoc={11} swingLoc={12} roomOk={13} volOk={14}'
         + ' | PB: pbOk={15} pbTrend={16} pbLoc={17} impulseATR={18}',
         str.tostring(bar_index), str.tostring(longContextScorePB, '#.#'), str.tostring(maxContextScorePB, '#.#'), str.tostring(_effMinScore, '#.#'), profileMode,
         str.tostring(mtfLongOkPB), str.tostring(structureLongOk), str.tostring(pocReclaimRecent), str.tostring(bullVolSpike),
         str.tostring(longPullbackSetupOk), str.tostring(longLocationOk), str.tostring(longRangeLocationOk), str.tostring(longSwingLocationOk), str.tostring(longRoomOk), str.tostring(longSetupVolumeOkPB),
         str.tostring(longPullbackSetupOk), str.tostring(longPullbackTrendOk), str.tostring(longPullbackLocationOk), str.tostring(longImpulseATR, '#.#')) + _regimeStr)

// SHORT DECISION
if debugMode and shortRRSignal
    log.info(str.format('WT3 SHORT DECISION | family=range_reversal | type=range_reversal | bar={0} | ctxScore={1}/{2} | profile={3}'
         + ' | WT: osc={4} sig={5} obRecent={6} barsSinceOB={7}'
         + ' | STRUCT: lh={8} hh={9} ll={10} hl={11} fresh={12} STRUCT={13}'
         + ' | VOLUME: ratio={14} bearSpike={15} VOL={16}'
         + ' | POC: px={17} reject={18} POC={19}'
         + ' | HTF: tf={20} bear={21} mtfOk={22} htf={23} anchor={24}'
         + ' | SETUP: ok={25} loc={26} rangeLoc={27} swingLoc={28} roomOk={29} volOk={30}'
         + ' | PB: pbOk={31} pbTrend={32} pbLoc={33} impulseATR={34}'
         + ' | TARGET: tp={35} sl={36}',
         str.tostring(bar_index), str.tostring(shortContextScoreRR, '#.#'), str.tostring(maxContextScoreRR, '#.#'), profileMode,
         str.tostring(wtOsc, '#.##'), str.tostring(wtSig, '#.##'), str.tostring(obRecent), str.tostring(barsSinceOB),
         str.tostring(lhDetected), str.tostring(hhDetected), str.tostring(llDetected), str.tostring(hlDetected), str.tostring(structureFresh), str.tostring(structureShortOk),
         str.tostring(_volRatio, '#.##'), str.tostring(bearVolSpike), str.tostring(bearVolSpike),
         str.tostring(pocPrice, format.mintick), str.tostring(pocRejectRecent), str.tostring(pocRejectRecent),
         _htfTF, str.tostring(htfBear), str.tostring(mtfShortOkRR), str.tostring(shortHtfScoreRR, '#.#'), str.tostring(shortAnchorScoreRR, '#.#'),
         str.tostring(shortRangeReversalSetupOk), str.tostring(shortLocationOk), str.tostring(shortRangeLocationOk), str.tostring(shortSwingLocationOk), str.tostring(shortRoomOk), str.tostring(shortSetupVolumeOkRR),
         str.tostring(shortPullbackSetupOk), str.tostring(shortPullbackTrendOk), str.tostring(shortPullbackLocationOk), str.tostring(shortImpulseATR, '#.#'),
         str.tostring(shortTakeProfit, format.mintick), str.tostring(shortStop, format.mintick)) + _regimeStr)

if debugMode and shortPBSignal and not shortRRSignal
    log.info(str.format('WT3 SHORT DECISION | family=pullback_continuation | type=pullback_continuation | bar={0} | ctxScore={1}/{2} | profile={3}'
         + ' | WT: osc={4} sig={5}'
         + ' | STRUCT: lh={6} hh={7} ll={8} hl={9} fresh={10} STRUCT={11}'
         + ' | VOLUME: ratio={12} bearSpike={13} VOL={14}'
         + ' | POC: px={15} reject={16} POC={17}'
         + ' | HTF: tf={18} bear={19} mtfOk={20} htf={21} anchor={22}'
         + ' | SETUP: ok={23} loc={24} rangeLoc={25} swingLoc={26} roomOk={27} volOk={28}'
         + ' | PB: pbOk={29} pbTrend={30} pbLoc={31} impulseATR={32}'
         + ' | TARGET: tp={33} sl={34}',
         str.tostring(bar_index), str.tostring(shortContextScorePB, '#.#'), str.tostring(maxContextScorePB, '#.#'), profileMode,
         str.tostring(wtOsc, '#.##'), str.tostring(wtSig, '#.##'),
         str.tostring(lhDetected), str.tostring(hhDetected), str.tostring(llDetected), str.tostring(hlDetected), str.tostring(structureFresh), str.tostring(structureShortOk),
         str.tostring(_volRatio, '#.##'), str.tostring(bearVolSpike), str.tostring(bearVolSpike),
         str.tostring(pocPrice, format.mintick), str.tostring(pocRejectRecent), str.tostring(pocRejectRecent),
         _htfTF, str.tostring(htfBear), str.tostring(mtfShortOkPB), str.tostring(shortHtfScorePB, '#.#'), str.tostring(shortAnchorScorePB, '#.#'),
         str.tostring(shortPullbackSetupOk), str.tostring(shortLocationOk), str.tostring(shortRangeLocationOk), str.tostring(shortSwingLocationOk), str.tostring(shortRoomOk), str.tostring(shortSetupVolumeOkPB),
         str.tostring(shortPullbackSetupOk), str.tostring(shortPullbackTrendOk), str.tostring(shortPullbackLocationOk), str.tostring(shortImpulseATR, '#.#'),
         str.tostring(shortTakeProfit, format.mintick), str.tostring(shortStop, format.mintick)) + _regimeStr)

// SHORT BLOCKED
if debugMode and rrTriggerShort and not shortRRSignal
    log.info(str.format('WT3 SHORT BLOCKED | family=range_reversal | type=range_reversal | bar={0} | ctxScore={1}/{2} min={3} | profile={4}'
         + ' | mtfOk={5} STRUCT={6} POC={7} VOL={8}'
         + ' | SETUP: ok={9} loc={10} rangeLoc={11} swingLoc={12} roomOk={13} volOk={14}'
         + ' | PB: pbOk={15} pbTrend={16} pbLoc={17}',
         str.tostring(bar_index), str.tostring(shortContextScoreRR, '#.#'), str.tostring(maxContextScoreRR, '#.#'), str.tostring(_effMinScore, '#.#'), profileMode,
         str.tostring(mtfShortOkRR), str.tostring(structureShortOk), str.tostring(pocRejectRecent), str.tostring(bearVolSpike),
         str.tostring(shortRangeReversalSetupOk), str.tostring(shortLocationOk), str.tostring(shortRangeLocationOk), str.tostring(shortSwingLocationOk), str.tostring(shortRoomOk), str.tostring(shortSetupVolumeOkRR),
         str.tostring(shortPullbackSetupOk), str.tostring(shortPullbackTrendOk), str.tostring(shortPullbackLocationOk)) + _regimeStr)

if debugMode and pbTriggerShort and not shortPBSignal
    log.info(str.format('WT3 SHORT BLOCKED | family=pullback_continuation | type=pullback_continuation | bar={0} | ctxScore={1}/{2} min={3} | profile={4}'
         + ' | mtfOk={5} STRUCT={6} POC={7} VOL={8}'
         + ' | SETUP: ok={9} loc={10} rangeLoc={11} swingLoc={12} roomOk={13} volOk={14}'
         + ' | PB: pbOk={15} pbTrend={16} pbLoc={17} impulseATR={18}',
         str.tostring(bar_index), str.tostring(shortContextScorePB, '#.#'), str.tostring(maxContextScorePB, '#.#'), str.tostring(_effMinScore, '#.#'), profileMode,
         str.tostring(mtfShortOkPB), str.tostring(structureShortOk), str.tostring(pocRejectRecent), str.tostring(bearVolSpike),
         str.tostring(shortPullbackSetupOk), str.tostring(shortLocationOk), str.tostring(shortRangeLocationOk), str.tostring(shortSwingLocationOk), str.tostring(shortRoomOk), str.tostring(shortSetupVolumeOkPB),
         str.tostring(shortPullbackSetupOk), str.tostring(shortPullbackTrendOk), str.tostring(shortPullbackLocationOk), str.tostring(shortImpulseATR, '#.#')) + _regimeStr)
// ─── Strategy inputs (generated) ─────────────────────────────────────────────
g_strat       = "Strategy"
tradeDirInput = input.string("Both", "Trade Direction",
     options=["Both", "Long Only", "Short Only"], group=g_strat,
     tooltip="Filter entries by direction. Useful for asymmetric instruments.")
confirmClose  = input.bool(true,  "Entries on Confirmed Bar Only", group=g_strat,
     tooltip="Only trigger entries on closed bars. Prevents repainting in live trading.")
cooldownBars  = input.int(0,     "Cooldown Bars After Exit", minval=0, group=g_strat,
     tooltip="Block new entries for N bars after a position closes. Set 0 to disable.")
enableBE      = input.bool(false, "Break-Even Stop", group=g_strat,
     tooltip="Move SL to entry price once the trade is N×ATR in profit.")
beATRInput    = input.float(1.0,  "Break-Even Trigger (ATR×)", minval=0.1, step=0.1, group=g_strat,
     tooltip="ATR distance from entry that triggers the break-even move.")

var int _lastExitBar = na
_justClosed = strategy.closedtrades > 0 and strategy.closedtrades.exit_bar_index(strategy.closedtrades - 1) == bar_index
if _justClosed
    _lastExitBar := bar_index
_inCooldown = cooldownBars > 0 and not na(_lastExitBar) and (bar_index - _lastExitBar) < cooldownBars
_canEntry   = not _inCooldown and (not confirmClose or barstate.isconfirmed)

// ─── Strategy execution (generated, directional fixed SL/TP) ─────────────────
_canLong  = tradeDirInput != "Short Only"
_canShort = tradeDirInput != "Long Only"

var float _longSL = na
var float _longTP = na
var float _shortSL = na
var float _shortTP = na

if (longSignal) and _canLong and _canEntry
    _longSL := longStop
    _longTP := longTakeProfit
    strategy.entry("Long", strategy.long)

if (shortSignal) and _canShort and _canEntry
    _shortSL := shortStop
    _shortTP := shortTakeProfit
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    strategy.exit("Long Exit", "Long", stop=_longSL, limit=_longTP)
if strategy.position_size < 0
    strategy.exit("Short Exit", "Short", stop=_shortSL, limit=_shortTP)

// ─── Indicator-driven exits (close on long_exit / short_exit signal) ─────────
if strategy.position_size > 0 and (longExitSignal)
    strategy.close("Long",  comment="Indicator Exit")
if strategy.position_size < 0 and (shortExitSignal)
    strategy.close("Short", comment="Indicator Exit")

// ─── Break-even management (generated) ────────────────────────────────────────
if enableBE
    _beAtr = ta.atr(14) * beATRInput
    if strategy.position_size > 0 and close >= strategy.position_avg_price + _beAtr
        strategy.exit("Long BE", "Long", stop=strategy.position_avg_price)
    if strategy.position_size < 0 and close <= strategy.position_avg_price - _beAtr
        strategy.exit("Short BE", "Short", stop=strategy.position_avg_price)
