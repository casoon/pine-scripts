         str.tostring(wtOsc, '#.##'), str.tostring(wtSig, '#.##'),
         str.tostring(hlDetected), str.tostring(llDetected), str.tostring(hhDetected), str.tostring(lhDetected), str.tostring(structureFresh), str.tostring(structureLongOk),
         str.tostring(_volRatio, '#.##'), str.tostring(bullVolSpike), str.tostring(bullVolSpike),
         str.tostring(pocPrice, format.mintick), str.tostring(pocReclaimRecent), str.tostring(pocReclaimRecent),
         _htfTF, str.tostring(htfBull), str.tostring(mtfLongOkPB), str.tostring(longHtfScorePB, '#.#'), str.tostring(longAnchorScorePB, '#.#'),
         str.tostring(longPullbackSetupOk), str.tostring(longLocationOk), str.tostring(longRangeLocationOk), str.tostring(longSwingLocationOk), str.tostring(longRoomOk), str.tostring(longSetupVolumeOkPB),
         str.tostring(longPullbackSetupOk), str.tostring(longPullbackTrendOk), str.tostring(longPullbackLocationOk), str.tostring(longImpulseATR, '#.#'),
         str.tostring(longTakeProfit, format.mintick), str.tostring(longStop, format.mintick)) + _regimeStr)

// LONG BLOCKED — one row per family trigger that didn't pass
if debugMode and rrTriggerLong and not longRRSignal
    log.info(str.format('WT3 LONG BLOCKED | family=range_reversal | type=range_reversal | bar={0} | ctxScore={1}/{2} min={3} | profile={4}'
