// ===========================================================================
// MODULE: modules/types.pine
// ===========================================================================

// ============================================================================
// TYPES - Data Structures
// ============================================================================

// === Pivot Point ===
type Pivot
    int barIndex
    float price
    bool isHigh  // true=high, false=low

// === ZigZag Leg ===
type ZigZagLeg
    int startIdx
    float startPrice
    int endIdx
    float endPrice
    bool isUp
    float moveAbs
    float movePct
    bool isValid

// === Envelope State ===
type EnvelopeState
    float kcUp
    float kcDn
    float kcBasis
    float dcUp
    float dcDn
    float bbUp
    float bbDn
    float bbBasis
    float squeeze        // <1=compressed, >1=expanded
    bool squeezeActive

// === Corridor Signal ===
type CorridorSignal
    bool touchUpKC
    bool touchDnKC
    bool dcBreakUp       // Re-entry from above
    bool dcBreakDown     // Re-entry from below
    bool squeezeBreakUp
    bool squeezeBreakDn
    bool interesting     // Combined signal
    int activeDir        // 1=up, -1=down, 0=neutral
    float depthKC        // 0-1, depth within KC range


// ===========================================================================
// MODULE: modules/helpers.pine
// ===========================================================================

// ============================================================================
// HELPERS - Utility Functions
// ============================================================================

// === Safe null handling ===
nzf(float x, float repl=0.0) =>
    na(x) ? repl : x

// === Percentage calculation ===
pct(float a, float b) =>
    b != 0.0 ? (a/b)*100.0 : 0.0

// === Absolute value ===
abs(float x) =>
    x < 0 ? -x : x

// === Distance in ticks ===
tickDistance(float a, float b) =>
    math.abs(a - b) / syminfo.mintick

// === Direction detection ===
getDirection(float a, float b) =>
    b > a ? 1 : b < a ? -1 : 0

// === Normalize value to 0-1 range ===
normalize(float val, float min, float max) =>
    float span = max - min
    span > 0 ? (val - min) / span : 0.5

// ============================================================================
// TECHNICAL INDICATORS - Centralized Calculations (Refactoring Phase 1)
// ============================================================================

// === EMA (Exponential Moving Average) ===
getEMA(simple int length) =>
    ta.ema(close, length)

// === EMA with HTF (Higher Timeframe) ===
getEMA_HTF(simple int length, simple string timeframe) =>
    request.security(syminfo.tickerid, timeframe, ta.ema(close, length), 
                     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// === ATR (Average True Range) ===
getATR(simple int length, simple float multiplier = 1.0) =>
    ta.atr(length) * multiplier

// === ATR for a specific leg (range of bars) ===
calcLegATR(int startIdx, int endIdx) =>
    float atrSum = 0.0
    int nBars = math.max(1, endIdx - startIdx + 1)
    int lookback = bar_index - startIdx
    for i = 0 to nBars - 1
        atrSum += ta.tr(true)[lookback - i]
    atrSum / nBars

// === RSI (Relative Strength Index) ===
getRSI(simple int length) =>
    ta.rsi(close, length)

// === ADX (Average Directional Index) ===
getADX(simple int length) =>
    [_, _, adx] = ta.dmi(length, length)
    adx

// === Generic HTF Value Wrapper ===
getHTFValue(series float value, simple string timeframe) =>
    request.security(syminfo.tickerid, timeframe, value, 
                     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)


// ===========================================================================
// MODULE: modules/pivot_detection.pine
// ===========================================================================

// ============================================================================
// PIVOT DETECTION - Confirmed Pivot Highs/Lows
// ============================================================================

// === Pivot Detection ===
// Returns confirmed pivot high/low (no repainting after confirmation)
detectPivots(int pivotLen) =>
    float pivotH = ta.pivothigh(high, pivotLen, pivotLen)
    float pivotL = ta.pivotlow (low,  pivotLen, pivotLen)
    
    bool isPH = not na(pivotH)
    bool isPL = not na(pivotL)
    
    // Return: [isPivotHigh, isPivotLow, pivotPrice, pivotIndex]
    [isPH, isPL, isPH ? pivotH : isPL ? pivotL : na, bar_index - pivotLen]

// === Pivot Detection (Flexible L/R) - Refactored Phase 3 ===
// Allows different left/right bars for asymmetric pivot detection
detectPivotsFlexible(int leftBars, int rightBars) =>
    float pivotH = ta.pivothigh(high, leftBars, rightBars)
    float pivotL = ta.pivotlow(low, leftBars, rightBars)
    
    bool isPH = not na(pivotH)
    bool isPL = not na(pivotL)
    
    // Return: [isPivotHigh, isPivotLow, pivotPrice, pivotIndex]
    [isPH, isPL, isPH ? pivotH : isPL ? pivotL : na, bar_index - rightBars]

// === Pivot Storage ===
// Maintains arrays of confirmed pivots with optional merge tolerance
storePivot(array<int> arrIdx, array<float> arrPx, int _idx, float _px, int mergeTicks) =>
    // Merge nearby pivots if tolerance set
    if mergeTicks > 0 and array.size(arrIdx) > 0
        float lastPx = array.get(arrPx, array.size(arrPx)-1)
        float tick   = syminfo.mintick
        
        if math.abs(_px - lastPx) <= mergeTicks * tick
            // Replace last pivot with current (merge)
            array.set(arrIdx, array.size(arrIdx)-1, _idx)
            array.set(arrPx,  array.size(arrPx)-1, _px)
            true  // merged
        else
            // Add new pivot
            array.push(arrIdx, _idx)
            array.push(arrPx,  _px)
            false  // new pivot
    else
        // Add new pivot
        array.push(arrIdx, _idx)
        array.push(arrPx,  _px)
        false  // new pivot

// === Get Last Pivot ===
getLastPivot(array<int> arrIdx, array<float> arrPx) =>
    int sz = array.size(arrIdx)
    if sz > 0
        [array.get(arrIdx, sz-1), array.get(arrPx, sz-1)]
    else
        [int(na), float(na)]

// === Get Pivot Count ===
getPivotCount(array<int> arrIdx) =>
    array.size(arrIdx)


// ===========================================================================
// MODULE: modules/zigzag_engine.pine
// ===========================================================================

// ============================================================================
// ZIGZAG ENGINE - Leg Validation & Drawing
// ============================================================================

// === Leg Validation ===
// Validates if a leg meets threshold criteria based on selected mode
isLegValid(string mode, float startPx, float endPx, float pctThreshold, float atrK, int atrLen, float devK, int devLen) =>
    float moveAbs = math.abs(endPx - startPx)
    float movePct = startPx != 0.0 ? (moveAbs / startPx) * 100.0 : 0.0
    
    // Mode-specific validation
    bool validPct = movePct >= pctThreshold
    bool validAtr = moveAbs >= atrK * ta.atr(atrLen)
    float dev     = ta.stdev(close, devLen)
    bool validDev = dev > 0 ? moveAbs >= devK * dev : false
    
    mode == "PCT" ? validPct : mode == "ATR" ? validAtr : validDev

// === Check Minimum Bar Length ===
hasMinBars(int startIdx, int endIdx, int minBars) =>
    (endIdx - startIdx) >= minBars

// Note: Drawing functions moved to global scope in calculations.pine

// === Calculate Leg Metrics ===
getLegMetrics(float startPx, float endPx) =>
    float moveAbs = math.abs(endPx - startPx)
    float movePct = startPx != 0.0 ? (moveAbs / startPx) * 100.0 : 0.0
    bool isUp = endPx > startPx
    [moveAbs, movePct, isUp]

// === Active Leg Direction ===
// Determines direction of current (unconfirmed) leg
getActiveLegDirection(array<int> arrIdx, array<float> arrPx) =>
    int sz = array.size(arrIdx)
    
    if sz >= 2
        // Get last two confirmed pivots
        float lastPx = array.get(arrPx, sz-1)
        float prevPx = array.get(arrPx, sz-2)
        
        // Direction of last confirmed leg
        int lastLegDir = lastPx > prevPx ? 1 : -1
        
        // Current price vs last pivot
        int currentDir = close > lastPx ? 1 : close < lastPx ? -1 : 0
        
        // If current direction differs from last leg, we're in new direction
        currentDir != 0 ? currentDir : lastLegDir
    else
        0  // neutral

// Note: renderZigZag moved to global scope in calculations.pine to comply with Pine Script v6 restrictions


// ===========================================================================
// MODULE: modules/dot_engine.pine
// ===========================================================================

// ============================================================================
// DOT ENGINE - 3-Tier Quality Signals (Watch/Confirm/HighConf)
// ============================================================================
// Unified dot system with quality filtering

// === Calculate Leg Quality (R²) ===
calcLegQuality(int r2LenMin) =>
    // Auto-detect leg length or use minimum
    int lenLeg = math.max(r2LenMin, 5)
    float lin = ta.linreg(close, lenLeg, 0)
    float resid = close - lin
    float varResid = ta.variance(resid, lenLeg)
    float varClose = ta.variance(close, lenLeg)
    float r2 = varClose > 0 ? 1.0 - (varResid / varClose) : 0.0
    math.max(0.0, math.min(1.0, r2))

// === Calculate Edge Proximity (0-1, higher = closer to KC edge) ===
calcEdgeProximity(float kcUp, float kcDn) =>
    float distKC = math.min(math.abs(close - kcUp), math.abs(close - kcDn)) / close
    1.0 - math.max(0.0, math.min(1.0, distKC / 0.006))  // 0.6% reference for NatGas

// === Calculate Quality Score ===
calcQualityScore(float r2, float edgeProx, bool biasOK) =>
    (r2 * 0.5 + edgeProx * 0.5) * (biasOK ? 1.0 : 0.5)

// === Detect Signal Tiers ===
detectSignalTiers(bool inZone, bool sqRelUp, bool sqRelDn, bool dirUpLeg, bool dirDnLeg, float hiConfThresh, float qualityScore) =>
    // Watch: 2-of-3 zone + squeeze release in direction
    bool watchLong = inZone and sqRelUp and dirUpLeg
    bool watchShort = inZone and sqRelDn and dirDnLeg
    
    // Confirm: Watch + candle confirmation
    bool confirmLong = watchLong and close > open
    bool confirmShort = watchShort and close < open
    
    // High-Confidence: Confirm + quality threshold
    bool hiLong = confirmLong and qualityScore >= hiConfThresh
    bool hiShort = confirmShort and qualityScore >= hiConfThresh
    
    [watchLong, watchShort, confirmLong, confirmShort, hiLong, hiShort]

// === Debounce Logic ===
// Note: This function is not used - spacing logic is inline in calculations.pine


// ===========================================================================
// MODULE: modules/keltner_channel.pine
// ===========================================================================

// ============================================================================
// KELTNER CHANNEL - Adaptive Volatility Envelope
// ============================================================================

// === Calculate Keltner Channel ===
calcKeltner(int emaLen, int atrLen, float mult) =>
    float basis = ta.ema(close, emaLen)
    float atr   = ta.atr(atrLen)
    float upper = basis + mult * atr
    float lower = basis - mult * atr
    
    [upper, lower, basis, atr]

// === Check KC Touch ===
checkKCTouch(float upper, float lower) =>
    bool touchUp = high >= upper
    bool touchDn = low <= lower
    
    [touchUp, touchDn]

// === Calculate Depth within KC ===
// Returns 0-1 value indicating how deep price is within the channel
getKCDepth(float basis, float upper, float lower) =>
    float span = math.max(1e-6, upper - lower)
    float depth = math.abs(close - basis) / span
    depth

// === KC Breakout Detection ===
checkKCBreakout(float upper, float lower) =>
    bool breakUp = close > upper
    bool breakDn = close < lower
    
    [breakUp, breakDn]


// ===========================================================================
// MODULE: modules/donchian_channel.pine
// ===========================================================================

// ============================================================================
// DONCHIAN CHANNEL - Objective Range Detection
// ============================================================================

// === Calculate Donchian Channel ===
calcDonchian(int length) =>
    float upper = ta.highest(high, length)
    float lower = ta.lowest(low, length)
    float mid   = (upper + lower) / 2.0
    
    [upper, lower, mid]

// === Check DC Re-Entry ===
// Detects when price breaks out and then re-enters the channel
checkDCReentry(int length, float upper, float lower) =>
    // Re-entry from above: was above upper[1], now below upper
    bool reentryDown = close[1] > upper[1] and close < upper
    
    // Re-entry from below: was below lower[1], now above lower
    bool reentryUp = close[1] < lower[1] and close > lower
    
    [reentryUp, reentryDown]

// === DC Breakout Detection ===
checkDCBreakout(float upper, float lower) =>
    bool breakUp = close > upper
    bool breakDn = close < lower
    
    [breakUp, breakDn]

// === DC Width (Volatility proxy) ===
getDCWidth(float upper, float lower) =>
    upper - lower


// ===========================================================================
// MODULE: modules/bbkc_squeeze.pine
// ===========================================================================

// ============================================================================
// BB/KC SQUEEZE - Compression/Expansion Detection
// ============================================================================

// === REFACTORED: Simplified Bollinger Bands (Phase 2) ===
// Short-form helper for inline usage
calcBB(simple int length, simple float mult) =>
    float mid = ta.sma(close, length)
    float std = ta.stdev(close, length)
    [mid + std * mult, mid - std * mult, mid, std]

// === REFACTORED: Simplified Keltner Channels (Phase 2) ===
// Short-form helper for inline usage
calcKC(simple int emaLen, simple int atrLen, simple float mult) =>
    float basis = getEMA(emaLen)
    float atrVal = getATR(atrLen)
    [basis + atrVal * mult, basis - atrVal * mult, basis, atrVal]

// === Calculate Bollinger Bands (Legacy - Full Return) ===
calcBollinger(int length, float mult) =>
    float basis = ta.sma(close, length)
    float dev   = ta.stdev(close, length)
    float upper = basis + mult * dev
    float lower = basis - mult * dev
    
    [upper, lower, basis, dev]

// === Calculate Squeeze Ratio ===
// <1 = Squeeze (compression), >1 = Expansion
calcSqueezeRatio(float bbDev, float kcMult, float atr) =>
    float bbWidth = 2.0 * bbDev
    float kcWidth = 2.0 * kcMult * atr
    
    kcWidth > 0 ? bbWidth / kcWidth : 1.0

// === Detect Squeeze State ===
detectSqueeze(float squeezeRatio) =>
    bool isSqueezed = squeezeRatio < 1.0
    bool isExpanded = squeezeRatio >= 1.0
    
    [isSqueezed, isExpanded]

// === Detect Squeeze Break ===
// Detects transition from squeeze to expansion with directional bias
detectSqueezeBreak(float squeezeRatio, float kcUp, float kcDn) =>
    bool wasSqueezeRatio = squeezeRatio[1] < 1.0
    bool isExpandedNow = squeezeRatio >= 1.0
    
    bool breakUp = wasSqueezeRatio and isExpandedNow and close > kcUp
    bool breakDn = wasSqueezeRatio and isExpandedNow and close < kcDn
    
    [breakUp, breakDn]

// === Get Squeeze History ===
// Checks if squeeze was active in recent bars
wasRecentlySqueezed(float squeezeRatio, int lookback) =>
    float minSqueeze = ta.lowest(squeezeRatio, lookback)
    minSqueeze < 1.0

// === Squeeze Intensity ===
// 0-1 scale, where 0=very tight, 1=very expanded
getSqueezeIntensity(float squeezeRatio) =>
    // Normalize: 0.5 = squeeze, 1.5 = expansion threshold
    // Return 0-1 where lower = tighter
    squeezeRatio < 0.5 ? 0.0 : squeezeRatio > 1.5 ? 1.0 : (squeezeRatio - 0.5)


// ===========================================================================
// MODULE: modules/swf_engine.pine
// ===========================================================================

// ============================================================================
// SWF ENGINE - Sliding Window Flow (Fair Value Window + State Machine)
// ============================================================================
// Verschiebbares Kursfenster mit adaptiver Volatilität und Zustandsautomat:
// Expansion → Pullback → Continuation/Reversal

// === Calculate Fair Value Center ===
calcFairValueCenter(simple string centerMode, simple int emaLen, bool zzReversed) =>
    float emaC = getEMA(emaLen)  // Refactored: Use centralized helper
    float vwapC = ta.vwap(close)
    
    // Anchored VWAP (reset bei ZigZag-Reversal)
    var float cumPV = 0.0
    var float cumV = 0.0
    var float basePV = na
    var float baseV = na
    
    cumPV += close * volume
    cumV += volume
    
    // Bei ZigZag-Reversal: Basis neu setzen
    if zzReversed
        basePV := cumPV
        baseV := cumV
    
    // Berechne AVWAP seit letztem Reset
    float avwapC = na(basePV) or na(baseV) or (cumV - baseV) <= 0 
      ? vwapC 
      : (cumPV - basePV) / (cumV - baseV)
    
    // Wähle Center je nach Modus
    float C = centerMode == "EMA" ? emaC : centerMode == "VWAP" ? vwapC : avwapC
    C

// === Calculate Adaptive Window Width ===
calcWindowWidth(simple int atrLen, simple float atrK, simple int bbLen, simple float bbK) =>
    // ATR Width (Refactored Phase 1: Use centralized helper)
    float atrW = getATR(atrLen, atrK)
    
    // BB Width (Refactored Phase 2: Use calcBB helper)
    [bbU, bbL, _, _] = calcBB(bbLen, bbK)
    float bbW = (bbU - bbL) / 2.0
    
    // Hybrid: nimm das Maximum (robuster)
    float W = math.max(atrW, bbW)
    W := W == 0 ? nz(W[1], 1e-6) : W  // Verhindere Division durch Null
    W

// === Calculate Z-Score ===
calcZ(float C, float W) =>
    // Standardisierte Entfernung (Z-Score-artig)
    (close - C) / W

// === Calculate Z-Slope ===
calcDZ(float z) =>
    z - nz(z[1], z)

// === Calculate Energy (Momentum + Volume) ===
calcEnergy(float z, bool useADX, simple int adxLen, bool useVol, simple int obvLen) =>
    // ADX Boost (Refactored: Use centralized helper)
    float adx = getADX(adxLen)
    float adxBoost = useADX ? (adx / 50.0) : 1.0
    
    // OBV Slope Boost (using built-in ta.obv for proper initialization)
    float obvVal = ta.obv
    float obvSlope = ta.linreg(obvVal, obvLen, 0) - ta.linreg(obvVal, obvLen, 1)
    float obvNorm = math.max(-1.0, math.min(1.0, obvSlope / 1e9))
    float volBoost = useVol ? (1.0 + obvNorm * 0.25) : 1.0
    
    // Energie: |z| * Boost
    float E = math.abs(z) * adxBoost * volBoost
    E

// === Get HTF EMA 20 (Refactored: Use centralized helpers) ===
getHTFEma20(bool useHTF, simple string tfHTF) =>
    useHTF ? getEMA_HTF(20, tfHTF) : getEMA(20)

// === Get HTF EMA 50 (Refactored: Use centralized helpers) ===
getHTFEma50(bool useHTF, simple string tfHTF) =>
    useHTF ? getEMA_HTF(50, tfHTF) : getEMA(50)

// === Update SWF State (Expansion → Pullback → Continuation/Reversal) ===
updateSWFState(string prevState, float z, float dz, float C, float W, 
                       simple float z1, simple float z2, simple float hys,
                       bool biasUp, bool biasDn) =>
    
    // ── Expansion (starke Überdehnung) ──
    bool expUp = z >= (z2 + (prevState == "PullbackUp" ? hys : 0.0)) and dz >= 0
    bool expDn = z <= -(z2 + (prevState == "PullbackDn" ? hys : 0.0)) and dz <= 0
    
    // ── Pullback Watch (Rücklauf zur Mitte) ──
    bool pbUp = (prevState == "ExpUp" or prevState == "ContUp") and z <= z1
    bool pbDn = (prevState == "ExpDn" or prevState == "ContDn") and z >= -z1
    
    // ── Continuation (Pullback hält am Fensterrand, HTF bestätigt) ──
    bool contUp = (prevState == "PullbackUp" or pbUp) and close >= C + 0.5 * W and biasUp
    bool contDn = (prevState == "PullbackDn" or pbDn) and close <= C - 0.5 * W and biasDn
    
    // ── Reversal (Durchbruch durch Mitte + HTF-Flip) ──
    bool crossUp = ta.cross(close, C)
    bool crossDn = ta.cross(C, close)
    bool revUp = (prevState == "ExpDn" or prevState == "PullbackDn" or prevState == "ContDn") and crossUp and biasUp
    bool revDn = (prevState == "ExpUp" or prevState == "PullbackUp" or prevState == "ContUp") and crossDn and biasDn
    
    // ── State Update (Order matters!) ──
    string newState = prevState
    if expUp
        newState := "ExpUp"
    else if expDn
        newState := "ExpDn"
    else if revUp
        newState := "RevUp"
    else if revDn
        newState := "RevDn"
    else if contUp
        newState := "ContUp"
    else if contDn
        newState := "ContDn"
    else if pbUp
        newState := "PullbackUp"
    else if pbDn
        newState := "PullbackDn"
    
    // Return state + signals
    [newState, expUp, expDn, pbUp, pbDn, contUp, contDn, revUp, revDn]



// ===========================================================================
// MODULE: modules/corridor_logic.pine
// ===========================================================================

// ============================================================================
// CORRIDOR LOGIC - Quality Zone Detection (2-of-3 Criteria)
// ============================================================================

// === 2-of-3 Quality Zone Detection ===
// Reduces false signals by requiring multiple confirmations
// Criteria: 1) KC touch, 2) Donchian touch, 3) Squeeze release in direction

detectQualityZones(bool useKC, bool touchUpKC, bool touchDnKC, bool useDC, bool dcBreakUp, bool dcBreakDown, bool useBBKC, bool squeezeBreakUp, bool squeezeBreakDn, float ema20) =>
    // Criteria 1: KC outer band touch
    bool atKC_up = useKC and touchUpKC
    bool atKC_dn = useKC and touchDnKC
    
    // Criteria 2: Donchian edge touch
    bool atDon_up = useDC and dcBreakUp
    bool atDon_dn = useDC and dcBreakDown
    
    // Criteria 3: Squeeze release in leg direction
    bool sqRelUp = useBBKC and squeezeBreakUp and close > ema20
    bool sqRelDn = useBBKC and squeezeBreakDn and close < ema20
    
    // Count criteria for long zones (need 2 of 3)
    int countLong = 0
    countLong += atKC_up ? 1 : 0
    countLong += atDon_up ? 1 : 0
    countLong += sqRelUp ? 1 : 0
    
    // Count criteria for short zones (need 2 of 3)
    int countShort = 0
    countShort += atKC_dn ? 1 : 0
    countShort += atDon_dn ? 1 : 0
    countShort += sqRelDn ? 1 : 0
    
    bool zoneLong = countLong >= 2
    bool zoneShort = countShort >= 2
    
    [zoneLong, zoneShort, countLong, countShort]

// === Legacy: Combined Interesting Zone Detection (kept for compatibility) ===
detectInterestingZone(int activeDir, bool useKC, bool touchUpKC, bool touchDnKC, bool useDC, bool dcBreakUp, bool dcBreakDown, bool useBBKC, bool squeezeBreakUp, bool squeezeBreakDn) =>
    bool isUpLeg = activeDir == 1
    bool isDnLeg = activeDir == -1
    
    bool interestingUp = (useKC and touchUpKC) or (useDC and dcBreakUp) or (useBBKC and squeezeBreakUp)
    bool interestingDn = (useKC and touchDnKC) or (useDC and dcBreakDown) or (useBBKC and squeezeBreakDn)
    
    bool interesting = (isUpLeg and interestingUp) or (isDnLeg and interestingDn)
    
    interesting

// === Build Signal Description ===
getSignalText(bool touchUpKC, bool touchDnKC, bool dcBreakUp, bool dcBreakDown, bool squeezeBreakUp, bool squeezeBreakDn) =>
    string signals = ""
    
    if touchUpKC
        signals += "KC↑ "
    if touchDnKC
        signals += "KC↓ "
    if dcBreakUp
        signals += "DC↘ "
    if dcBreakDown
        signals += "DC↗ "
    if squeezeBreakUp
        signals += "SQ↑ "
    if squeezeBreakDn
        signals += "SQ↓ "
    
    signals != "" ? signals : "-"


