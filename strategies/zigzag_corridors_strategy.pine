// ===========================================================================
// MODULE: modules/leg_table.pine
// ===========================================================================

// ============================================================================
// LEG TABLE - Live Information Display
// ============================================================================

// === Create & Update Leg Info Table ===
updateLegTable(bool showTable, int activeDir, float depthKC, string signalText, bool interesting) =>
    var table t = na
    
    if showTable
        // Initialize table once on first bar
        if barstate.isfirst
            t := table.new(position.top_right, 4, 2, border_width=1)
        
        // Update content only on last bar (performance optimization)
        if barstate.islast and not na(t)
            // Clear and rebuild
            table.clear(t, 0, 0, 3, 1)
            
            // Headers
            table.cell(t, 0, 0, "Leg", bgcolor=color.new(color.gray, 0), text_color=color.white)
            table.cell(t, 1, 0, "Dir", bgcolor=color.new(color.gray, 0), text_color=color.white)
            table.cell(t, 2, 0, "KC Depth", bgcolor=color.new(color.gray, 0), text_color=color.white)
            table.cell(t, 3, 0, "Signals", bgcolor=color.new(color.gray, 0), text_color=color.white)
            
            // Update content
            string dirStr = activeDir == 1 ? "UP ▲" : activeDir == -1 ? "DOWN ▼" : "-"
            color dirColor = activeDir == 1 ? color.new(color.lime, 0) : activeDir == -1 ? color.new(color.red, 0) : color.gray
            
            table.cell(t, 0, 1, "Active", bgcolor=color.new(color.white, 0), text_color=color.black)
            table.cell(t, 1, 1, dirStr, bgcolor=color.new(color.white, 0), text_color=dirColor)
            table.cell(t, 2, 1, str.tostring(depthKC, "#.00"), bgcolor=color.new(color.white, 0), text_color=color.black)
            table.cell(t, 3, 1, signalText, bgcolor=interesting ? color.new(color.yellow, 20) : color.new(color.white, 0), text_color=color.black)
    
    t


