//@version=6
// ============================================================================
// NG Reversal Labeler 4H [WavesUnchained]
// Version: 0.1.0
// Author: WavesUnchained
// ============================================================================
// Objective historical labeling of bullish/bearish reversals on 4H NatGas.
// Uses forward-looking ATR-based rules to define reversal bars.
// Lookahead is intentional — this script is for research/labeling only.
//
// Features:
//   ✓ ATR-based forward reversal detection
//   ✓ Bullish / Bearish / Neutral labels per bar
//   ✓ Configurable target and adverse move thresholds
//   ✓ Light / Debug / Research display modes
//   ✓ Chart markers and numeric label plot
//
// ============================================================================
indicator("NG Reversal Labeler 4H [WavesUnchained]", "NG Label", overlay=true, max_labels_count=500)

// ============================================================================
// MODULE: inputs
// ============================================================================

var gLabel = "Labeling Parameters"
int   atrLen        = input.int(14, "ATR Length", minval=1, group=gLabel)
int   forwardBars   = input.int(8, "Forward Bars", minval=1, maxval=50, group=gLabel)
float targetATR     = input.float(1.5, "Target Move (ATR multiple)", minval=0.1, step=0.1, group=gLabel)
float maxAdverseATR = input.float(0.6, "Max Adverse Move (ATR multiple)", minval=0.1, step=0.1, group=gLabel)
bool  useClose      = input.bool(false, "Use Close instead of High/Low for targets", group=gLabel)

var gDisplay = "Display"
string displayMode = input.string("Light", "Display Mode", options=["Light", "Debug", "Research"], group=gDisplay)
bool   showLabels  = input.bool(true, "Show Chart Labels", group=gDisplay)
color  bullColor   = input.color(color.new(color.lime, 0), "Bullish Label Color", group=gDisplay)
color  bearColor   = input.color(color.new(color.red, 0), "Bearish Label Color", group=gDisplay)

// ============================================================================
// MODULE: core
// ============================================================================

// ATR calculation
atrValue = ta.atr(atrLen)

// Forward-looking reversal detection
// NOTE: Lookahead is intentional for historical labeling purposes
f_checkBullish(int bars, float atr, float target, float maxAdv, bool closeOnly) =>
    float startLevel = close
    bool  targetHit  = false
    bool  stopHit    = false
    if not na(atr) and atr > 0
        for i = 1 to bars
            float hi = closeOnly ? close[- i] : high[- i]
            float lo = closeOnly ? close[- i] : low[- i]
            if lo < startLevel - maxAdv * atr
                stopHit := true
                break
            if hi >= startLevel + target * atr
                targetHit := true
                break
    targetHit and not stopHit

f_checkBearish(int bars, float atr, float target, float maxAdv, bool closeOnly) =>
    float startLevel = close
    bool  targetHit  = false
    bool  stopHit    = false
    if not na(atr) and atr > 0
        for i = 1 to bars
            float hi = closeOnly ? close[- i] : high[- i]
            float lo = closeOnly ? close[- i] : low[- i]
            if hi > startLevel + maxAdv * atr
                stopHit := true
                break
            if lo <= startLevel - target * atr
                targetHit := true
                break
    targetHit and not stopHit

// We need enough future bars to evaluate — suppress labels near chart edge
bool hasFutureBars = bar_index + forwardBars < last_bar_index

bool isBull = hasFutureBars ? f_checkBullish(forwardBars, atrValue, targetATR, maxAdverseATR, useClose) : false
bool isBear = hasFutureBars ? f_checkBearish(forwardBars, atrValue, targetATR, maxAdverseATR, useClose) : false

// If both trigger (rare), neutralize
int reversalLabel = isBull and not isBear ? 1 : isBear and not isBull ? -1 : 0

// ============================================================================
// MODULE: visuals
// ============================================================================

// Numeric label plot (always available in Data Window)
plot(reversalLabel, "Reversal Label", color=color.new(color.gray, 100), display=display.data_window)

// Chart markers
if showLabels and reversalLabel == 1
    label.new(bar_index, low, "▲", style=label.style_label_up, color=bullColor, textcolor=color.white, size=size.tiny)

if showLabels and reversalLabel == -1
    label.new(bar_index, high, "▼", style=label.style_label_down, color=bearColor, textcolor=color.white, size=size.tiny)

// Background highlight in Debug/Research mode
bool showBg = displayMode == "Debug" or displayMode == "Research"
bgcolor(showBg and reversalLabel == 1 ? color.new(bullColor, 90) : showBg and reversalLabel == -1 ? color.new(bearColor, 90) : na)

// ============================================================================
// MODULE: debug
// ============================================================================

// Debug plots — ATR and target levels
bool isDebug   = displayMode == "Debug" or displayMode == "Research"

plot(isDebug ? atrValue : na, "ATR", color=color.new(color.orange, 60), display=display.data_window)
plot(isDebug ? close + targetATR * atrValue : na, "Bull Target", color=color.new(bullColor, 80), style=plot.style_cross, display=display.data_window)
plot(isDebug ? close - targetATR * atrValue : na, "Bear Target", color=color.new(bearColor, 80), style=plot.style_cross, display=display.data_window)

// Research mode: count labels
var int bullCount = 0
var int bearCount = 0
if reversalLabel == 1
    bullCount += 1
if reversalLabel == -1
    bearCount += 1

bool isResearch = displayMode == "Research"

// Summary table in Research mode
var table summaryTable = na
if isResearch and barstate.islast
    summaryTable := table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80), border_color=color.gray, border_width=1)
    table.cell(summaryTable, 0, 0, "NG Labeler", text_color=color.white, text_size=size.small)
    table.cell(summaryTable, 1, 0, "v0.1", text_color=color.gray, text_size=size.small)
    table.cell(summaryTable, 0, 1, "Bull Labels", text_color=bullColor, text_size=size.small)
    table.cell(summaryTable, 1, 1, str.tostring(bullCount), text_color=bullColor, text_size=size.small)
    table.cell(summaryTable, 0, 2, "Bear Labels", text_color=bearColor, text_size=size.small)
    table.cell(summaryTable, 1, 2, str.tostring(bearCount), text_color=bearColor, text_size=size.small)
    table.cell(summaryTable, 0, 3, "Total Bars", text_color=color.gray, text_size=size.small)
    table.cell(summaryTable, 1, 3, str.tostring(bar_index + 1), text_color=color.gray, text_size=size.small)
