//@version=6
// ============================================================================
// NG Reversal Labeler 4H [WavesUnchained]
// Version: 0.1.0
// Author: WavesUnchained
// ============================================================================
// Objective historical labeling of bullish/bearish reversals on 4H NatGas.
// Uses forward-looking ATR-based rules to define reversal bars.
// Lookahead is intentional — this script is for research/labeling only.
//
// Features:
//   ✓ ATR-based forward reversal detection
//   ✓ Bullish / Bearish / Neutral labels per bar
//   ✓ Configurable target and adverse move thresholds
//   ✓ Light / Debug / Research display modes
//   ✓ Chart markers and numeric label plot
//
// ============================================================================
indicator("NG Reversal Labeler 4H [WavesUnchained]", "NG Label", overlay=true, max_labels_count=500)

// ============================================================================
// MODULE: inputs
// ============================================================================

var gLabel = "Labeling Parameters"
int   atrLen        = input.int(14, "ATR Length", minval=1, group=gLabel)
int   forwardBars   = input.int(8, "Forward Bars", minval=1, maxval=50, group=gLabel)
float targetATR     = input.float(1.5, "Target Move (ATR multiple)", minval=0.1, step=0.1, group=gLabel)
float maxAdverseATR = input.float(0.6, "Max Adverse Move (ATR multiple)", minval=0.1, step=0.1, group=gLabel)
bool  useClose      = input.bool(false, "Use Close instead of High/Low for targets", group=gLabel)

var gCluster = "Cluster Filter"
int   minGapBars = input.int(3, "Min Bars Between Labels (same direction)", minval=0, maxval=20, group=gCluster, tooltip="Suppresses repeated labels of the same type within N bars. 0 = no filter.")

var gDisplay = "Display"
string displayMode = input.string("Light", "Display Mode", options=["Light", "Debug", "Research"], group=gDisplay)
bool   showLabels  = input.bool(true, "Show Chart Labels", group=gDisplay)
color  bullColor   = input.color(color.new(color.lime, 0), "Bullish Label Color", group=gDisplay)
color  bearColor   = input.color(color.new(color.red, 0), "Bearish Label Color", group=gDisplay)

// ============================================================================
// MODULE: core
// ============================================================================

// ATR calculation
atrValue = ta.atr(atrLen)

// ── Forward-looking reversal detection via backward evaluation ──
// Pine cannot reference future bars with negative indices.
// Strategy: each bar checks whether it was the START of a reversal
// by looking BACK from later bars. We store per-bar reference data
// in arrays and evaluate once enough bars have passed.

// Rolling ring buffer of close/high/low/atr for the last forwardBars bars
var array<float> bufClose = array.new_float(forwardBars + 1, na)
var array<float> bufHigh  = array.new_float(forwardBars + 1, na)
var array<float> bufLow   = array.new_float(forwardBars + 1, na)
var array<float> bufATR   = array.new_float(forwardBars + 1, na)

// Shift buffer: remove oldest, append current
array.shift(bufClose)
array.push(bufClose, close)
array.shift(bufHigh)
array.push(bufHigh, high)
array.shift(bufLow)
array.push(bufLow, low)
array.shift(bufATR)
array.push(bufATR, atrValue)

// Evaluate the bar that is forwardBars bars ago (index 0 in buffer)
float startClose = array.get(bufClose, 0)
float startATR   = array.get(bufATR, 0)
bool  canEval    = not na(startClose) and not na(startATR) and startATR > 0 and bar_index >= forwardBars

// Check bullish: from start bar, price must rise >= target*ATR
// without first dropping > maxAdverse*ATR
f_evalBull(array<float> hi, array<float> lo, array<float> cl, int bars, float refClose, float atr, float target, float maxAdv, bool closeOnly) =>
    bool  tgtHit  = false
    bool  stpHit  = false
    for i = 1 to bars
        float barHi = closeOnly ? array.get(cl, i) : array.get(hi, i)
        float barLo = closeOnly ? array.get(cl, i) : array.get(lo, i)
        if barLo < refClose - maxAdv * atr
            stpHit := true
            break
        if barHi >= refClose + target * atr
            tgtHit := true
            break
    tgtHit and not stpHit

f_evalBear(array<float> hi, array<float> lo, array<float> cl, int bars, float refClose, float atr, float target, float maxAdv, bool closeOnly) =>
    bool  tgtHit  = false
    bool  stpHit  = false
    for i = 1 to bars
        float barHi = closeOnly ? array.get(cl, i) : array.get(hi, i)
        float barLo = closeOnly ? array.get(cl, i) : array.get(lo, i)
        if barHi > refClose + maxAdv * atr
            stpHit := true
            break
        if barLo <= refClose - target * atr
            tgtHit := true
            break
    tgtHit and not stpHit

bool isBull = canEval ? f_evalBull(bufHigh, bufLow, bufClose, forwardBars, startClose, startATR, targetATR, maxAdverseATR, useClose) : false
bool isBear = canEval ? f_evalBear(bufHigh, bufLow, bufClose, forwardBars, startClose, startATR, targetATR, maxAdverseATR, useClose) : false

// If both trigger (rare), neutralize
int rawLabel = isBull and not isBear ? 1 : isBear and not isBull ? -1 : 0

// ── Cluster filter: suppress repeated labels within minGapBars ──
var int barsSinceLastBull = 999
var int barsSinceLastBear = 999

barsSinceLastBull += 1
barsSinceLastBear += 1

int reversalLabel = rawLabel
if minGapBars > 0
    if rawLabel == 1 and barsSinceLastBull < minGapBars
        reversalLabel := 0
    if rawLabel == -1 and barsSinceLastBear < minGapBars
        reversalLabel := 0

if reversalLabel == 1
    barsSinceLastBull := 0
if reversalLabel == -1
    barsSinceLastBear := 0

// ============================================================================
// MODULE: visuals
// ============================================================================

// Numeric label plot (always available in Data Window)
// Note: plot is delayed by forwardBars so it aligns with the evaluated bar
plot(reversalLabel, "Reversal Label", color=color.new(color.gray, 100), display=display.data_window, offset=-forwardBars)

// Chart markers — placed on the start bar (forwardBars ago)
int targetBarIdx = bar_index - forwardBars

if showLabels and reversalLabel == 1
    label.new(targetBarIdx, low[forwardBars], "▲", style=label.style_label_up, color=bullColor, textcolor=color.white, size=size.tiny)

if showLabels and reversalLabel == -1
    label.new(targetBarIdx, high[forwardBars], "▼", style=label.style_label_down, color=bearColor, textcolor=color.white, size=size.tiny)

// Background highlight in Debug/Research mode — shifted to start bar
bool showBg = displayMode == "Debug" or displayMode == "Research"
bgcolor(showBg and reversalLabel[forwardBars] == 1 ? color.new(bullColor, 90) : showBg and reversalLabel[forwardBars] == -1 ? color.new(bearColor, 90) : na, offset=-forwardBars)

// ============================================================================
// MODULE: debug
// ============================================================================

// Debug plots — ATR and target levels
bool isDebug   = displayMode == "Debug" or displayMode == "Research"

plot(isDebug ? atrValue : na, "ATR", color=color.new(color.orange, 60), display=display.data_window)
plot(isDebug ? close + targetATR * atrValue : na, "Bull Target", color=color.new(bullColor, 80), style=plot.style_cross, display=display.data_window)
plot(isDebug ? close - targetATR * atrValue : na, "Bear Target", color=color.new(bearColor, 80), style=plot.style_cross, display=display.data_window)

// Research mode: count labels
var int bullCount = 0
var int bearCount = 0
if reversalLabel == 1
    bullCount += 1
if reversalLabel == -1
    bearCount += 1

bool isResearch = displayMode == "Research"

// Summary table in Research mode
float bullPct = bar_index > 0 ? bullCount / (bar_index + 1) * 100 : 0.0
float bearPct = bar_index > 0 ? bearCount / (bar_index + 1) * 100 : 0.0
float neutralPct = 100.0 - bullPct - bearPct

var table summaryTable = na
if isResearch and barstate.islast
    summaryTable := table.new(position.top_right, 3, 6, bgcolor=color.new(#1a1a2e, 5), border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.gray, 50), frame_width=2)
    // Header
    table.cell(summaryTable, 0, 0, "NG Reversal Labeler", text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(summaryTable, 1, 0, "", text_color=color.gray, text_size=size.normal)
    table.cell(summaryTable, 2, 0, "v0.1", text_color=color.gray, text_size=size.normal, text_halign=text.align_right)
    // Column headers
    table.cell(summaryTable, 0, 1, "", text_size=size.normal)
    table.cell(summaryTable, 1, 1, "Count", text_color=color.new(color.white, 30), text_size=size.normal, text_halign=text.align_right)
    table.cell(summaryTable, 2, 1, "%", text_color=color.new(color.white, 30), text_size=size.normal, text_halign=text.align_right)
    // Bull
    table.cell(summaryTable, 0, 2, "Bull Labels", text_color=color.lime, text_size=size.normal, text_halign=text.align_left)
    table.cell(summaryTable, 1, 2, str.tostring(bullCount), text_color=color.lime, text_size=size.normal, text_halign=text.align_right)
    table.cell(summaryTable, 2, 2, str.tostring(bullPct, "#.0") + "%", text_color=color.lime, text_size=size.normal, text_halign=text.align_right)
    // Bear
    table.cell(summaryTable, 0, 3, "Bear Labels", text_color=color.red, text_size=size.normal, text_halign=text.align_left)
    table.cell(summaryTable, 1, 3, str.tostring(bearCount), text_color=color.red, text_size=size.normal, text_halign=text.align_right)
    table.cell(summaryTable, 2, 3, str.tostring(bearPct, "#.0") + "%", text_color=color.red, text_size=size.normal, text_halign=text.align_right)
    // Neutral
    table.cell(summaryTable, 0, 4, "Neutral", text_color=color.gray, text_size=size.normal, text_halign=text.align_left)
    table.cell(summaryTable, 1, 4, str.tostring(bar_index + 1 - bullCount - bearCount), text_color=color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(summaryTable, 2, 4, str.tostring(neutralPct, "#.0") + "%", text_color=color.gray, text_size=size.normal, text_halign=text.align_right)
    // Total
    table.cell(summaryTable, 0, 5, "Total Bars", text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(summaryTable, 1, 5, str.tostring(bar_index + 1), text_color=color.white, text_size=size.normal, text_halign=text.align_right)
    table.cell(summaryTable, 2, 5, "", text_size=size.normal)
