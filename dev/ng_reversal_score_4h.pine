//@version=6
// ============================================================================
// NG Reversal Score 4H [WavesUnchained]
// Version: 0.1.0
// Author: WavesUnchained
// ============================================================================
// Weighted reversal score combining features and structure events for 4H NatGas.
// Transparent, rule-based scoring — no black-box approach.
//
// Features:
//   ✓ Bullish / Bearish score from momentum, structure, volume, volatility
//   ✓ Score zones: Ignore / Watch / Setup / Strong Candidate
//   ✓ Traffic light background
//   ✓ Deductions for counter-trend / missing confirmation
//   ✓ Light / Debug / Research display modes
//   ✓ Alert conditions for score thresholds
//
// ============================================================================
indicator("NG Reversal Score 4H [WavesUnchained]", "NG Score", overlay=false, max_labels_count=200)

// ============================================================================
// MODULE: inputs — indicator parameters
// ============================================================================

var gCore = "Core Parameters"
int emaFastLen  = input.int(20, "EMA Fast", minval=1, group=gCore)
int emaSlowLen  = input.int(50, "EMA Slow", minval=1, group=gCore)
int emaSlopeLen = input.int(3, "EMA Slope Lookback", minval=1, group=gCore)
int rsiLen      = input.int(14, "RSI Length", minval=1, group=gCore)
int stochRsiLen = input.int(14, "Stoch RSI Length", minval=1, group=gCore)
int stochK      = input.int(3, "Stoch RSI K", minval=1, group=gCore)
int stochD      = input.int(3, "Stoch RSI D", minval=1, group=gCore)
int mfiLen      = input.int(14, "MFI Length", minval=1, group=gCore)
int atrLen      = input.int(14, "ATR Length", minval=1, group=gCore)
int bbLen       = input.int(20, "Bollinger Length", minval=1, group=gCore)
float bbMult    = input.float(2.0, "Bollinger Multiplier", minval=0.5, step=0.1, group=gCore)
int volAvgLen   = input.int(20, "Volume Average Length", minval=5, group=gCore)

var gSwing = "Swing / Structure"
int leftBars      = input.int(3, "Pivot Left Bars", minval=1, group=gSwing)
int rightBars     = input.int(3, "Pivot Right Bars", minval=1, group=gSwing)
float minWickRatio   = input.float(0.35, "Spring/UT Min Wick Ratio", minval=0.1, step=0.05, group=gSwing)
float minCandleATR   = input.float(0.5, "Spring/UT Min Candle/ATR", minval=0.1, step=0.1, group=gSwing)
float climaxRangeATR = input.float(1.8, "Climax Min Range/ATR", minval=1.0, step=0.1, group=gSwing)
float climaxVolFact  = input.float(1.8, "Climax Min Vol Factor", minval=1.0, step=0.1, group=gSwing)

// ============================================================================
// MODULE: inputs — score thresholds
// ============================================================================

var gThresh = "Score Thresholds"
float rsiBullThresh  = input.float(35.0, "RSI Bull Threshold", minval=10, maxval=50, group=gThresh)
float rsiBearThresh  = input.float(65.0, "RSI Bear Threshold", minval=50, maxval=90, group=gThresh)
float stochExtLow    = input.float(20.0, "Stoch RSI Low Zone", minval=5, maxval=40, group=gThresh)
float stochExtHigh   = input.float(80.0, "Stoch RSI High Zone", minval=60, maxval=95, group=gThresh)
float mfiBullThresh  = input.float(30.0, "MFI Bull Threshold", minval=10, maxval=50, group=gThresh)
float mfiBearThresh  = input.float(70.0, "MFI Bear Threshold", minval=50, maxval=90, group=gThresh)
float priceEmaATRThresh = input.float(1.5, "Price→EMA20 ATR Threshold", minval=0.5, step=0.1, group=gThresh)
float wickThresh     = input.float(0.4, "Wick Ratio Threshold", minval=0.1, maxval=0.8, step=0.05, group=gThresh)
float slopeThresh    = input.float(0.0, "EMA Slope Strong Threshold", minval=0.0, step=0.01, group=gThresh, tooltip="Absolute slope value for strong trend deduction")

var gZones = "Score Zones"
int watchMin  = input.int(3, "Watch Zone Minimum", minval=1, group=gZones)
int setupMin  = input.int(5, "Setup Zone Minimum", minval=2, group=gZones)
int strongMin = input.int(7, "Strong Candidate Minimum", minval=3, group=gZones)

var gDisplay = "Display"
string displayMode = input.string("Light", "Display Mode", options=["Light", "Debug", "Research"], group=gDisplay)
bool showBg        = input.bool(true, "Show Background Colors", group=gDisplay)

// ============================================================================
// MODULE: calculations — indicators
// ============================================================================

// Trend
float ema20 = ta.ema(close, emaFastLen)
float ema50 = ta.ema(close, emaSlowLen)
float ema20Slope = (ema20 - ema20[emaSlopeLen]) / emaSlopeLen
float atr14 = ta.atr(atrLen)
float priceToEma20ATR = atr14 > 0 ? (close - ema20) / atr14 : 0.0

// Momentum
float rsi14 = ta.rsi(close, rsiLen)
float stochRsiRaw = ta.stoch(rsi14, rsi14, rsi14, stochRsiLen)
float stochRsiKVal = ta.sma(stochRsiRaw, stochK)
float stochRsiDVal = ta.sma(stochRsiKVal, stochD)

// MACD
[macdLine, signalLine, macdHist] = ta.macd(close, 12, 26, 9)

// Volume
float mfi14 = ta.mfi(hlc3, mfiLen)
float avgVol = ta.sma(volume, volAvgLen)
float relVol = avgVol > 0 ? volume / avgVol : 1.0

// Bollinger
float bbBasis = ta.sma(close, bbLen)
float bbDev   = ta.stdev(close, bbLen) * bbMult
float bbUpper = bbBasis + bbDev
float bbLower = bbBasis - bbDev

// Candle
float candleRange = high - low
float upperWick   = high - math.max(open, close)
float lowerWick   = math.min(open, close) - low
float upperWickRatio = candleRange > 0 ? upperWick / candleRange : 0.0
float lowerWickRatio = candleRange > 0 ? lowerWick / candleRange : 0.0
float candleATR      = atr14 > 0 ? candleRange / atr14 : 0.0

// ============================================================================
// MODULE: calculations — structure events
// ============================================================================

float pivotHi = ta.pivothigh(high, leftBars, rightBars)
float pivotLo = ta.pivotlow(low, leftBars, rightBars)

var float lastSwingHigh = na
var float lastSwingLow  = na

if not na(pivotHi)
    lastSwingHigh := pivotHi
if not na(pivotLo)
    lastSwingLow := pivotLo

// BOS
bool bullishBOS = not na(lastSwingHigh) and close > lastSwingHigh and close[1] <= lastSwingHigh
bool bearishBOS = not na(lastSwingLow) and close < lastSwingLow and close[1] >= lastSwingLow

// Fake breaks
bool fakeBreakout  = not na(lastSwingHigh) and high > lastSwingHigh and close <= lastSwingHigh
bool fakeBreakdown = not na(lastSwingLow) and low < lastSwingLow and close >= lastSwingLow

// Spring / Upthrust
bool isSpring   = fakeBreakdown and lowerWickRatio >= minWickRatio and candleATR >= minCandleATR
bool isUpthrust = fakeBreakout and upperWickRatio >= minWickRatio and candleATR >= minCandleATR

// Climax
bool isClimaxCandle = candleATR >= climaxRangeATR and avgVol > 0 and volume >= climaxVolFact * avgVol

// ============================================================================
// MODULE: scoring — bullish
// ============================================================================

float bullScore = 0.0

// RSI oversold and rising
if rsi14 < rsiBullThresh and rsi14 > rsi14[1]
    bullScore += 1.0

// MFI low or rising after weakness
if mfi14 < mfiBullThresh or (mfi14 > mfi14[1] and mfi14[1] < mfiBullThresh)
    bullScore += 1.0

// Stoch RSI bullish cross in low zone
if stochRsiKVal < stochExtLow or (ta.crossover(stochRsiKVal, stochRsiDVal) and stochRsiKVal < stochExtLow + 10)
    bullScore += 1.0

// Price far below EMA20
if priceToEma20ATR < -priceEmaATRThresh
    bullScore += 1.0

// Strong lower wick
if lowerWickRatio >= wickThresh
    bullScore += 1.0

// Bollinger lower band touch / below
if low <= bbLower
    bullScore += 1.0

// Spring detected
if isSpring
    bullScore += 2.0

// Bullish BOS
if bullishBOS
    bullScore += 2.0

// Climax candle (potential selling climax in downtrend context)
if isClimaxCandle and close < ema20
    bullScore += 1.0

// Deductions
// Strong negative slope
if ema20Slope < -math.abs(slopeThresh) and slopeThresh > 0
    bullScore -= 1.0

// No volume confirmation
if relVol < 0.8
    bullScore -= 1.0

bullScore := math.max(0.0, bullScore)

// ============================================================================
// MODULE: scoring — bearish
// ============================================================================

float bearScore = 0.0

// RSI overbought and falling
if rsi14 > rsiBearThresh and rsi14 < rsi14[1]
    bearScore += 1.0

// MFI high or falling after strength
if mfi14 > mfiBearThresh or (mfi14 < mfi14[1] and mfi14[1] > mfiBearThresh)
    bearScore += 1.0

// Stoch RSI bearish cross in high zone
if stochRsiKVal > stochExtHigh or (ta.crossunder(stochRsiKVal, stochRsiDVal) and stochRsiKVal > stochExtHigh - 10)
    bearScore += 1.0

// Price far above EMA20
if priceToEma20ATR > priceEmaATRThresh
    bearScore += 1.0

// Strong upper wick
if upperWickRatio >= wickThresh
    bearScore += 1.0

// Bollinger upper band touch / above
if high >= bbUpper
    bearScore += 1.0

// Upthrust detected
if isUpthrust
    bearScore += 2.0

// Bearish BOS
if bearishBOS
    bearScore += 2.0

// Climax candle (potential buying climax in uptrend context)
if isClimaxCandle and close > ema20
    bearScore += 1.0

// Deductions
// Strong positive slope (trend up, working against bearish)
if ema20Slope > math.abs(slopeThresh) and slopeThresh > 0
    bearScore -= 1.0

// No volume confirmation
if relVol < 0.8
    bearScore -= 1.0

bearScore := math.max(0.0, bearScore)

// ============================================================================
// MODULE: net score and status
// ============================================================================

float netScore = bullScore - bearScore

// Status determination
string bullStatus = bullScore >= strongMin ? "STRONG" : bullScore >= setupMin ? "SETUP" : bullScore >= watchMin ? "WATCH" : "—"
string bearStatus = bearScore >= strongMin ? "STRONG" : bearScore >= setupMin ? "SETUP" : bearScore >= watchMin ? "WATCH" : "—"

// ============================================================================
// MODULE: visuals — score plot
// ============================================================================

color bullBarColor = bullScore >= strongMin ? color.new(color.lime, 0) : bullScore >= setupMin ? color.new(color.lime, 40) : bullScore >= watchMin ? color.new(color.lime, 70) : color.new(color.gray, 80)
color bearBarColor = bearScore >= strongMin ? color.new(color.red, 0) : bearScore >= setupMin ? color.new(color.red, 40) : bearScore >= watchMin ? color.new(color.red, 70) : color.new(color.gray, 80)

plot(bullScore, "Bull Score", color=bullBarColor, style=plot.style_columns, linewidth=3)
plot(-bearScore, "Bear Score", color=bearBarColor, style=plot.style_columns, linewidth=3)
plot(netScore, "Net Score", color=color.new(color.white, 30), linewidth=2)

hline(strongMin, "Strong", color=color.new(color.lime, 70), linestyle=hline.style_dotted)
hline(setupMin, "Setup", color=color.new(color.yellow, 70), linestyle=hline.style_dotted)
hline(watchMin, "Watch", color=color.new(color.gray, 70), linestyle=hline.style_dotted)
hline(0, "Zero", color=color.new(color.gray, 85))
hline(-watchMin, "Watch Bear", color=color.new(color.gray, 70), linestyle=hline.style_dotted)
hline(-setupMin, "Setup Bear", color=color.new(color.yellow, 70), linestyle=hline.style_dotted)
hline(-strongMin, "Strong Bear", color=color.new(color.red, 70), linestyle=hline.style_dotted)

// Background
color bgColor = na
if showBg
    if bullScore >= strongMin
        bgColor := color.new(color.lime, 90)
    else if bearScore >= strongMin
        bgColor := color.new(color.red, 90)
    else if bullScore >= setupMin
        bgColor := color.new(color.lime, 95)
    else if bearScore >= setupMin
        bgColor := color.new(color.red, 95)
bgcolor(bgColor)

// ============================================================================
// MODULE: data window
// ============================================================================

plot(bullScore, "Bull Score [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearScore, "Bear Score [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(netScore, "Net Score [dw]", display=display.data_window, color=color.new(color.gray, 100))

// ============================================================================
// MODULE: debug breakdown
// ============================================================================

bool isDebug   = displayMode == "Debug" or displayMode == "Research"
bool isResearch = displayMode == "Research"

// Debug: individual component contributions
var table scoreTable = na
if isDebug and barstate.islast
    scoreTable := table.new(position.top_right, 3, 14, bgcolor=color.new(color.black, 80), border_color=color.gray, border_width=1)
    table.cell(scoreTable, 0, 0, "Component", text_color=color.white, text_size=size.tiny)
    table.cell(scoreTable, 1, 0, "Bull", text_color=color.lime, text_size=size.tiny)
    table.cell(scoreTable, 2, 0, "Bear", text_color=color.red, text_size=size.tiny)

    table.cell(scoreTable, 0, 1, "RSI", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 1, str.tostring(rsi14, "#.0"), text_color=color.yellow, text_size=size.tiny)
    table.cell(scoreTable, 2, 1, bullStatus, text_color=color.white, text_size=size.tiny)

    table.cell(scoreTable, 0, 2, "StochRSI K", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 2, str.tostring(stochRsiKVal, "#.0"), text_color=color.aqua, text_size=size.tiny)
    table.cell(scoreTable, 2, 2, bearStatus, text_color=color.white, text_size=size.tiny)

    table.cell(scoreTable, 0, 3, "MFI", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 3, str.tostring(mfi14, "#.0"), text_color=color.teal, text_size=size.tiny)

    table.cell(scoreTable, 0, 4, "Price→EMA20", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 4, str.tostring(priceToEma20ATR, "#.00"), text_color=color.orange, text_size=size.tiny)

    table.cell(scoreTable, 0, 5, "Lower Wick", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 5, str.tostring(lowerWickRatio, "#.00"), text_color=color.green, text_size=size.tiny)

    table.cell(scoreTable, 0, 6, "Upper Wick", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 6, str.tostring(upperWickRatio, "#.00"), text_color=color.red, text_size=size.tiny)

    table.cell(scoreTable, 0, 7, "BB Contact", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 7, low <= bbLower ? "Lower" : high >= bbUpper ? "Upper" : "—", text_color=color.aqua, text_size=size.tiny)

    table.cell(scoreTable, 0, 8, "Spring", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 8, isSpring ? "YES" : "—", text_color=isSpring ? color.lime : color.gray, text_size=size.tiny)

    table.cell(scoreTable, 0, 9, "Upthrust", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 9, isUpthrust ? "YES" : "—", text_color=isUpthrust ? color.red : color.gray, text_size=size.tiny)

    table.cell(scoreTable, 0, 10, "BOS Bull", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 10, bullishBOS ? "YES" : "—", text_color=bullishBOS ? color.lime : color.gray, text_size=size.tiny)

    table.cell(scoreTable, 0, 11, "BOS Bear", text_color=color.gray, text_size=size.tiny)
    table.cell(scoreTable, 1, 11, bearishBOS ? "YES" : "—", text_color=bearishBOS ? color.red : color.gray, text_size=size.tiny)

    table.cell(scoreTable, 0, 12, "BULL SCORE", text_color=color.lime, text_size=size.small)
    table.cell(scoreTable, 1, 12, str.tostring(bullScore, "#.0"), text_color=color.lime, text_size=size.small)
    table.cell(scoreTable, 2, 12, bullStatus, text_color=color.lime, text_size=size.small)

    table.cell(scoreTable, 0, 13, "BEAR SCORE", text_color=color.red, text_size=size.small)
    table.cell(scoreTable, 1, 13, str.tostring(bearScore, "#.0"), text_color=color.red, text_size=size.small)
    table.cell(scoreTable, 2, 13, bearStatus, text_color=color.red, text_size=size.small)

// ============================================================================
// MODULE: alerts
// ============================================================================

alertcondition(bullScore >= strongMin, "Bull Strong Candidate", "NG 4H: Bullish reversal score >= STRONG threshold")
alertcondition(bearScore >= strongMin, "Bear Strong Candidate", "NG 4H: Bearish reversal score >= STRONG threshold")
alertcondition(bullScore >= setupMin, "Bull Setup Active", "NG 4H: Bullish reversal score >= SETUP threshold")
alertcondition(bearScore >= setupMin, "Bear Setup Active", "NG 4H: Bearish reversal score >= SETUP threshold")
alertcondition(isSpring, "Spring Detected", "NG 4H: Spring heuristic triggered")
alertcondition(isUpthrust, "Upthrust Detected", "NG 4H: Upthrust heuristic triggered")
alertcondition(bullishBOS, "Bullish BOS", "NG 4H: Bullish Break of Structure")
alertcondition(bearishBOS, "Bearish BOS", "NG 4H: Bearish Break of Structure")
