//@version=6
// ============================================================================
// NG Reversal Score 4H [WavesUnchained]
// Version: 0.2.0
// Author: WavesUnchained
// ============================================================================
// Two-layer reversal scoring for 4H NatGas.
//
// Layer A: SETUP SCORE — momentum, overextension, candle, volume
//   → "conditions are building"
//
// Layer B: CONFIRMATION SCORE — BOS, Spring/Upthrust, Fake Break, Climax+Test
//   → "structure confirms the setup"
//
// Combined status logic:
//   Setup only          → WATCH (observe, don't act)
//   Setup + Confirmation → CANDIDATE (take seriously)
//   Confirmation only    → ALERT (structure event, check context)
//
// Features:
//   ✓ Separate Setup and Confirmation scores (bull/bear)
//   ✓ Combined status with clear decision logic
//   ✓ Dual-panel visualization
//   ✓ Traffic light background
//   ✓ Light / Debug / Research display modes
//   ✓ Alert conditions
//
// ============================================================================
indicator("NG Reversal Score 4H [WavesUnchained]", "NG Score", overlay=false, max_labels_count=200)

// ============================================================================
// MODULE: inputs — indicator parameters
// ============================================================================

var gCore = "Core Parameters"
int emaFastLen  = input.int(20, "EMA Fast", minval=1, group=gCore)
int emaSlowLen  = input.int(50, "EMA Slow", minval=1, group=gCore)
int emaSlopeLen = input.int(3, "EMA Slope Lookback", minval=1, group=gCore)
int rsiLen      = input.int(14, "RSI Length", minval=1, group=gCore)
int stochRsiLen = input.int(14, "Stoch RSI Length", minval=1, group=gCore)
int stochK      = input.int(3, "Stoch RSI K", minval=1, group=gCore)
int stochD      = input.int(3, "Stoch RSI D", minval=1, group=gCore)
int mfiLen      = input.int(14, "MFI Length", minval=1, group=gCore)
int atrLen      = input.int(14, "ATR Length", minval=1, group=gCore)
int bbLen       = input.int(20, "Bollinger Length", minval=1, group=gCore)
float bbMult    = input.float(2.0, "Bollinger Multiplier", minval=0.5, step=0.1, group=gCore)
int volAvgLen   = input.int(20, "Volume Average Length", minval=5, group=gCore)

var gSwing = "Swing / Structure"
int leftBars       = input.int(3, "Micro Pivot Left Bars", minval=1, group=gSwing)
int rightBars      = input.int(3, "Micro Pivot Right Bars", minval=1, group=gSwing)
int majorLeftBars  = input.int(7, "Major Pivot Left Bars", minval=3, group=gSwing)
int majorRightBars = input.int(7, "Major Pivot Right Bars", minval=3, group=gSwing)
float minWickRatio   = input.float(0.35, "Spring/UT Min Wick Ratio", minval=0.1, step=0.05, group=gSwing)
float minCandleATR   = input.float(0.5, "Spring/UT Min Candle/ATR", minval=0.1, step=0.1, group=gSwing)
float climaxRangeATR = input.float(1.8, "Climax Min Range/ATR", minval=1.0, step=0.1, group=gSwing)
float climaxVolFact  = input.float(1.8, "Climax Min Vol Factor", minval=1.0, step=0.1, group=gSwing)

// ============================================================================
// MODULE: inputs — score thresholds
// ============================================================================

var gVariant = "Score Variant"
string scoreVariant = input.string("A: RSI+MFI+MACD", "Momentum Mix", options=["A: RSI+MFI+MACD", "B: RSI+MFI+StochRSI", "C: All"], group=gVariant, tooltip="A = ohne Stoch RSI (sauberer)\nB = ohne MACD, mit Stoch RSI (schneller)\nC = alles aktiv (max Score)")
bool useStochRSI = scoreVariant == "B: RSI+MFI+StochRSI" or scoreVariant == "C: All"
bool useMACD     = scoreVariant == "A: RSI+MFI+MACD" or scoreVariant == "C: All"

var gThresh = "Score Thresholds"
float rsiBullThresh    = input.float(35.0, "RSI Bull Threshold", minval=10, maxval=50, group=gThresh)
float rsiBearThresh    = input.float(65.0, "RSI Bear Threshold", minval=50, maxval=90, group=gThresh)
float stochExtLow      = input.float(20.0, "Stoch RSI Low Zone", minval=5, maxval=40, group=gThresh)
float stochExtHigh     = input.float(80.0, "Stoch RSI High Zone", minval=60, maxval=95, group=gThresh)
float mfiBullThresh    = input.float(30.0, "MFI Bull Threshold", minval=10, maxval=50, group=gThresh)
float mfiBearThresh    = input.float(70.0, "MFI Bear Threshold", minval=50, maxval=90, group=gThresh)
float priceEmaATRThresh = input.float(1.5, "Price→EMA20 ATR Threshold", minval=0.5, step=0.1, group=gThresh)
float wickThresh       = input.float(0.4, "Wick Ratio Threshold", minval=0.1, maxval=0.8, step=0.05, group=gThresh)
float slopeThresh      = input.float(0.0, "EMA Slope Strong Threshold", minval=0.0, step=0.01, group=gThresh, tooltip="Absolute slope value for strong trend deduction")

var gZones = "Score Zones"
float setupReady   = input.float(3.0, "Setup Ready (min setup score)", minval=1, step=0.5, group=gZones)
float setupStrong  = input.float(5.0, "Setup Strong (high setup score)", minval=2, step=0.5, group=gZones)
float confRequired = input.float(2.0, "Confirmation Required (min conf score)", minval=1, step=0.5, group=gZones)

var gDisplay = "Display"
string displayMode = input.string("Light", "Display Mode", options=["Light", "Debug", "Research"], group=gDisplay)
bool showBg        = input.bool(true, "Show Background Colors", group=gDisplay)
bool showComponents = input.bool(false, "Show Component Lines (Setup/Conf separate)", group=gDisplay, tooltip="Plots Setup and Confirm as separate lines for research")

// ============================================================================
// MODULE: calculations — indicators
// ============================================================================

// Trend
float ema20 = ta.ema(close, emaFastLen)
float ema50 = ta.ema(close, emaSlowLen)
float ema20Slope = (ema20 - ema20[emaSlopeLen]) / emaSlopeLen
float atr14 = ta.atr(atrLen)
float priceToEma20ATR = atr14 > 0 ? (close - ema20) / atr14 : 0.0

// Momentum
float rsi14 = ta.rsi(close, rsiLen)
float stochRsiRaw = ta.stoch(rsi14, rsi14, rsi14, stochRsiLen)
float stochRsiKVal = ta.sma(stochRsiRaw, stochK)
float stochRsiDVal = ta.sma(stochRsiKVal, stochD)

// MACD
[macdLine, signalLine, macdHist] = ta.macd(close, 12, 26, 9)

// Volume
float mfi14 = ta.mfi(hlc3, mfiLen)
float avgVol = ta.sma(volume, volAvgLen)
float relVol = avgVol > 0 ? volume / avgVol : 1.0

// Bollinger
float bbBasis = ta.sma(close, bbLen)
float bbDev   = ta.stdev(close, bbLen) * bbMult
float bbUpper = bbBasis + bbDev
float bbLower = bbBasis - bbDev

// Candle
float candleRange = high - low
float upperWick   = high - math.max(open, close)
float lowerWick   = math.min(open, close) - low
float upperWickRatio = candleRange > 0 ? upperWick / candleRange : 0.0
float lowerWickRatio = candleRange > 0 ? lowerWick / candleRange : 0.0
float candleATR      = atr14 > 0 ? candleRange / atr14 : 0.0

// ============================================================================
// MODULE: regime detection
// ============================================================================
// Simple regime filter based on EMA alignment, slope, and BB width.
// Regimes: TREND_UP, TREND_DOWN, RANGE, HIGH_VOL, LOW_VOL

// Trend detection: EMA20 vs EMA50 + slope strength
float absSlope = math.abs(ema20Slope)
bool ema20AboveEma50 = ema20 > ema50
bool ema20BelowEma50 = ema20 < ema50

// Volatility regime: BB width percentile (simple: vs SMA of BB width)
float bbWidthRaw = bbUpper - bbLower
float bbWidthAvg = ta.sma(bbWidthRaw, 50)
float bbWidthRatio = bbWidthAvg > 0 ? bbWidthRaw / bbWidthAvg : 1.0

// ADX-like trend strength via efficiency ratio
float priceChange = math.abs(close - close[10])
float pathLength  = math.sum(math.abs(close - close[1]), 10)
float efficiencyRatio = pathLength > 0 ? priceChange / pathLength : 0.0

// Regime classification
bool isTrendUp   = ema20AboveEma50 and efficiencyRatio > 0.35
bool isTrendDown = ema20BelowEma50 and efficiencyRatio > 0.35
bool isRange     = efficiencyRatio <= 0.35
bool isHighVol   = bbWidthRatio > 1.3
bool isLowVol    = bbWidthRatio < 0.7

// Combined regime string for display
string regime = isTrendUp ? "TREND ↑" : isTrendDown ? "TREND ↓" : "RANGE"
string volRegime = isHighVol ? "HIGH VOL" : isLowVol ? "LOW VOL" : "NORMAL VOL"

// Regime weight multipliers for score components
// In range: oscillators and mean-reversion signals are more valuable
// In trend: structure events (BOS) are more valuable, oscillators less
float setupMultiplier = isRange ? 1.2 : isTrendUp or isTrendDown ? 0.8 : 1.0
float confMultiplier  = isTrendUp or isTrendDown ? 1.3 : isRange ? 1.0 : 1.0

// High vol bonus for structure events (climax/spring more meaningful)
float volBonus = isHighVol ? 1.2 : isLowVol ? 0.8 : 1.0

// ============================================================================
// MODULE: level context
// ============================================================================
// How close is price to significant levels? Reversals at key levels are higher quality.

// 20-bar range extremes
float range20High = ta.highest(high, 20)
float range20Low  = ta.lowest(low, 20)
float range20Span = range20High - range20Low

// Distance to range extremes (normalized 0..1, 0 = at the extreme)
float distToRange20High = range20Span > 0 ? (range20High - close) / range20Span : 0.5
float distToRange20Low  = range20Span > 0 ? (close - range20Low) / range20Span : 0.5

// Near range extreme?
bool nearRange20High = distToRange20High < 0.15
bool nearRange20Low  = distToRange20Low < 0.15

// Distance to major swings (will be set after swing detection below)
var float distToMajorSwingHighATR = na
var float distToMajorSwingLowATR  = na

// ============================================================================
// MODULE: calculations — structure events (micro + major)
// ============================================================================

// Micro swings
float pivotHi = ta.pivothigh(high, leftBars, rightBars)
float pivotLo = ta.pivotlow(low, leftBars, rightBars)

var float lastSwingHigh = na
var float lastSwingLow  = na

if not na(pivotHi)
    lastSwingHigh := pivotHi
if not na(pivotLo)
    lastSwingLow := pivotLo

// Major swings
float majorPivotHi = ta.pivothigh(high, majorLeftBars, majorRightBars)
float majorPivotLo = ta.pivotlow(low, majorLeftBars, majorRightBars)

var float lastMajorSwingHigh = na
var float lastMajorSwingLow  = na

if not na(majorPivotHi)
    lastMajorSwingHigh := majorPivotHi
if not na(majorPivotLo)
    lastMajorSwingLow := majorPivotLo

// Level context: distance to major swings
distToMajorSwingHighATR := not na(lastMajorSwingHigh) and atr14 > 0 ? (close - lastMajorSwingHigh) / atr14 : na
distToMajorSwingLowATR  := not na(lastMajorSwingLow) and atr14 > 0 ? (close - lastMajorSwingLow) / atr14 : na

// Near major swing levels?
bool nearMajorSwingHigh = not na(distToMajorSwingHighATR) and math.abs(distToMajorSwingHighATR) < 0.5
bool nearMajorSwingLow  = not na(distToMajorSwingLowATR) and math.abs(distToMajorSwingLowATR) < 0.5

// Level quality: is this reversal happening at a meaningful location?
// Bull setups are better near lows, bear setups near highs
bool bullAtLevel = nearMajorSwingLow or nearRange20Low
bool bearAtLevel = nearMajorSwingHigh or nearRange20High

// Micro BOS
bool microBullBOS = not na(lastSwingHigh) and close > lastSwingHigh and close[1] <= lastSwingHigh
bool microBearBOS = not na(lastSwingLow) and close < lastSwingLow and close[1] >= lastSwingLow

// Major BOS
bool majorBullBOS = not na(lastMajorSwingHigh) and close > lastMajorSwingHigh and close[1] <= lastMajorSwingHigh
bool majorBearBOS = not na(lastMajorSwingLow) and close < lastMajorSwingLow and close[1] >= lastMajorSwingLow

bool bullishBOS = microBullBOS or majorBullBOS
bool bearishBOS = microBearBOS or majorBearBOS

// Fake breaks (micro + major)
bool fakeBreakout  = not na(lastSwingHigh) and high > lastSwingHigh and close <= lastSwingHigh
bool fakeBreakdown = not na(lastSwingLow) and low < lastSwingLow and close >= lastSwingLow
bool majorFakeBreakout  = not na(lastMajorSwingHigh) and high > lastMajorSwingHigh and close <= lastMajorSwingHigh
bool majorFakeBreakdown = not na(lastMajorSwingLow) and low < lastMajorSwingLow and close >= lastMajorSwingLow

// Spring / Upthrust (micro)
bool isSpring   = fakeBreakdown and lowerWickRatio >= minWickRatio and candleATR >= minCandleATR
bool isUpthrust = fakeBreakout and upperWickRatio >= minWickRatio and candleATR >= minCandleATR

// Major Spring / Upthrust
bool isMajorSpring   = majorFakeBreakdown and lowerWickRatio >= minWickRatio and candleATR >= minCandleATR
bool isMajorUpthrust = majorFakeBreakout and upperWickRatio >= minWickRatio and candleATR >= minCandleATR

// Climax detection
bool isClimaxCandle = candleATR >= climaxRangeATR and avgVol > 0 and volume >= climaxVolFact * avgVol
bool isSellingClimax = isClimaxCandle and close < open
bool isBuyingClimax  = isClimaxCandle and close > open

// ── Climax Sequence State Machine (mirrored from structure events) ──
var int   clxState     = 0
var int   clxDirection  = 0
var float clxClose     = na
var float clxHigh      = na
var float clxLow       = na
var float clxRange     = na
var float clxVolume    = na
var int   clxBar       = na
var int   clxTestBar   = na

if isClimaxCandle
    clxState     := 1
    clxDirection := isSellingClimax ? 1 : isBuyingClimax ? -1 : 0
    clxClose     := close
    clxHigh      := high
    clxLow       := low
    clxRange     := candleRange
    clxVolume    := volume
    clxBar       := bar_index
    clxTestBar   := na

int clxLookback = 20
bool hasActiveClx = clxState >= 1 and not na(clxBar) and (bar_index - clxBar) <= clxLookback

if hasActiveClx and clxState == 1
    if clxDirection == 1 and close > clxClose
        clxState := 2
    if clxDirection == -1 and close < clxClose
        clxState := 2

if hasActiveClx and clxState == 2
    bool returningToZone = false
    if clxDirection == 1 and not na(clxClose) and atr14 > 0
        returningToZone := close < clxClose + 1.5 * atr14 and close > clxLow - 0.5 * atr14
    if clxDirection == -1 and not na(clxClose) and atr14 > 0
        returningToZone := close > clxClose - 1.5 * atr14 and close < clxHigh + 0.5 * atr14
    if returningToZone and (bar_index - clxBar) >= 2
        clxState := 3

if hasActiveClx and clxState == 3
    bool isTestBar = not na(clxRange) and not na(clxVolume) and candleRange <= clxRange * 0.6 and volume <= clxVolume * 0.7 and candleRange > 0
    bool inZone = not na(clxClose) and atr14 > 0 and math.abs(close - clxClose) <= 1.5 * atr14
    if isTestBar and inZone
        clxState   := 4
        clxTestBar := bar_index

if hasActiveClx and clxState == 4
    if clxDirection == 1 and (microBullBOS or majorBullBOS)
        clxState := 5
    if clxDirection == -1 and (microBearBOS or majorBearBOS)
        clxState := 5

if hasActiveClx and not na(clxBar) and (bar_index - clxBar) > clxLookback
    clxState := 0

bool clxTestValid    = clxState == 4 or clxState == 5
bool clxConfirmed    = clxState == 5
bool clxBullSequence = clxDirection == 1 and clxState >= 1
bool clxBearSequence = clxDirection == -1 and clxState >= 1
string clxStateStr   = clxState == 0 ? "—" : clxState == 1 ? "CLX" : clxState == 2 ? "REACTING" : clxState == 3 ? "TEST PENDING" : clxState == 4 ? "TEST VALID" : clxState == 5 ? "CONFIRMED" : "—"

bool isTestCandle = clxState == 4 and bar_index == clxTestBar

// ============================================================================
// MODULE: Layer A — SETUP SCORE (bullish)
// ============================================================================
// Momentum + Overextension + Candle + Volume
// Max theoretical: ~8.5

float bullSetup = 0.0

// RSI in oversold zone
if rsi14 < rsiBullThresh
    bullSetup += 1.0
// RSI turning up from low
if rsi14 < rsiBullThresh + 10 and rsi14 > rsi14[1]
    bullSetup += 0.5

// MFI in oversold zone
if mfi14 < mfiBullThresh
    bullSetup += 1.0
// MFI turning up
if mfi14 > mfi14[1] and mfi14[1] < mfiBullThresh + 10
    bullSetup += 0.5

// Stoch RSI in low zone (only in variant B/C)
if useStochRSI and stochRsiKVal < stochExtLow
    bullSetup += 0.5
// Stoch RSI bullish cross (only in variant B/C)
if useStochRSI and ta.crossover(stochRsiKVal, stochRsiDVal) and stochRsiKVal < stochExtLow + 15
    bullSetup += 1.0

// MACD histogram turning (only in variant A/C)
if useMACD and macdHist > macdHist[1] and macdHist[1] < 0
    bullSetup += 0.5

// Price below EMA20
if priceToEma20ATR < -priceEmaATRThresh
    bullSetup += 1.0
if priceToEma20ATR < -priceEmaATRThresh * 1.5
    bullSetup += 0.5

// Bollinger lower band
if low <= bbLower
    bullSetup += 1.0

// Strong lower wick
if lowerWickRatio >= wickThresh
    bullSetup += 1.0

// Level context bonus
if bullAtLevel
    bullSetup += 1.0

// Deductions
if ema20Slope < -math.abs(slopeThresh) and slopeThresh > 0
    bullSetup -= 1.0
if relVol < 0.6
    bullSetup -= 0.5
// Far from any meaningful level — penalty
if not bullAtLevel and not na(distToMajorSwingLowATR) and distToMajorSwingLowATR > 2.0 and distToRange20Low > 0.5
    bullSetup -= 0.5

bullSetup := math.max(0.0, bullSetup) * setupMultiplier

// ============================================================================
// MODULE: Layer B — CONFIRMATION SCORE (bullish)
// ============================================================================
// Structure events only
// Max theoretical: ~6.5

float bullConf = 0.0

// Spring quality factors for scoring
float sprSweep = isSpring and not na(lastSwingLow) and atr14 > 0 ? (lastSwingLow - low) / atr14 : 0.0
float majSprSweep = isMajorSpring and not na(lastMajorSwingLow) and atr14 > 0 ? (lastMajorSwingLow - low) / atr14 : 0.0
float bullBOSSw = microBullBOS and not na(lastSwingHigh) and atr14 > 0 ? (close - lastSwingHigh) / atr14 : 0.0
float majBullBOSSw = majorBullBOS and not na(lastMajorSwingHigh) and atr14 > 0 ? (close - lastMajorSwingHigh) / atr14 : 0.0

// Spring scoring helper
f_springScore(bool triggered, float wickR, float cATR, float rv, float sweep, bool isMajor) =>
    float sc = 0.0
    if triggered
        int factors = 0
        if wickR >= 0.55
            factors += 1
        if cATR >= 0.8
            factors += 1
        if rv >= 1.3
            factors += 1
        if sweep >= 0.15
            factors += 1
        // weak=1, normal=2, strong=3+
        float base = isMajor ? 3.0 : 1.5
        sc := factors >= 3 ? base + 1.5 : factors >= 1 ? base + 0.5 : base
    sc

// Major Spring
if isMajorSpring
    bullConf += f_springScore(true, lowerWickRatio, candleATR, relVol, majSprSweep, true)
// Micro Spring
else if isSpring
    bullConf += f_springScore(true, lowerWickRatio, candleATR, relVol, sprSweep, false)

// BOS scoring helper
f_bosScore(bool triggered, float sweep, float rv, bool isMajor) =>
    float sc = 0.0
    if triggered
        int factors = 0
        if sweep >= 0.1
            factors += 1
        if sweep >= 0.3
            factors += 1
        if rv >= 1.3
            factors += 1
        float base = isMajor ? 2.0 : 0.5
        sc := factors >= 2 ? base + 1.5 : factors >= 1 ? base + 0.5 : base
    sc

// Major BOS
if majorBullBOS
    bullConf += f_bosScore(true, majBullBOSSw, relVol, true)
// Micro BOS
else if microBullBOS
    bullConf += f_bosScore(true, bullBOSSw, relVol, false)

// Fake Breakdown at swing (without Spring quality)
if fakeBreakdown and not isSpring and not isMajorSpring
    bullConf += 0.5
if majorFakeBreakdown and not isMajorSpring
    bullConf += 1.0

// ── Climax Sequence (progressive scoring) ──
// Each stage of the sequence adds more confirmation
// Selling climax = bullish reversal potential
if isClimaxCandle and close < ema20
    bullConf += 1.0   // CLX detected

// Test validated after climax
if clxTestValid and clxDirection == 1
    bullConf += 1.5   // Test confirms climax wasn't just noise

// Full sequence: CLX → Test → BOS
if clxConfirmed and clxDirection == 1
    bullConf += 2.5   // Strongest possible confirmation

bullConf := math.max(0.0, bullConf) * confMultiplier * volBonus

// ============================================================================
// MODULE: Layer A — SETUP SCORE (bearish)
// ============================================================================

float bearSetup = 0.0

// RSI in overbought zone
if rsi14 > rsiBearThresh
    bearSetup += 1.0
if rsi14 > rsiBearThresh - 10 and rsi14 < rsi14[1]
    bearSetup += 0.5

// MFI in overbought zone
if mfi14 > mfiBearThresh
    bearSetup += 1.0
if mfi14 < mfi14[1] and mfi14[1] > mfiBearThresh - 10
    bearSetup += 0.5

// Stoch RSI in high zone (only in variant B/C)
if useStochRSI and stochRsiKVal > stochExtHigh
    bearSetup += 0.5
if useStochRSI and ta.crossunder(stochRsiKVal, stochRsiDVal) and stochRsiKVal > stochExtHigh - 15
    bearSetup += 1.0

// MACD histogram turning (only in variant A/C)
if useMACD and macdHist < macdHist[1] and macdHist[1] > 0
    bearSetup += 0.5

// Price above EMA20
if priceToEma20ATR > priceEmaATRThresh
    bearSetup += 1.0
if priceToEma20ATR > priceEmaATRThresh * 1.5
    bearSetup += 0.5

// Bollinger upper band
if high >= bbUpper
    bearSetup += 1.0

// Strong upper wick
if upperWickRatio >= wickThresh
    bearSetup += 1.0

// Level context bonus
if bearAtLevel
    bearSetup += 1.0

// Deductions
if ema20Slope > math.abs(slopeThresh) and slopeThresh > 0
    bearSetup -= 1.0
if relVol < 0.6
    bearSetup -= 0.5
// Far from any meaningful level — penalty
if not bearAtLevel and not na(distToMajorSwingHighATR) and distToMajorSwingHighATR < -2.0 and distToRange20High > 0.5
    bearSetup -= 0.5

bearSetup := math.max(0.0, bearSetup) * setupMultiplier

// ============================================================================
// MODULE: Layer B — CONFIRMATION SCORE (bearish)
// ============================================================================

float bearConf = 0.0

// Upthrust quality factors
float utSweep = isUpthrust and not na(lastSwingHigh) and atr14 > 0 ? (high - lastSwingHigh) / atr14 : 0.0
float majUtSweep = isMajorUpthrust and not na(lastMajorSwingHigh) and atr14 > 0 ? (high - lastMajorSwingHigh) / atr14 : 0.0
float bearBOSSw = microBearBOS and not na(lastSwingLow) and atr14 > 0 ? (lastSwingLow - close) / atr14 : 0.0
float majBearBOSSw = majorBearBOS and not na(lastMajorSwingLow) and atr14 > 0 ? (lastMajorSwingLow - close) / atr14 : 0.0

// Major Upthrust
if isMajorUpthrust
    bearConf += f_springScore(true, upperWickRatio, candleATR, relVol, majUtSweep, true)
// Micro Upthrust
else if isUpthrust
    bearConf += f_springScore(true, upperWickRatio, candleATR, relVol, utSweep, false)

// Major BOS
if majorBearBOS
    bearConf += f_bosScore(true, majBearBOSSw, relVol, true)
// Micro BOS
else if microBearBOS
    bearConf += f_bosScore(true, bearBOSSw, relVol, false)

// Fake Breakout at swing (without Upthrust quality)
if fakeBreakout and not isUpthrust and not isMajorUpthrust
    bearConf += 0.5
if majorFakeBreakout and not isMajorUpthrust
    bearConf += 1.0

// ── Climax Sequence (progressive scoring) ──
// Buying climax = bearish reversal potential
if isClimaxCandle and close > ema20
    bearConf += 1.0

// Test validated after climax
if clxTestValid and clxDirection == -1
    bearConf += 1.5

// Full sequence: CLX → Test → BOS
if clxConfirmed and clxDirection == -1
    bearConf += 2.5

bearConf := math.max(0.0, bearConf) * confMultiplier * volBonus

// ============================================================================
// MODULE: event tracking — trigger level + age
// ============================================================================
// Track the most recent bull/bear confirmation event for follow-through

var float bullTriggerLevel = na   // price level the bull event occurred at
var int   bullEventBar     = na   // bar_index when bull event fired
var float bullEventConf    = 0.0  // confirmation score at time of event
var float bearTriggerLevel = na
var int   bearEventBar     = na
var float bearEventConf    = 0.0

// Register new bull confirmation events
bool newBullEvent = (isSpring or isMajorSpring or microBullBOS or majorBullBOS or (clxConfirmed and clxDirection == 1))
bool newBearEvent = (isUpthrust or isMajorUpthrust or microBearBOS or majorBearBOS or (clxConfirmed and clxDirection == -1))

if newBullEvent
    bullTriggerLevel := isSpring or isMajorSpring ? low : close
    bullEventBar     := bar_index
    bullEventConf    := bullConf
if newBearEvent
    bearTriggerLevel := isUpthrust or isMajorUpthrust ? high : close
    bearEventBar     := bar_index
    bearEventConf    := bearConf

// ============================================================================
// MODULE: event decay
// ============================================================================
// Events lose weight over time. After decayBars, confirmation is heavily discounted.

int decayStart = 3    // bars before decay begins
int decayFull  = 6    // bars until event is expired

int bullEventAge = not na(bullEventBar) ? bar_index - bullEventBar : 999
int bearEventAge = not na(bearEventBar) ? bar_index - bearEventBar : 999

// Decay multiplier: 1.0 within decayStart, linear fade to 0.2 at decayFull, then 0
float bullDecay = bullEventAge <= decayStart ? 1.0 : bullEventAge <= decayFull ? 1.0 - 0.8 * (bullEventAge - decayStart) / (decayFull - decayStart) : 0.0
float bearDecay = bearEventAge <= decayStart ? 1.0 : bearEventAge <= decayFull ? 1.0 - 0.8 * (bearEventAge - decayStart) / (decayFull - decayStart) : 0.0

// Apply decay to confirmation scores
float bullConfDecayed = bullConf * bullDecay
float bearConfDecayed = bearConf * bearDecay

// ============================================================================
// MODULE: follow-through
// ============================================================================
// After a bull/bear event, check if price confirms in the expected direction.
// Follow-through requires within 2-4 bars after event:
//   Bull: higher close, price holds above trigger level
//   Bear: lower close, price holds below trigger level

bool bullEventActive = bullEventAge >= 1 and bullEventAge <= 4 and not na(bullTriggerLevel)
bool bearEventActive = bearEventAge >= 1 and bearEventAge <= 4 and not na(bearTriggerLevel)

// Bull follow-through checks
bool bullHigherClose    = bullEventActive and close > close[1]
bool bullHoldsAbove     = bullEventActive and close > bullTriggerLevel
bool bullNoCounterBOS   = bullEventActive and not microBearBOS and not majorBearBOS
bool bullFollowThrough  = bullHigherClose and bullHoldsAbove and bullNoCounterBOS

// Bear follow-through checks
bool bearLowerClose     = bearEventActive and close < close[1]
bool bearHoldsBelow     = bearEventActive and close < bearTriggerLevel
bool bearNoCounterBOS   = bearEventActive and not microBullBOS and not majorBullBOS
bool bearFollowThrough  = bearLowerClose and bearHoldsBelow and bearNoCounterBOS

// Track if follow-through was ever achieved for current event
var bool bullFTAchieved = false
var bool bearFTAchieved = false

if newBullEvent
    bullFTAchieved := false
if newBearEvent
    bearFTAchieved := false
if bullFollowThrough
    bullFTAchieved := true
if bearFollowThrough
    bearFTAchieved := true

// ============================================================================
// MODULE: failed reversal / trap detection
// ============================================================================
// A confirmed event that fails to follow through, or where price
// breaks back through the trigger level, is a failed reversal.
// Failed reversals can hint at continuation in the opposite direction.

bool bullExpiredNoFT = bullEventAge > decayFull and not bullFTAchieved and not na(bullTriggerLevel)
bool bearExpiredNoFT = bearEventAge > decayFull and not bearFTAchieved and not na(bearTriggerLevel)

// Active failure: price breaks back through trigger level after event
bool bullTriggerLost = not na(bullTriggerLevel) and bullEventAge >= 1 and bullEventAge <= decayFull * 2 and close < bullTriggerLevel and bullFTAchieved
bool bearTriggerLost = not na(bearTriggerLevel) and bearEventAge >= 1 and bearEventAge <= decayFull * 2 and close > bearTriggerLevel and bearFTAchieved

// Failed status
var bool bullFailed = false
var bool bearFailed = false

if newBullEvent
    bullFailed := false
if newBearEvent
    bearFailed := false
if bullExpiredNoFT or bullTriggerLost
    bullFailed := true
if bearExpiredNoFT or bearTriggerLost
    bearFailed := true

// Trap hint: failed reversal suggests opposite direction
bool bullTrapHint = bullFailed and bearSetup > 0  // failed bull = potential bear continuation
bool bearTrapHint = bearFailed and bullSetup > 0  // failed bear = potential bull continuation

// ============================================================================
// MODULE: combined status
// ============================================================================

// Raw setup/conf thresholds
bool bullSetupReady   = bullSetup >= setupReady
bool bullSetupStrong  = bullSetup >= setupStrong
bool bullConfirmed    = bullConfDecayed >= confRequired  // uses decayed confirmation

bool bearSetupReady   = bearSetup >= setupReady
bool bearSetupStrong  = bearSetup >= setupStrong
bool bearConfirmed    = bearConfDecayed >= confRequired

// ── Conflict detection (multi-dimensional) ──

bool setupConflict = bullSetupReady and bearSetupReady
bool confConflict = bullConfirmed and bearConfirmed
bool bullTrendConflict = bullSetupReady and isTrendDown and efficiencyRatio > 0.45
bool bearTrendConflict = bearSetupReady and isTrendUp and efficiencyRatio > 0.45
bool bullCandidateOpposed = bullSetupReady and bullConfirmed and bearConfirmed
bool bearCandidateOpposed = bearSetupReady and bearConfirmed and bullConfirmed

bool isConflict = setupConflict or confConflict or bullTrendConflict or bearTrendConflict or bullCandidateOpposed or bearCandidateOpposed
bool bothConfirmed = confConflict

int conflictCount = (setupConflict ? 1 : 0) + (confConflict ? 1 : 0) + (bullTrendConflict ? 1 : 0) + (bearTrendConflict ? 1 : 0)
string conflictSeverity = conflictCount >= 3 ? "HIGH" : conflictCount >= 2 ? "MODERATE" : conflictCount >= 1 ? "LOW" : "NONE"

string conflictReason = ""
if setupConflict
    conflictReason := "Both setups active"
if confConflict
    conflictReason := conflictReason + (str.length(conflictReason) > 0 ? " + " : "") + "Both confirmed"
if bullTrendConflict
    conflictReason := conflictReason + (str.length(conflictReason) > 0 ? " + " : "") + "Bull vs downtrend"
if bearTrendConflict
    conflictReason := conflictReason + (str.length(conflictReason) > 0 ? " + " : "") + "Bear vs uptrend"

// ── Status with follow-through and failure awareness ──
string bullStatus = "—"
if bullFailed
    bullStatus := "FAILED"
else if bullSetupReady and bullConfirmed and bullFTAchieved
    bullStatus := bullCandidateOpposed ? "CONFLICTED" : bullTrendConflict ? "CONFLICTED" : "CANDIDATE"
else if bullSetupReady and bullConfirmed and not bullFTAchieved and bullEventActive
    bullStatus := bullCandidateOpposed ? "CONFLICTED" : bullTrendConflict ? "CONFLICTED" : "PENDING"
else if bullSetupReady and bullConfirmed
    bullStatus := bullCandidateOpposed ? "CONFLICTED" : bullTrendConflict ? "CONFLICTED" : bullDecay < 0.5 ? "EXPIRED" : "CANDIDATE"
else if bullSetupStrong
    bullStatus := bullTrendConflict ? "CONFLICTED" : "SETUP"
else if bullConfirmed and not bullSetupReady
    bullStatus := "ALERT"
else if bullSetupReady
    bullStatus := "WATCH"

string bearStatus = "—"
if bearFailed
    bearStatus := "FAILED"
else if bearSetupReady and bearConfirmed and bearFTAchieved
    bearStatus := bearCandidateOpposed ? "CONFLICTED" : bearTrendConflict ? "CONFLICTED" : "CANDIDATE"
else if bearSetupReady and bearConfirmed and not bearFTAchieved and bearEventActive
    bearStatus := bearCandidateOpposed ? "CONFLICTED" : bearTrendConflict ? "CONFLICTED" : "PENDING"
else if bearSetupReady and bearConfirmed
    bearStatus := bearCandidateOpposed ? "CONFLICTED" : bearTrendConflict ? "CONFLICTED" : bearDecay < 0.5 ? "EXPIRED" : "CANDIDATE"
else if bearSetupStrong
    bearStatus := bearTrendConflict ? "CONFLICTED" : "SETUP"
else if bearConfirmed and not bearSetupReady
    bearStatus := "ALERT"
else if bearSetupReady
    bearStatus := "WATCH"

// Overall market state
string marketState = bothConfirmed ? "CONFLICT" : setupConflict ? "MIXED" : bullStatus == "CANDIDATE" ? "BULL CANDIDATE" : bearStatus == "CANDIDATE" ? "BEAR CANDIDATE" : bullStatus == "PENDING" ? "BULL PENDING" : bearStatus == "PENDING" ? "BEAR PENDING" : bullStatus == "FAILED" ? "BULL FAILED" : bearStatus == "FAILED" ? "BEAR FAILED" : bullStatus == "SETUP" ? "BULL SETUP" : bearStatus == "SETUP" ? "BEAR SETUP" : bullStatus == "WATCH" or bearStatus == "WATCH" ? "BUILDING" : "QUIET"

// Combined scores
float bullScore = bullSetup + bullConf
float bearScore = bearSetup + bearConf

// (Conflict detection and marketState are defined in the combined status module above)

// ============================================================================
// MODULE: visuals — dual score plot
// ============================================================================

// Setup bars
color bullSetupColor = bullSetupStrong ? color.new(#00e676, 20) : bullSetupReady ? color.new(#00e676, 50) : bullSetup > 0 ? color.new(#00e676, 75) : na
color bearSetupColor = bearSetupStrong ? color.new(#ff1744, 20) : bearSetupReady ? color.new(#ff1744, 50) : bearSetup > 0 ? color.new(#ff1744, 75) : na

plot(bullSetup, "Bull Setup", color=bullSetupColor, style=plot.style_columns, linewidth=4)
plot(-bearSetup, "Bear Setup", color=bearSetupColor, style=plot.style_columns, linewidth=4)

// Confirmation dots (bright, on top)
color bullConfColor = bullConfirmed ? color.new(#00e676, 0) : bullConf > 0 ? color.new(#00e676, 40) : na
color bearConfColor = bearConfirmed ? color.new(#ff1744, 0) : bearConf > 0 ? color.new(#ff1744, 40) : na

plot(bullConf > 0 ? bullSetup + bullConf : na, "Bull Confirmation", color=bullConfColor, style=plot.style_circles, linewidth=4)
plot(bearConf > 0 ? -(bearSetup + bearConf) : na, "Bear Confirmation", color=bearConfColor, style=plot.style_circles, linewidth=4)

// ── Component lines (optional, for research) ──
plot(showComponents ? bullSetup : na, "Bull Setup Line", color=color.new(#00e676, 30), linewidth=2, style=plot.style_stepline)
plot(showComponents ? bullConf : na, "Bull Conf Line", color=color.new(#69f0ae, 0), linewidth=2, style=plot.style_stepline)
plot(showComponents ? -bearSetup : na, "Bear Setup Line", color=color.new(#ff1744, 30), linewidth=2, style=plot.style_stepline)
plot(showComponents ? -bearConf : na, "Bear Conf Line", color=color.new(#ff8a80, 0), linewidth=2, style=plot.style_stepline)

// Reference lines
hline(setupStrong, "Setup Strong", color=color.new(#00e676, 50), linestyle=hline.style_dotted)
hline(setupReady, "Setup Ready", color=color.new(color.yellow, 50), linestyle=hline.style_dotted)
hline(0, "Zero", color=color.new(color.gray, 65))
hline(-setupReady, "Setup Ready Bear", color=color.new(color.yellow, 50), linestyle=hline.style_dotted)
hline(-setupStrong, "Setup Strong Bear", color=color.new(#ff1744, 50), linestyle=hline.style_dotted)

// Background — status-driven coloring
color bgColor = na
if showBg
    if bullStatus == "FAILED" or bearStatus == "FAILED"
        bgColor := color.new(#ff6d00, 90)  // orange = failed reversal
    else if bullStatus == "CONFLICTED" or bearStatus == "CONFLICTED"
        bgColor := color.new(#78909c, 80)
    else if bothConfirmed
        bgColor := color.new(#ffab00, 82)
    else if setupConflict
        bgColor := color.new(#78909c, 88)
    else if bullStatus == "CANDIDATE"
        bgColor := color.new(#00e676, 85)
    else if bearStatus == "CANDIDATE"
        bgColor := color.new(#ff1744, 85)
    else if bullStatus == "PENDING"
        bgColor := color.new(#00e676, 92)
    else if bearStatus == "PENDING"
        bgColor := color.new(#ff1744, 92)
    else if bullStatus == "ALERT" or bearStatus == "ALERT"
        bgColor := color.new(#ffab00, 92)
bgcolor(bgColor)

// ============================================================================
// MODULE: status bar (always visible, bottom left)
// ============================================================================

var table statusBar = na
if barstate.islast
    statusBar := table.new(position.bottom_left, 8, 2, bgcolor=color.new(#1a1a2e, 5), border_color=color.new(color.gray, 60), border_width=1, frame_color=color.new(color.gray, 60), frame_width=1)

    // Row 0: Labels
    // Regime cells
    color regimeColor = isTrendUp ? #00e676 : isTrendDown ? #ff1744 : #ffab00
    color volColor = isHighVol ? color.orange : isLowVol ? color.new(color.gray, 30) : color.new(color.white, 50)
    table.cell(statusBar, 0, 0, regime, text_color=regimeColor, text_size=size.small, text_halign=text.align_center)
    table.cell(statusBar, 1, 0, volRegime, text_color=volColor, text_size=size.small, text_halign=text.align_center)
    // Score cells
    table.cell(statusBar, 2, 0, "BULL", text_color=color.new(color.white, 40), text_size=size.small, text_halign=text.align_center)
    table.cell(statusBar, 3, 0, "Setup", text_color=color.new(color.white, 40), text_size=size.small, text_halign=text.align_center)
    table.cell(statusBar, 4, 0, "Conf", text_color=color.new(color.white, 40), text_size=size.small, text_halign=text.align_center)
    table.cell(statusBar, 5, 0, "BEAR", text_color=color.new(color.white, 40), text_size=size.small, text_halign=text.align_center)
    table.cell(statusBar, 6, 0, "Setup", text_color=color.new(color.white, 40), text_size=size.small, text_halign=text.align_center)
    table.cell(statusBar, 7, 0, "Conf", text_color=color.new(color.white, 40), text_size=size.small, text_halign=text.align_center)

    // Row 1: Regime multipliers + state indicators
    string regimeDetail = "ER: " + str.tostring(efficiencyRatio, "#.00")
    table.cell(statusBar, 0, 1, regimeDetail, text_color=color.new(color.white, 50), text_size=size.small, text_halign=text.align_center)
    string volDetail = "Setup×" + str.tostring(setupMultiplier, "#.0") + " Conf×" + str.tostring(confMultiplier * volBonus, "#.0")
    table.cell(statusBar, 1, 1, volDetail, text_color=color.new(color.white, 50), text_size=size.small, text_halign=text.align_center)

    // Bull status icon
    string bullIcon = bullStatus == "CANDIDATE" ? "◉" : bullStatus == "PENDING" ? "◎" : bullStatus == "CONFLICTED" ? "⊘" : bullStatus == "FAILED" ? "✗" : bullStatus == "EXPIRED" ? "◌" : bullStatus == "SETUP" ? "◈" : bullStatus == "WATCH" ? "○" : bullStatus == "ALERT" ? "⚡" : "·"
    color  bullIconColor = bullStatus == "CANDIDATE" ? #00e676 : bullStatus == "PENDING" ? color.new(#00e676, 30) : bullStatus == "CONFLICTED" ? #78909c : bullStatus == "FAILED" ? #ff6d00 : bullStatus == "EXPIRED" ? color.new(color.gray, 30) : bullStatus == "SETUP" ? color.yellow : bullStatus == "WATCH" ? color.new(color.white, 30) : bullStatus == "ALERT" ? #ffab00 : color.gray
    color  bullIconBg = bullStatus == "CANDIDATE" ? color.new(#00e676, 80) : bullStatus == "CONFLICTED" ? color.new(#78909c, 75) : bullStatus == "FAILED" ? color.new(#ff6d00, 80) : na
    table.cell(statusBar, 2, 1, bullIcon + " " + bullStatus, text_color=bullIconColor, text_size=size.normal, text_halign=text.align_center, bgcolor=bullIconBg)

    color bullSetupValColor = bullSetupStrong ? #00e676 : bullSetupReady ? color.yellow : color.gray
    table.cell(statusBar, 3, 1, str.tostring(bullSetup, "#.0"), text_color=bullSetupValColor, text_size=size.normal, text_halign=text.align_center)

    color bullConfValColor = bullConfirmed ? #00e676 : bullConf > 0 ? color.new(#00e676, 40) : color.gray
    table.cell(statusBar, 4, 1, str.tostring(bullConf, "#.0"), text_color=bullConfValColor, text_size=size.normal, text_halign=text.align_center)

    // Bear status icon
    string bearIcon = bearStatus == "CANDIDATE" ? "◉" : bearStatus == "PENDING" ? "◎" : bearStatus == "CONFLICTED" ? "⊘" : bearStatus == "FAILED" ? "✗" : bearStatus == "EXPIRED" ? "◌" : bearStatus == "SETUP" ? "◈" : bearStatus == "WATCH" ? "○" : bearStatus == "ALERT" ? "⚡" : "·"
    color  bearIconColor = bearStatus == "CANDIDATE" ? #ff1744 : bearStatus == "PENDING" ? color.new(#ff1744, 30) : bearStatus == "CONFLICTED" ? #78909c : bearStatus == "FAILED" ? #ff6d00 : bearStatus == "EXPIRED" ? color.new(color.gray, 30) : bearStatus == "SETUP" ? color.yellow : bearStatus == "WATCH" ? color.new(color.white, 30) : bearStatus == "ALERT" ? #ffab00 : color.gray
    color  bearIconBg = bearStatus == "CANDIDATE" ? color.new(#ff1744, 80) : bearStatus == "CONFLICTED" ? color.new(#78909c, 75) : bearStatus == "FAILED" ? color.new(#ff6d00, 80) : na
    table.cell(statusBar, 5, 1, bearIcon + " " + bearStatus, text_color=bearIconColor, text_size=size.normal, text_halign=text.align_center, bgcolor=bearIconBg)

    color bearSetupValColor = bearSetupStrong ? #ff1744 : bearSetupReady ? color.yellow : color.gray
    table.cell(statusBar, 6, 1, str.tostring(bearSetup, "#.0"), text_color=bearSetupValColor, text_size=size.normal, text_halign=text.align_center)

    color bearConfValColor = bearConfirmed ? #ff1744 : bearConf > 0 ? color.new(#ff1744, 40) : color.gray
    table.cell(statusBar, 7, 1, str.tostring(bearConf, "#.0"), text_color=bearConfValColor, text_size=size.normal, text_halign=text.align_center)

// ============================================================================
// MODULE: data window
// ============================================================================

plot(nz(distToMajorSwingHighATR), "Dist Major SH (ATR) [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(nz(distToMajorSwingLowATR), "Dist Major SL (ATR) [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(distToRange20High, "Dist Range20 High [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(distToRange20Low, "Dist Range20 Low [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullAtLevel ? 1 : 0, "Bull At Level [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearAtLevel ? 1 : 0, "Bear At Level [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(efficiencyRatio, "Efficiency Ratio [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bbWidthRatio, "BB Width Ratio [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(isTrendUp ? 1 : isTrendDown ? -1 : 0, "Trend Direction [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(isHighVol ? 1 : isLowVol ? -1 : 0, "Vol Regime [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(setupMultiplier, "Setup Multiplier [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(confMultiplier * volBonus, "Conf Multiplier [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullSetup, "Bull Setup [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullConf, "Bull Conf [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullSetupReady ? 1 : 0, "Bull Setup Active [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullConfirmed ? 1 : 0, "Bull Confirmed [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearSetup, "Bear Setup [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearConf, "Bear Conf [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearSetupReady ? 1 : 0, "Bear Setup Active [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearConfirmed ? 1 : 0, "Bear Confirmed [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(isConflict ? 1 : 0, "Conflict [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(conflictCount, "Conflict Count (0-4) [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullTrendConflict ? 1 : 0, "Bull Trend Conflict [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearTrendConflict ? 1 : 0, "Bear Trend Conflict [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullStatus == "CONFLICTED" ? 1 : 0, "Bull Conflicted [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearStatus == "CONFLICTED" ? 1 : 0, "Bear Conflicted [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullFTAchieved ? 1 : 0, "Bull Follow-Through [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearFTAchieved ? 1 : 0, "Bear Follow-Through [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullFailed ? 1 : 0, "Bull Failed [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearFailed ? 1 : 0, "Bear Failed [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullDecay, "Bull Event Decay [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearDecay, "Bear Event Decay [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullEventAge < 999 ? bullEventAge : na, "Bull Event Age [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearEventAge < 999 ? bearEventAge : na, "Bear Event Age [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bullScore, "Bull Total [dw]", display=display.data_window, color=color.new(color.gray, 100))
plot(bearScore, "Bear Total [dw]", display=display.data_window, color=color.new(color.gray, 100))

// ============================================================================
// MODULE: debug / research table
// ============================================================================

bool isDebug   = displayMode == "Debug" or displayMode == "Research"
bool isResearch = displayMode == "Research"

var table scoreTable = na
if isDebug and barstate.islast
    scoreTable := table.new(position.top_right, 3, 18, bgcolor=color.new(#1a1a2e, 5), border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.gray, 50), frame_width=2)

    // Header
    table.cell(scoreTable, 0, 0, "NG Score v0.2 [" + scoreVariant + "]", text_color=color.white, text_size=size.normal)
    table.cell(scoreTable, 1, 0, "Bull", text_color=#00e676, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 0, "Bear", text_color=#ff1744, text_size=size.normal, text_halign=text.align_right)

    // Layer A header
    table.cell(scoreTable, 0, 1, "─ SETUP ─", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(scoreTable, 1, 1, "", text_size=size.small)
    table.cell(scoreTable, 2, 1, "", text_size=size.small)

    table.cell(scoreTable, 0, 2, "RSI " + str.tostring(rsi14, "#.0"), text_color=color.yellow, text_size=size.normal)
    table.cell(scoreTable, 1, 2, rsi14 < rsiBullThresh ? "✓" : "·", text_color=rsi14 < rsiBullThresh ? #00e676 : color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 2, rsi14 > rsiBearThresh ? "✓" : "·", text_color=rsi14 > rsiBearThresh ? #ff1744 : color.gray, text_size=size.normal, text_halign=text.align_right)

    table.cell(scoreTable, 0, 3, "MFI " + str.tostring(mfi14, "#.0"), text_color=color.teal, text_size=size.normal)
    table.cell(scoreTable, 1, 3, mfi14 < mfiBullThresh ? "✓" : "·", text_color=mfi14 < mfiBullThresh ? #00e676 : color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 3, mfi14 > mfiBearThresh ? "✓" : "·", text_color=mfi14 > mfiBearThresh ? #ff1744 : color.gray, text_size=size.normal, text_halign=text.align_right)

    table.cell(scoreTable, 0, 4, "StochK " + str.tostring(stochRsiKVal, "#.0"), text_color=color.aqua, text_size=size.normal)
    table.cell(scoreTable, 1, 4, stochRsiKVal < stochExtLow ? "✓" : "·", text_color=stochRsiKVal < stochExtLow ? #00e676 : color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 4, stochRsiKVal > stochExtHigh ? "✓" : "·", text_color=stochRsiKVal > stochExtHigh ? #ff1744 : color.gray, text_size=size.normal, text_halign=text.align_right)

    table.cell(scoreTable, 0, 5, "Pr→EMA " + str.tostring(priceToEma20ATR, "#.00"), text_color=color.orange, text_size=size.normal)
    table.cell(scoreTable, 1, 5, priceToEma20ATR < -priceEmaATRThresh ? "✓" : "·", text_color=priceToEma20ATR < -priceEmaATRThresh ? #00e676 : color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 5, priceToEma20ATR > priceEmaATRThresh ? "✓" : "·", text_color=priceToEma20ATR > priceEmaATRThresh ? #ff1744 : color.gray, text_size=size.normal, text_halign=text.align_right)

    table.cell(scoreTable, 0, 6, "At Level", text_color=color.new(color.white, 30), text_size=size.normal)
    table.cell(scoreTable, 1, 6, bullAtLevel ? "✓ LEVEL" : "·", text_color=bullAtLevel ? #00e676 : color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 6, bearAtLevel ? "✓ LEVEL" : "·", text_color=bearAtLevel ? #ff1744 : color.gray, text_size=size.normal, text_halign=text.align_right)

    // Setup total
    table.cell(scoreTable, 0, 7, "SETUP SCORE", text_color=color.white, text_size=size.normal)
    table.cell(scoreTable, 1, 7, str.tostring(bullSetup, "#.0"), text_color=bullSetupStrong ? #00e676 : bullSetupReady ? color.yellow : color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 7, str.tostring(bearSetup, "#.0"), text_color=bearSetupStrong ? #ff1744 : bearSetupReady ? color.yellow : color.gray, text_size=size.normal, text_halign=text.align_right)

    // Layer B header
    table.cell(scoreTable, 0, 8, "─ CONFIRM ─", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(scoreTable, 1, 8, "", text_size=size.small)
    table.cell(scoreTable, 2, 8, "", text_size=size.small)

    table.cell(scoreTable, 0, 9, "Spring / UT", text_color=color.new(color.white, 30), text_size=size.normal)
    table.cell(scoreTable, 1, 9, isSpring ? "SPRING" : "—", text_color=isSpring ? #00e676 : color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 9, isUpthrust ? "UT" : "—", text_color=isUpthrust ? #ff1744 : color.gray, text_size=size.normal, text_halign=text.align_right)

    table.cell(scoreTable, 0, 10, "BOS", text_color=color.new(color.white, 30), text_size=size.normal)
    string bullBOSText = majorBullBOS ? "MAJOR ↑" : microBullBOS ? "micro ↑" : "—"
    string bearBOSText = majorBearBOS ? "MAJOR ↓" : microBearBOS ? "micro ↓" : "—"
    table.cell(scoreTable, 1, 10, bullBOSText, text_color=majorBullBOS ? #00e676 : microBullBOS ? color.new(#00e676, 40) : color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 10, bearBOSText, text_color=majorBearBOS ? #ff1744 : microBearBOS ? color.new(#ff1744, 40) : color.gray, text_size=size.normal, text_halign=text.align_right)

    table.cell(scoreTable, 0, 11, "Fake Break", text_color=color.new(color.white, 30), text_size=size.normal)
    table.cell(scoreTable, 1, 11, fakeBreakdown and not isSpring ? "FB ↓" : "—", text_color=fakeBreakdown and not isSpring ? #00e676 : color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 11, fakeBreakout and not isUpthrust ? "FB ↑" : "—", text_color=fakeBreakout and not isUpthrust ? #ff1744 : color.gray, text_size=size.normal, text_halign=text.align_right)

    table.cell(scoreTable, 0, 12, "CLX Sequence", text_color=color.new(color.white, 30), text_size=size.normal)
    color clxBullCol = clxConfirmed and clxDirection == 1 ? #00e676 : clxTestValid and clxDirection == 1 ? color.new(#00e676, 30) : clxBullSequence ? color.new(#e040fb, 30) : color.gray
    color clxBearCol = clxConfirmed and clxDirection == -1 ? #ff1744 : clxTestValid and clxDirection == -1 ? color.new(#ff1744, 30) : clxBearSequence ? color.new(#e040fb, 30) : color.gray
    table.cell(scoreTable, 1, 12, clxBullSequence ? clxStateStr : "—", text_color=clxBullCol, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 12, clxBearSequence ? clxStateStr : "—", text_color=clxBearCol, text_size=size.normal, text_halign=text.align_right)

    // Confirmation total
    table.cell(scoreTable, 0, 13, "CONF SCORE", text_color=color.white, text_size=size.normal)
    table.cell(scoreTable, 1, 13, str.tostring(bullConf, "#.0"), text_color=bullConfirmed ? #00e676 : color.gray, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 13, str.tostring(bearConf, "#.0"), text_color=bearConfirmed ? #ff1744 : color.gray, text_size=size.normal, text_halign=text.align_right)

    // Separator
    table.cell(scoreTable, 0, 14, "", text_size=size.tiny)

    // Final status
    table.cell(scoreTable, 0, 15, "STATUS", text_color=color.white, text_size=size.normal)
    color bullStatusColor = bullStatus == "CANDIDATE" ? #00e676 : bullStatus == "PENDING" ? color.new(#00e676, 30) : bullStatus == "CONFLICTED" ? #78909c : bullStatus == "FAILED" ? #ff6d00 : bullStatus == "EXPIRED" ? color.gray : bullStatus == "SETUP" ? color.yellow : bullStatus == "ALERT" ? #ffab00 : bullStatus == "WATCH" ? color.new(color.white, 40) : color.gray
    color bearStatusColor = bearStatus == "CANDIDATE" ? #ff1744 : bearStatus == "PENDING" ? color.new(#ff1744, 30) : bearStatus == "CONFLICTED" ? #78909c : bearStatus == "FAILED" ? #ff6d00 : bearStatus == "EXPIRED" ? color.gray : bearStatus == "SETUP" ? color.yellow : bearStatus == "ALERT" ? #ffab00 : bearStatus == "WATCH" ? color.new(color.white, 40) : color.gray
    table.cell(scoreTable, 1, 15, bullStatus, text_color=bullStatusColor, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 15, bearStatus, text_color=bearStatusColor, text_size=size.normal, text_halign=text.align_right)

    // Follow-through row
    table.cell(scoreTable, 0, 16, "Follow-thru", text_color=color.new(color.white, 30), text_size=size.normal)
    string bullFTStr = bullFTAchieved ? "✓ FT" : bullFailed ? "✗ FAILED" : bullEventActive ? "pending" : bullDecay < 0.5 and bullEventAge < 999 ? "expired" : "—"
    string bearFTStr = bearFTAchieved ? "✓ FT" : bearFailed ? "✗ FAILED" : bearEventActive ? "pending" : bearDecay < 0.5 and bearEventAge < 999 ? "expired" : "—"
    color bullFTCol = bullFTAchieved ? #00e676 : bullFailed ? #ff6d00 : bullEventActive ? color.new(color.white, 40) : color.gray
    color bearFTCol = bearFTAchieved ? #ff1744 : bearFailed ? #ff6d00 : bearEventActive ? color.new(color.white, 40) : color.gray
    table.cell(scoreTable, 1, 16, bullFTStr, text_color=bullFTCol, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 16, bearFTStr, text_color=bearFTCol, text_size=size.normal, text_halign=text.align_right)

    // Conflict row
    color conflictCol = conflictCount >= 3 ? color.new(#ff6d00, 0) : conflictCount >= 2 ? color.new(#ffab00, 0) : conflictCount >= 1 ? color.new(#78909c, 0) : color.gray
    table.cell(scoreTable, 0, 17, isConflict ? "⊘ CONFLICT" : "✓ CLEAR", text_color=isConflict ? conflictCol : color.new(#00e676, 40), text_size=size.normal, text_halign=text.align_left)
    table.cell(scoreTable, 1, 17, isConflict ? conflictSeverity : "", text_color=conflictCol, text_size=size.normal, text_halign=text.align_right)
    table.cell(scoreTable, 2, 17, isConflict ? str.tostring(conflictCount) : "", text_color=conflictCol, text_size=size.normal, text_halign=text.align_right)

// ============================================================================
// MODULE: alerts
// ============================================================================

// ── REVIEW ALERTS — "look at this, situation is building" ──
bool bullReview = bullSetup >= 4.0 and bullConfDecayed >= 1.5 and conflictCount < 2 and (newBullEvent or bullEventAge <= 2)
bool bearReview = bearSetup >= 4.0 and bearConfDecayed >= 1.5 and conflictCount < 2 and (newBearEvent or bearEventAge <= 2)

alertcondition(bullReview, "Bull Review", "NG 4H REVIEW: Bull setup building with confirmation — check chart")
alertcondition(bearReview, "Bear Review", "NG 4H REVIEW: Bear setup building with confirmation — check chart")

// ── ACTION ALERTS — "this is serious, consider acting" ──
bool bullAction = bullSetup >= 5.0 and bullConfDecayed >= 3.0 and bullFTAchieved and not bullCandidateOpposed and not bullTrendConflict and close > nz(bullTriggerLevel)
bool bearAction = bearSetup >= 5.0 and bearConfDecayed >= 3.0 and bearFTAchieved and not bearCandidateOpposed and not bearTrendConflict and close < nz(bearTriggerLevel)

alertcondition(bullAction, "Bull Action", "NG 4H ACTION: Bull confirmed + follow-through + no conflict — strong candidate")
alertcondition(bearAction, "Bear Action", "NG 4H ACTION: Bear confirmed + follow-through + no conflict — strong candidate")

// ── INVALIDATION ALERTS — "previous signal is dead" ──
alertcondition(bullFailed and not bullFailed[1], "Bull Invalidation", "NG 4H INVALIDATION: Bull candidate failed — no follow-through or trigger lost")
alertcondition(bearFailed and not bearFailed[1], "Bear Invalidation", "NG 4H INVALIDATION: Bear candidate failed — no follow-through or trigger lost")

// ── STRUCTURAL ALERTS ──
alertcondition(bullStatus == "CANDIDATE", "Bull Candidate", "NG 4H: Bull CANDIDATE status active")
alertcondition(bearStatus == "CANDIDATE", "Bear Candidate", "NG 4H: Bear CANDIDATE status active")
alertcondition(isConflict and conflictCount >= 2, "Conflict", "NG 4H: Significant conflict detected")
alertcondition(isSpring or isMajorSpring, "Spring Detected", "NG 4H: Spring heuristic triggered")
alertcondition(isUpthrust or isMajorUpthrust, "Upthrust Detected", "NG 4H: Upthrust heuristic triggered")
alertcondition(majorBullBOS, "Major Bull BOS", "NG 4H: Major Bullish Break of Structure")
alertcondition(majorBearBOS, "Major Bear BOS", "NG 4H: Major Bearish Break of Structure")
alertcondition(bullTrapHint and not bullTrapHint[1], "Bull Trap Hint", "NG 4H: Failed bull reversal — possible bear continuation")
alertcondition(bearTrapHint and not bearTrapHint[1], "Bear Trap Hint", "NG 4H: Failed bear reversal — possible bull continuation")
