//@version=6
// ============================================================================
// NG Structure Events 4H [WavesUnchained]
// Version: 0.1.0
// Author: WavesUnchained
// ============================================================================
// Formal detection of structural events and simplified Wyckoff building blocks
// for 4H NatGas reversal research.
//
// Features:
//   ✓ Swing High / Swing Low detection (pivot-based)
//   ✓ Bullish / Bearish Break of Structure (BOS)
//   ✓ Fake Breakout / Fake Breakdown
//   ✓ Spring heuristic
//   ✓ Upthrust heuristic
//   ✓ Climax Candle detection
//   ✓ Test Candle heuristic
//   ✓ Rejection Candle detection
//   ✓ Light / Debug / Research display modes
//
// ============================================================================
indicator("NG Structure Events 4H [WavesUnchained]", "NG Struct", overlay=true, max_labels_count=500, max_lines_count=200)

// ============================================================================
// MODULE: inputs
// ============================================================================

var gSwing = "Swing / Pivot"
int leftBars  = input.int(3, "Micro Pivot Left Bars", minval=1, maxval=20, group=gSwing)
int rightBars = input.int(3, "Micro Pivot Right Bars", minval=1, maxval=20, group=gSwing)
int majorLeftBars  = input.int(7, "Major Pivot Left Bars", minval=3, maxval=30, group=gSwing, tooltip="Longer pivots = more significant structure")
int majorRightBars = input.int(7, "Major Pivot Right Bars", minval=3, maxval=30, group=gSwing)

var gStructure = "Structure"
float bosBuffer = input.float(0.0, "BOS Buffer (points)", minval=0.0, step=0.001, group=gStructure, tooltip="Minimum close beyond swing to confirm BOS")

var gWyckoff = "Wyckoff Heuristics"
float minWickRatio     = input.float(0.35, "Min Wick Ratio for Spring/Upthrust", minval=0.1, maxval=0.8, step=0.05, group=gWyckoff)
float minCandleATR     = input.float(0.5, "Min Candle Range / ATR for Spring/Upthrust", minval=0.1, step=0.1, group=gWyckoff)
float climaxRangeATR   = input.float(1.8, "Climax: Min Range / ATR", minval=1.0, step=0.1, group=gWyckoff)
float climaxVolFactor  = input.float(1.8, "Climax: Min Volume / Avg Volume", minval=1.0, step=0.1, group=gWyckoff)
float testRangeFactor  = input.float(0.6, "Test: Max Range vs Climax Range", minval=0.1, maxval=1.0, step=0.1, group=gWyckoff)
float testVolFactor    = input.float(0.7, "Test: Max Volume vs Climax Volume", minval=0.1, maxval=1.0, step=0.1, group=gWyckoff)
int   testLookback     = input.int(10, "Test: Lookback for Climax Reference", minval=3, maxval=30, group=gWyckoff)
float rejWickRatio     = input.float(0.5, "Rejection: Min Wick Ratio", minval=0.2, maxval=0.8, step=0.05, group=gWyckoff)
float rejBodyMax       = input.float(0.3, "Rejection: Max Body/Range", minval=0.1, maxval=0.6, step=0.05, group=gWyckoff)

var gQuality = "Event Quality Thresholds"
float strongWickRatio  = input.float(0.55, "Strong: Min Wick Ratio", minval=0.3, maxval=0.8, step=0.05, group=gQuality, tooltip="Wick ratio above this = strong Spring/UT/Rejection")
float strongCandleATR  = input.float(0.8, "Strong: Min Candle / ATR", minval=0.3, step=0.1, group=gQuality, tooltip="Candle range above this = strong event")
float strongVolFactor  = input.float(1.3, "Strong: Min Volume / Avg", minval=1.0, step=0.1, group=gQuality, tooltip="Volume above this = strong event")
float strongSweepATR   = input.float(0.15, "Strong Spring/UT: Min Sweep Depth (ATR)", minval=0.0, step=0.05, group=gQuality, tooltip="How far price swept beyond the swing level")

var gVolume = "Volume"
int volAvgLen = input.int(20, "Volume Average Length", minval=5, group=gVolume)

var gATR = "ATR"
int atrLen = input.int(14, "ATR Length", minval=1, group=gATR)

var gDisplay = "Display"
string displayMode  = input.string("Light", "Display Mode", options=["Light", "Debug", "Research"], group=gDisplay)
bool showSwings     = input.bool(true, "Show Swing Labels", group=gDisplay)
bool showBOS        = input.bool(true, "Show BOS Labels", group=gDisplay)
bool showFakeBreaks = input.bool(true, "Show Fake Break Labels", group=gDisplay)
bool showSpringUT   = input.bool(true, "Show Spring / Upthrust Labels", group=gDisplay)
bool showClimax     = input.bool(true, "Show Climax Labels", group=gDisplay)
bool showTest       = input.bool(true, "Show Test Labels", group=gDisplay)
bool showRejection  = input.bool(true, "Show Rejection Labels", group=gDisplay)

// ============================================================================
// MODULE: base calculations
// ============================================================================

float atrValue = ta.atr(atrLen)
float avgVol   = ta.sma(volume, volAvgLen)
float candleRange = high - low
float bodySize    = math.abs(close - open)
float bodyToRange = candleRange > 0 ? bodySize / candleRange : 0.0
float upperWick   = high - math.max(open, close)
float lowerWick   = math.min(open, close) - low
float upperWickRatio = candleRange > 0 ? upperWick / candleRange : 0.0
float lowerWickRatio = candleRange > 0 ? lowerWick / candleRange : 0.0

// ============================================================================
// MODULE: swing detection — micro + major
// ============================================================================

// Micro swings (short pivots — local structure)
float pivotHi = ta.pivothigh(high, leftBars, rightBars)
float pivotLo = ta.pivotlow(low, leftBars, rightBars)

bool isSwingHigh = not na(pivotHi)
bool isSwingLow  = not na(pivotLo)

var float lastSwingHigh = na
var float lastSwingLow  = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar  = na

if isSwingHigh
    lastSwingHigh := pivotHi
    lastSwingHighBar := bar_index - rightBars
if isSwingLow
    lastSwingLow := pivotLo
    lastSwingLowBar := bar_index - rightBars

// Major swings (longer pivots — significant structure)
float majorPivotHi = ta.pivothigh(high, majorLeftBars, majorRightBars)
float majorPivotLo = ta.pivotlow(low, majorLeftBars, majorRightBars)

bool isMajorSwingHigh = not na(majorPivotHi)
bool isMajorSwingLow  = not na(majorPivotLo)

var float lastMajorSwingHigh = na
var float lastMajorSwingLow  = na
var int   lastMajorSwingHighBar = na
var int   lastMajorSwingLowBar  = na

if isMajorSwingHigh
    lastMajorSwingHigh := majorPivotHi
    lastMajorSwingHighBar := bar_index - majorRightBars
if isMajorSwingLow
    lastMajorSwingLow := majorPivotLo
    lastMajorSwingLowBar := bar_index - majorRightBars

// ============================================================================
// MODULE: break of structure — micro + major
// ============================================================================

// Micro BOS: breaks the last short-term swing
bool microBullBOS = not na(lastSwingHigh) and close > lastSwingHigh + bosBuffer and close[1] <= lastSwingHigh + bosBuffer
bool microBearBOS = not na(lastSwingLow) and close < lastSwingLow - bosBuffer and close[1] >= lastSwingLow - bosBuffer

// Major BOS: breaks the last significant swing
bool majorBullBOS = not na(lastMajorSwingHigh) and close > lastMajorSwingHigh + bosBuffer and close[1] <= lastMajorSwingHigh + bosBuffer
bool majorBearBOS = not na(lastMajorSwingLow) and close < lastMajorSwingLow - bosBuffer and close[1] >= lastMajorSwingLow - bosBuffer

// Combined (any BOS)
bool bullishBOS = microBullBOS or majorBullBOS
bool bearishBOS = microBearBOS or majorBearBOS

// ============================================================================
// MODULE: fake breakout / fake breakdown
// ============================================================================

// Fake breaks — check against both micro and major swings
bool fakeBreakout  = not na(lastSwingHigh) and high > lastSwingHigh and close <= lastSwingHigh
bool fakeBreakdown = not na(lastSwingLow) and low < lastSwingLow and close >= lastSwingLow
bool majorFakeBreakout  = not na(lastMajorSwingHigh) and high > lastMajorSwingHigh and close <= lastMajorSwingHigh
bool majorFakeBreakdown = not na(lastMajorSwingLow) and low < lastMajorSwingLow and close >= lastMajorSwingLow

// ============================================================================
// MODULE: spring / upthrust heuristics
// ============================================================================

float candleATR = atrValue > 0 ? candleRange / atrValue : 0.0

// Spring/Upthrust at micro swings
bool isSpring   = fakeBreakdown and lowerWickRatio >= minWickRatio and candleATR >= minCandleATR
bool isUpthrust = fakeBreakout and upperWickRatio >= minWickRatio and candleATR >= minCandleATR

// Spring/Upthrust at major swings
bool isMajorSpring   = majorFakeBreakdown and lowerWickRatio >= minWickRatio and candleATR >= minCandleATR
bool isMajorUpthrust = majorFakeBreakout and upperWickRatio >= minWickRatio and candleATR >= minCandleATR

// ============================================================================
// MODULE: rejection candle (defined here, before quality grading needs it)
// ============================================================================

bool isBullRejection = lowerWickRatio >= rejWickRatio and bodyToRange <= rejBodyMax and close > open
bool isBearRejection = upperWickRatio >= rejWickRatio and bodyToRange <= rejBodyMax and close < open

// ============================================================================
// MODULE: event quality grading
// ============================================================================
// Quality: 0 = not triggered, 1 = weak, 2 = normal, 3 = strong
// Strong = deep sweep + large wick + large candle + high volume
// Weak = barely qualifies on minimum thresholds

// Quality factor counting for Spring
float springSweepDepth = isSpring and not na(lastSwingLow) and atrValue > 0 ? (lastSwingLow - low) / atrValue : 0.0
float majorSpringSweepDepth = isMajorSpring and not na(lastMajorSwingLow) and atrValue > 0 ? (lastMajorSwingLow - low) / atrValue : 0.0

f_eventQuality(bool triggered, float wickR, float cATR, float relV, float sweepD, float sWickR, float sCATR, float sVolF, float sSweep) =>
    int q = 0
    if triggered
        int factors = 0
        if wickR >= sWickR
            factors += 1
        if cATR >= sCATR
            factors += 1
        if relV >= sVolF
            factors += 1
        if sweepD >= sSweep
            factors += 1
        q := factors >= 3 ? 3 : factors >= 1 ? 2 : 1
    q

float relVol = avgVol > 0 ? volume / avgVol : 1.0

// Spring quality
int springQuality = f_eventQuality(isSpring, lowerWickRatio, candleATR, relVol, springSweepDepth, strongWickRatio, strongCandleATR, strongVolFactor, strongSweepATR)
int majorSpringQuality = f_eventQuality(isMajorSpring, lowerWickRatio, candleATR, relVol, majorSpringSweepDepth, strongWickRatio, strongCandleATR, strongVolFactor, strongSweepATR)

// Upthrust quality
float upthrustSweepDepth = isUpthrust and not na(lastSwingHigh) and atrValue > 0 ? (high - lastSwingHigh) / atrValue : 0.0
float majorUpthrustSweepDepth = isMajorUpthrust and not na(lastMajorSwingHigh) and atrValue > 0 ? (high - lastMajorSwingHigh) / atrValue : 0.0

int upthrustQuality = f_eventQuality(isUpthrust, upperWickRatio, candleATR, relVol, upthrustSweepDepth, strongWickRatio, strongCandleATR, strongVolFactor, strongSweepATR)
int majorUpthrustQuality = f_eventQuality(isMajorUpthrust, upperWickRatio, candleATR, relVol, majorUpthrustSweepDepth, strongWickRatio, strongCandleATR, strongVolFactor, strongSweepATR)

// BOS quality: based on how far close exceeded swing + volume
float bullBOSSweep = microBullBOS and not na(lastSwingHigh) and atrValue > 0 ? (close - lastSwingHigh) / atrValue : 0.0
float majorBullBOSSweep = majorBullBOS and not na(lastMajorSwingHigh) and atrValue > 0 ? (close - lastMajorSwingHigh) / atrValue : 0.0
float bearBOSSweep = microBearBOS and not na(lastSwingLow) and atrValue > 0 ? (lastSwingLow - close) / atrValue : 0.0
float majorBearBOSSweep = majorBearBOS and not na(lastMajorSwingLow) and atrValue > 0 ? (lastMajorSwingLow - close) / atrValue : 0.0

f_bosQuality(bool triggered, float sweep, float relV, float sVolF) =>
    int q = 0
    if triggered
        int factors = 0
        if sweep >= 0.1
            factors += 1
        if sweep >= 0.3
            factors += 1
        if relV >= sVolF
            factors += 1
        q := factors >= 2 ? 3 : factors >= 1 ? 2 : 1
    q

int microBullBOSQuality = f_bosQuality(microBullBOS, bullBOSSweep, relVol, strongVolFactor)
int majorBullBOSQuality = f_bosQuality(majorBullBOS, majorBullBOSSweep, relVol, strongVolFactor)
int microBearBOSQuality = f_bosQuality(microBearBOS, bearBOSSweep, relVol, strongVolFactor)
int majorBearBOSQuality = f_bosQuality(majorBearBOS, majorBearBOSSweep, relVol, strongVolFactor)

// Rejection quality
int bullRejQuality = f_eventQuality(isBullRejection, lowerWickRatio, candleATR, relVol, 0.0, strongWickRatio, strongCandleATR, strongVolFactor, 0.0)
int bearRejQuality = f_eventQuality(isBearRejection, upperWickRatio, candleATR, relVol, 0.0, strongWickRatio, strongCandleATR, strongVolFactor, 0.0)

// Quality label helper
f_qualityTag(int q) =>
    q == 3 ? "★" : q == 2 ? "" : q == 1 ? "~" : ""

// ============================================================================
// MODULE: climax candle
// ============================================================================

bool isClimaxCandle = candleATR >= climaxRangeATR and avgVol > 0 and volume >= climaxVolFactor * avgVol

// ============================================================================
// MODULE: climax sequence state machine
// ============================================================================
// Tracks the progression: CLX → reaction → TEST → BOS = confirmed reversal
//
// States:
//   0 = IDLE         — no active climax sequence
//   1 = CLX_DETECTED — climax just fired, waiting for reaction
//   2 = REACTING     — price moving away from climax zone
//   3 = TEST_PENDING — reaction happened, now waiting for test
//   4 = TEST_VALID   — test candle confirmed (smaller range+vol near climax zone)
//   5 = CONFIRMED    — BOS after test = full reversal sequence
//
// Direction: 1 = selling climax (bullish reversal), -1 = buying climax (bearish reversal)

var int   clxState     = 0
var int   clxDirection  = 0    // 1 = bull reversal, -1 = bear reversal
var float clxClose     = na
var float clxHigh      = na
var float clxLow       = na
var float clxRange     = na
var float clxVolume    = na
var int   clxBar       = na
var float clxReactionExtreme = na  // how far price reacted away from climax
var int   clxTestBar   = na

// Climax context: selling climax = close near low (bullish), buying climax = close near high (bearish)
bool isSellingClimax = isClimaxCandle and close < open   // bearish candle = potential selling climax
bool isBuyingClimax  = isClimaxCandle and close > open   // bullish candle = potential buying climax

// New climax resets the sequence
if isClimaxCandle
    clxState     := 1
    clxDirection := isSellingClimax ? 1 : isBuyingClimax ? -1 : 0
    clxClose     := close
    clxHigh      := high
    clxLow       := low
    clxRange     := candleRange
    clxVolume    := volume
    clxBar       := bar_index
    clxReactionExtreme := na
    clxTestBar   := na

// State transitions (only if we have an active sequence)
bool hasActiveClx = clxState >= 1 and not na(clxBar) and (bar_index - clxBar) <= testLookback * 2

if hasActiveClx and clxState == 1
    // CLX_DETECTED → REACTING: price moves away from climax
    if clxDirection == 1 and close > clxClose  // selling climax, price bouncing up
        clxState := 2
        clxReactionExtreme := high
    if clxDirection == -1 and close < clxClose  // buying climax, price dropping
        clxState := 2
        clxReactionExtreme := low

if hasActiveClx and clxState == 2
    // REACTING: track the reaction extreme
    if clxDirection == 1
        clxReactionExtreme := math.max(nz(clxReactionExtreme), high)
    if clxDirection == -1
        clxReactionExtreme := math.min(nz(clxReactionExtreme, high), low)
    // REACTING → TEST_PENDING: price returns toward climax zone
    bool returningToZone = false
    if clxDirection == 1 and not na(clxClose) and atrValue > 0
        returningToZone := close < clxClose + 1.5 * atrValue and close > clxLow - 0.5 * atrValue
    if clxDirection == -1 and not na(clxClose) and atrValue > 0
        returningToZone := close > clxClose - 1.5 * atrValue and close < clxHigh + 0.5 * atrValue
    if returningToZone and (bar_index - clxBar) >= 2
        clxState := 3

if hasActiveClx and clxState == 3
    // TEST_PENDING → TEST_VALID: test candle criteria met
    bool isTestBar = not na(clxRange) and not na(clxVolume) and candleRange <= clxRange * testRangeFactor and volume <= clxVolume * testVolFactor and candleRange > 0
    bool inZone = not na(clxClose) and atrValue > 0 and math.abs(close - clxClose) <= 1.5 * atrValue
    if isTestBar and inZone
        clxState   := 4
        clxTestBar := bar_index

if hasActiveClx and clxState == 4
    // TEST_VALID → CONFIRMED: BOS in the reversal direction
    if clxDirection == 1 and (microBullBOS or majorBullBOS)
        clxState := 5
    if clxDirection == -1 and (microBearBOS or majorBearBOS)
        clxState := 5

// Timeout: expire sequence if too many bars pass
if hasActiveClx and not na(clxBar) and (bar_index - clxBar) > testLookback * 2
    clxState := 0

// Readable booleans for use in score and visuals
bool clxDetected     = clxState >= 1
bool clxTestPending  = clxState == 3
bool clxTestValid    = clxState == 4 or clxState == 5
bool clxConfirmed    = clxState == 5
bool clxBullSequence = clxDirection == 1 and clxState >= 1
bool clxBearSequence = clxDirection == -1 and clxState >= 1

// Legacy compatibility: isTestCandle for other modules
var int barsSinceLastTest = 999
barsSinceLastTest += 1
bool isTestCandle = clxState == 4 and bar_index == clxTestBar and barsSinceLastTest >= 3
if isTestCandle
    barsSinceLastTest := 0

// Sequence state string for display
string clxStateStr = clxState == 0 ? "—" : clxState == 1 ? "CLX" : clxState == 2 ? "REACTING" : clxState == 3 ? "TEST PENDING" : clxState == 4 ? "TEST VALID" : clxState == 5 ? "CONFIRMED" : "—"
string clxDirStr = clxDirection == 1 ? "Bull" : clxDirection == -1 ? "Bear" : "—"

// (Rejection candle definitions moved above event quality grading)

// ============================================================================
// MODULE: event codes (for data window / export)
// ============================================================================

// Encode events as bit flags for compact export
int eventCode = 0
eventCode += isSwingHigh        ? 1     : 0
eventCode += isSwingLow         ? 2     : 0
eventCode += microBullBOS       ? 4     : 0
eventCode += microBearBOS       ? 8     : 0
eventCode += majorBullBOS       ? 16    : 0
eventCode += majorBearBOS       ? 32    : 0
eventCode += fakeBreakout       ? 64    : 0
eventCode += fakeBreakdown      ? 128   : 0
eventCode += isSpring           ? 256   : 0
eventCode += isUpthrust         ? 512   : 0
eventCode += isMajorSpring      ? 1024  : 0
eventCode += isMajorUpthrust    ? 2048  : 0
eventCode += isClimaxCandle     ? 4096  : 0
eventCode += isTestCandle       ? 8192  : 0
eventCode += isBullRejection    ? 16384 : 0
eventCode += isBearRejection  ? 2048 : 0

// ============================================================================
// MODULE: visuals
// ============================================================================

bool isDebug    = displayMode == "Debug" or displayMode == "Research"
bool isResearch = displayMode == "Research"

// ── Visual hierarchy ──
// Tier 1 (prominent):  Spring, Upthrust, BOS  — large, bold colors
// Tier 2 (medium):     Climax, Fake Breaks    — medium, offset to avoid overlap
// Tier 3 (subtle):     Rejection, Test         — small, muted
// Tier 4 (minimal):    Swing H/L              — tiny dots, no text labels

float offsetUnit = atrValue * 0.4  // vertical spacing between label tiers

// ── Tier 4: Swing High / Low — minimal dots ──
if showSwings and isSwingHigh
    label.new(bar_index - rightBars, pivotHi, "·", style=label.style_label_down, color=color.new(#ef5350, 50), textcolor=color.white, size=size.tiny, tooltip="Swing High: " + str.tostring(pivotHi, "#.####"))
if showSwings and isSwingLow
    label.new(bar_index - rightBars, pivotLo, "·", style=label.style_label_up, color=color.new(#66bb6a, 50), textcolor=color.white, size=size.tiny, tooltip="Swing Low: " + str.tostring(pivotLo, "#.####"))

// ── Tier 1: Spring / Upthrust — with quality grading ──
// Quality: ★ = strong (3), normal (2), ~ = weak (1)
if showSpringUT and isMajorSpring
    int q = majorSpringQuality
    string qTag = f_qualityTag(q)
    color  qCol = q == 3 ? color.lime : q == 2 ? color.new(color.lime, 15) : color.new(color.lime, 35)
    label.new(bar_index, low - offsetUnit * 1.2, qTag + " SPRING", style=label.style_label_up, color=qCol, textcolor=color.black, size=size.normal, tooltip="MAJOR Spring [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nSweep: " + str.tostring(majorSpringSweepDepth, "#.00") + " ATR | Wick: " + str.tostring(lowerWickRatio * 100, "#.0") + "% | Vol: " + str.tostring(relVol, "#.0") + "x\nMajor Swing Low: " + str.tostring(lastMajorSwingLow, "#.####"))
else if showSpringUT and isSpring
    int q = springQuality
    string qTag = f_qualityTag(q)
    color  qCol = q == 3 ? color.lime : q == 2 ? color.new(color.lime, 25) : color.new(color.lime, 50)
    label.new(bar_index, low - offsetUnit, qTag + " spring", style=label.style_label_up, color=qCol, textcolor=color.black, size=size.small, tooltip="Micro Spring [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nSweep: " + str.tostring(springSweepDepth, "#.00") + " ATR | Wick: " + str.tostring(lowerWickRatio * 100, "#.0") + "% | Vol: " + str.tostring(relVol, "#.0") + "x")

if showSpringUT and isMajorUpthrust
    int q = majorUpthrustQuality
    string qTag = f_qualityTag(q)
    color  qCol = q == 3 ? color.red : q == 2 ? color.new(color.red, 15) : color.new(color.red, 35)
    label.new(bar_index, high + offsetUnit * 1.2, qTag + " UPTHRUST", style=label.style_label_down, color=qCol, textcolor=color.white, size=size.normal, tooltip="MAJOR Upthrust [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nSweep: " + str.tostring(majorUpthrustSweepDepth, "#.00") + " ATR | Wick: " + str.tostring(upperWickRatio * 100, "#.0") + "% | Vol: " + str.tostring(relVol, "#.0") + "x\nMajor Swing High: " + str.tostring(lastMajorSwingHigh, "#.####"))
else if showSpringUT and isUpthrust
    int q = upthrustQuality
    string qTag = f_qualityTag(q)
    color  qCol = q == 3 ? color.red : q == 2 ? color.new(color.red, 25) : color.new(color.red, 50)
    label.new(bar_index, high + offsetUnit, qTag + " upthrust", style=label.style_label_down, color=qCol, textcolor=color.white, size=size.small, tooltip="Micro Upthrust [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nSweep: " + str.tostring(upthrustSweepDepth, "#.00") + " ATR | Wick: " + str.tostring(upperWickRatio * 100, "#.0") + "% | Vol: " + str.tostring(relVol, "#.0") + "x")

// ── Tier 1: BOS — Major vs Micro, with quality ──
if showBOS and majorBullBOS
    int q = majorBullBOSQuality
    string qTag = f_qualityTag(q)
    color  qCol = q == 3 ? color.new(#00e676, 0) : q == 2 ? color.new(#00e676, 15) : color.new(#00e676, 35)
    label.new(bar_index, low - offsetUnit * 0.5, qTag + " BOS ↑↑", style=label.style_label_up, color=qCol, textcolor=color.white, size=size.small, tooltip="MAJOR Bull BOS [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nClose: " + str.tostring(close, "#.####") + " | Sweep: " + str.tostring(majorBullBOSSweep, "#.00") + " ATR | Vol: " + str.tostring(relVol, "#.0") + "x")
else if showBOS and microBullBOS
    int q = microBullBOSQuality
    string qTag = f_qualityTag(q)
    color  qCol = q == 3 ? color.new(#00e676, 20) : q == 2 ? color.new(#00e676, 40) : color.new(#00e676, 60)
    label.new(bar_index, low - offsetUnit * 0.3, qTag + " bos ↑", style=label.style_label_up, color=qCol, textcolor=color.white, size=size.tiny, tooltip="Micro Bull BOS [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nClose: " + str.tostring(close, "#.####") + " | Sweep: " + str.tostring(bullBOSSweep, "#.00") + " ATR | Vol: " + str.tostring(relVol, "#.0") + "x")

if showBOS and majorBearBOS
    int q = majorBearBOSQuality
    string qTag = f_qualityTag(q)
    color  qCol = q == 3 ? color.new(#ff1744, 0) : q == 2 ? color.new(#ff1744, 15) : color.new(#ff1744, 35)
    label.new(bar_index, high + offsetUnit * 0.5, qTag + " BOS ↓↓", style=label.style_label_down, color=qCol, textcolor=color.white, size=size.small, tooltip="MAJOR Bear BOS [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nClose: " + str.tostring(close, "#.####") + " | Sweep: " + str.tostring(majorBearBOSSweep, "#.00") + " ATR | Vol: " + str.tostring(relVol, "#.0") + "x")
else if showBOS and microBearBOS
    int q = microBearBOSQuality
    string qTag = f_qualityTag(q)
    color  qCol = q == 3 ? color.new(#ff1744, 20) : q == 2 ? color.new(#ff1744, 40) : color.new(#ff1744, 60)
    label.new(bar_index, high + offsetUnit * 0.3, qTag + " bos ↓", style=label.style_label_down, color=qCol, textcolor=color.white, size=size.tiny, tooltip="Micro Bear BOS [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nClose: " + str.tostring(close, "#.####") + " | Sweep: " + str.tostring(bearBOSSweep, "#.00") + " ATR | Vol: " + str.tostring(relVol, "#.0") + "x")

// ── Tier 2: Climax Sequence ──
// Climax candle itself
if showClimax and isClimaxCandle
    string clxType = isSellingClimax ? "Selling CLX" : isBuyingClimax ? "Buying CLX" : "CLX"
    color  clxCol  = isSellingClimax ? color.new(#e040fb, 10) : isBuyingClimax ? color.new(#e040fb, 10) : color.new(color.fuchsia, 10)
    label.new(bar_index, high + offsetUnit, clxType, style=label.style_label_down, color=clxCol, textcolor=color.white, size=size.small, tooltip="Climax Candle [" + clxDirStr + "]\nRange: " + str.tostring(candleRange / atrValue, "#.0") + "x ATR | Vol: " + str.tostring(volume / avgVol, "#.0") + "x avg\nSequence started — watching for test")

// Test candle in sequence
if showTest and isTestCandle
    color tstCol = color.new(#ce93d8, 15)
    string tstDir = clxDirection == 1 ? "↑" : clxDirection == -1 ? "↓" : ""
    label.new(bar_index, clxDirection == 1 ? low - offsetUnit * 0.3 : high + offsetUnit * 0.3, "TST " + tstDir, style=clxDirection == 1 ? label.style_label_up : label.style_label_down, color=tstCol, textcolor=color.white, size=size.small, tooltip="Test Validated [" + clxDirStr + "]\nRange: " + str.tostring(candleRange / atrValue, "#.0") + "x ATR (vs CLX " + str.tostring(nz(clxRange) / atrValue, "#.0") + "x)\nVol: " + str.tostring(volume / avgVol, "#.0") + "x (vs CLX " + str.tostring(nz(clxVolume) / avgVol, "#.0") + "x)\nWaiting for BOS to confirm")

// Confirmed sequence
if showClimax and clxConfirmed and clxState[1] == 4
    color confCol = clxDirection == 1 ? color.new(#00e676, 0) : color.new(#ff1744, 0)
    string confText = clxDirection == 1 ? "CLX→TST→BOS ↑" : "CLX→TST→BOS ↓"
    label.new(bar_index, clxDirection == 1 ? low - offsetUnit * 1.5 : high + offsetUnit * 1.5, confText, style=clxDirection == 1 ? label.style_label_up : label.style_label_down, color=confCol, textcolor=color.white, size=size.normal, tooltip="CONFIRMED Reversal Sequence\nClimax → Reaction → Test → Break of Structure\nThis is the strongest signal the system produces")

// ── Tier 2: Fake Breaks — medium, warm orange ──
if showFakeBreaks and fakeBreakout and not isUpthrust
    label.new(bar_index, high + offsetUnit * 0.7, "FB", style=label.style_label_down, color=color.new(#ff9800, 20), textcolor=color.white, size=size.tiny, tooltip="Fake Breakout: High above Swing High but closed below")
if showFakeBreaks and fakeBreakdown and not isSpring
    label.new(bar_index, low - offsetUnit * 0.7, "FB", style=label.style_label_up, color=color.new(#ff9800, 20), textcolor=color.white, size=size.tiny, tooltip="Fake Breakdown: Low below Swing Low but closed above")

// (Test candle visualization is handled in the Climax Sequence block above)

// ── Tier 3: Rejection — with quality ──
if showRejection and isBullRejection and not isSpring and not isMajorSpring
    int q = bullRejQuality
    color qCol = q == 3 ? color.new(#4db6ac, 10) : q == 2 ? color.new(#4db6ac, 30) : color.new(#4db6ac, 50)
    label.new(bar_index, low, f_qualityTag(q) + "rej", style=label.style_label_up, color=qCol, textcolor=color.white, size=size.tiny, tooltip="Bull Rejection [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nWick: " + str.tostring(lowerWickRatio * 100, "#.0") + "% | Body: " + str.tostring(bodyToRange * 100, "#.0") + "% | Vol: " + str.tostring(relVol, "#.0") + "x")
if showRejection and isBearRejection and not isUpthrust and not isMajorUpthrust
    int q = bearRejQuality
    color qCol = q == 3 ? color.new(#c62828, 10) : q == 2 ? color.new(#c62828, 30) : color.new(#c62828, 50)
    label.new(bar_index, high, f_qualityTag(q) + "rej", style=label.style_label_down, color=qCol, textcolor=color.white, size=size.tiny, tooltip="Bear Rejection [" + (q == 3 ? "STRONG" : q == 2 ? "normal" : "weak") + "]\nWick: " + str.tostring(upperWickRatio * 100, "#.0") + "% | Body: " + str.tostring(bodyToRange * 100, "#.0") + "% | Vol: " + str.tostring(relVol, "#.0") + "x")

// Swing level lines in Debug mode
plot(isDebug ? lastSwingHigh : na, "Last Micro Swing High", color=color.new(#ef5350, 55), style=plot.style_stepline, linewidth=1)
plot(isDebug ? lastSwingLow : na, "Last Micro Swing Low", color=color.new(#66bb6a, 55), style=plot.style_stepline, linewidth=1)
plot(isDebug ? lastMajorSwingHigh : na, "Last Major Swing High", color=color.new(#ef5350, 20), style=plot.style_stepline, linewidth=2)
plot(isDebug ? lastMajorSwingLow : na, "Last Major Swing Low", color=color.new(#66bb6a, 20), style=plot.style_stepline, linewidth=2)

// ============================================================================
// MODULE: data window plots
// ============================================================================

plot(eventCode, "Event Code", display=display.data_window, color=color.new(color.gray, 100))
plot(isSwingHigh ? 1 : 0, "Micro Swing High", display=display.data_window, color=color.new(color.gray, 100))
plot(isSwingLow ? 1 : 0, "Micro Swing Low", display=display.data_window, color=color.new(color.gray, 100))
plot(isMajorSwingHigh ? 1 : 0, "Major Swing High", display=display.data_window, color=color.new(color.gray, 100))
plot(isMajorSwingLow ? 1 : 0, "Major Swing Low", display=display.data_window, color=color.new(color.gray, 100))
plot(microBullBOS ? 1 : 0, "Micro Bull BOS", display=display.data_window, color=color.new(color.gray, 100))
plot(microBearBOS ? 1 : 0, "Micro Bear BOS", display=display.data_window, color=color.new(color.gray, 100))
plot(majorBullBOS ? 1 : 0, "Major Bull BOS", display=display.data_window, color=color.new(color.gray, 100))
plot(majorBearBOS ? 1 : 0, "Major Bear BOS", display=display.data_window, color=color.new(color.gray, 100))
plot(fakeBreakout ? 1 : 0, "Fake Breakout", display=display.data_window, color=color.new(color.gray, 100))
plot(fakeBreakdown ? 1 : 0, "Fake Breakdown", display=display.data_window, color=color.new(color.gray, 100))
plot(springQuality, "Spring Quality (0-3)", display=display.data_window, color=color.new(color.gray, 100))
plot(upthrustQuality, "Upthrust Quality (0-3)", display=display.data_window, color=color.new(color.gray, 100))
plot(majorSpringQuality, "Major Spring Quality (0-3)", display=display.data_window, color=color.new(color.gray, 100))
plot(majorUpthrustQuality, "Major Upthrust Quality (0-3)", display=display.data_window, color=color.new(color.gray, 100))
plot(microBullBOSQuality, "Micro Bull BOS Quality (0-3)", display=display.data_window, color=color.new(color.gray, 100))
plot(microBearBOSQuality, "Micro Bear BOS Quality (0-3)", display=display.data_window, color=color.new(color.gray, 100))
plot(majorBullBOSQuality, "Major Bull BOS Quality (0-3)", display=display.data_window, color=color.new(color.gray, 100))
plot(majorBearBOSQuality, "Major Bear BOS Quality (0-3)", display=display.data_window, color=color.new(color.gray, 100))
plot(isClimaxCandle ? 1 : 0, "Climax", display=display.data_window, color=color.new(color.gray, 100))
plot(clxState, "CLX Sequence State (0-5)", display=display.data_window, color=color.new(color.gray, 100))
plot(clxDirection, "CLX Direction (1=bull,-1=bear)", display=display.data_window, color=color.new(color.gray, 100))
plot(isTestCandle ? 1 : 0, "Test Candle", display=display.data_window, color=color.new(color.gray, 100))
plot(clxTestValid ? 1 : 0, "CLX Test Valid", display=display.data_window, color=color.new(color.gray, 100))
plot(clxConfirmed ? 1 : 0, "CLX Confirmed", display=display.data_window, color=color.new(color.gray, 100))
plot(isBullRejection ? 1 : 0, "Bull Rejection", display=display.data_window, color=color.new(color.gray, 100))
plot(isBearRejection ? 1 : 0, "Bear Rejection", display=display.data_window, color=color.new(color.gray, 100))

// ============================================================================
// MODULE: research summary
// ============================================================================

var int swHighCount = 0
var int swLowCount = 0
var int bosUpCount = 0
var int bosDnCount = 0
var int springCount = 0
var int utCount = 0
var int climaxCount = 0

if isSwingHigh
    swHighCount += 1
if isSwingLow
    swLowCount += 1
if bullishBOS
    bosUpCount += 1
if bearishBOS
    bosDnCount += 1
if isSpring
    springCount += 1
if isUpthrust
    utCount += 1
if isClimaxCandle
    climaxCount += 1

var table statsTable = na
if isResearch and barstate.islast
    statsTable := table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 80), border_color=color.gray, border_width=1)
    table.cell(statsTable, 0, 0, "NG Structure", text_color=color.white, text_size=size.small)
    table.cell(statsTable, 1, 0, "v0.1", text_color=color.gray, text_size=size.small)
    table.cell(statsTable, 0, 1, "Swing Highs", text_color=color.red, text_size=size.tiny)
    table.cell(statsTable, 1, 1, str.tostring(swHighCount), text_color=color.red, text_size=size.tiny)
    table.cell(statsTable, 0, 2, "Swing Lows", text_color=color.green, text_size=size.tiny)
    table.cell(statsTable, 1, 2, str.tostring(swLowCount), text_color=color.green, text_size=size.tiny)
    table.cell(statsTable, 0, 3, "BOS Bull", text_color=color.lime, text_size=size.tiny)
    table.cell(statsTable, 1, 3, str.tostring(bosUpCount), text_color=color.lime, text_size=size.tiny)
    table.cell(statsTable, 0, 4, "BOS Bear", text_color=color.red, text_size=size.tiny)
    table.cell(statsTable, 1, 4, str.tostring(bosDnCount), text_color=color.red, text_size=size.tiny)
    table.cell(statsTable, 0, 5, "Springs", text_color=color.lime, text_size=size.tiny)
    table.cell(statsTable, 1, 5, str.tostring(springCount), text_color=color.lime, text_size=size.tiny)
    table.cell(statsTable, 0, 6, "Upthrusts", text_color=color.red, text_size=size.tiny)
    table.cell(statsTable, 1, 6, str.tostring(utCount), text_color=color.red, text_size=size.tiny)
    table.cell(statsTable, 0, 7, "Climax", text_color=color.fuchsia, text_size=size.tiny)
    table.cell(statsTable, 1, 7, str.tostring(climaxCount), text_color=color.fuchsia, text_size=size.tiny)
