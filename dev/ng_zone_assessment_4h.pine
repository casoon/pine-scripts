//@version=6
// ============================================================================
// NG Zone Assessment 4H [WavesUnchained]
// Version: 0.1.0
// Author: WavesUnchained
// ============================================================================
// Conditional probability assessment for nearest major S/R zones.
// Evaluates: Structural Strength, Historical Respect, Approach Quality,
// Context Alignment → Reach / Hold / Break likelihoods.
//
// Features:
//   ✓ Nearest Major Support + Resistance zone tracking
//   ✓ 4-block zone assessment (Structural, Respect, Approach, Context)
//   ✓ Reach / Hold / Break likelihood (0-100)
//   ✓ Bounce Quality classification
//   ✓ Zone State (stable → under_pressure → likely_break)
//   ✓ Assessment table + interpretation text
//   ✓ Review / Hold / Break / Failed alerts
//
// ============================================================================
indicator("NG Zone Assessment 4H [WavesUnchained]", "NG ZoneA", overlay=true, max_labels_count=20, max_boxes_count=10)

// ============================================================================
// MODULE: inputs
// ============================================================================

var gCore = "Core"
int atrLen           = input.int(14, "ATR Length", minval=1, group=gCore)
int volAvgLen        = input.int(20, "Volume Average Length", minval=5, group=gCore)
int majorLeft        = input.int(7, "Major Pivot Left", minval=3, group=gCore)
int majorRight       = input.int(7, "Major Pivot Right", minval=3, group=gCore)
int microLeft        = input.int(3, "Micro Pivot Left", minval=1, group=gCore)
int microRight       = input.int(3, "Micro Pivot Right", minval=1, group=gCore)

var gWyckoff = "Event Detection"
float minWickRatio   = input.float(0.35, "Spring/UT Min Wick Ratio", minval=0.1, step=0.05, group=gWyckoff)
float minCandleATR   = input.float(0.5, "Spring/UT Min Candle/ATR", minval=0.1, step=0.1, group=gWyckoff)
float climaxRangeATR = input.float(1.8, "Climax Min Range/ATR", minval=1.0, step=0.1, group=gWyckoff)
float climaxVolFact  = input.float(1.8, "Climax Min Vol Factor", minval=1.0, step=0.1, group=gWyckoff)

var gAssess = "Assessment"
float zoneWidthATR   = input.float(0.3, "Zone Width (ATR)", minval=0.1, step=0.05, group=gAssess)
float maxDistATR     = input.float(3.0, "Max Zone Distance (ATR)", minval=1.0, step=0.5, group=gAssess)
int   approachBars   = input.int(5, "Approach Lookback Bars", minval=2, maxval=15, group=gAssess)
int   zoneExpire     = input.int(200, "Zone Expire Bars", minval=50, group=gAssess)

var gDisplay = "Display"
string displayMode   = input.string("Light", "Display Mode", options=["Light", "Debug", "Research"], group=gDisplay)
bool showLabels      = input.bool(true, "Show Zone Labels on Chart", group=gDisplay)
bool showTable       = input.bool(true, "Show Assessment Table", group=gDisplay)

// ============================================================================
// MODULE: base calculations
// ============================================================================

float atr14    = ta.atr(atrLen)
float avgVol   = ta.sma(volume, volAvgLen)
float relVol   = avgVol > 0 ? volume / avgVol : 1.0
float candleRange = high - low
float candleATR   = atr14 > 0 ? candleRange / atr14 : 0.0
float upperWickR  = candleRange > 0 ? (high - math.max(open, close)) / candleRange : 0.0
float lowerWickR  = candleRange > 0 ? (math.min(open, close) - low) / candleRange : 0.0

// EMAs for trend/regime
float ema20 = ta.ema(close, 20)
float ema50 = ta.ema(close, 50)
float rsi14 = ta.rsi(close, 14)
float mfi14 = ta.mfi(hlc3, 14)

// Regime
float priceChange10 = math.abs(close - close[10])
float pathLength10  = math.sum(math.abs(close - close[1]), 10)
float effRatio      = pathLength10 > 0 ? priceChange10 / pathLength10 : 0.0
bool  isTrendUp     = ema20 > ema50 and effRatio > 0.35
bool  isTrendDown   = ema20 < ema50 and effRatio > 0.35
bool  isRange       = effRatio <= 0.35

float bbBasis = ta.sma(close, 20)
float bbDev   = ta.stdev(close, 20) * 2.0
float bbWidth = bbBasis > 0 ? (bbBasis + bbDev - (bbBasis - bbDev)) / bbBasis : 0.0
float bbWidthAvg = ta.sma(bbBasis > 0 ? (2 * bbDev) / bbBasis : 0.0, 50)
float bbWidthRatio = bbWidthAvg > 0 ? bbWidth / bbWidthAvg : 1.0
bool  isHighVol = bbWidthRatio > 1.3
bool  isLowVol  = bbWidthRatio < 0.7

// ============================================================================
// MODULE: swing + event detection (minimal, for zone creation)
// ============================================================================

float majorPivotHi = ta.pivothigh(high, majorLeft, majorRight)
float majorPivotLo = ta.pivotlow(low, majorLeft, majorRight)
float microPivotHi = ta.pivothigh(high, microLeft, microRight)
float microPivotLo = ta.pivotlow(low, microLeft, microRight)

var float lastMajorHi = na
var float lastMajorLo = na
var float lastMicroHi = na
var float lastMicroLo = na

if not na(majorPivotHi)
    lastMajorHi := majorPivotHi
if not na(majorPivotLo)
    lastMajorLo := majorPivotLo
if not na(microPivotHi)
    lastMicroHi := microPivotHi
if not na(microPivotLo)
    lastMicroLo := microPivotLo

// BOS
bool microBullBOS = not na(lastMicroHi) and close > lastMicroHi and close[1] <= lastMicroHi
bool microBearBOS = not na(lastMicroLo) and close < lastMicroLo and close[1] >= lastMicroLo
bool majorBullBOS = not na(lastMajorHi) and close > lastMajorHi and close[1] <= lastMajorHi
bool majorBearBOS = not na(lastMajorLo) and close < lastMajorLo and close[1] >= lastMajorLo

// Fake breaks + Spring/Upthrust
bool majorFakeBD = not na(lastMajorLo) and low < lastMajorLo and close >= lastMajorLo
bool majorFakeBO = not na(lastMajorHi) and high > lastMajorHi and close <= lastMajorHi
bool isMajorSpring   = majorFakeBD and lowerWickR >= minWickRatio and candleATR >= minCandleATR
bool isMajorUpthrust = majorFakeBO and upperWickR >= minWickRatio and candleATR >= minCandleATR

// Climax
bool isClimaxCandle = candleATR >= climaxRangeATR and avgVol > 0 and volume >= climaxVolFact * avgVol

// ============================================================================
// MODULE: zone tracking (simplified for assessment)
// ============================================================================

type AZone
    int    zType       // 1=swing_sup, 2=swing_res, 3=spring, 4=upthrust, 5=bos_flip_sup, 6=bos_flip_res, 7=clx_sup, 8=clx_res
    float  top
    float  bot
    float  mid
    int    dir         // 1=support, -1=resistance
    int    quality     // 1-3
    int    createBar
    int    status      // 0=fresh, 1=tested, 2=confirmed, 3=broken
    int    touches
    int    goodBounces // bounces > 0.5 ATR
    int    weakBounces // bounces < 0.5 ATR
    float  maxBounce   // largest bounce in ATR
    float  lastBounce  // most recent bounce in ATR
    int    deepPenetrations  // closes deep inside zone

var array<AZone> zones = array.new<AZone>()

f_addZone(int t, float top, float bot, int dir, int qual) =>
    AZone z = AZone.new()
    z.zType := t
    z.top := top
    z.bot := bot
    z.mid := (top + bot) / 2.0
    z.dir := dir
    z.quality := qual
    z.createBar := bar_index
    z.status := 0
    z.touches := 0
    z.goodBounces := 0
    z.weakBounces := 0
    z.maxBounce := 0.0
    z.lastBounce := 0.0
    z.deepPenetrations := 0
    array.push(zones, z)

float hw = atr14 * zoneWidthATR / 2.0

// Create zones from events
if not na(majorPivotHi)
    f_addZone(2, majorPivotHi + hw, majorPivotHi - hw, -1, 2)
if not na(majorPivotLo)
    f_addZone(1, majorPivotLo + hw, majorPivotLo - hw, 1, 2)
if isMajorSpring and not na(lastMajorLo)
    int q = lowerWickR >= 0.55 and candleATR >= 0.8 ? 3 : 2
    f_addZone(3, math.max(low, lastMajorLo), math.min(low, lastMajorLo), 1, q)
if isMajorUpthrust and not na(lastMajorHi)
    int q = upperWickR >= 0.55 and candleATR >= 0.8 ? 3 : 2
    f_addZone(4, math.max(high, lastMajorHi), math.min(high, lastMajorHi), -1, q)
if majorBullBOS and not na(lastMajorHi)
    f_addZone(5, lastMajorHi + hw, lastMajorHi - hw, 1, 2)
if majorBearBOS and not na(lastMajorLo)
    f_addZone(6, lastMajorLo + hw, lastMajorLo - hw, -1, 2)
if isClimaxCandle
    int dir = close < open ? 1 : -1
    int q = relVol >= climaxVolFact * 1.5 ? 3 : 2
    f_addZone(dir == 1 ? 7 : 8, high, low, dir, q)

// Update zone status
int zSize = array.size(zones)
if zSize > 0
    for i = zSize - 1 to 0
        AZone z = array.get(zones, i)
        int age = bar_index - z.createBar
        if age > zoneExpire
            array.remove(zones, i)
            continue
        bool inZone = high >= z.bot and low <= z.top
        bool above  = close > z.top
        bool below  = close < z.bot
        if inZone and z.status == 0
            z.status := 1
            z.touches += 1
        else if inZone and z.status >= 1 and z.status < 3
            z.touches += 1
        // Track bounces for support zones
        if z.dir == 1 and z.status >= 1 and inZone and close > z.mid and close > open
            z.status := 2
            float bounce = atr14 > 0 ? (close - z.bot) / atr14 : 0.0
            z.lastBounce := bounce
            z.maxBounce := math.max(z.maxBounce, bounce)
            if bounce >= 0.5
                z.goodBounces += 1
            else
                z.weakBounces += 1
        // Track bounces for resistance zones
        if z.dir == -1 and z.status >= 1 and inZone and close < z.mid and close < open
            z.status := 2
            float bounce = atr14 > 0 ? (z.top - close) / atr14 : 0.0
            z.lastBounce := bounce
            z.maxBounce := math.max(z.maxBounce, bounce)
            if bounce >= 0.5
                z.goodBounces += 1
            else
                z.weakBounces += 1
        // Deep penetration
        if z.dir == 1 and inZone and close < z.mid
            z.deepPenetrations += 1
        if z.dir == -1 and inZone and close > z.mid
            z.deepPenetrations += 1
        // Broken
        if z.dir == 1 and below and close[1] >= z.bot
            z.status := 3
        if z.dir == -1 and above and close[1] <= z.top
            z.status := 3
        array.set(zones, i, z)

// ============================================================================
// MODULE: nearest zone selector
// ============================================================================

var int nearSupIdx = -1
var int nearResIdx = -1
float nearSupDist = 999.0
float nearResDist = 999.0

nearSupIdx := -1
nearResIdx := -1
nearSupDist := 999.0
nearResDist := 999.0

if array.size(zones) > 0
    for i = 0 to array.size(zones) - 1
        AZone z = array.get(zones, i)
        if z.status == 3
            continue
        float distATR = atr14 > 0 ? math.abs(close - z.mid) / atr14 : 999.0
        if distATR > maxDistATR
            continue
        // Support: zone below price
        if z.dir == 1 and z.mid < close and distATR < nearSupDist
            nearSupDist := distATR
            nearSupIdx := i
        // Resistance: zone above price
        if z.dir == -1 and z.mid > close and distATR < nearResIdx
            nearResDist := distATR
            nearResIdx := i

// ============================================================================
// MODULE: assessment functions
// ============================================================================

f_zoneTypeStr(int t) =>
    t == 1 ? "Swing Support" : t == 2 ? "Swing Resist" : t == 3 ? "Spring Zone" : t == 4 ? "Upthrust Zone" : t == 5 ? "BOS Flip Sup" : t == 6 ? "BOS Flip Res" : t == 7 ? "CLX Support" : t == 8 ? "CLX Resist" : "?"

f_structuralStrength(AZone z) =>
    float s = 0.0
    // Zone type base
    s += z.zType == 3 or z.zType == 4 ? 30.0 : z.zType == 5 or z.zType == 6 ? 25.0 : z.zType == 7 or z.zType == 8 ? 25.0 : 20.0
    // Event quality
    s += z.quality == 3 ? 20.0 : z.quality == 2 ? 10.0 : 4.0
    // Status
    s += z.status == 2 ? 20.0 : z.status == 1 ? 10.0 : z.status == 0 ? 6.0 : -25.0
    // Freshness
    int age = bar_index - z.createBar
    s += age < 30 ? 10.0 : age < 80 ? 5.0 : age > 150 ? -5.0 : 0.0
    math.max(0.0, math.min(100.0, s))

f_historicalRespect(AZone z) =>
    float h = 30.0  // base
    // Successful bounces
    h += math.min(30.0, z.goodBounces * 12.0)
    // Strong max bounce
    h += z.maxBounce >= 1.0 ? 15.0 : z.maxBounce >= 0.5 ? 8.0 : 0.0
    // Penalties
    h -= math.min(20.0, z.deepPenetrations * 5.0)
    h -= z.weakBounces > z.goodBounces ? 10.0 : 0.0
    // Many touches penalty
    h -= z.touches > 3 ? (z.touches - 3) * 5.0 : 0.0
    // Diminishing bounces
    if z.goodBounces >= 2 and z.lastBounce < z.maxBounce * 0.5
        h -= 10.0
    math.max(0.0, math.min(100.0, h))

f_approachQuality(AZone z, float _atr, int lookback) =>
    float aq = 0.0
    if z.dir == 1  // support
        // Momentum slowing? (candle ranges shrinking)
        float avgRange = ta.sma(high - low, lookback)
        float recentRange = (high - low)
        if recentRange < avgRange * 0.8
            aq += 15.0
        // Volume declining in selloff
        if volume < avgVol * 0.9 and close < close[1]
            aq += 10.0
        // Lower wicks increasing
        if lowerWickR > lowerWickR[1] and lowerWickR > 0.3
            aq += 10.0
        // RSI/MFI exhaustion
        if rsi14 < 35
            aq += 10.0
        if mfi14 < 30
            aq += 8.0
        // Negative: expanding red candles
        if recentRange > avgRange * 1.2 and close < open
            aq -= 15.0
        // Volume expanding on selling
        if volume > avgVol * 1.3 and close < open
            aq -= 12.0
        // Fresh bearish major BOS
        if majorBearBOS
            aq -= 18.0
    else  // resistance
        float avgRange = ta.sma(high - low, lookback)
        float recentRange = (high - low)
        if recentRange < avgRange * 0.8
            aq += 15.0
        if volume < avgVol * 0.9 and close > close[1]
            aq += 10.0
        if upperWickR > upperWickR[1] and upperWickR > 0.3
            aq += 10.0
        if rsi14 > 65
            aq += 10.0
        if mfi14 > 70
            aq += 8.0
        if recentRange > avgRange * 1.2 and close > open
            aq -= 15.0
        if volume > avgVol * 1.3 and close > open
            aq -= 12.0
        if majorBullBOS
            aq -= 18.0
    math.max(-100.0, math.min(100.0, aq))

f_contextAlignment(AZone z) =>
    float ca = 0.0
    if z.dir == 1  // support
        ca += isRange ? 15.0 : isTrendDown ? -20.0 : 5.0
        ca += isHighVol and isTrendDown ? -10.0 : isLowVol ? -5.0 : 0.0
        ca += effRatio < 0.25 ? 10.0 : 0.0  // very choppy = support friendly
    else  // resistance
        ca += isRange ? 15.0 : isTrendUp ? -20.0 : 5.0
        ca += isHighVol and isTrendUp ? -10.0 : isLowVol ? -5.0 : 0.0
        ca += effRatio < 0.25 ? 10.0 : 0.0
    math.max(-100.0, math.min(100.0, ca))

f_reachLikelihood(float distATR, AZone z) =>
    float r = distATR <= 0.5 ? 75.0 : distATR <= 1.0 ? 60.0 : distATR <= 2.0 ? 40.0 : 20.0
    // Momentum toward zone
    if z.dir == 1 and close < close[1] and close[1] < close[2]
        r += 15.0  // falling toward support
    if z.dir == -1 and close > close[1] and close[1] > close[2]
        r += 15.0  // rising toward resistance
    // Against momentum
    if z.dir == 1 and close > close[1] and close[1] > close[2]
        r -= 15.0
    if z.dir == -1 and close < close[1] and close[1] < close[2]
        r -= 15.0
    math.max(0.0, math.min(100.0, r))

f_holdLikelihood(float structural, float respect, float aqRaw, float caRaw) =>
    // Map approach (-100..100) to (0..100)
    float aqMapped = (aqRaw + 100.0) / 2.0
    float caMapped = (caRaw + 100.0) / 2.0
    float hold = 0.30 * structural + 0.25 * respect + 0.30 * aqMapped + 0.15 * caMapped
    math.max(0.0, math.min(100.0, hold))

f_breakLikelihood(float hold, float aqRaw, AZone z) =>
    float br = 100.0 - hold  // base inverse
    // Extra break factors
    if aqRaw < -30
        br += 10.0
    if z.touches > 3
        br += z.touches * 3.0
    if z.weakBounces > z.goodBounces
        br += 10.0
    if z.goodBounces >= 2 and z.lastBounce < z.maxBounce * 0.4
        br += 12.0  // diminishing reactions
    math.max(0.0, math.min(100.0, br))

f_bounceQuality(float hold, float structural, bool trendAgainst) =>
    hold < 35 ? "none" : hold < 50 and trendAgainst ? "minor bounce" : hold < 65 ? "reaction bounce" : "reversal candidate"

f_zoneState(float hold, float brk, float aqRaw, AZone z) =>
    brk >= 65 and aqRaw < -20 ? "likely_break" : hold >= 65 ? "likely_reaction" : hold >= 50 and brk >= 50 ? "under_pressure" : z.touches > 3 and z.lastBounce < z.maxBounce * 0.5 ? "weakening" : hold >= 50 ? "holding_candidate" : "stable"

f_holdClass(float h) =>
    h < 31 ? "schwach" : h < 51 ? "brauchbar" : h < 71 ? "solide" : "stark"

f_reachClass(float r) =>
    r < 26 ? "niedrig" : r < 51 ? "mittel" : r < 76 ? "erhoeht" : "hoch"

f_breakClass(float b) =>
    b < 26 ? "niedrig" : b < 51 ? "mittel" : b < 76 ? "erhoeht" : "hoch"

f_stateStr(string s) =>
    s == "likely_break" ? "BREAK WAHRSCHEINLICH" : s == "likely_reaction" ? "REAKTION WAHRSCHEINLICH" : s == "under_pressure" ? "UNTER DRUCK" : s == "weakening" ? "SCHWAECHELT" : s == "holding_candidate" ? "HALT MOEGLICH" : "STABIL"

// ============================================================================
// MODULE: run assessment for nearest zones
// ============================================================================

// Support assessment
var float supStructural = 0.0
var float supRespect    = 0.0
var float supApproach   = 0.0
var float supContext    = 0.0
var float supReach      = 0.0
var float supHold       = 0.0
var float supBreak      = 0.0
var string supBounceQ   = "none"
var string supState     = "stable"
var string supTypeStr   = "—"
var float supTop        = na
var float supBot        = na
var float supMid        = na
var bool  supActive     = false

if nearSupIdx >= 0 and nearSupIdx < array.size(zones)
    AZone z = array.get(zones, nearSupIdx)
    supStructural := f_structuralStrength(z)
    supRespect    := f_historicalRespect(z)
    supApproach   := f_approachQuality(z, atr14, approachBars)
    supContext    := f_contextAlignment(z)
    supReach      := f_reachLikelihood(nearSupDist, z)
    supHold       := f_holdLikelihood(supStructural, supRespect, supApproach, supContext)
    supBreak      := f_breakLikelihood(supHold, supApproach, z)
    supBounceQ    := f_bounceQuality(supHold, supStructural, isTrendDown)
    supState      := f_zoneState(supHold, supBreak, supApproach, z)
    supTypeStr    := f_zoneTypeStr(z.zType)
    supTop        := z.top
    supBot        := z.bot
    supMid        := z.mid
    supActive     := true
else
    supActive := false

// Resistance assessment
var float resStructural = 0.0
var float resRespect    = 0.0
var float resApproach   = 0.0
var float resContext    = 0.0
var float resReach      = 0.0
var float resHold       = 0.0
var float resBreak      = 0.0
var string resBounceQ   = "none"
var string resState     = "stable"
var string resTypeStr   = "—"
var float resTop        = na
var float resBot        = na
var float resMid        = na
var bool  resActive     = false

if nearResIdx >= 0 and nearResIdx < array.size(zones)
    AZone z = array.get(zones, nearResIdx)
    resStructural := f_structuralStrength(z)
    resRespect    := f_historicalRespect(z)
    resApproach   := f_approachQuality(z, atr14, approachBars)
    resContext    := f_contextAlignment(z)
    resReach      := f_reachLikelihood(nearResDist, z)
    resHold       := f_holdLikelihood(resStructural, resRespect, resApproach, resContext)
    resBreak      := f_breakLikelihood(resHold, resApproach, z)
    resBounceQ    := f_bounceQuality(resHold, resStructural, isTrendUp)
    resState      := f_zoneState(resHold, resBreak, resApproach, z)
    resTypeStr    := f_zoneTypeStr(z.zType)
    resTop        := z.top
    resBot        := z.bot
    resMid        := z.mid
    resActive     := true
else
    resActive := false

// ============================================================================
// MODULE: visuals — zone labels on chart
// ============================================================================

var label supLabel = na
var label resLabel = na
var box   supBox   = na
var box   resBox   = na

if barstate.islast
    if not na(supLabel)
        label.delete(supLabel)
    if not na(resLabel)
        label.delete(resLabel)
    if not na(supBox)
        box.delete(supBox)
    if not na(resBox)
        box.delete(resBox)

    if showLabels and supActive and not na(supMid)
        string supText = "SUP: H" + str.tostring(supHold, "#") + " B" + str.tostring(supBreak, "#") + " R" + str.tostring(supReach, "#")
        color  supCol  = supHold > supBreak + 10 ? color.new(#00e676, 10) : supBreak > supHold + 10 ? color.new(#ff1744, 10) : color.new(#ffab00, 10)
        supBox := box.new(bar_index - 20, supTop, bar_index + 5, supBot, border_color=color.new(#00e676, 40), border_width=1, bgcolor=color.new(#00e676, 90))
        supLabel := label.new(bar_index + 6, supMid, supText, style=label.style_label_left, color=color.new(color.black, 100), textcolor=supCol, size=size.small, tooltip="Support: " + supTypeStr + "\nReach: " + str.tostring(supReach, "#") + " (" + f_reachClass(supReach) + ")\nHold: " + str.tostring(supHold, "#") + " (" + f_holdClass(supHold) + ")\nBreak: " + str.tostring(supBreak, "#") + " (" + f_breakClass(supBreak) + ")\nBounce: " + supBounceQ + "\nState: " + f_stateStr(supState))

    if showLabels and resActive and not na(resMid)
        string resText = "RES: H" + str.tostring(resHold, "#") + " B" + str.tostring(resBreak, "#") + " R" + str.tostring(resReach, "#")
        color  resCol  = resHold > resBreak + 10 ? color.new(#ff1744, 10) : resBreak > resHold + 10 ? color.new(#00e676, 10) : color.new(#ffab00, 10)
        resBox := box.new(bar_index - 20, resTop, bar_index + 5, resBot, border_color=color.new(#ff1744, 40), border_width=1, bgcolor=color.new(#ff1744, 90))
        resLabel := label.new(bar_index + 6, resMid, resText, style=label.style_label_left, color=color.new(color.black, 100), textcolor=resCol, size=size.small, tooltip="Resistance: " + resTypeStr + "\nReach: " + str.tostring(resReach, "#") + " (" + f_reachClass(resReach) + ")\nHold: " + str.tostring(resHold, "#") + " (" + f_holdClass(resHold) + ")\nBreak: " + str.tostring(resBreak, "#") + " (" + f_breakClass(resBreak) + ")\nBounce: " + resBounceQ + "\nState: " + f_stateStr(resState))

// ============================================================================
// MODULE: assessment table
// ============================================================================

var table assessTable = na
if showTable and barstate.islast
    assessTable := table.new(position.top_left, 3, 12, bgcolor=color.new(#1a1a2e, 5), border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.gray, 50), frame_width=2)

    table.cell(assessTable, 0, 0, "Zone Assessment", text_color=color.white, text_size=size.normal)
    table.cell(assessTable, 1, 0, "SUPPORT", text_color=#00e676, text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 2, 0, "RESISTANCE", text_color=#ff1744, text_size=size.normal, text_halign=text.align_center)

    // Zone type
    table.cell(assessTable, 0, 1, "Zone", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 1, supActive ? supTypeStr : "—", text_color=supActive ? color.new(color.white, 20) : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 1, resActive ? resTypeStr : "—", text_color=resActive ? color.new(color.white, 20) : color.gray, text_size=size.small, text_halign=text.align_center)

    // Distance
    table.cell(assessTable, 0, 2, "Distanz", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 2, supActive ? str.tostring(nearSupDist, "#.1") + " ATR" : "—", text_color=supActive ? color.new(color.white, 20) : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 2, resActive ? str.tostring(nearResDist, "#.1") + " ATR" : "—", text_color=resActive ? color.new(color.white, 20) : color.gray, text_size=size.small, text_halign=text.align_center)

    // Structural
    table.cell(assessTable, 0, 3, "Struktur", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 3, supActive ? str.tostring(supStructural, "#") : "—", text_color=supActive ? (supStructural >= 60 ? #00e676 : supStructural >= 40 ? color.yellow : color.gray) : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 3, resActive ? str.tostring(resStructural, "#") : "—", text_color=resActive ? (resStructural >= 60 ? #ff1744 : resStructural >= 40 ? color.yellow : color.gray) : color.gray, text_size=size.small, text_halign=text.align_center)

    // Respect
    table.cell(assessTable, 0, 4, "Respekt", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 4, supActive ? str.tostring(supRespect, "#") : "—", text_color=supActive ? (supRespect >= 60 ? #00e676 : supRespect >= 40 ? color.yellow : color.gray) : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 4, resActive ? str.tostring(resRespect, "#") : "—", text_color=resActive ? (resRespect >= 60 ? #ff1744 : resRespect >= 40 ? color.yellow : color.gray) : color.gray, text_size=size.small, text_halign=text.align_center)

    // Approach
    table.cell(assessTable, 0, 5, "Anlauf", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 5, supActive ? str.tostring(supApproach, "#") : "—", text_color=supActive ? (supApproach > 10 ? #00e676 : supApproach < -10 ? #ff1744 : color.yellow) : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 5, resActive ? str.tostring(resApproach, "#") : "—", text_color=resActive ? (resApproach > 10 ? #ff1744 : resApproach < -10 ? #00e676 : color.yellow) : color.gray, text_size=size.small, text_halign=text.align_center)

    // Context
    table.cell(assessTable, 0, 6, "Kontext", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(assessTable, 1, 6, supActive ? str.tostring(supContext, "#") : "—", text_color=supActive ? (supContext > 5 ? #00e676 : supContext < -5 ? #ff1744 : color.yellow) : color.gray, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 6, resActive ? str.tostring(resContext, "#") : "—", text_color=resActive ? (resContext > 5 ? #ff1744 : resContext < -5 ? #00e676 : color.yellow) : color.gray, text_size=size.small, text_halign=text.align_center)

    // Separator
    table.cell(assessTable, 0, 7, "─ ERGEBNIS ─", text_color=color.new(color.white, 40), text_size=size.small)
    table.cell(assessTable, 1, 7, "", text_size=size.small)
    table.cell(assessTable, 2, 7, "", text_size=size.small)

    // Reach
    table.cell(assessTable, 0, 8, "Reach", text_color=color.new(color.white, 30), text_size=size.normal)
    table.cell(assessTable, 1, 8, supActive ? str.tostring(supReach, "#") + " " + f_reachClass(supReach) : "—", text_color=supActive ? (supReach >= 60 ? #00e676 : color.new(color.white, 30)) : color.gray, text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 2, 8, resActive ? str.tostring(resReach, "#") + " " + f_reachClass(resReach) : "—", text_color=resActive ? (resReach >= 60 ? #ff1744 : color.new(color.white, 30)) : color.gray, text_size=size.normal, text_halign=text.align_center)

    // Hold
    table.cell(assessTable, 0, 9, "Hold", text_color=color.new(color.white, 30), text_size=size.normal)
    color supHoldCol = supActive ? (supHold >= 60 ? #00e676 : supHold >= 45 ? color.yellow : #ff1744) : color.gray
    color resHoldCol = resActive ? (resHold >= 60 ? #ff1744 : resHold >= 45 ? color.yellow : #00e676) : color.gray
    table.cell(assessTable, 1, 9, supActive ? str.tostring(supHold, "#") + " " + f_holdClass(supHold) : "—", text_color=supHoldCol, text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 2, 9, resActive ? str.tostring(resHold, "#") + " " + f_holdClass(resHold) : "—", text_color=resHoldCol, text_size=size.normal, text_halign=text.align_center)

    // Break
    table.cell(assessTable, 0, 10, "Break", text_color=color.new(color.white, 30), text_size=size.normal)
    color supBreakCol = supActive ? (supBreak >= 60 ? #ff1744 : supBreak >= 45 ? color.yellow : #00e676) : color.gray
    color resBreakCol = resActive ? (resBreak >= 60 ? #00e676 : resBreak >= 45 ? color.yellow : #ff1744) : color.gray
    table.cell(assessTable, 1, 10, supActive ? str.tostring(supBreak, "#") + " " + f_breakClass(supBreak) : "—", text_color=supBreakCol, text_size=size.normal, text_halign=text.align_center)
    table.cell(assessTable, 2, 10, resActive ? str.tostring(resBreak, "#") + " " + f_breakClass(resBreak) : "—", text_color=resBreakCol, text_size=size.normal, text_halign=text.align_center)

    // State
    table.cell(assessTable, 0, 11, "Status", text_color=color.white, text_size=size.normal)
    color supStateCol = supState == "likely_reaction" ? #00e676 : supState == "likely_break" ? #ff1744 : supState == "under_pressure" or supState == "weakening" ? #ffab00 : color.new(color.white, 30)
    color resStateCol = resState == "likely_reaction" ? #ff1744 : resState == "likely_break" ? #00e676 : resState == "under_pressure" or resState == "weakening" ? #ffab00 : color.new(color.white, 30)
    table.cell(assessTable, 1, 11, supActive ? f_stateStr(supState) : "—", text_color=supStateCol, text_size=size.small, text_halign=text.align_center)
    table.cell(assessTable, 2, 11, resActive ? f_stateStr(resState) : "—", text_color=resStateCol, text_size=size.small, text_halign=text.align_center)

// ============================================================================
// MODULE: data window
// ============================================================================

plot(supActive ? supReach : na, "Sup Reach", display=display.data_window, color=color.new(color.gray, 100))
plot(supActive ? supHold : na, "Sup Hold", display=display.data_window, color=color.new(color.gray, 100))
plot(supActive ? supBreak : na, "Sup Break", display=display.data_window, color=color.new(color.gray, 100))
plot(resActive ? resReach : na, "Res Reach", display=display.data_window, color=color.new(color.gray, 100))
plot(resActive ? resHold : na, "Res Hold", display=display.data_window, color=color.new(color.gray, 100))
plot(resActive ? resBreak : na, "Res Break", display=display.data_window, color=color.new(color.gray, 100))

// ============================================================================
// MODULE: alerts
// ============================================================================

bool supNear = supActive and nearSupDist <= 1.0
bool resNear = resActive and nearResDist <= 1.0

alertcondition(supNear and supReach >= 60 and (supHold >= 50 or supBreak >= 50), "Support Review", "NG 4H: Support zone becoming relevant — check chart")
alertcondition(resNear and resReach >= 60 and (resHold >= 50 or resBreak >= 50), "Resistance Review", "NG 4H: Resistance zone becoming relevant — check chart")
alertcondition(supNear and supReach >= 70 and supHold >= 60 and supBreak < 45, "Likely Support Hold", "NG 4H: Support likely to hold — reaction probable")
alertcondition(resNear and resReach >= 70 and resHold >= 60 and resBreak < 45, "Likely Resistance Hold", "NG 4H: Resistance likely to hold — reaction probable")
alertcondition(supNear and supReach >= 70 and supBreak >= 60 and supHold < 45, "Likely Support Break", "NG 4H: Support under pressure — break risk elevated")
alertcondition(resNear and resReach >= 70 and resBreak >= 60 and resHold < 45, "Likely Resistance Break", "NG 4H: Resistance under pressure — break risk elevated")
