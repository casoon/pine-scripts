// ============================================================================
// RTA-CORE: DIVERGENCE DETECTION - Universal Divergence Analysis
// ============================================================================
// @description: Comprehensive divergence detection for oscillators
//
// Purpose:
//   - Regular divergence (trend reversal signals)
//   - Hidden divergence (trend continuation signals)
//   - Both series-based and array-based implementations
//   - Used by: FlowZone, Smart Money, Pattern Detection, Wave Analysis
//
// Divergence Types:
//   Regular Bullish: Price LL + Oscillator HL (reversal up)
//   Regular Bearish: Price HH + Oscillator LH (reversal down)
//   Hidden Bullish: Price HL + Oscillator LL (continuation up)
//   Hidden Bearish: Price LH + Oscillator HH (continuation down)
//
// Integration:
//   import RedefiningTechnicalAnalysis/RTACore/1 as RTA
//   RTA.detectDivergence(...)
//
// Migrated from: _shared/divergence.pine
// ============================================================================

// ==== HELPER: LAST TWO PIVOTS ====
// Track last two confirmed pivots for divergence comparison
// @param s: Source series (price or oscillator)
// @param l: Left bars for pivot
// @param r: Right bars for pivot
// @param isHigh: true for highs, false for lows
// @returns [val1, idx1, val2, idx2]
export lastTwoPivots(series float s, int l, int r, bool isHigh) =>
    var float v1 = na
    var float v2 = na
    var int i1 = na
    var int i2 = na

    float piv = isHigh ? ta.pivothigh(s, l, r) : ta.pivotlow(s, l, r)

    if not na(piv)
        // Shift old pivot to slot 2
        v2 := v1
        i2 := i1
        // Store new pivot in slot 1
        v1 := piv
        i1 := bar_index - r

    [v1, i1, v2, i2]

// ==== REGULAR DIVERGENCE (SERIES-BASED) ====
// Detect regular divergence using series data (CPM-style)
// Best for: Real-time detection, inline processing
// @param oscSeries: Oscillator series (RSI, MACD, etc.)
// @param leftBars: Left lookback for pivot
// @param rightBars: Right lookback for pivot
// @returns [bullishDiv, bearishDiv]
export detectRegularDivergence(series float oscSeries, int leftBars, int rightBars) =>
    // Get price pivots
    [pH1, iPH1, pH2, iPH2] = lastTwoPivots(high, leftBars, rightBars, true)
    [pL1, iPL1, pL2, iPL2] = lastTwoPivots(low, leftBars, rightBars, false)

    // Get oscillator pivots
    [oH1, iOH1, oH2, iOH2] = lastTwoPivots(oscSeries, leftBars, rightBars, true)
    [oL1, iOL1, oL2, iOL2] = lastTwoPivots(oscSeries, leftBars, rightBars, false)

    // Check validity
    bool okH = not na(iPH1) and not na(iPH2) and not na(iOH1) and not na(iOH2)
    bool okL = not na(iPL1) and not na(iPL2) and not na(iOL1) and not na(iOL2)

    // Regular Bearish: Price HH + Osc LH
    bool regBear = okH and (pH1 > pH2) and (oH1 < oH2)

    // Regular Bullish: Price LL + Osc HL
    bool regBull = okL and (pL1 < pL2) and (oL1 > oL2)

    [regBull, regBear]

// ==== REGULAR DIVERGENCE (ARRAY-BASED) ====
// Detect regular divergence using pre-computed pivot arrays (Pattern Pilot-style)
// Best for: Post-processing, batch analysis
// @param pricePivots: Array of price pivots (most recent last)
// @param oscPivots: Array of oscillator pivots (same size)
// @param isHigh: true for highs (bearish div), false for lows (bullish div)
// @returns Boolean divergence flag
export detectRegularDivergenceArray(array<float> pricePivots, array<float> oscPivots, bool isHigh) =>
    bool hasDivergence = false

    if array.size(pricePivots) >= 2 and array.size(oscPivots) >= 2
        float pivot1 = array.get(pricePivots, array.size(pricePivots) - 2)
        float pivot2 = array.get(pricePivots, array.size(pricePivots) - 1)
        float ind1 = array.get(oscPivots, array.size(oscPivots) - 2)
        float ind2 = array.get(oscPivots, array.size(oscPivots) - 1)

        if isHigh
            // Bearish: Price HH, Indicator LH
            hasDivergence := pivot2 > pivot1 and ind2 < ind1
        else
            // Bullish: Price LL, Indicator HL
            hasDivergence := pivot2 < pivot1 and ind2 > ind1

    hasDivergence

// ==== HIDDEN DIVERGENCE (ARRAY-BASED) ====
// Detect hidden divergence (trend continuation)
// @param pricePivots: Array of price pivots
// @param oscPivots: Array of oscillator pivots
// @param isHigh: true for highs (bullish hidden), false for lows (bearish hidden)
// @returns Boolean divergence flag
export detectHiddenDivergenceArray(array<float> pricePivots, array<float> oscPivots, bool isHigh) =>
    bool hasDivergence = false

    if array.size(pricePivots) >= 2 and array.size(oscPivots) >= 2
        float pivot1 = array.get(pricePivots, array.size(pricePivots) - 2)
        float pivot2 = array.get(pricePivots, array.size(pricePivots) - 1)
        float ind1 = array.get(oscPivots, array.size(oscPivots) - 2)
        float ind2 = array.get(oscPivots, array.size(oscPivots) - 1)

        if isHigh
            // Bullish Hidden: Price LH, Indicator HH (uptrend continuation)
            hasDivergence := pivot2 < pivot1 and ind2 > ind1
        else
            // Bearish Hidden: Price HL, Indicator LL (downtrend continuation)
            hasDivergence := pivot2 > pivot1 and ind2 < ind1

    hasDivergence

// ==== HIDDEN DIVERGENCE (SERIES-BASED) ====
// Detect hidden divergence using series data
// @param oscSeries: Oscillator series
// @param leftBars: Left lookback
// @param rightBars: Right lookback
// @returns [bullishHidden, bearishHidden]
export detectHiddenDivergence(series float oscSeries, int leftBars, int rightBars) =>
    // Get price pivots
    [pH1, iPH1, pH2, iPH2] = lastTwoPivots(high, leftBars, rightBars, true)
    [pL1, iPL1, pL2, iPL2] = lastTwoPivots(low, leftBars, rightBars, false)

    // Get oscillator pivots
    [oH1, iOH1, oH2, iOH2] = lastTwoPivots(oscSeries, leftBars, rightBars, true)
    [oL1, iOL1, oL2, iOL2] = lastTwoPivots(oscSeries, leftBars, rightBars, false)

    // Check validity
    bool okH = not na(iPH1) and not na(iPH2) and not na(iOH1) and not na(iOH2)
    bool okL = not na(iPL1) and not na(iPL2) and not na(iOL1) and not na(iOL2)

    // Bullish Hidden: Price LH + Osc HH (uptrend continuation)
    bool hidBull = okH and (pH1 < pH2) and (oH1 > oH2)

    // Bearish Hidden: Price HL + Osc LL (downtrend continuation)
    bool hidBear = okL and (pL1 > pL2) and (oL1 < oL2)

    [hidBull, hidBear]

// ==== UNIVERSAL DIVERGENCE DETECTOR ====
// Comprehensive divergence detection with all types
// @param oscSeries: Oscillator series
// @param leftBars: Left lookback
// @param rightBars: Right lookback
// @returns [regBull, regBear, hidBull, hidBear]
export detectAllDivergences(series float oscSeries, int leftBars, int rightBars) =>
    [regBull, regBear] = detectRegularDivergence(oscSeries, leftBars, rightBars)
    [hidBull, hidBear] = detectHiddenDivergence(oscSeries, leftBars, rightBars)
    [regBull, regBear, hidBull, hidBear]

// ==== DIVERGENCE STRENGTH CALCULATOR ====
// Calculate divergence strength based on price/oscillator gap
// @param priceVal1: First price pivot
// @param priceVal2: Second price pivot
// @param oscVal1: First oscillator pivot
// @param oscVal2: Second oscillator pivot
// @returns Strength score (0-1)
export calculateDivergenceStrength(float priceVal1, float priceVal2, float oscVal1, float oscVal2) =>
    float priceChange = math.abs(priceVal2 - priceVal1)
    float oscChange = math.abs(oscVal2 - oscVal1)

    // Normalize to percentage
    float pricePct = priceVal1 != 0 ? priceChange / math.abs(priceVal1) * 100 : 0
    float oscPct = oscVal1 != 0 ? oscChange / math.abs(oscVal1) * 100 : 0

    // Strength = divergence gap
    float strength = math.abs(pricePct - oscPct)

    // Normalize to 0-1 (cap at 20% difference = strength 1.0)
    math.min(strength / 20.0, 1.0)

// ============================================================================
// END OF SHARED DIVERGENCE MODULE
// ============================================================================
// Available Functions:
//   Series-based:
//     - f_divergence_regular_series(osc, left, right) => [bull, bear]
//     - f_divergence_hidden_series(osc, left, right) => [bull, bear]
//     - f_detect_basic_divergences(osc, left, right) => [regBull, regBear, hidBull, hidBear]
//
//   Array-based:
//     - f_divergence_regular_array(prices, oscs, isHigh) => bool
//     - f_divergence_hidden_array(prices, oscs, isHigh) => bool
//
//   Utilities:
//     - f_divergence_strength(pv1, pv2, ov1, ov2) => float (0-1)
//     - f_last_two_pivots(series, left, right, isHigh) => [v1, i1, v2, i2]
//
// Usage Example (Series-based):
//   float rsi = ta.rsi(close, 14)
//   [regBull, regBear, hidBull, hidBear] = f_detect_basic_divergences(rsi, 5, 5)
//   if regBull
//       // Bullish reversal setup
//
// Usage Example (Array-based):
//   array<float> priceHighs = array.new_float()
//   array<float> rsiHighs = array.new_float()
//   // ... populate arrays ...
//   bool bearishDiv = f_divergence_regular_array(priceHighs, rsiHighs, true)
// ============================================================================


// ============================================================================
// MODULE: FIBONACCI_ANALYSIS
// ============================================================================

// ============================================================================
// RTA-CORE: FIBONACCI ANALYSIS - Universal Fibonacci Calculations
// ============================================================================
// @description: Fibonacci retracement and extension levels
//
// Purpose:
//   - Standard Fibonacci levels (23.6%, 38.2%, 50%, 61.8%, 78.6%, 100%)
//   - Extension levels (127.2%, 161.8%, 200%, 261.8%, 423.6%)
//   - Range tolerance checking
//   - Automatic level calculation from swing highs/lows
//   - Used by: FlowZone, Wave Navigator, Pattern Detection
//
// Applications:
//   - Retracement level calculation for pullbacks
//   - Extension targets for breakouts
//   - Support/Resistance zone identification
//   - Wave analysis (Elliott Wave, etc.)
//
// Integration:
//   import RedefiningTechnicalAnalysis/RTACore/1 as RTA
//   RTA.calculateFibonacci(...)
//
// Migrated from: _shared/fibonacci.pine
// ============================================================================

// ==== FIBONACCI CONSTANTS ====

export const float FIB_0 = 0.0
export const float FIB_236 = 0.236
export const float FIB_382 = 0.382
export const float FIB_500 = 0.500
export const float FIB_618 = 0.618
export const float FIB_786 = 0.786
export const float FIB_1000 = 1.000
export const float FIB_1272 = 1.272
export const float FIB_1618 = 1.618
export const float FIB_2000 = 2.000
export const float FIB_2618 = 2.618
export const float FIB_4236 = 4.236

// ==== RETRACEMENT CALCULATIONS ====

// Calculate Fibonacci retracement level
export calculateFibRetracement(float start, float end, float fibLevel) =>
    float rangeVal = end - start
    end - (rangeVal * fibLevel)

// Calculate all standard retracement levels
export calculateFibRetracements(float start, float end) =>
    float fib0 = end
    float fib236 = calculateFibRetracement(start, end, FIB_236)
    float fib382 = calculateFibRetracement(start, end, FIB_382)
    float fib500 = calculateFibRetracement(start, end, FIB_500)
    float fib618 = calculateFibRetracement(start, end, FIB_618)
    float fib786 = calculateFibRetracement(start, end, FIB_786)
    float fib1000 = start

    [fib0, fib236, fib382, fib500, fib618, fib786, fib1000]

// ==== EXTENSION CALCULATIONS ====

export calculateFibExtension(float start, float end, float fibLevel, bool isUpward) =>
    float rangeVal = math.abs(end - start)
    if isUpward
        end + (rangeVal * (fibLevel - 1.0))
    else
        end - (rangeVal * (fibLevel - 1.0))

export calculateFibExtensions(float start, float end, bool isUpward) =>
    float fib1272 = calculateFibExtension(start, end, FIB_1272, isUpward)
    float fib1618 = calculateFibExtension(start, end, FIB_1618, isUpward)
    float fib2000 = calculateFibExtension(start, end, FIB_2000, isUpward)
    float fib2618 = calculateFibExtension(start, end, FIB_2618, isUpward)
    float fib4236 = calculateFibExtension(start, end, FIB_4236, isUpward)

    [fib1272, fib1618, fib2000, fib2618, fib4236]

// ==== RANGE CHECKING ====

export isInFibRange(float actual, float target, float tolerance) =>
    float lower = target * (1.0 - tolerance)
    float upper = target * (1.0 + tolerance)
    actual >= lower and actual <= upper

export isNearFibLevel(float price, float start, float end, float tolerance = 0.02) =>
    [fib0, fib236, fib382, fib500, fib618, fib786, fib1000] = calculateFibRetracements(start, end)

    bool nearFib = false
    float closestLevel = na
    float closestDistance = 999999.0

    // Check each level
    array<float> levels = array.from(fib0, fib236, fib382, fib500, fib618, fib786, fib1000)
    array<float> ratios = array.from(0.0, 0.236, 0.382, 0.500, 0.618, 0.786, 1.000)

    for i = 0 to array.size(levels) - 1
        float level = array.get(levels, i)
        float distance = math.abs(price - level)
        float rangeVal = math.abs(end - start)
        float toleranceAbs = rangeVal * tolerance

        if distance <= toleranceAbs and distance < closestDistance
            nearFib := true
            closestLevel := array.get(ratios, i)
            closestDistance := distance

    [nearFib, closestLevel, closestDistance]

// ==== WAVE ANALYSIS HELPERS ====

export calculateRetracementRatio(float swing1Start, float swing1End, float swing2End) =>
    float swing1Range = math.abs(swing1End - swing1Start)
    float swing2Range = math.abs(swing2End - swing1End)

    if swing1Range > 0
        swing2Range / swing1Range
    else
        na

export calculateExtensionRatio(float swing1Start, float swing1End, float swing2End) =>
    float swing1Range = math.abs(swing1End - swing1Start)
    float swing2Range = math.abs(swing2End - swing1Start)

    if swing1Range > 0
        swing2Range / swing1Range
    else
        na

// ==== CLUSTERING DETECTION ====

export detectFibCluster(float price, array<float> swings, float tolerance = 0.02) =>
    int clusterCount = 0
    float totalLevel = 0.0

    int numSwings = array.size(swings) / 2
    for i = 0 to numSwings - 1
        float start = array.get(swings, i * 2)
        float end = array.get(swings, i * 2 + 1)

        [nearFib, level, _] = isNearFibLevel(price, start, end, tolerance)
        if nearFib
            clusterCount += 1
            totalLevel += level

    bool isClustered = clusterCount >= 2
    float avgLevel = clusterCount > 0 ? totalLevel / clusterCount : na

    [isClustered, clusterCount, avgLevel]

// ==== PROJECTION HELPERS ====

export projectFibTarget(float swingLow, float swingHigh, float pullbackLevel, float extensionRatio, bool isBullish) =>
    float rangeVal = swingHigh - swingLow

    if isBullish
        pullbackLevel + (rangeVal * extensionRatio)
    else
        pullbackLevel - (rangeVal * extensionRatio)

export calculateIdealEntryZone(float start, float end) =>
    float fib382 = calculateFibRetracement(start, end, FIB_382)
    float fib618 = calculateFibRetracement(start, end, FIB_618)

    [math.min(fib382, fib618), math.max(fib382, fib618)]

// ============================================================================
// END OF SHARED FIBONACCI MODULE
// ============================================================================
// Available Functions:
//   Retracements:
//     - f_fib_retracement(start, end, level) => price
//     - f_fib_retracements(start, end) => [7 levels]
//
//   Extensions:
//     - f_fib_extension(start, end, level, isUp) => price
//     - f_fib_extensions(start, end, isUp) => [5 levels]
//
//   Range Checking:
//     - f_in_fib_range(actual, target, tolerance) => bool
//     - f_near_fib_level(price, start, end, tol) => [isNear, level, distance]
//
//   Wave Analysis:
//     - f_retracement_ratio(s1Start, s1End, s2End) => ratio
//     - f_extension_ratio(s1Start, s1End, s2End) => ratio
//
//   Advanced:
//     - f_fib_cluster(price, swings, tol) => [isClustered, count, avgLevel]
//     - f_project_target(low, high, pullback, ext, isUp) => target
//     - f_ideal_entry_zone(start, end) => [lower, upper]
//
// Usage Example:
//   // Calculate retracement levels
//   [fib0, fib236, fib382, fib500, fib618, fib786, fib1000] = f_fib_retracements(swingLow, swingHigh)
//
//   // Check if price is at golden ratio
//   bool atGolden = f_in_fib_range(close, fib618, 0.02)
//
//   // Project extension target
//   float target1618 = f_project_target(swingLow, swingHigh, close, 1.618, true)
//
//   // Find ideal entry zone
//   [entryLower, entryUpper] = f_ideal_entry_zone(swingLow, swingHigh)
// ============================================================================


// ============================================================================
// MODULE: PATTERN_GEOMETRY
// ============================================================================

// ============================================================================
// RTA-CORE: PATTERN GEOMETRY - Line Analysis and Pattern Detection
// ============================================================================
// @description: Geometric calculations for pattern detection
//
// Purpose:
//   - Line slope calculations
//   - Convergence/divergence detection
//   - Parallel line detection
//   - Touch counting
//   - Used by: Wave Corridors, Pattern Recognition, Chart Pattern Detection
//
// Applications:
//   - Triangle pattern detection (ascending, descending, symmetrical)
//   - Wedge pattern detection (rising, falling)
//   - Channel detection (parallel lines)
//   - Trendline validation
//
// Integration:
//   import RedefiningTechnicalAnalysis/RTACore/1 as RTA
//   RTA.calculateGeometry(...)
//
// Migrated from: _shared/geometry.pine
// ============================================================================

// ==== LINE SLOPE CALCULATIONS ====

export calculateLineSlope(float y1, float y2, int x1, int x2) =>
    float slope = x2 - x1 != 0 ? (y2 - y1) / (x2 - x1) : 0.0
    slope

export calculateSlopeAngle(float slope) =>
    math.todegrees(math.atan(slope))

export calculateLineYAt(int x1, float y1, float slope, int x) =>
    y1 + slope * (x - x1)

// ==== LINE RELATIONSHIP DETECTION ====

export areLinesConverging(float upperSlope, float lowerSlope, bool isAscending) =>
    bool converging = false
    if isAscending
        converging := upperSlope < lowerSlope
    else
        converging := upperSlope > lowerSlope
    converging

export areLinesDiverging(float upperSlope, float lowerSlope, bool isAscending) =>
    not areLinesConverging(upperSlope, lowerSlope, isAscending)

export areLinesParallel(float upperSlope, float lowerSlope, float tolerance = 0.1) =>
    float diff = math.abs(upperSlope - lowerSlope)
    float avg = (math.abs(upperSlope) + math.abs(lowerSlope)) / 2.0
    bool isParallel = avg > 0 ? (diff / avg) < tolerance : diff < tolerance / 100.0
    isParallel

// ==== TOUCH DETECTION ====

export priceTouchesLine(float price, float lineY, float tolerance = 1.0) =>
    float toleranceRange = lineY * (tolerance / 100.0)
    bool touches = math.abs(price - lineY) <= toleranceRange
    touches

export countLineTouches(int startBar, int endBar, float y1, float y2, bool isUpper, float tolerance = 1.0) =>
    int touches = 0
    int barRange = endBar - startBar

    if barRange > 0
        float slope = calculateLineSlope(y1, y2, startBar, endBar)

        for i = 0 to math.min(barRange, 100)
            int currentBar = startBar + i
            int barsAgo = bar_index - currentBar

            if barsAgo >= 0
                float priceAtBar = isUpper ? high[barsAgo] : low[barsAgo]
                float lineYAtBar = calculateLineYAt(startBar, y1, slope, currentBar)

                if priceTouchesLine(priceAtBar, lineYAtBar, tolerance)
                    touches += 1

    touches

// ==== BREAKOUT DETECTION ====

export checkBreakout(float upperY, float lowerY) =>
    bool bullishBreakout = close > upperY
    bool bearishBreakout = close < lowerY
    bool hasBreakout = bullishBreakout or bearishBreakout
    bool isBullish = bullishBreakout
    [hasBreakout, isBullish]

export checkBreakoutConfirmed(float upperY, float lowerY, bool requireBodyClose = true) =>
    bool bullishBreakout = close > upperY
    bool bearishBreakout = close < lowerY

    bool bodyCloseOut = true
    if requireBodyClose
        bodyCloseOut := (bullishBreakout and math.min(open, close) > upperY) or (bearishBreakout and math.max(open, close) < lowerY)

    bool hasBreakout = bullishBreakout or bearishBreakout
    bool isBullish = bullishBreakout
    bool isConfirmed = hasBreakout and bodyCloseOut

    [hasBreakout, isBullish, isConfirmed]

// ==== DISTANCE CALCULATIONS ====

export calculatePointToLineDistance(int px, float py, int x1, float y1, int x2, float y2) =>
    float dx = x2 - x1
    float dy = y2 - y1
    float lengthSq = dx * dx + dy * dy

    if lengthSq == 0.0
        math.sqrt((px - x1) * (px - x1) + (py - y1) * (py - y1))
    else
        float t = ((px - x1) * dx + (py - y1) * dy) / lengthSq
        t := math.max(0.0, math.min(1.0, t))
        float projX = x1 + t * dx
        float projY = y1 + t * dy
        math.sqrt((px - projX) * (px - projX) + (py - projY) * (py - projY))

export calculateVerticalDistance(float price, float lineY) =>
    math.abs(price - lineY)

// ==== PATTERN VALIDATION ====

export validateTriangle(int upperTouches, int lowerTouches, int minTouches = 2) =>
    upperTouches >= minTouches and lowerTouches >= minTouches

export validateChannel(float upperSlope, float lowerSlope, float tolerance = 0.1) =>
    areLinesParallel(upperSlope, lowerSlope, tolerance)

// ==== INTERSECTION CALCULATIONS ====

export calculateLineIntersection(int x1a, float y1a, int x2a, float y2a, int x1b, float y1b, int x2b, float y2b) =>
    float dxa = x2a - x1a
    float dya = y2a - y1a
    float dxb = x2b - x1b
    float dyb = y2b - y1b

    float det = dxa * dyb - dya * dxb

    if math.abs(det) < 0.0001
        [na, na, false]
    else
        float t = ((x1b - x1a) * dyb - (y1b - y1a) * dxb) / det
        float intersectX = x1a + t * dxa
        float intersectY = y1a + t * dya
        [intersectX, intersectY, true]

// ============================================================================
// END OF SHARED GEOMETRY MODULE
// ============================================================================
// Available Functions:
//   Slope: f_lineSlope, f_slopeAngle, f_lineYAt
//   Relationships: f_linesConverging, f_linesDiverging, f_linesParallel
//   Touches: f_priceTouchesLine, f_countLineTouches
//   Breakouts: f_checkBreakout, f_checkBreakoutConfirmed
//   Distance: f_pointToLineDistance, f_verticalDistance
//   Validation: f_validateTriangle, f_validateChannel
//   Intersection: f_lineIntersection
//
// Usage Example (Triangle Detection):
//   // Define upper and lower trendlines
//   float upperSlope = f_lineSlope(high[50], high[10], bar_index[50], bar_index[10])
//   float lowerSlope = f_lineSlope(low[50], low[10], bar_index[50], bar_index[10])
//
//   // Check if converging (triangle)
//   bool isTriangle = f_linesConverging(upperSlope, lowerSlope, true)
//
//   // Count touches
//   int upperTouches = f_countLineTouches(bar_index[50], bar_index, high[50], high, true, 1.0)
//   int lowerTouches = f_countLineTouches(bar_index[50], bar_index, low[50], low, false, 1.0)
//
//   // Validate pattern
//   bool validTriangle = f_validateTriangle(upperTouches, lowerTouches, 2)
// ============================================================================


