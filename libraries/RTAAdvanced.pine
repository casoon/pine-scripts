// ============================================================================

// ============================================================================
// RTA-ADVANCED: PIVOT DETECTION - Universal Pivot Point Analysis
// ============================================================================
// @description: Comprehensive pivot point detection and management
//
// Purpose:
//   - Detect swing highs and swing lows (pivots)
//   - Manage pivot history with configurable storage
//   - Query pivot data for pattern recognition
//   - Support both real-time and historical pivot analysis
//
// Pivot Types:
//   - Pivot High: Local maximum (swing high)
//   - Pivot Low: Local minimum (swing low)
//   - Configurable left/right bars for pivot confirmation
//
// Use Cases:
//   - Pattern recognition (triangles, wedges, channels)
//   - Support/resistance identification
//   - Trend structure analysis
//   - Wave counting (Elliott Wave, etc.)
//
// Integration:
//   import "pivot_detection" as pivots
//   [pH, pL] = pivots.detectPivots(5, 5)
//
// Extracted from: pattern-recognition/modules/pivot_engine.pine
// ============================================================================

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

// @type Pivot point data structure
// @field price Pivot price level
// @field barIndex Bar index where pivot occurred
// @field isPivotHigh True if pivot high, false if pivot low
// @field timestamp Time when pivot formed
export type Pivot
    float price
    int barIndex
    bool isPivotHigh
    int timestamp

// @type Pivot history storage
// @field highs Array of pivot high prices
// @field highBars Array of pivot high bar indices
// @field lows Array of pivot low prices
// @field lowBars Array of pivot low bar indices
// @field maxStored Maximum number of pivots to store
export type PivotHistory
    array<float> highs
    array<int> highBars
    array<float> lows
    array<int> lowBars
    int maxStored

// ============================================================================
// CORE DETECTION FUNCTIONS
// ============================================================================

// @function Detect pivot high using Pine Script's built-in function
// @param src Source series (typically high)
// @param leftBars Number of bars to the left that must be lower
// @param rightBars Number of bars to the right that must be lower
// @returns Pivot high price (na if no pivot detected)
export detectPivotHigh(series float src, int leftBars = 5, int rightBars = 5) =>
    ta.pivothigh(src, leftBars, rightBars)

// @function Detect pivot low using Pine Script's built-in function
// @param src Source series (typically low)
// @param leftBars Number of bars to the left that must be higher
// @param rightBars Number of bars to the right that must be higher
// @returns Pivot low price (na if no pivot detected)
export detectPivotLow(series float src, int leftBars = 5, int rightBars = 5) =>
    ta.pivotlow(src, leftBars, rightBars)

// @function Detect both pivot high and low in one call
// @param highSrc Source for pivot high detection (typically high)
// @param lowSrc Source for pivot low detection (typically low)
// @param leftBars Number of bars to the left
// @param rightBars Number of bars to the right
// @returns [pivotHigh, pivotLow] Both can be na
export detectPivots(series float highSrc, series float lowSrc, int leftBars = 5, int rightBars = 5) =>
    pivotHigh = ta.pivothigh(highSrc, leftBars, rightBars)
    pivotLow = ta.pivotlow(lowSrc, leftBars, rightBars)
    [pivotHigh, pivotLow]

// ============================================================================
// PIVOT HISTORY MANAGEMENT
// ============================================================================

// @function Create new pivot history storage
// @param maxStored Maximum number of pivots to store (default 10)
// @returns Initialized PivotHistory object
export newPivotHistory(int maxStored = 10) =>
    PivotHistory.new(
         array.new<float>(),
         array.new<int>(),
         array.new<float>(),
         array.new<int>(),
         maxStored
     )

// @function Add pivot high to history
// @param history PivotHistory object
// @param price Pivot high price
// @param barIdx Bar index where pivot occurred
// @returns Updated PivotHistory object
export addPivotHigh(PivotHistory history, float price, int barIdx) =>
    if array.size(history.highs) >= history.maxStored
        array.shift(history.highs)
        array.shift(history.highBars)
    array.push(history.highs, price)
    array.push(history.highBars, barIdx)
    history

// @function Add pivot low to history
// @param history PivotHistory object
// @param price Pivot low price
// @param barIdx Bar index where pivot occurred
// @returns Updated PivotHistory object
export addPivotLow(PivotHistory history, float price, int barIdx) =>
    if array.size(history.lows) >= history.maxStored
        array.shift(history.lows)
        array.shift(history.lowBars)
    array.push(history.lows, price)
    array.push(history.lowBars, barIdx)
    history

// @function Update pivot history with detected pivots
// @param history PivotHistory object
// @param leftBars Left bars for pivot detection
// @param rightBars Right bars for pivot detection
// @returns [history, newPivotHigh, newPivotLow] Updated history and detected pivots
export updatePivotHistory(PivotHistory history, int leftBars = 5, int rightBars = 5) =>
    pivotHigh = ta.pivothigh(high, leftBars, rightBars)
    pivotLow = ta.pivotlow(low, leftBars, rightBars)

    newPivotHigh = false
    newPivotLow = false

    if not na(pivotHigh)
        addPivotHigh(history, pivotHigh, bar_index - rightBars)
        newPivotHigh := true

    if not na(pivotLow)
        addPivotLow(history, pivotLow, bar_index - rightBars)
        newPivotLow := true

    [history, newPivotHigh, newPivotLow]

// ============================================================================
// PIVOT QUERY FUNCTIONS
// ============================================================================

// @function Get the last N pivot highs
// @param history PivotHistory object
// @param count Number of pivots to retrieve (default 1)
// @returns Array of last N pivot high prices (newest first)
export getLastPivotHighs(PivotHistory history, int count = 1) =>
    size = array.size(history.highs)
    result = array.new<float>()

    if size > 0
        startIdx = math.max(0, size - count)
        for i = size - 1 to startIdx by -1
            array.push(result, array.get(history.highs, i))

    result

// @function Get the last N pivot lows
// @param history PivotHistory object
// @param count Number of pivots to retrieve (default 1)
// @returns Array of last N pivot low prices (newest first)
export getLastPivotLows(PivotHistory history, int count = 1) =>
    size = array.size(history.lows)
    result = array.new<float>()

    if size > 0
        startIdx = math.max(0, size - count)
        for i = size - 1 to startIdx by -1
            array.push(result, array.get(history.lows, i))

    result

// @function Get pivot high count in history
// @param history PivotHistory object
// @returns Number of pivot highs stored
export getPivotHighCount(PivotHistory history) =>
    array.size(history.highs)

// @function Get pivot low count in history
// @param history PivotHistory object
// @returns Number of pivot lows stored
export getPivotLowCount(PivotHistory history) =>
    array.size(history.lows)

// @function Get last two pivot highs for divergence/pattern analysis
// @param history PivotHistory object
// @returns [price1, barIndex1, price2, barIndex2] Most recent first
export getLastTwoPivotHighs(PivotHistory history) =>
    size = array.size(history.highs)

    if size >= 2
        price1 = array.get(history.highs, size - 1)
        bar1 = array.get(history.highBars, size - 1)
        price2 = array.get(history.highs, size - 2)
        bar2 = array.get(history.highBars, size - 2)
        [price1, bar1, price2, bar2]
    else
        [na, na, na, na]

// @function Get last two pivot lows for divergence/pattern analysis
// @param history PivotHistory object
// @returns [price1, barIndex1, price2, barIndex2] Most recent first
export getLastTwoPivotLows(PivotHistory history) =>
    size = array.size(history.lows)

    if size >= 2
        price1 = array.get(history.lows, size - 1)
        bar1 = array.get(history.lowBars, size - 1)
        price2 = array.get(history.lows, size - 2)
        bar2 = array.get(history.lowBars, size - 2)
        [price1, bar1, price2, bar2]
    else
        [na, na, na, na]

// ============================================================================
// PIVOT ANALYSIS FUNCTIONS
// ============================================================================

// @function Check if price is making higher highs
// @param history PivotHistory object
// @param count Number of pivots to check (default 2)
// @returns True if making higher highs
export isHigherHighs(PivotHistory history, int count = 2) =>
    size = array.size(history.highs)

    if size < count
        false
    else
        isHH = true
        for i = size - 1 to size - count + 1 by -1
            if array.get(history.highs, i) <= array.get(history.highs, i - 1)
                isHH := false
                break
        isHH

// @function Check if price is making lower lows
// @param history PivotHistory object
// @param count Number of pivots to check (default 2)
// @returns True if making lower lows
export isLowerLows(PivotHistory history, int count = 2) =>
    size = array.size(history.lows)

    if size < count
        false
    else
        isLL = true
        for i = size - 1 to size - count + 1 by -1
            if array.get(history.lows, i) >= array.get(history.lows, i - 1)
                isLL := false
                break
        isLL

// @function Check if price is making higher lows (uptrend)
// @param history PivotHistory object
// @param count Number of pivots to check (default 2)
// @returns True if making higher lows
export isHigherLows(PivotHistory history, int count = 2) =>
    size = array.size(history.lows)

    if size < count
        false
    else
        isHL = true
        for i = size - 1 to size - count + 1 by -1
            if array.get(history.lows, i) <= array.get(history.lows, i - 1)
                isHL := false
                break
        isHL

// @function Check if price is making lower highs (downtrend)
// @param history PivotHistory object
// @param count Number of pivots to check (default 2)
// @returns True if making lower highs
export isLowerHighs(PivotHistory history, int count = 2) =>
    size = array.size(history.highs)

    if size < count
        false
    else
        isLH = true
        for i = size - 1 to size - count + 1 by -1
            if array.get(history.highs, i) >= array.get(history.highs, i - 1)
                isLH := false
                break
        isLH

// @function Identify trend structure using pivot analysis
// @param history PivotHistory object
// @returns "UPTREND", "DOWNTREND", or "RANGING"
export getTrendStructure(PivotHistory history) =>
    hh = isHigherHighs(history, 2)
    hl = isHigherLows(history, 2)
    ll = isLowerLows(history, 2)
    lh = isLowerHighs(history, 2)

    if hh and hl
        "UPTREND"
    else if ll and lh
        "DOWNTREND"
    else
        "RANGING"

// ============================================================================
// PIVOT DISTANCE CALCULATIONS
// ============================================================================

// @function Calculate distance between last two pivot highs
// @param history PivotHistory object
// @returns [priceDistance, barDistance] Both in absolute values
export getPivotHighDistance(PivotHistory history) =>
    [p1, b1, p2, b2] = getLastTwoPivotHighs(history)

    if not na(p1) and not na(p2)
        priceDistance = math.abs(p1 - p2)
        barDistance = math.abs(b1 - b2)
        [priceDistance, barDistance]
    else
        [na, na]

// @function Calculate distance between last two pivot lows
// @param history PivotHistory object
// @returns [priceDistance, barDistance] Both in absolute values
export getPivotLowDistance(PivotHistory history) =>
    [p1, b1, p2, b2] = getLastTwoPivotLows(history)

    if not na(p1) and not na(p2)
        priceDistance = math.abs(p1 - p2)
        barDistance = math.abs(b1 - b2)
        [priceDistance, barDistance]
    else
        [na, na]

// @function Get highest pivot high in history
// @param history PivotHistory object
// @returns Highest pivot high price
export getHighestPivotHigh(PivotHistory history) =>
    array.size(history.highs) > 0 ? array.max(history.highs) : na

// @function Get lowest pivot low in history
// @param history PivotHistory object
// @returns Lowest pivot low price
export getLowestPivotLow(PivotHistory history) =>
    array.size(history.lows) > 0 ? array.min(history.lows) : na


// ============================================================================
// MODULE: ZIGZAG_DETECTION
// ============================================================================

// ============================================================================
// RTA-ADVANCED: ZIGZAG DETECTION - Non-Repainting ZigZag Algorithm
// ============================================================================
// @description: Production-ready non-repainting ZigZag detection with multiple modes
//
// Purpose:
//   - Detect trend legs and reversals using ZigZag algorithm
//   - Non-repainting: confirmed pivots never change
//   - Multiple threshold modes: ATR, Percentage, Standard Deviation
//   - Customizable minimum bars per leg for noise filtering
//
// ZigZag Characteristics:
//   - Uptrend Leg: Series of higher highs
//   - Downtrend Leg: Series of lower lows
//   - Reversal Detection: Price moves against trend by threshold amount
//   - Minimum Bars: Ensures legs have sufficient bars before reversal
//
// Threshold Modes:
//   - ATR: Reversal = ATR * Multiplier (adaptive to volatility)
//   - PCT: Reversal = Price * Percentage (fixed percentage moves)
//   - DEV: Reversal = StdDev * Multiplier (statistical threshold)
//
// Use Cases:
//   - Wave counting and Elliott Wave analysis
//   - Trend structure identification
//   - Support/resistance levels from pivots
//   - Pattern recognition (corridors, channels)
//   - Divergence detection on swing points
//
// Integration:
//   import "zigzag_detection" as zz
//   state = zz.newZigZagState()
//   zz.updateZigZag(state, config)
//
// Extracted from: wave-corridors/wave_corridors.pine
// ============================================================================

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

// @type ZigZag configuration settings
// @field mode Threshold mode: "ATR", "PCT", or "DEV"
// @field atrLength ATR period for ATR mode
// @field atrMultiplier ATR multiplier for reversal threshold
// @field pctThreshold Percentage threshold for PCT mode (e.g., 2.0 = 2%)
// @field devLength Standard deviation period for DEV mode
// @field devMultiplier StdDev multiplier for DEV mode
// @field minBarsPerLeg Minimum bars required before reversal can occur
// @field mergeTolerance Tolerance in ticks for merging near-identical pivots
export type ZigZagConfig
    string mode
    int atrLength
    float atrMultiplier
    float pctThreshold
    int devLength
    float devMultiplier
    int minBarsPerLeg
    int mergeTolerance

// @type ZigZag state (persistent variables for non-repainting behavior)
// @field extremumPrice Current extremum price (highest high or lowest low)
// @field extremumIndex Bar index where extremum occurred
// @field legDirection Current leg direction (1 = up, -1 = down)
// @field barsInLeg Number of bars in current active leg
// @field lastPivotIndex Bar index of last confirmed pivot
// @field lastPivotPrice Price of last confirmed pivot
// @field reversalDetected True if reversal detected on current bar
// @field newPivotPrice Price of new pivot (if reversal detected)
// @field newPivotIndex Bar index of new pivot (if reversal detected)
export type ZigZagState
    float extremumPrice
    int extremumIndex
    int legDirection
    int barsInLeg
    int lastPivotIndex
    float lastPivotPrice
    bool reversalDetected
    float newPivotPrice
    int newPivotIndex

// @type ZigZag leg information
// @field startPrice Starting price of leg
// @field startIndex Starting bar index
// @field endPrice Ending price of leg (current extremum)
// @field endIndex Ending bar index
// @field direction Leg direction (1 = up, -1 = down)
// @field barsCount Number of bars in leg
// @field priceChange Absolute price change
// @field percentChange Percentage change
export type ZigZagLeg
    float startPrice
    int startIndex
    float endPrice
    int endIndex
    int direction
    int barsCount
    float priceChange
    float percentChange

// ============================================================================
// CONFIGURATION CONSTRUCTORS
// ============================================================================

// @function Create default ZigZag configuration
// @returns ZigZagConfig with ATR mode defaults
export newZigZagConfig() =>
    ZigZagConfig.new(
         "ATR",      // mode
         14,         // atrLength
         2.0,        // atrMultiplier
         2.0,        // pctThreshold
         20,         // devLength
         1.5,        // devMultiplier
         3,          // minBarsPerLeg
         0           // mergeTolerance
     )

// @function Create ZigZag configuration with ATR mode
// @param atrLength ATR period
// @param atrMultiplier ATR multiplier
// @param minBars Minimum bars per leg
// @returns ZigZagConfig configured for ATR mode
export newATRConfig(int atrLength = 14, float atrMultiplier = 2.0, int minBars = 3) =>
    ZigZagConfig.new("ATR", atrLength, atrMultiplier, 2.0, 20, 1.5, minBars, 0)

// @function Create ZigZag configuration with Percentage mode
// @param pctThreshold Percentage threshold (e.g., 2.0 for 2%)
// @param minBars Minimum bars per leg
// @returns ZigZagConfig configured for PCT mode
export newPercentConfig(float pctThreshold = 2.0, int minBars = 3) =>
    ZigZagConfig.new("PCT", 14, 2.0, pctThreshold, 20, 1.5, minBars, 0)

// @function Create ZigZag configuration with Standard Deviation mode
// @param devLength StdDev period
// @param devMultiplier StdDev multiplier
// @param minBars Minimum bars per leg
// @returns ZigZagConfig configured for DEV mode
export newStdDevConfig(int devLength = 20, float devMultiplier = 1.5, int minBars = 3) =>
    ZigZagConfig.new("DEV", 14, 2.0, 2.0, devLength, devMultiplier, minBars, 0)

// ============================================================================
// STATE MANAGEMENT
// ============================================================================

// @function Initialize new ZigZag state
// @param initialPrice Starting price (default: close)
// @param initialIndex Starting bar index (default: bar_index)
// @param initialDirection Starting direction (default: 1 = up)
// @returns Initialized ZigZagState
export newZigZagState(float initialPrice = close, int initialIndex = bar_index, int initialDirection = 1) =>
    ZigZagState.new(
         initialPrice,      // extremumPrice
         initialIndex,      // extremumIndex
         initialDirection,  // legDirection
         1,                 // barsInLeg
         initialIndex,      // lastPivotIndex
         initialPrice,      // lastPivotPrice
         false,             // reversalDetected
         na,                // newPivotPrice
         na                 // newPivotIndex
     )

// ============================================================================
// THRESHOLD CALCULATION
// ============================================================================

// @function Calculate reversal threshold based on configuration mode
// @param config ZigZagConfig
// @param currentExtremum Current extremum price (for PCT mode)
// @returns Threshold value for reversal detection
export calculateThreshold(ZigZagConfig config, float currentExtremum) =>
    switch config.mode
        "ATR" => config.atrMultiplier * ta.atr(config.atrLength)
        "PCT" => currentExtremum * (config.pctThreshold / 100.0)
        "DEV" => config.devMultiplier * ta.stdev(close, config.devLength)
        => config.atrMultiplier * ta.atr(14)  // Default to ATR

// ============================================================================
// CORE ZIGZAG UPDATE LOGIC
// ============================================================================

// @function Update ZigZag state for current bar (non-repainting)
// @param state ZigZagState to update
// @param config ZigZagConfig settings
// @returns Updated ZigZagState
export updateZigZag(ZigZagState state, ZigZagConfig config) =>
    // Reset reversal flag
    state.reversalDetected := false
    state.newPivotPrice := na
    state.newPivotIndex := na

    // Update extremum based on current direction
    if state.legDirection == 1  // Uptrend leg
        if high > state.extremumPrice
            state.extremumPrice := high
            state.extremumIndex := bar_index
    else  // Downtrend leg
        if low < state.extremumPrice
            state.extremumPrice := low
            state.extremumIndex := bar_index

    // Increment bars in leg
    state.barsInLeg += 1

    // Calculate reversal threshold
    threshold = calculateThreshold(config, state.extremumPrice)

    // Check for reversal
    bool reversed = false
    if state.legDirection == 1  // In uptrend, check for downside reversal
        if (state.extremumPrice - low >= threshold) and (state.barsInLeg >= config.minBarsPerLeg)
            reversed := true
    else  // In downtrend, check for upside reversal
        if (high - state.extremumPrice >= threshold) and (state.barsInLeg >= config.minBarsPerLeg)
            reversed := true

    // Process reversal
    if reversed
        // Mark reversal detected
        state.reversalDetected := true
        state.newPivotPrice := state.extremumPrice
        state.newPivotIndex := state.extremumIndex

        // Update last pivot to confirmed extremum
        state.lastPivotIndex := state.extremumIndex
        state.lastPivotPrice := state.extremumPrice

        // Flip direction
        state.legDirection := state.legDirection == 1 ? -1 : 1

        // Reset leg tracking
        state.barsInLeg := 1
        state.extremumPrice := close
        state.extremumIndex := bar_index

    state

// ============================================================================
// LEG INFORMATION EXTRACTION
// ============================================================================

// @function Get current active leg information
// @param state ZigZagState
// @returns ZigZagLeg with current leg data
export getCurrentLeg(ZigZagState state) =>
    priceChange = math.abs(state.extremumPrice - state.lastPivotPrice)
    percentChange = state.lastPivotPrice != 0 ?
         (priceChange / state.lastPivotPrice) * 100.0 : 0.0

    ZigZagLeg.new(
         state.lastPivotPrice,  // startPrice
         state.lastPivotIndex,  // startIndex
         state.extremumPrice,   // endPrice
         state.extremumIndex,   // endIndex
         state.legDirection,    // direction
         state.barsInLeg,       // barsCount
         priceChange,           // priceChange
         percentChange          // percentChange
     )

// @function Get last confirmed leg information (if reversal just occurred)
// @param state ZigZagState
// @returns ZigZagLeg of last confirmed leg (or na values if no reversal)
export getLastConfirmedLeg(ZigZagState state) =>
    if state.reversalDetected
        // Last leg ended at the new pivot
        direction = state.legDirection == 1 ? -1 : 1  // Opposite of current
        priceChange = math.abs(state.newPivotPrice - state.lastPivotPrice)
        percentChange = state.lastPivotPrice != 0 ?
             (priceChange / state.lastPivotPrice) * 100.0 : 0.0

        ZigZagLeg.new(
             state.lastPivotPrice,  // startPrice (previous pivot)
             state.lastPivotIndex,  // startIndex
             state.newPivotPrice,   // endPrice (new pivot)
             state.newPivotIndex,   // endIndex
             direction,             // direction
             state.barsInLeg,       // barsCount
             priceChange,           // priceChange
             percentChange          // percentChange
         )
    else
        ZigZagLeg.new(na, na, na, na, 0, 0, na, na)

// ============================================================================
// QUERY FUNCTIONS
// ============================================================================

// @function Check if current leg is up
// @param state ZigZagState
// @returns True if uptrend leg
export isUpLeg(ZigZagState state) =>
    state.legDirection == 1

// @function Check if current leg is down
// @param state ZigZagState
// @returns True if downtrend leg
export isDownLeg(ZigZagState state) =>
    state.legDirection == -1

// @function Get leg direction as string
// @param state ZigZagState
// @returns "UP" or "DOWN"
export getLegDirectionText(ZigZagState state) =>
    state.legDirection == 1 ? "UP" : "DOWN"

// @function Get distance from last pivot
// @param state ZigZagState
// @returns [priceDistance, barsDistance]
export getDistanceFromPivot(ZigZagState state) =>
    priceDistance = math.abs(close - state.lastPivotPrice)
    barsDistance = bar_index - state.lastPivotIndex
    [priceDistance, barsDistance]

// @function Get distance to current extremum
// @param state ZigZagState
// @returns [priceDistance, barsDistance]
export getDistanceToExtremum(ZigZagState state) =>
    priceDistance = math.abs(close - state.extremumPrice)
    barsDistance = bar_index - state.extremumIndex
    [priceDistance, barsDistance]

// @function Calculate leg strength (0-100)
// @param leg ZigZagLeg
// @param atrValue Current ATR for normalization
// @returns Strength score (0-100)
export getLegStrength(ZigZagLeg leg, float atrValue) =>
    if atrValue > 0 and not na(leg.priceChange)
        // Strength based on price move relative to ATR and time
        priceScore = math.min((leg.priceChange / atrValue) * 10.0, 50.0)
        timeScore = math.min(leg.barsCount * 2.0, 50.0)
        math.min(priceScore + timeScore, 100.0)
    else
        0.0

// ============================================================================
// VISUALIZATION HELPERS
// ============================================================================

// @function Get color for leg direction
// @param state ZigZagState
// @param bullColor Color for up legs (default: green)
// @param bearColor Color for down legs (default: red)
// @returns Appropriate color for current leg
export getLegColor(ZigZagState state, color bullColor = color.green, color bearColor = color.red) =>
    state.legDirection == 1 ? bullColor : bearColor

// @function Draw ZigZag line for confirmed pivot
// @param state ZigZagState
// @param lineColor Color for line
// @param lineWidth Width of line (default: 2)
// @returns Line object (or na if no reversal)
export drawConfirmedLine(ZigZagState state, color lineColor, int lineWidth = 2) =>
    if state.reversalDetected
        line.new(
             state.lastPivotIndex,
             state.lastPivotPrice,
             state.newPivotIndex,
             state.newPivotPrice,
             color = lineColor,
             width = lineWidth
         )
    else
        line(na)

// @function Draw ZigZag preview line (current unconfirmed leg)
// @param state ZigZagState
// @param lineColor Color for preview line
// @param transparency Transparency level (default: 60)
// @returns Line object
export drawPreviewLine(ZigZagState state, color lineColor, int transparency = 60) =>
    line.new(
         state.lastPivotIndex,
         state.lastPivotPrice,
         bar_index,
         close,
         color = color.new(lineColor, transparency),
         width = 2,
         style = line.style_dotted
     )

// ============================================================================
// ADVANCED ANALYSIS
// ============================================================================

// @function Check if leg is accelerating (comparing recent vs. earlier progress)
// @param state ZigZagState
// @param checkBars Number of recent bars to analyze (default: 5)
// @returns True if recent progress is faster than average
export isLegAccelerating(ZigZagState state, int checkBars = 5) =>
    if state.barsInLeg < checkBars * 2
        false
    else
        // Compare recent rate of change to overall rate
        totalMove = math.abs(state.extremumPrice - state.lastPivotPrice)
        recentMove = state.legDirection == 1 ?
             high - ta.highest(high, checkBars)[checkBars] :
             ta.lowest(low, checkBars)[checkBars] - low

        avgRateOverall = totalMove / state.barsInLeg
        avgRateRecent = math.abs(recentMove) / checkBars

        avgRateRecent > avgRateOverall * 1.2  // 20% faster = acceleration

// @function Check if leg is showing weakness (price not making progress)
// @param state ZigZagState
// @param checkBars Number of recent bars to analyze (default: 5)
// @returns True if recent progress is minimal
export isLegWeakening(ZigZagState state, int checkBars = 5) =>
    if state.barsInLeg < checkBars
        false
    else
        // Check if extremum hasn't moved recently
        barsFromExtremum = bar_index - state.extremumIndex
        barsFromExtremum >= checkBars

// @function Get ZigZag state summary as text
// @param state ZigZagState
// @returns Multi-line summary string
export getStateSummary(ZigZagState state) =>
    leg = getCurrentLeg(state)
    str.format(
         "Direction: {0}\\nBars in Leg: {1}\\nPrice Move: {2}%\\nExtremum: {3}",
         getLegDirectionText(state),
         str.tostring(state.barsInLeg),
         str.tostring(leg.percentChange, "#.##"),
         str.tostring(state.extremumPrice, "#.####")
     )


// ============================================================================
// MODULE: SMC_PATTERNS
// ============================================================================

// ============================================================================
// RTA-ADVANCED: SMC PATTERNS - Smart Money Concepts
// ============================================================================
// @description: Advanced Smart Money Concepts patterns (ICT methodology)
//
// Purpose:
//   - Order Blocks (OB): Last opposing candle before impulse move
//   - Fair Value Gaps (FVG): Inefficient price areas to be filled
//   - Breaker Blocks: Failed support becomes resistance (or vice versa)
//   - Mitigation Blocks: Zones where price returns to fill imbalance
//
// Concepts:
//   - Order Block = Where institutions placed orders (last stop hunt)
//   - FVG/Imbalance = Gap in price that acts as magnet
//   - Breaker = Structure break, old support now resistance
//   - Mitigation = When price returns to "fill" the imbalance
//
// Usage:
//   import "RTAAdvanced" as ADV
//   var smcState = ADV.newSMCState()
//   ADV.updateSMCPatterns(smcState)
//   orderBlocks = ADV.getActiveOrderBlocks(smcState)
// ============================================================================

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

// @type Represents an Order Block
// @field obType "BULLISH" or "BEARISH"
// @field obHigh Upper boundary of OB
// @field obLow Lower boundary of OB
// @field obBar Bar index where OB formed
// @field strength OB strength based on impulse move (0-100)
// @field mitigated True if price has returned to OB
// @field mitigationBar Bar where mitigation occurred
// @field touches Number of times price touched OB
export type OrderBlock
    string obType
    float obHigh
    float obLow
    int obBar
    float strength
    bool mitigated
    int mitigationBar
    int touches

// @type Represents a Fair Value Gap (Imbalance)
// @field fvgType "BULLISH" or "BEARISH"
// @field fvgHigh Upper boundary of FVG
// @field fvgLow Lower boundary of FVG
// @field fvgBar Bar where FVG formed
// @field gapSize Size of gap in points
// @field filled True if gap has been filled
// @field fillBar Bar where gap was filled
// @field fillPercentage How much of gap filled (0-100)
export type FairValueGap
    string fvgType
    float fvgHigh
    float fvgLow
    int fvgBar
    float gapSize
    bool filled
    int fillBar
    float fillPercentage

// @type Represents a Breaker Block
// @field breakerType "BULLISH" or "BEARISH"
// @field originalType Original structure type before break
// @field breakerHigh Upper boundary
// @field breakerLow Lower boundary
// @field breakBar Bar where structure broke
// @field retestBar Bar where retest occurred (if any)
// @field retested True if breakout was retested
// @field holdingZone True if zone is holding as new SR
export type BreakerBlock
    string breakerType
    string originalType
    float breakerHigh
    float breakerLow
    int breakBar
    int retestBar
    bool retested
    bool holdingZone

// @type Main SMC state
// @field orderBlocks Array of detected order blocks
// @field fairValueGaps Array of detected FVGs
// @field breakerBlocks Array of detected breakers
// @field lastBullishOB Most recent bullish OB
// @field lastBearishOB Most recent bearish OB
export type SMCState
    array<OrderBlock> orderBlocks
    array<FairValueGap> fairValueGaps
    array<BreakerBlock> breakerBlocks
    OrderBlock lastBullishOB
    OrderBlock lastBearishOB

// @type Configuration for SMC detection
// @field minImpulseSize Minimum impulse candle size in ATR
// @field fvgMinSize Minimum FVG size in ATR
// @field maxOBs Maximum order blocks to track
// @field maxFVGs Maximum FVGs to track
// @field maxBreakers Maximum breakers to track
export type SMCConfig
    float minImpulseSize
    float fvgMinSize
    int maxOBs
    int maxFVGs
    int maxBreakers

// ============================================================================
// INITIALIZATION FUNCTIONS
// ============================================================================

// @function Create default SMC configuration
// @returns New SMCConfig with standard settings
export newSMCConfig() =>
    SMCConfig.new(
        1.5,    // minImpulseSize (1.5x ATR)
        0.3,    // fvgMinSize (0.3x ATR)
        10,     // maxOBs
        15,     // maxFVGs
        10      // maxBreakers
    )

// @function Initialize empty order block
// @param obType "BULLISH" or "BEARISH"
// @returns New OrderBlock
export newOrderBlock(string obType) =>
    OrderBlock.new(
        obType,
        na,     // obHigh
        na,     // obLow
        0,      // obBar
        0.0,    // strength
        false,  // mitigated
        na,     // mitigationBar
        0       // touches
    )

// @function Initialize empty FVG
// @param fvgType "BULLISH" or "BEARISH"
// @returns New FairValueGap
export newFairValueGap(string fvgType) =>
    FairValueGap.new(
        fvgType,
        na,     // fvgHigh
        na,     // fvgLow
        0,      // fvgBar
        0.0,    // gapSize
        false,  // filled
        na,     // fillBar
        0.0     // fillPercentage
    )

// @function Initialize empty breaker block
// @param breakerType "BULLISH" or "BEARISH"
// @returns New BreakerBlock
export newBreakerBlock(string breakerType) =>
    BreakerBlock.new(
        breakerType,
        "NONE",     // originalType
        na,         // breakerHigh
        na,         // breakerLow
        0,          // breakBar
        na,         // retestBar
        false,      // retested
        false       // holdingZone
    )

// @function Initialize SMC state
// @returns New SMCState with empty arrays
export newSMCState() =>
    SMCState.new(
        array.new<OrderBlock>(),
        array.new<FairValueGap>(),
        array.new<BreakerBlock>(),
        newOrderBlock("BULLISH"),
        newOrderBlock("BEARISH")
    )

// ============================================================================
// ORDER BLOCK DETECTION
// ============================================================================

// @function Detect if current setup has order block
// @param config SMCConfig
// @returns [hasOB, obType, obHigh, obLow, strength]
export detectOrderBlock(SMCConfig config) =>
    hasOB = false
    obType = "NONE"
    obHigh = na
    obLow = na
    strength = 0.0

    if bar_index < 3
        [hasOB, obType, obHigh, obLow, strength]
    else
        atr = ta.atr(14)
        minSize = atr * config.minImpulseSize

        // Bullish Order Block:
        // 1. Down candle (potential last bearish before reversal)
        // 2. Followed by strong bullish impulse
        wasBearish = close[2] < open[2]
        impulseSize = math.abs(close - open)
        isBullishImpulse = close > open and impulseSize >= minSize

        if wasBearish and isBullishImpulse and low > low[2]
            hasOB := true
            obType := "BULLISH"
            obHigh := high[2]
            obLow := low[2]
            // Strength based on impulse size
            strength := math.min(100, (impulseSize / atr) * 30)

        // Bearish Order Block:
        // 1. Up candle (potential last bullish before reversal)
        // 2. Followed by strong bearish impulse
        else
            wasBullish = close[2] > open[2]
            isBearishImpulse = close < open and impulseSize >= minSize

            if wasBullish and isBearishImpulse and high < high[2]
                hasOB := true
                obType := "BEARISH"
                obHigh := high[2]
                obLow := low[2]
                strength := math.min(100, (impulseSize / atr) * 30)

        [hasOB, obType, obHigh, obLow, strength]

// @function Update order blocks in state
// @param state SMCState
// @param config SMCConfig
export updateOrderBlocks(SMCState state, SMCConfig config) =>
    [hasOB, obType, obHigh, obLow, strength] = detectOrderBlock(config)

    if hasOB and not na(obHigh) and not na(obLow)
        ob = OrderBlock.new(
            obType,
            obHigh,
            obLow,
            bar_index - 2,  // OB is 2 bars back
            strength,
            false,
            na,
            0
        )

        // Add to array
        array.push(state.orderBlocks, ob)

        // Keep only max OBs
        if array.size(state.orderBlocks) > config.maxOBs
            array.shift(state.orderBlocks)

        // Update last OB references
        if obType == "BULLISH"
            state.lastBullishOB := ob
        else
            state.lastBearishOB := ob

    // Check mitigation of existing OBs
    if array.size(state.orderBlocks) > 0
        for i = array.size(state.orderBlocks) - 1 to 0
            ob = array.get(state.orderBlocks, i)
            if not ob.mitigated
                // Check if price returned to OB
                if low <= ob.obHigh and high >= ob.obLow
                    ob.mitigated := true
                    ob.mitigationBar := bar_index
                    ob.touches += 1
                    array.set(state.orderBlocks, i, ob)

// ============================================================================
// FAIR VALUE GAP DETECTION
// ============================================================================

// @function Detect Fair Value Gap (3-candle pattern)
// @param config SMCConfig
// @returns [hasFVG, fvgType, fvgHigh, fvgLow, gapSize]
export detectFairValueGap(SMCConfig config) =>
    hasFVG = false
    fvgType = "NONE"
    fvgHigh = na
    fvgLow = na
    gapSize = 0.0

    if bar_index < 2
        [hasFVG, fvgType, fvgHigh, fvgLow, gapSize]
    else
        atr = ta.atr(14)
        minGap = atr * config.fvgMinSize

        // Bullish FVG: Gap between candle[2] high and current low
        // (middle candle didn't fill the space)
        bullishGap = low - high[2]
        if bullishGap > minGap
            hasFVG := true
            fvgType := "BULLISH"
            fvgHigh := low
            fvgLow := high[2]
            gapSize := bullishGap

        // Bearish FVG: Gap between candle[2] low and current high
        else
            bearishGap = low[2] - high
            if bearishGap > minGap
                hasFVG := true
                fvgType := "BEARISH"
                fvgHigh := low[2]
                fvgLow := high
                gapSize := bearishGap

        [hasFVG, fvgType, fvgHigh, fvgLow, gapSize]

// @function Update FVGs in state
// @param state SMCState
// @param config SMCConfig
export updateFairValueGaps(SMCState state, SMCConfig config) =>
    [hasFVG, fvgType, fvgHigh, fvgLow, gapSize] = detectFairValueGap(config)

    if hasFVG and not na(fvgHigh) and not na(fvgLow)
        fvg = FairValueGap.new(
            fvgType,
            fvgHigh,
            fvgLow,
            bar_index,
            gapSize,
            false,
            na,
            0.0
        )

        array.push(state.fairValueGaps, fvg)

        if array.size(state.fairValueGaps) > config.maxFVGs
            array.shift(state.fairValueGaps)

    // Check if existing FVGs are being filled
    if array.size(state.fairValueGaps) > 0
        for i = array.size(state.fairValueGaps) - 1 to 0
            fvg = array.get(state.fairValueGaps, i)
            if not fvg.filled
                // Calculate fill percentage
                if low <= fvg.fvgHigh and high >= fvg.fvgLow
                    // Price entered the gap
                    if fvg.fvgType == "BULLISH"
                        // How far down into gap did price go?
                        fillDepth = fvg.fvgHigh - low
                        fillPct = (fillDepth / fvg.gapSize) * 100
                    else
                        // How far up into gap did price go?
                        fillDepth = high - fvg.fvgLow
                        fillPct = (fillDepth / fvg.gapSize) * 100

                    fvg.fillPercentage := math.min(100, fillPct)

                    // Mark as filled if > 50%
                    if fvg.fillPercentage >= 50
                        fvg.filled := true
                        fvg.fillBar := bar_index

                    array.set(state.fairValueGaps, i, fvg)

// ============================================================================
// BREAKER BLOCK DETECTION
// ============================================================================

// @function Detect breaker block (structure break)
// @param lookback Bars to look back for structure
// @returns [hasBreaker, breakerType, breakerHigh, breakerLow]
export detectBreakerBlock(int lookback = 10) =>
    hasBreaker = false
    breakerType = "NONE"
    breakerHigh = na
    breakerLow = na

    if bar_index < lookback + 2
        [hasBreaker, breakerType, breakerHigh, breakerLow]
    else
        // Find recent swing high/low
        swingHigh = ta.highest(high, lookback)[1]
        swingLow = ta.lowest(low, lookback)[1]

        // Bullish breaker: Price broke above resistance, now support
        if close > swingHigh and close[1] <= swingHigh
            hasBreaker := true
            breakerType := "BULLISH"
            // Old resistance zone
            breakerHigh := swingHigh
            breakerLow := swingHigh * 0.998  // Small zone around level

        // Bearish breaker: Price broke below support, now resistance
        else if close < swingLow and close[1] >= swingLow
            hasBreaker := true
            breakerType := "BEARISH"
            // Old support zone
            breakerHigh := swingLow * 1.002
            breakerLow := swingLow

        [hasBreaker, breakerType, breakerHigh, breakerLow]

// @function Update breaker blocks in state
// @param state SMCState
// @param config SMCConfig
export updateBreakerBlocks(SMCState state, SMCConfig config) =>
    [hasBreaker, breakerType, breakerHigh, breakerLow] = detectBreakerBlock(10)

    if hasBreaker and not na(breakerHigh) and not na(breakerLow)
        breaker = BreakerBlock.new(
            breakerType,
            breakerType == "BULLISH" ? "RESISTANCE" : "SUPPORT",
            breakerHigh,
            breakerLow,
            bar_index,
            na,
            false,
            true
        )

        array.push(state.breakerBlocks, breaker)

        if array.size(state.breakerBlocks) > config.maxBreakers
            array.shift(state.breakerBlocks)

    // Check for retests
    if array.size(state.breakerBlocks) > 0
        for i = array.size(state.breakerBlocks) - 1 to 0
            breaker = array.get(state.breakerBlocks, i)
            if not breaker.retested
                // Check if price returned to test the breaker
                if low <= breaker.breakerHigh and high >= breaker.breakerLow
                    breaker.retested := true
                    breaker.retestBar := bar_index

                    // Check if zone is holding
                    if breaker.breakerType == "BULLISH"
                        // Should bounce up from old resistance (now support)
                        breaker.holdingZone := close > open
                    else
                        // Should reject down from old support (now resistance)
                        breaker.holdingZone := close < open

                    array.set(state.breakerBlocks, i, breaker)

// ============================================================================
// MAIN UPDATE FUNCTION
// ============================================================================

// @function Update all SMC patterns
// @param state SMCState to update
// @param config SMCConfig (optional)
export updateSMCPatterns(SMCState state, SMCConfig config = na) =>
    useConfig = na(config) ? newSMCConfig() : config

    updateOrderBlocks(state, useConfig)
    updateFairValueGaps(state, useConfig)
    updateBreakerBlocks(state, useConfig)

// ============================================================================
// QUERY FUNCTIONS
// ============================================================================

// @function Get active (unmitigated) order blocks
// @param state SMCState
// @returns Array of active OBs
export getActiveOrderBlocks(SMCState state) =>
    active = array.new<OrderBlock>()
    if array.size(state.orderBlocks) > 0
        for i = 0 to array.size(state.orderBlocks) - 1
            ob = array.get(state.orderBlocks, i)
            if not ob.mitigated
                array.push(active, ob)
    active

// @function Get unfilled FVGs
// @param state SMCState
// @returns Array of unfilled FVGs
export getUnfilledFVGs(SMCState state) =>
    unfilled = array.new<FairValueGap>()
    if array.size(state.fairValueGaps) > 0
        for i = 0 to array.size(state.fairValueGaps) - 1
            fvg = array.get(state.fairValueGaps, i)
            if not fvg.filled
                array.push(unfilled, fvg)
    unfilled

// @function Get active breaker blocks (retested and holding)
// @param state SMCState
// @returns Array of active breakers
export getActiveBreakerBlocks(SMCState state) =>
    active = array.new<BreakerBlock>()
    if array.size(state.breakerBlocks) > 0
        for i = 0 to array.size(state.breakerBlocks) - 1
            breaker = array.get(state.breakerBlocks, i)
            if breaker.holdingZone
                array.push(active, breaker)
    active

// @function Check if price is near an order block
// @param state SMCState
// @param atr Current ATR
// @param threshold Distance threshold in ATR
// @returns [nearBullish, nearBearish]
export isNearOrderBlock(SMCState state, float atr, float threshold = 1.0) =>
    nearBullish = false
    nearBearish = false
    dist = atr * threshold

    if array.size(state.orderBlocks) > 0
        for i = 0 to array.size(state.orderBlocks) - 1
            ob = array.get(state.orderBlocks, i)
            if not ob.mitigated
                if ob.obType == "BULLISH" and low - ob.obHigh <= dist and low > ob.obHigh
                    nearBullish := true
                else if ob.obType == "BEARISH" and ob.obLow - high <= dist and high < ob.obLow
                    nearBearish := true

    [nearBullish, nearBearish]

// @function Get SMC summary string
// @param state SMCState
// @returns Formatted summary
export getSMCSummary(SMCState state) =>
    activeOBs = array.size(getActiveOrderBlocks(state))
    unfilledFVGs = array.size(getUnfilledFVGs(state))
    activeBreakers = array.size(getActiveBreakerBlocks(state))

    str.format(
        "SMC Patterns\nOrder Blocks: {0}\nFVGs: {1}\nBreakers: {2}",
        activeOBs, unfilledFVGs, activeBreakers
    )


// ============================================================================
// MODULE: ELLIOTT_WAVE_DETECTION
// ============================================================================

// ============================================================================
// RTA ADVANCED - Elliott Wave Detection
// ============================================================================
// @description: Elliott Wave Theory - Wave counting and structure identification
//
// Purpose:
//   - Identify 5-wave impulse patterns (1-2-3-4-5)
//   - Identify 3-wave corrective patterns (A-B-C)
//   - Classify wave degrees (Grand Supercycle to Subminuette)
//   - Validate wave relationships using Elliott rules
//   - Calculate Fibonacci relationships between waves
//
// Elliott Wave Rules:
//   IMPULSE WAVES (5-wave):
//   - Wave 2 never retraces more than 100% of wave 1
//   - Wave 3 is never the shortest (usually longest)
//   - Wave 4 never overlaps wave 1 price territory
//   - Wave 3 often extends (161.8% of wave 1)
//   - Wave 5 often equals wave 1 or 61.8% of wave 1-3
//
//   CORRECTIVE WAVES (3-wave):
//   - Wave A: Initial correction
//   - Wave B: Counter-trend bounce (often 50-61.8% of A)
//   - Wave C: Final move (often 100-161.8% of A)
//
// Wave Degrees (largest to smallest):
//   - Grand Supercycle (multi-decade)
//   - Supercycle (multi-year)
//   - Cycle (1-2 years)
//   - Primary (months to year)
//   - Intermediate (weeks to months)
//   - Minor (weeks)
//   - Minute (days)
//   - Minuette (hours)
//   - Subminuette (minutes)
//
// Usage:
//   import "RTAAdvanced" as ADV
//   var ewState = ADV.newElliottWaveState()
//   ADV.updateElliottWaves(ewState, zigzagPivots)
// ============================================================================

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

// @type Wave degree classification
// @field name Degree name (e.g., "PRIMARY", "INTERMEDIATE")
// @field symbol Symbol for labeling (e.g., "I", "1", "(1)")
// @field minBars Minimum bars for this degree
// @field maxBars Maximum bars for this degree
export type WaveDegree
    string name
    string symbol
    int minBars
    int maxBars

// @type Individual wave
// @field waveNumber Wave number (1-5 for impulse, A-B-C for corrective)
// @field waveType Type: "IMPULSE" or "CORRECTIVE"
// @field direction Direction: 1 (up) or -1 (down)
// @field startBar Bar index where wave starts
// @field endBar Bar index where wave ends
// @field startPrice Price at wave start
// @field endPrice Price at wave end
// @field length Wave length in price
// @field bars Number of bars in wave
// @field degree Wave degree
// @field fibRatio Fibonacci ratio to previous wave (if applicable)
// @field isExtension True if this is an extension wave
// @field confidence Confidence score (0-100)
export type Wave
    string waveNumber
    string waveType
    int direction
    int startBar
    int endBar
    float startPrice
    float endPrice
    float length
    int bars
    WaveDegree degree
    float fibRatio
    bool isExtension
    float confidence

// @type Wave pattern (5-wave or 3-wave sequence)
// @field patternType "IMPULSE" (1-2-3-4-5) or "CORRECTIVE" (A-B-C)
// @field waves Array of waves in pattern
// @field startBar Pattern start bar
// @field endBar Pattern end bar
// @field startPrice Pattern start price
// @field endPrice Pattern end price
// @field totalBars Total bars in pattern
// @field degree Pattern degree
// @field isComplete True if pattern is complete
// @field isValid True if pattern follows Elliott rules
// @field confidence Overall confidence (0-100)
export type WavePattern
    string patternType
    array<Wave> waves
    int startBar
    int endBar
    float startPrice
    float endPrice
    int totalBars
    WaveDegree degree
    bool isComplete
    bool isValid
    float confidence

// @type Elliott Wave state
// @field currentPattern Current wave pattern being tracked
// @field completedPatterns Array of completed patterns
// @field pivots Array of pivot points for wave counting
// @field lastUpdateBar Last bar when updated
// @field activeWaveCount Current wave count (1-5 or A-C)
// @field trendDirection Overall trend direction (1 up, -1 down)
export type ElliottWaveState
    WavePattern currentPattern
    array<WavePattern> completedPatterns
    array<Wave> pivots
    int lastUpdateBar
    int activeWaveCount
    int trendDirection

// @type Elliott Wave configuration
// @field minWaveSize Minimum wave size (% of price)
// @field maxWaveOverlap Maximum allowed overlap for wave 4 (%)
// @field fibTolerance Fibonacci ratio tolerance (%)
// @field minConfidence Minimum confidence to accept pattern
// @field useStrictRules Use strict Elliott rules
export type ElliottWaveConfig
    float minWaveSize
    float maxWaveOverlap
    float fibTolerance
    float minConfidence
    bool useStrictRules

// ============================================================================
// WAVE DEGREE DEFINITIONS
// ============================================================================

// @function Get wave degree by bar count
// @param bars Number of bars in wave
// @returns WaveDegree
export getWaveDegree(int bars) =>
    if bars >= 5000
        WaveDegree.new("GRAND_SUPERCYCLE", "⟨I⟩", 5000, 999999)
    else if bars >= 2000
        WaveDegree.new("SUPERCYCLE", "(I)", 2000, 4999)
    else if bars >= 500
        WaveDegree.new("CYCLE", "I", 500, 1999)
    else if bars >= 200
        WaveDegree.new("PRIMARY", "[1]", 200, 499)
    else if bars >= 50
        WaveDegree.new("INTERMEDIATE", "(1)", 50, 199)
    else if bars >= 20
        WaveDegree.new("MINOR", "1", 20, 49)
    else if bars >= 10
        WaveDegree.new("MINUTE", "①", 10, 19)
    else if bars >= 5
        WaveDegree.new("MINUETTE", "❶", 5, 9)
    else
        WaveDegree.new("SUBMINUETTE", "⓵", 1, 4)

// ============================================================================
// INITIALIZATION FUNCTIONS
// ============================================================================

// @function Initialize Elliott Wave state
// @returns New ElliottWaveState
export newElliottWaveState() =>
    ElliottWaveState.new(
        na,                                 // currentPattern
        array.new<WavePattern>(),          // completedPatterns
        array.new<Wave>(),                 // pivots
        0,                                  // lastUpdateBar
        0,                                  // activeWaveCount
        0                                   // trendDirection
    )

// @function Initialize Elliott Wave configuration
// @returns New ElliottWaveConfig
export newElliottWaveConfig() =>
    ElliottWaveConfig.new(
        1.0,        // minWaveSize (1%)
        25.0,       // maxWaveOverlap (25%)
        10.0,       // fibTolerance (10%)
        60.0,       // minConfidence (60%)
        true        // useStrictRules
    )

// @function Create new wave
// @param waveNumber Wave number (e.g., "1", "A")
// @param waveType "IMPULSE" or "CORRECTIVE"
// @param direction 1 (up) or -1 (down)
// @param startBar Start bar index
// @param endBar End bar index
// @param startPrice Start price
// @param endPrice End price
// @returns New Wave
export newWave(string waveNumber, string waveType, int direction, int startBar, int endBar, float startPrice, float endPrice) =>
    length = math.abs(endPrice - startPrice)
    bars = endBar - startBar
    degree = getWaveDegree(bars)

    Wave.new(
        waveNumber,     // waveNumber
        waveType,       // waveType
        direction,      // direction
        startBar,       // startBar
        endBar,         // endBar
        startPrice,     // startPrice
        endPrice,       // endPrice
        length,         // length
        bars,           // bars
        degree,         // degree
        na,             // fibRatio
        false,          // isExtension
        50.0            // confidence
    )

// ============================================================================
// FIBONACCI RATIO CALCULATIONS
// ============================================================================

// @function Calculate Fibonacci ratio between two waves
// @param wave1 First wave
// @param wave2 Second wave
// @returns Fibonacci ratio
export calculateWaveFibRatio(Wave wave1, Wave wave2) =>
    if na(wave1) or na(wave2)
        na
    else
        wave1Length = math.abs(wave1.length)
        wave2Length = math.abs(wave2.length)

        if wave1Length == 0
            na
        else
            wave2Length / wave1Length

// @function Check if ratio is near Fibonacci level
// @param ratio Ratio to check
// @param fibLevel Fibonacci level (e.g., 0.618, 1.618)
// @param tolerance Tolerance percentage
// @returns True if near Fibonacci level
export isNearFibLevel(float ratio, float fibLevel, float tolerance = 10.0) =>
    if na(ratio)
        false
    else
        diff = math.abs(ratio - fibLevel) / fibLevel * 100
        diff <= tolerance

// ============================================================================
// ELLIOTT WAVE RULES VALIDATION
// ============================================================================

// @function Validate impulse wave pattern (1-2-3-4-5)
// @param waves Array of 5 waves
// @param config Elliott Wave configuration
// @returns [isValid, confidence, reasons]
export validateImpulsePattern(array<Wave> waves, ElliottWaveConfig config) =>
    if array.size(waves) != 5
        [false, 0.0, "Need 5 waves for impulse"]
    else
        wave1 = array.get(waves, 0)
        wave2 = array.get(waves, 1)
        wave3 = array.get(waves, 2)
        wave4 = array.get(waves, 3)
        wave5 = array.get(waves, 4)

        confidence = 100.0
        reasons = ""
        isValid = true

        // Rule 1: Wave 2 never retraces more than 100% of wave 1
        wave2Retrace = math.abs(wave2.length) / math.abs(wave1.length) * 100
        if wave2Retrace > 100
            isValid := false
            reasons := reasons + "Wave 2 retraces > 100%; "
            confidence -= 50
        else if wave2Retrace > 90
            confidence -= 20
            reasons := reasons + "Wave 2 deep retrace; "

        // Rule 2: Wave 3 is never the shortest
        len1 = math.abs(wave1.length)
        len3 = math.abs(wave3.length)
        len5 = math.abs(wave5.length)

        if len3 < len1 and len3 < len5
            isValid := false
            reasons := reasons + "Wave 3 is shortest; "
            confidence -= 50

        // Rule 3: Wave 4 never overlaps wave 1
        if wave1.direction > 0  // Uptrend
            overlap = wave4.endPrice <= wave1.endPrice
            if config.useStrictRules and overlap
                isValid := false
                reasons := reasons + "Wave 4 overlaps Wave 1; "
                confidence -= 40
        else  // Downtrend
            overlap = wave4.endPrice >= wave1.endPrice
            if config.useStrictRules and overlap
                isValid := false
                reasons := reasons + "Wave 4 overlaps Wave 1; "
                confidence -= 40

        // Fibonacci relationships (bonus points)
        ratio32 = calculateWaveFibRatio(wave1, wave3)
        if isNearFibLevel(ratio32, 1.618, config.fibTolerance)
            confidence += 10
            wave3.isExtension := true

        ratio52 = calculateWaveFibRatio(wave3, wave5)
        if isNearFibLevel(ratio52, 0.618, config.fibTolerance)
            confidence += 10

        confidence := math.max(0, math.min(100, confidence))
        [isValid, confidence, reasons]

// @function Validate corrective wave pattern (A-B-C)
// @param waves Array of 3 waves
// @param config Elliott Wave configuration
// @returns [isValid, confidence, reasons]
export validateCorrectivePattern(array<Wave> waves, ElliottWaveConfig config) =>
    if array.size(waves) != 3
        [false, 0.0, "Need 3 waves for correction"]
    else
        waveA = array.get(waves, 0)
        waveB = array.get(waves, 1)
        waveC = array.get(waves, 2)

        confidence = 80.0
        reasons = ""
        isValid = true

        // Wave B typically retraces 38.2-61.8% of wave A
        ratioBA = calculateWaveFibRatio(waveA, waveB)
        if isNearFibLevel(ratioBA, 0.618, config.fibTolerance) or
           isNearFibLevel(ratioBA, 0.500, config.fibTolerance) or
           isNearFibLevel(ratioBA, 0.382, config.fibTolerance)
            confidence += 10
        else if ratioBA > 1.0
            confidence -= 20
            reasons := reasons + "Wave B > 100% of A; "

        // Wave C typically equals wave A or extends to 161.8%
        ratioCA = calculateWaveFibRatio(waveA, waveC)
        if isNearFibLevel(ratioCA, 1.0, config.fibTolerance)
            confidence += 10
        else if isNearFibLevel(ratioCA, 1.618, config.fibTolerance)
            confidence += 15
            waveC.isExtension := true
        else if isNearFibLevel(ratioCA, 0.618, config.fibTolerance)
            confidence += 5

        confidence := math.max(0, math.min(100, confidence))
        [isValid, confidence, reasons]

// ============================================================================
// WAVE COUNTING LOGIC
// ============================================================================

// @function Count waves from pivot points
// @param state ElliottWaveState
// @param pivots Array of pivot points (from ZigZag)
// @param config Elliott Wave configuration
export countWaves(ElliottWaveState state, array<float> pivotPrices, array<int> pivotBars, ElliottWaveConfig config) =>
    if na(pivotPrices) or na(pivotBars)
        return

    pivotCount = array.size(pivotPrices)
    if pivotCount < 6  // Need at least 6 pivots for 5-wave pattern
        return

    // Clear existing pivots
    array.clear(state.pivots)

    // Convert pivots to waves
    for i = 0 to pivotCount - 2
        startBar = array.get(pivotBars, i)
        endBar = array.get(pivotBars, i + 1)
        startPrice = array.get(pivotPrices, i)
        endPrice = array.get(pivotPrices, i + 1)

        direction = endPrice > startPrice ? 1 : -1
        waveNum = str.tostring(i + 1)

        wave = newWave(waveNum, "UNKNOWN", direction, startBar, endBar, startPrice, endPrice)
        array.push(state.pivots, wave)

    // Try to identify impulse patterns (5 waves)
    if array.size(state.pivots) >= 5
        identifyImpulsePatterns(state, config)

    // Try to identify corrective patterns (3 waves)
    if array.size(state.pivots) >= 3
        identifyCorrectivePatterns(state, config)

// @function Identify impulse patterns from waves
// @param state ElliottWaveState
// @param config Elliott Wave configuration
export identifyImpulsePatterns(ElliottWaveState state, ElliottWaveConfig config) =>
    pivotCount = array.size(state.pivots)

    // Look for 5-wave patterns
    for start = pivotCount - 5 to 0
        if start < 0
            break

        // Extract 5 waves
        waves = array.new<Wave>()
        for i = 0 to 4
            wave = array.get(state.pivots, start + i)
            array.push(waves, wave)

        // Check if waves alternate direction
        alternating = true
        for i = 0 to 3
            w1 = array.get(waves, i)
            w2 = array.get(waves, i + 1)
            if w1.direction == w2.direction
                alternating := false
                break

        if alternating
            // Rename waves to 1-2-3-4-5
            for i = 0 to 4
                wave = array.get(waves, i)
                wave.waveNumber := str.tostring(i + 1)
                wave.waveType := "IMPULSE"

            // Validate pattern
            [isValid, confidence, reasons] = validateImpulsePattern(waves, config)

            if isValid and confidence >= config.minConfidence
                // Create pattern
                wave1 = array.get(waves, 0)
                wave5 = array.get(waves, 4)

                degree = getWaveDegree(wave5.endBar - wave1.startBar)

                pattern = WavePattern.new(
                    "IMPULSE",
                    waves,
                    wave1.startBar,
                    wave5.endBar,
                    wave1.startPrice,
                    wave5.endPrice,
                    wave5.endBar - wave1.startBar,
                    degree,
                    true,
                    isValid,
                    confidence
                )

                state.currentPattern := pattern
                state.activeWaveCount := 5
                state.trendDirection := wave5.endPrice > wave1.startPrice ? 1 : -1

                break

// @function Identify corrective patterns from waves
// @param state ElliottWaveState
// @param config Elliott Wave configuration
export identifyCorrectivePatterns(ElliottWaveState state, ElliottWaveConfig config) =>
    pivotCount = array.size(state.pivots)

    // Look for 3-wave patterns
    for start = pivotCount - 3 to 0
        if start < 0
            break

        // Extract 3 waves
        waves = array.new<Wave>()
        for i = 0 to 2
            wave = array.get(state.pivots, start + i)
            array.push(waves, wave)

        // Check if waves alternate direction
        w1 = array.get(waves, 0)
        w2 = array.get(waves, 1)
        w3 = array.get(waves, 2)

        if w1.direction != w2.direction and w2.direction != w3.direction
            // Rename waves to A-B-C
            w1.waveNumber := "A"
            w2.waveNumber := "B"
            w3.waveNumber := "C"

            w1.waveType := "CORRECTIVE"
            w2.waveType := "CORRECTIVE"
            w3.waveType := "CORRECTIVE"

            // Validate pattern
            [isValid, confidence, reasons] = validateCorrectivePattern(waves, config)

            if isValid and confidence >= config.minConfidence
                degree = getWaveDegree(w3.endBar - w1.startBar)

                pattern = WavePattern.new(
                    "CORRECTIVE",
                    waves,
                    w1.startBar,
                    w3.endBar,
                    w1.startPrice,
                    w3.endPrice,
                    w3.endBar - w1.startBar,
                    degree,
                    true,
                    isValid,
                    confidence
                )

                // Only set if no impulse pattern active
                if na(state.currentPattern) or state.currentPattern.patternType != "IMPULSE"
                    state.currentPattern := pattern
                    state.activeWaveCount := 3

                break

// ============================================================================
// MAIN UPDATE FUNCTION
// ============================================================================

// @function Update Elliott Wave analysis
// @param state ElliottWaveState
// @param pivotPrices Array of pivot prices (from ZigZag)
// @param pivotBars Array of pivot bars (from ZigZag)
// @param config Elliott Wave configuration
export updateElliottWaves(ElliottWaveState state, array<float> pivotPrices, array<int> pivotBars, ElliottWaveConfig config = na) =>
    cfg = na(config) ? newElliottWaveConfig() : config

    // Update wave counting
    countWaves(state, pivotPrices, pivotBars, cfg)

    state.lastUpdateBar := bar_index

// ============================================================================
// QUERY FUNCTIONS
// ============================================================================

// @function Get current wave pattern
// @param state ElliottWaveState
// @returns Current WavePattern or na
export getCurrentPattern(ElliottWaveState state) =>
    state.currentPattern

// @function Get wave count string (e.g., "Wave 3 of 5")
// @param state ElliottWaveState
// @returns Wave count description
export getWaveCountString(ElliottWaveState state) =>
    if na(state.currentPattern)
        "No pattern"
    else
        pattern = state.currentPattern
        if pattern.patternType == "IMPULSE"
            waveNum = state.activeWaveCount > 0 ? state.activeWaveCount : array.size(pattern.waves)
            str.format("Wave {0} of 5 ({1})", waveNum, pattern.degree.name)
        else
            waveNum = state.activeWaveCount > 0 ? state.activeWaveCount : array.size(pattern.waves)
            waveLabel = waveNum == 1 ? "A" : waveNum == 2 ? "B" : "C"
            str.format("Wave {0} ({1})", waveLabel, pattern.degree.name)

// @function Check if in wave 3 (strongest wave)
// @param state ElliottWaveState
// @returns True if in wave 3
export isInWave3(ElliottWaveState state) =>
    if na(state.currentPattern)
        false
    else
        pattern = state.currentPattern
        pattern.patternType == "IMPULSE" and state.activeWaveCount == 3

// @function Check if in wave 5 (final wave)
// @param state ElliottWaveState
// @returns True if in wave 5
export isInWave5(ElliottWaveState state) =>
    if na(state.currentPattern)
        false
    else
        pattern = state.currentPattern
        pattern.patternType == "IMPULSE" and state.activeWaveCount == 5

// @function Check if in corrective wave
// @param state ElliottWaveState
// @returns True if in ABC correction
export isInCorrection(ElliottWaveState state) =>
    if na(state.currentPattern)
        false
    else
        state.currentPattern.patternType == "CORRECTIVE"

// @function Get expected target for current wave
// @param state ElliottWaveState
// @returns [hasTarget, targetPrice, targetReason]
export getWaveTarget(ElliottWaveState state) =>
    if na(state.currentPattern)
        [false, na, "No pattern"]
    else
        pattern = state.currentPattern

        if pattern.patternType == "IMPULSE" and state.activeWaveCount == 3
            // Wave 3 often extends to 161.8% of wave 1
            if array.size(pattern.waves) >= 1
                wave1 = array.get(pattern.waves, 0)
                target = wave1.startPrice + (wave1.length * 1.618 * wave1.direction)
                [true, target, "Wave 3 extension (161.8% of Wave 1)"]
            else
                [false, na, "Insufficient data"]

        else if pattern.patternType == "IMPULSE" and state.activeWaveCount == 5
            // Wave 5 often equals wave 1 or 61.8% of wave 1-3
            if array.size(pattern.waves) >= 4
                wave1 = array.get(pattern.waves, 0)
                wave3 = array.get(pattern.waves, 2)
                wave4 = array.get(pattern.waves, 3)

                totalMove = wave3.endPrice - wave1.startPrice
                target = wave4.endPrice + (totalMove * 0.618 * wave1.direction)
                [true, target, "Wave 5 target (61.8% of 1-3)"]
            else
                [false, na, "Insufficient data"]

        else if pattern.patternType == "CORRECTIVE" and state.activeWaveCount == 3
            // Wave C often equals wave A
            if array.size(pattern.waves) >= 2
                waveA = array.get(pattern.waves, 0)
                waveB = array.get(pattern.waves, 1)

                target = waveB.endPrice + (waveA.length * waveA.direction)
                [true, target, "Wave C target (100% of Wave A)"]
            else
                [false, na, "Insufficient data"]
        else
            [false, na, "No target available"]

// ============================================================================
// SUMMARY & DISPLAY
// ============================================================================

// @function Get Elliott Wave summary
// @param state ElliottWaveState
// @returns Formatted summary string
export getElliottWaveSummary(ElliottWaveState state) =>
    if na(state.currentPattern)
        "No Elliott Wave pattern detected"
    else
        pattern = state.currentPattern
        waveCount = getWaveCountString(state)
        confidence = str.tostring(pattern.confidence, "#")

        [hasTarget, target, reason] = getWaveTarget(state)
        targetStr = hasTarget ? str.format("\nTarget: {0} ({1})", str.tostring(target, "#.##"), reason) : ""

        str.format(
            "Elliott Wave Analysis\n{0}\nConfidence: {1}%\nDegree: {2}{3}",
            waveCount,
            confidence,
            pattern.degree.name,
            targetStr
        )


// ============================================================================
// MODULE: HARMONIC_PATTERNS
// ============================================================================

// ============================================================================
// RTA ADVANCED - Harmonic Patterns Detection
// ============================================================================
// @description: Harmonic pattern detection with Fibonacci validation
//
// Purpose:
//   - Identify classic XABCD harmonic patterns (Gartley, Bat, Butterfly, Crab, etc.)
//   - Detect ABC corrective patterns (Zigzag, Flat, Triangle)
//   - Validate patterns using Fibonacci ratios
//   - Calculate pattern completion zones (PRZ)
//   - Project price targets based on pattern type
//
// XABCD Harmonic Patterns:
//   All harmonic patterns follow a 5-point structure: X-A-B-C-D
//   Each pattern has specific Fibonacci ratios between legs
//
//   GARTLEY:
//   - B: 0.618 retracement of XA
//   - D: 0.786 retracement of XA
//   - C: 0.382-0.886 retracement of AB
//   - D: 1.272-1.618 extension of BC
//
//   BAT:
//   - B: 0.382-0.500 retracement of XA
//   - D: 0.886 retracement of XA
//   - C: 0.382-0.886 retracement of AB
//   - D: 1.618-2.618 extension of BC
//
//   BUTTERFLY:
//   - B: 0.786 retracement of XA
//   - D: 1.272-1.618 extension of XA
//   - C: 0.382-0.886 retracement of AB
//   - D: 1.618-2.24 extension of BC
//
//   CRAB:
//   - B: 0.382-0.618 retracement of XA
//   - D: 1.618 extension of XA
//   - C: 0.382-0.886 retracement of AB
//   - D: 2.24-3.618 extension of BC
//
// ABC Corrective Patterns:
//   - ZIGZAG: Sharp correction (A=C typically)
//   - FLAT: Sideways correction (A=B, B=C)
//   - TRIANGLE: Converging range
//
// Usage:
//   import "RTAAdvanced" as ADV
//   var harmonicState = ADV.newHarmonicState()
//   ADV.updateHarmonicPatterns(harmonicState, pivotPrices, pivotBars)
// ============================================================================

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

// @type Harmonic pattern point (X, A, B, C, or D)
// @field name Point name ("X", "A", "B", "C", "D")
// @field bar Bar index
// @field price Price level
// @field isHigh True if swing high, false if swing low
export type HarmonicPoint
    string name
    int bar
    float price
    bool isHigh

// @type XABCD harmonic pattern
// @field patternName Pattern name (GARTLEY, BAT, BUTTERFLY, CRAB, SHARK, CYPHER)
// @field direction Direction (1 bullish, -1 bearish)
// @field pointX X point
// @field pointA A point
// @field pointB B point
// @field pointC C point
// @field pointD D point
// @field ratioXAB B retracement of XA
// @field ratioBCD D retracement of XA
// @field ratioABC C retracement of AB
// @field ratioBCD_ext D extension of BC
// @field isComplete True if D point reached
// @field isValid True if ratios match pattern
// @field confidence Confidence score (0-100)
// @field prz Potential Reversal Zone (D target)
// @field target1 First profit target
// @field target2 Second profit target
export type HarmonicPattern
    string patternName
    int direction
    HarmonicPoint pointX
    HarmonicPoint pointA
    HarmonicPoint pointB
    HarmonicPoint pointC
    HarmonicPoint pointD
    float ratioXAB
    float ratioXAD
    float ratioABC
    float ratioBCD
    bool isComplete
    bool isValid
    float confidence
    float prz
    float target1
    float target2

// @type ABC corrective pattern
// @field patternType Type (ZIGZAG, FLAT, TRIANGLE)
// @field direction Direction (1 up, -1 down)
// @field pointA A point
// @field pointB B point
// @field pointC C point
// @field ratioAB_C C retracement of AB
// @field ratioA_BC BC extension of A
// @field isComplete True if C point reached
// @field confidence Confidence score (0-100)
export type ABCPattern
    string patternType
    int direction
    HarmonicPoint pointA
    HarmonicPoint pointB
    HarmonicPoint pointC
    float ratioAB_C
    float ratioA_BC
    bool isComplete
    float confidence

// @type Harmonic state
// @field xabcdPatterns Array of XABCD patterns
// @field abcPatterns Array of ABC patterns
// @field pivotPoints Array of pivot points for pattern detection
// @field lastUpdateBar Last bar when updated
export type HarmonicState
    array<HarmonicPattern> xabcdPatterns
    array<ABCPattern> abcPatterns
    array<HarmonicPoint> pivotPoints
    int lastUpdateBar

// @type Harmonic configuration
// @field minPatternBars Minimum bars for pattern
// @field maxPatternBars Maximum bars for pattern
// @field fibTolerance Fibonacci ratio tolerance (%)
// @field minConfidence Minimum confidence to accept pattern
export type HarmonicConfig
    int minPatternBars
    int maxPatternBars
    float fibTolerance
    float minConfidence

// ============================================================================
// INITIALIZATION FUNCTIONS
// ============================================================================

// @function Initialize Harmonic state
// @returns New HarmonicState
export newHarmonicState() =>
    HarmonicState.new(
        array.new<HarmonicPattern>(),      // xabcdPatterns
        array.new<ABCPattern>(),            // abcPatterns
        array.new<HarmonicPoint>(),         // pivotPoints
        0                                    // lastUpdateBar
    )

// @function Initialize Harmonic configuration
// @returns New HarmonicConfig
export newHarmonicConfig() =>
    HarmonicConfig.new(
        20,         // minPatternBars
        200,        // maxPatternBars
        5.0,        // fibTolerance (%)
        70.0        // minConfidence
    )

// @function Create harmonic point
// @param name Point name
// @param bar Bar index
// @param price Price
// @param isHigh True if swing high
// @returns New HarmonicPoint
export newHarmonicPoint(string name, int bar, float price, bool isHigh) =>
    HarmonicPoint.new(name, bar, price, isHigh)

// ============================================================================
// FIBONACCI RATIO CALCULATIONS
// ============================================================================

// @function Calculate Fibonacci ratio between two points
// @param point1Price First point price
// @param point2Price Second point price
// @param point3Price Third point price (for retracement)
// @returns Retracement ratio
export calculateRetracement(float point1Price, float point2Price, float point3Price) =>
    move = math.abs(point2Price - point1Price)
    retracement = math.abs(point3Price - point2Price)

    if move == 0
        0.0
    else
        retracement / move

// @function Calculate Fibonacci extension
// @param point1Price First point price
// @param point2Price Second point price
// @param point3Price Third point price
// @returns Extension ratio
export calculateExtension(float point1Price, float point2Price, float point3Price) =>
    move = math.abs(point2Price - point1Price)
    extension = math.abs(point3Price - point1Price)

    if move == 0
        0.0
    else
        extension / move

// @function Check if ratio is within tolerance of target
// @param ratio Actual ratio
// @param target Target ratio
// @param tolerance Tolerance (%)
// @returns True if within tolerance
export isRatioValid(float ratio, float target, float tolerance) =>
    diff = math.abs(ratio - target) / target * 100
    diff <= tolerance

// ============================================================================
// XABCD PATTERN DETECTION
// ============================================================================

// @function Detect Gartley pattern
// @param X X point
// @param A A point
// @param B B point
// @param C C point
// @param D D point (potential)
// @param tolerance Fibonacci tolerance
// @returns [isValid, confidence]
export detectGartley(HarmonicPoint X, HarmonicPoint A, HarmonicPoint B, HarmonicPoint C, HarmonicPoint D, float tolerance) =>
    confidence = 100.0

    // B: 0.618 retracement of XA
    ratioXAB = calculateRetracement(X.price, A.price, B.price)
    if not isRatioValid(ratioXAB, 0.618, tolerance)
        confidence -= 30

    // D: 0.786 retracement of XA
    ratioXAD = calculateRetracement(X.price, A.price, D.price)
    if not isRatioValid(ratioXAD, 0.786, tolerance)
        confidence -= 30

    // C: 0.382-0.886 retracement of AB
    ratioABC = calculateRetracement(A.price, B.price, C.price)
    if ratioABC < 0.382 or ratioABC > 0.886
        confidence -= 20

    // D: 1.272-1.618 extension of BC
    ratioBCD = calculateExtension(B.price, C.price, D.price)
    if ratioBCD < 1.272 or ratioBCD > 1.618
        confidence -= 20

    isValid = confidence >= 60
    [isValid, confidence]

// @function Detect Bat pattern
// @param X X point
// @param A A point
// @param B B point
// @param C C point
// @param D D point (potential)
// @param tolerance Fibonacci tolerance
// @returns [isValid, confidence]
export detectBat(HarmonicPoint X, HarmonicPoint A, HarmonicPoint B, HarmonicPoint C, HarmonicPoint D, float tolerance) =>
    confidence = 100.0

    // B: 0.382-0.500 retracement of XA
    ratioXAB = calculateRetracement(X.price, A.price, B.price)
    if ratioXAB < 0.382 or ratioXAB > 0.500
        confidence -= 30

    // D: 0.886 retracement of XA
    ratioXAD = calculateRetracement(X.price, A.price, D.price)
    if not isRatioValid(ratioXAD, 0.886, tolerance)
        confidence -= 30

    // C: 0.382-0.886 retracement of AB
    ratioABC = calculateRetracement(A.price, B.price, C.price)
    if ratioABC < 0.382 or ratioABC > 0.886
        confidence -= 20

    // D: 1.618-2.618 extension of BC
    ratioBCD = calculateExtension(B.price, C.price, D.price)
    if ratioBCD < 1.618 or ratioBCD > 2.618
        confidence -= 20

    isValid = confidence >= 60
    [isValid, confidence]

// @function Detect Butterfly pattern
// @param X X point
// @param A A point
// @param B B point
// @param C C point
// @param D D point (potential)
// @param tolerance Fibonacci tolerance
// @returns [isValid, confidence]
export detectButterfly(HarmonicPoint X, HarmonicPoint A, HarmonicPoint B, HarmonicPoint C, HarmonicPoint D, float tolerance) =>
    confidence = 100.0

    // B: 0.786 retracement of XA
    ratioXAB = calculateRetracement(X.price, A.price, B.price)
    if not isRatioValid(ratioXAB, 0.786, tolerance)
        confidence -= 30

    // D: 1.272-1.618 extension of XA
    ratioXAD = calculateExtension(X.price, A.price, D.price)
    if ratioXAD < 1.272 or ratioXAD > 1.618
        confidence -= 30

    // C: 0.382-0.886 retracement of AB
    ratioABC = calculateRetracement(A.price, B.price, C.price)
    if ratioABC < 0.382 or ratioABC > 0.886
        confidence -= 20

    // D: 1.618-2.24 extension of BC
    ratioBCD = calculateExtension(B.price, C.price, D.price)
    if ratioBCD < 1.618 or ratioBCD > 2.24
        confidence -= 20

    isValid = confidence >= 60
    [isValid, confidence]

// @function Detect Crab pattern
// @param X X point
// @param A A point
// @param B B point
// @param C C point
// @param D D point (potential)
// @param tolerance Fibonacci tolerance
// @returns [isValid, confidence]
export detectCrab(HarmonicPoint X, HarmonicPoint A, HarmonicPoint B, HarmonicPoint C, HarmonicPoint D, float tolerance) =>
    confidence = 100.0

    // B: 0.382-0.618 retracement of XA
    ratioXAB = calculateRetracement(X.price, A.price, B.price)
    if ratioXAB < 0.382 or ratioXAB > 0.618
        confidence -= 30

    // D: 1.618 extension of XA
    ratioXAD = calculateExtension(X.price, A.price, D.price)
    if not isRatioValid(ratioXAD, 1.618, tolerance)
        confidence -= 30

    // C: 0.382-0.886 retracement of AB
    ratioABC = calculateRetracement(A.price, B.price, C.price)
    if ratioABC < 0.382 or ratioABC > 0.886
        confidence -= 20

    // D: 2.24-3.618 extension of BC
    ratioBCD = calculateExtension(B.price, C.price, D.price)
    if ratioBCD < 2.24 or ratioBCD > 3.618
        confidence -= 20

    isValid = confidence >= 60
    [isValid, confidence]

// ============================================================================
// ABC PATTERN DETECTION
// ============================================================================

// @function Detect Zigzag pattern (sharp correction)
// @param A A point
// @param B B point
// @param C C point
// @param tolerance Fibonacci tolerance
// @returns [isValid, confidence]
export detectZigzag(HarmonicPoint A, HarmonicPoint B, HarmonicPoint C, float tolerance) =>
    confidence = 100.0

    // C typically retraces 0.50-0.786 of AB
    ratioABC = calculateRetracement(A.price, B.price, C.price)
    if ratioABC < 0.50 or ratioABC > 0.786
        confidence -= 30

    // BC typically extends 1.0-1.618 of A
    moveAB = math.abs(B.price - A.price)
    moveBC = math.abs(C.price - B.price)
    ratioBC = moveBC / moveAB

    if not isRatioValid(ratioBC, 1.0, tolerance * 2)
        confidence -= 20

    isValid = confidence >= 60
    [isValid, confidence]

// @function Detect Flat pattern (sideways correction)
// @param A A point
// @param B B point
// @param C C point
// @param tolerance Fibonacci tolerance
// @returns [isValid, confidence]
export detectFlat(HarmonicPoint A, HarmonicPoint B, HarmonicPoint C, float tolerance) =>
    confidence = 100.0

    // B typically retraces 0.90-1.0 of A
    moveAB = math.abs(B.price - A.price)
    moveA = math.abs(A.price - A.price)  // From origin

    // C typically near A level (flat)
    levelDiff = math.abs(C.price - A.price) / math.abs(B.price - A.price)
    if levelDiff > 0.382
        confidence -= 30

    // BC typically 1.0-1.382 of AB
    moveBC = math.abs(C.price - B.price)
    ratioBC = moveBC / moveAB

    if ratioBC < 1.0 or ratioBC > 1.382
        confidence -= 20

    isValid = confidence >= 60
    [isValid, confidence]

// ============================================================================
// PATTERN IDENTIFICATION
// ============================================================================

// @function Identify XABCD patterns from pivots
// @param state HarmonicState
// @param config HarmonicConfig
export identifyXABCDPatterns(HarmonicState state, HarmonicConfig config) =>
    pivotCount = array.size(state.pivotPoints)

    // Need at least 5 pivots for XABCD
    if pivotCount < 5
        return

    // Clear existing patterns
    array.clear(state.xabcdPatterns)

    // Look for XABCD patterns in recent pivots
    for start = math.max(0, pivotCount - 10) to pivotCount - 5
        X = array.get(state.pivotPoints, start)
        A = array.get(state.pivotPoints, start + 1)
        B = array.get(state.pivotPoints, start + 2)
        C = array.get(state.pivotPoints, start + 3)
        D = array.get(state.pivotPoints, start + 4)

        // Check if pattern alternates (high-low-high-low-high or vice versa)
        if X.isHigh == A.isHigh or A.isHigh == B.isHigh or
           B.isHigh == C.isHigh or C.isHigh == D.isHigh
            continue

        direction = A.isHigh ? -1 : 1

        // Try each pattern type
        [isGartley, gartleyConf] = detectGartley(X, A, B, C, D, config.fibTolerance)
        [isBat, batConf] = detectBat(X, A, B, C, D, config.fibTolerance)
        [isButterfly, butterflyConf] = detectButterfly(X, A, B, C, D, config.fibTolerance)
        [isCrab, crabConf] = detectCrab(X, A, B, C, D, config.fibTolerance)

        // Select best matching pattern
        patternName = ""
        confidence = 0.0

        if isGartley and gartleyConf > confidence
            patternName := "GARTLEY"
            confidence := gartleyConf

        if isBat and batConf > confidence
            patternName := "BAT"
            confidence := batConf

        if isButterfly and butterflyConf > confidence
            patternName := "BUTTERFLY"
            confidence := butterflyConf

        if isCrab and crabConf > confidence
            patternName := "CRAB"
            confidence := crabConf

        // Create pattern if valid
        if patternName != "" and confidence >= config.minConfidence
            pattern = HarmonicPattern.new(
                patternName,
                direction,
                X, A, B, C, D,
                calculateRetracement(X.price, A.price, B.price),
                calculateRetracement(X.price, A.price, D.price),
                calculateRetracement(A.price, B.price, C.price),
                calculateExtension(B.price, C.price, D.price),
                true,
                true,
                confidence,
                D.price,
                C.price,
                B.price
            )

            array.push(state.xabcdPatterns, pattern)

// @function Identify ABC patterns from pivots
// @param state HarmonicState
// @param config HarmonicConfig
export identifyABCPatterns(HarmonicState state, HarmonicConfig config) =>
    pivotCount = array.size(state.pivotPoints)

    // Need at least 3 pivots for ABC
    if pivotCount < 3
        return

    // Clear existing ABC patterns
    array.clear(state.abcPatterns)

    // Look for ABC patterns
    for start = math.max(0, pivotCount - 10) to pivotCount - 3
        A = array.get(state.pivotPoints, start)
        B = array.get(state.pivotPoints, start + 1)
        C = array.get(state.pivotPoints, start + 2)

        // Check if pattern alternates
        if A.isHigh == B.isHigh or B.isHigh == C.isHigh
            continue

        direction = B.isHigh ? -1 : 1

        // Try each ABC pattern type
        [isZigzag, zigzagConf] = detectZigzag(A, B, C, config.fibTolerance)
        [isFlat, flatConf] = detectFlat(A, B, C, config.fibTolerance)

        // Select best matching pattern
        patternType = ""
        confidence = 0.0

        if isZigzag and zigzagConf > confidence
            patternType := "ZIGZAG"
            confidence := zigzagConf

        if isFlat and flatConf > confidence
            patternType := "FLAT"
            confidence := flatConf

        // Create pattern if valid
        if patternType != "" and confidence >= config.minConfidence
            pattern = ABCPattern.new(
                patternType,
                direction,
                A, B, C,
                calculateRetracement(A.price, B.price, C.price),
                calculateExtension(A.price, B.price, C.price),
                true,
                confidence
            )

            array.push(state.abcPatterns, pattern)

// ============================================================================
// MAIN UPDATE FUNCTION
// ============================================================================

// @function Update harmonic pattern analysis
// @param state HarmonicState
// @param pivotPrices Array of pivot prices
// @param pivotBars Array of pivot bars
// @param pivotTypes Array of pivot types (true for high, false for low)
// @param config Harmonic configuration
export updateHarmonicPatterns(HarmonicState state, array<float> pivotPrices, array<int> pivotBars, array<bool> pivotTypes, HarmonicConfig config = na) =>
    cfg = na(config) ? newHarmonicConfig() : config

    // Convert pivots to harmonic points
    array.clear(state.pivotPoints)

    if not na(pivotPrices) and not na(pivotBars) and not na(pivotTypes)
        pivotCount = array.size(pivotPrices)

        for i = 0 to pivotCount - 1
            price = array.get(pivotPrices, i)
            bar = array.get(pivotBars, i)
            isHigh = array.get(pivotTypes, i)

            point = newHarmonicPoint("", bar, price, isHigh)
            array.push(state.pivotPoints, point)

    // Identify patterns
    identifyXABCDPatterns(state, cfg)
    identifyABCPatterns(state, cfg)

    state.lastUpdateBar := bar_index

// ============================================================================
// QUERY FUNCTIONS
// ============================================================================

// @function Get active XABCD patterns
// @param state HarmonicState
// @returns Array of active patterns
export getActiveXABCDPatterns(HarmonicState state) =>
    state.xabcdPatterns

// @function Get active ABC patterns
// @param state HarmonicState
// @returns Array of active ABC patterns
export getActiveABCPatterns(HarmonicState state) =>
    state.abcPatterns

// @function Get harmonic summary
// @param state HarmonicState
// @returns Formatted summary string
export getHarmonicSummary(HarmonicState state) =>
    xabcdCount = array.size(state.xabcdPatterns)
    abcCount = array.size(state.abcPatterns)

    str.format(
        "Harmonic Patterns\nXABCD Patterns: {0}\nABC Patterns: {1}",
        xabcdCount,
        abcCount
    )

