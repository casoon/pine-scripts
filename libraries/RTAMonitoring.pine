// ============================================================================
// BASIC RESULT TYPE
// ============================================================================

export type Result
    bool success
    string errorMessage
    string context

export newSuccess(string context = "") =>
    Result.new(true, "", context)

export newError(string errorMessage, string context = "") =>
    Result.new(false, errorMessage, context)

export isSuccess(Result result) =>
    result.success

export isError(Result result) =>
    not result.success

