// ============================================================================
// MODULE: DEBUGGING_TOOLS
// ============================================================================

// Debugging Tools Module - Development debugging aids and diagnostics

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================
// Copied from RTAFramework for standalone operation

// Join array of strings with separator
joinStrings(array<string> strings, string separator = ", ") =>
    size = array.size(strings)
    if size == 0
        ""
    else if size == 1
        array.get(strings, 0)
    else
        result = array.get(strings, 0)
        for i = 1 to size - 1
            result := result + separator + array.get(strings, i)
        result

// Format timestamp to readable date/time
formatTimestamp(int timestamp, string format = "datetime") =>
    switch format
        "date" => str.tostring(timestamp, "yyyy-MM-dd")
        "time" => str.tostring(timestamp, "HH:mm")
        "datetime" => str.tostring(timestamp, "yyyy-MM-dd HH:mm")
        => str.tostring(timestamp)

// Create formatted header for display tables
formatTableHeader(string title, int width = 40) =>
    titleLength = str.length(title)
    actualWidth = math.max(10, math.min(100, math.max(width, titleLength + 4)))
    padding = math.max(0, actualWidth - titleLength - 2)
    leftPad = math.max(0, math.min(50, padding / 2))
    rightPad = math.max(0, math.min(50, padding - leftPad))
    "┌" + str.repeat("─", actualWidth) + "┐\n" + "│ " + str.repeat(" ", leftPad) + title + str.repeat(" ", rightPad) + "│\n" + "├" + str.repeat("─", actualWidth) + "┤"

// Format table row with key-value pair
formatTableRow(string key, string value, int width = 40) =>
    keyLength = str.length(key)
    valueLength = str.length(value)
    totalContent = keyLength + valueLength + 3
    safeWidth = math.max(10, math.min(100, width))
    if totalContent <= safeWidth - 2
        padding = math.max(0, math.min(50, safeWidth - 2 - totalContent))
        "│ " + key + " : " + value + str.repeat(" ", padding) + "│"
    else
        available = math.max(3, safeWidth - keyLength - 5)
        truncatedValue = str.substring(value, 0, math.max(0, available))
        "│ " + key + " : " + truncatedValue + "│"

// Close table formatting
formatTableFooter(int width = 40) =>
    safeWidth = math.max(10, math.min(100, width))
    "└" + str.repeat("─", safeWidth) + "┘"

// ============================================================================
// DEBUG LOGGING & TRACING
// ============================================================================

// @type Debug log entry
export type DebugLogEntry
    int timestamp               // When log entry was created
    string level               // "DEBUG", "INFO", "WARN", "ERROR", "TRACE"
    string module              // Module/component name
    string function            // Function name
    string message             // Debug message
    string context             // Additional context
    map<string, string> data   // Key-value data pairs
    int barIndex              // Bar index when logged
    string timeframe          // Timeframe context

// @type Debug logger with configurable levels
export type DebugLogger
    array<DebugLogEntry> entries      // Log entries
    int maxEntries                    // Maximum entries to keep
    string currentLevel               // Current log level
    bool enabled                      // Logger enabled/disabled
    array<string> enabledModules      // Modules to log
    bool showTimestamp               // Include timestamp in output
    bool showBarIndex               // Include bar index in output
    string outputFormat             // "SIMPLE", "DETAILED", "JSON"

// @function Create new debug logger
newDebugLogger(int maxEntries = 100, string level = "INFO") =>
    DebugLogger.new(array.new<DebugLogEntry>(), maxEntries, level, true, array.new<string>(), true, true, "DETAILED")

// @function Create new debug log entry
newDebugLogEntry(string level, string module, string function, string message, string context = "") =>
    DebugLogEntry.new(time, level, module, function, message, context, map.new<string, string>(), bar_index, timeframe.period)

// @function Check if log level should be logged
shouldLog(DebugLogger logger, string level) =>
    if not logger.enabled
        false
    else
        levelPriority = switch level
            "TRACE" => 0
            "DEBUG" => 1
            "INFO" => 2
            "WARN" => 3
            "ERROR" => 4
            => 2

        currentPriority = switch logger.currentLevel
            "TRACE" => 0
            "DEBUG" => 1
            "INFO" => 2
            "WARN" => 3
            "ERROR" => 4
            => 2

        levelPriority >= currentPriority

// @function Add log entry to logger
addLogEntry(DebugLogger logger, DebugLogEntry entry) =>
    if shouldLog(logger, entry.level)
        // Check if module filtering is enabled
        if array.size(logger.enabledModules) > 0
            moduleEnabled = false
            for i = 0 to array.size(logger.enabledModules) - 1
                if array.get(logger.enabledModules, i) == entry.module
                    moduleEnabled := true
                    break
            if not moduleEnabled
                logger // Return without logging
        else
            // Add entry
            array.push(logger.entries, entry)

            // Trim if exceeding max entries
            while array.size(logger.entries) > logger.maxEntries
                array.shift(logger.entries)

    logger

// @function Log debug message
logDebug(DebugLogger logger, string module, string function, string message, string context = "") =>
    entry = newDebugLogEntry("DEBUG", module, function, message, context)
    addLogEntry(logger, entry)

// @function Log info message
logInfo(DebugLogger logger, string module, string function, string message, string context = "") =>
    entry = newDebugLogEntry("INFO", module, function, message, context)
    addLogEntry(logger, entry)

// @function Log warning message
logWarn(DebugLogger logger, string module, string function, string message, string context = "") =>
    entry = newDebugLogEntry("WARN", module, function, message, context)
    addLogEntry(logger, entry)

// @function Log error message
logError(DebugLogger logger, string module, string function, string message, string context = "") =>
    entry = newDebugLogEntry("ERROR", module, function, message, context)
    addLogEntry(logger, entry)

// @function Log trace message
logTrace(DebugLogger logger, string module, string function, string message, string context = "") =>
    entry = newDebugLogEntry("TRACE", module, function, message, context)
    addLogEntry(logger, entry)

// ============================================================================
// PERFORMANCE DEBUGGING
// ============================================================================

// @type Performance measurement
export type PerformanceMeasurement
    string name                // Measurement name
    int startTime             // Start timestamp
    int endTime               // End timestamp
    float duration            // Duration in milliseconds
    int iterations            // Number of iterations
    float avgDuration         // Average duration per iteration
    string status             // "RUNNING", "COMPLETED", "FAILED"
    string context            // Additional context

// @function Start performance measurement
startMeasurement(string name, string context = "") =>
    PerformanceMeasurement.new(name, timenow, 0, 0.0, 1, 0.0, "RUNNING", context)

// @function End performance measurement
endMeasurement(PerformanceMeasurement measurement) =>
    measurement.endTime := timenow
    measurement.duration := measurement.endTime - measurement.startTime
    measurement.avgDuration := measurement.duration / measurement.iterations
    measurement.status := "COMPLETED"
    measurement

// @function Benchmark a function call (conceptual - Pine Script limitations)
// This would be used as a wrapper around function calls
benchmarkFunction(string functionName, string context = "") =>
    // Return measurement object to be used with actual function call
    startMeasurement(functionName, context)

// ============================================================================
// DATA INSPECTION
// ============================================================================

// @function Inspect array contents (for debugging)
inspectArray(array<float> arr, string name = "Array", int maxItems = 10) =>
    size = array.size(arr)
    result = name + " (size=" + str.tostring(size) + "): ["

    itemsToShow = math.min(size, maxItems)
    for i = 0 to itemsToShow - 1
        value = array.get(arr, i)
        result := result + (i > 0 ? ", " : "") + str.tostring(value, "#.##")

    if size > maxItems
        result := result + ", ... (" + str.tostring(size - maxItems) + " more)"

    result + "]"

// @function Inspect string array contents
inspectStringArray(array<string> arr, string name = "StringArray", int maxItems = 10) =>
    size = array.size(arr)
    result = name + " (size=" + str.tostring(size) + "): ["

    itemsToShow = math.min(size, maxItems)
    for i = 0 to itemsToShow - 1
        value = array.get(arr, i)
        result := result + (i > 0 ? ", " : "") + "\"" + value + "\""

    if size > maxItems
        result := result + ", ... (" + str.tostring(size - maxItems) + " more)"

    result + "]"

// @function Inspect map contents (key sample)
inspectMapKeys(map<string, float> m, string name = "Map", int maxKeys = 5) =>
    // Note: Pine Script has limited map inspection capabilities
    // This is a conceptual function for debugging purposes
    result = name + " (map with float values)"
    // In actual usage, you'd need to track keys separately
    result

// @function Create variable dump string
dumpVariables(string[] names, string[] values) =>
    result = "=== VARIABLE DUMP ===\n"
    size = math.min(array.size(names), array.size(values))

    for i = 0 to size - 1
        name = array.get(names, i)
        value = array.get(values, i)
        result := result + name + " = " + value + "\n"

    result + "===================="

// ============================================================================
// STATE VALIDATION
// ============================================================================

// @function Assert condition with message
assert(bool condition, string message, DebugLogger logger = na) =>
    if not condition
        errorMsg = "ASSERTION FAILED: " + message
        if na(logger)
            // Use Pine Script's built-in runtime error
            runtime.error(errorMsg)
        else
            logError(logger, "ASSERT", "assert", errorMsg)
        false
    else
        true

// @function Validate range
validateRange(float value, float min, float max, string varName = "value") =>
    if value < min or value > max
        "ERROR: " + varName + " (" + str.tostring(value) + ") is outside valid range [" + str.tostring(min) + ", " + str.tostring(max) + "]"
    else
        "OK: " + varName + " is within valid range"

// @function Validate array state
validateArrayState(array<float> arr, string name = "array") =>
    issues = array.new<string>()

    if na(arr)
        array.push(issues, "Array is na")
    else
        size = array.size(arr)
        if size == 0
            array.push(issues, "Array is empty")
        else
            // Check for invalid values
            hasNaN = false
            hasInf = false
            for i = 0 to size - 1
                value = array.get(arr, i)
                if na(value)
                    hasNaN := true
                else if not (value == value) // NaN check
                    hasNaN := true
                else if math.abs(value) > 1e308
                    hasInf := true

            if hasNaN
                array.push(issues, "Contains NaN values")
            if hasInf
                array.push(issues, "Contains infinite values")

    if array.size(issues) == 0
        "OK: " + name + " is valid"
    else
        "ISSUES in " + name + ": " + joinStrings(issues, ", ")

// ============================================================================
// EXECUTION TRACING
// ============================================================================

// @type Execution trace entry
export type TraceEntry
    string function           // Function name
    string module            // Module name
    int entryTime           // Entry timestamp
    int exitTime            // Exit timestamp
    bool isEntry            // true for entry, false for exit
    string parameters       // Parameter values (as string)
    string returnValue      // Return value (as string)
    int depth              // Call stack depth

// @type Execution tracer
export type ExecutionTracer
    array<TraceEntry> traces    // Trace entries
    int currentDepth           // Current call depth
    int maxDepth              // Maximum depth to trace
    bool enabled              // Tracer enabled
    int maxTraces            // Maximum traces to keep

// @function Create new execution tracer
newExecutionTracer(int maxTraces = 200, int maxDepth = 10) =>
    ExecutionTracer.new(array.new<TraceEntry>(), 0, maxDepth, true, maxTraces)

// @function Trace function entry
traceEntry(ExecutionTracer tracer, string module, string function, string parameters = "") =>
    if tracer.enabled and tracer.currentDepth < tracer.maxDepth
        entry = TraceEntry.new(function, module, timenow, 0, true, parameters, "", tracer.currentDepth)

        array.push(tracer.traces, entry)
        tracer.currentDepth := tracer.currentDepth + 1

        // Trim if needed
        while array.size(tracer.traces) > tracer.maxTraces
            array.shift(tracer.traces)

    tracer

// @function Trace function exit
traceExit(ExecutionTracer tracer, string module, string function, string returnValue = "") =>
    if tracer.enabled and tracer.currentDepth > 0
        tracer.currentDepth := tracer.currentDepth - 1

        entry = TraceEntry.new(function, module, 0, timenow, false, "", returnValue, tracer.currentDepth)

        array.push(tracer.traces, entry)

        // Trim if needed
        while array.size(tracer.traces) > tracer.maxTraces
            array.shift(tracer.traces)

    tracer

// ============================================================================
// DEBUG OUTPUT FORMATTING
// ============================================================================

// @function Format debug log entry
formatLogEntry(DebugLogEntry entry, DebugLogger logger) =>
    result = ""

    if logger.showTimestamp
        result := result + "[" + formatTimestamp(entry.timestamp, "time") + "] "

    if logger.showBarIndex
        result := result + "(Bar:" + str.tostring(entry.barIndex) + ") "

    result := result + entry.level + " "

    if logger.outputFormat == "DETAILED"
        result := result + entry.module + "." + entry.function + ": " + entry.message
        if str.length(entry.context) > 0
            result := result + " | " + entry.context
    else
        result := result + entry.message

    result

// @function Get recent log entries as formatted string
getRecentLogs(DebugLogger logger, int count = 10) =>
    entries = logger.entries
    size = array.size(entries)
    startIdx = math.max(0, size - count)

    result = "=== DEBUG LOG (Last " + str.tostring(math.min(count, size)) + " entries) ===\n"

    for i = startIdx to size - 1
        entry = array.get(entries, i)
        result := result + formatLogEntry(entry, logger) + "\n"

    result + "=================================================="

// @function Clear debug log
clearLog(DebugLogger logger) =>
    array.clear(logger.entries)
    logger

// @function Get log statistics
getLogStats(DebugLogger logger) =>
    entries = logger.entries
    size = array.size(entries)

    if size == 0
        "No log entries"
    else
        debugCount = 0
        infoCount = 0
        warnCount = 0
        errorCount = 0
        traceCount = 0

        for i = 0 to size - 1
            entry = array.get(entries, i)
            switch entry.level
                "DEBUG" => debugCount := debugCount + 1
                "INFO" => infoCount := infoCount + 1
                "WARN" => warnCount := warnCount + 1
                "ERROR" => errorCount := errorCount + 1
                "TRACE" => traceCount := traceCount + 1

        "Log Stats: " + str.tostring(size) + " total | " + "ERROR:" + str.tostring(errorCount) + " " + "WARN:" + str.tostring(warnCount) + " " + "INFO:" + str.tostring(infoCount) + " " + "DEBUG:" + str.tostring(debugCount) + " " + "TRACE:" + str.tostring(traceCount)

// ============================================================================
// UTILITY FUNCTIONS
// ============================================================================

// @function Enable/disable debug module
setDebugModule(DebugLogger logger, string module, bool enabled) =>
    if enabled
        // Add if not present
        found = false
        for i = 0 to array.size(logger.enabledModules) - 1
            if array.get(logger.enabledModules, i) == module
                found := true
                break
        if not found
            array.push(logger.enabledModules, module)
    else
        // Remove if present
        for i = array.size(logger.enabledModules) - 1 to 0
            if array.get(logger.enabledModules, i) == module
                array.remove(logger.enabledModules, i)
                break

    logger

// @function Get current debug configuration
getDebugConfig(DebugLogger logger) =>
    "Debug Config: " + "Level=" + logger.currentLevel + " " + "Enabled=" + str.tostring(logger.enabled) + " " + "MaxEntries=" + str.tostring(logger.maxEntries) + " " + "Modules=" + str.tostring(array.size(logger.enabledModules)) + " " + "Format=" + logger.outputFormat

// Global debug logger instance (if needed)
