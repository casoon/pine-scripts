// Base Types Module - Core infrastructure types for RedefiningTechnicalAnalysis Core Library
// Contains Result<T> pattern, ValidationResult, PerformanceProfile, HealthStatus

// ============================================================================
// RESULT PATTERN - Generic Error Handling & Safe Operations
// ============================================================================

// @type Generic Result type for safe operations with error handling and fallbacks
export type Result
    float floatValue
    string stringValue
    bool boolValue
    int intValue
    // Status & Error Information
    bool isSuccess
    string errorCode
    string errorMessage
    // Fallback & Recovery
    float floatFallback
    string stringFallback
    bool boolFallback
    int intFallback
    // Additional Context
    string operationContext
    int timestamp
    string[] tags

// @function Create a successful Result with float value
export newFloatResult(float value, string context = "") =>
    Result.new(floatValue = value, stringValue = na, boolValue = false, intValue = 0, isSuccess = true, errorCode = "", errorMessage = "", floatFallback = na, stringFallback = "", boolFallback = false, intFallback = 0, operationContext = context, timestamp = time, tags = array.new<string>())

// @function Create a successful Result with string value
export newStringResult(string value, string context = "") =>
    Result.new(floatValue = na, stringValue = value, boolValue = false, intValue = 0, isSuccess = true, errorCode = "", errorMessage = "", floatFallback = na, stringFallback = "", boolFallback = false, intFallback = 0, operationContext = context, timestamp = time, tags = array.new<string>())

// @function Create a successful Result with boolean value
export newBoolResult(bool value, string context = "") =>
    Result.new(floatValue = na, stringValue = "", boolValue = value, intValue = 0, isSuccess = true, errorCode = "", errorMessage = "", floatFallback = na, stringFallback = "", boolFallback = false, intFallback = 0, operationContext = context, timestamp = time, tags = array.new<string>())

// @function Create an error Result with fallback values
export newErrorResult(string errorCode, string errorMessage, float floatFallback = na, string stringFallback = "", bool boolFallback = false, string context = "") =>
    Result.new(floatValue = floatFallback, stringValue = stringFallback, boolValue = boolFallback, intValue = 0, isSuccess = false, errorCode = errorCode, errorMessage = errorMessage, floatFallback = floatFallback, stringFallback = stringFallback, boolFallback = boolFallback, intFallback = 0, operationContext = context, timestamp = time, tags = array.new<string>())

// @function Add a tag to Result
export addResultTag(Result result, string tag) =>
    if not array.includes(result.tags, tag)
        array.push(result.tags, tag)
    result

// ============================================================================
// TRADING-SPECIFIC RESULT FACTORIES - Common Use Cases
// ============================================================================

// @function Create a signal Result with trading-specific tags
export newSignalResult(float signalStrength, string signalType = "NEUTRAL") =>
    result = newFloatResult(signalStrength, "Signal Generation")
    addResultTag(result, "SIGNAL")
    addResultTag(result, signalType) // "LONG", "SHORT", "NEUTRAL"
    result

// @function Create an indicator calculation Result with indicator tag
export newIndicatorResult(float value, string indicatorName) =>
    result = newFloatResult(value, "Indicator: " + indicatorName)
    addResultTag(result, "INDICATOR")
    addResultTag(result, indicatorName) // "RSI", "MACD", "VWAP", etc.
    result

// @function Create a timeframe-specific Result
export newTimeframeResult(float value, string timeframe, string context = "") =>
    result = newFloatResult(value, context)
    addResultTag(result, "TIMEFRAME")
    addResultTag(result, timeframe) // "1m", "5m", "1h", "4h", "1D", etc.
    result

// @function Create a confluence Result with confidence level
export newConfluenceResult(float confluenceScore, string confidenceLevel = "MEDIUM") =>
    result = newFloatResult(confluenceScore, "Confluence Analysis")
    addResultTag(result, "CONFLUENCE")
    addResultTag(result, confidenceLevel) // "LOW", "MEDIUM", "HIGH"
    result

// ============================================================================
// VALIDATION TYPES - Input Validation & Data Integrity
// ============================================================================

// @type Comprehensive validation result with errors, warnings, and corrections
export type ValidationResult
    bool isValid
    string[] errors
    string[] warnings
    string[] corrections
    string[] suggestions
    float validationScore        // 0-100 validation quality score
    string validationMode        // "STRICT", "LENIENT", "AUTO_CORRECT"
    int validatedFields
    int totalFields
    string validationContext
    int validationTime

// @function Create a new validation result (starts as valid)
export newValidationResult(string context = "") =>
    ValidationResult.new(isValid = true, errors = array.new<string>(), warnings = array.new<string>(), corrections = array.new<string>(), suggestions = array.new<string>(), validationScore = 100.0, validationMode = "STRICT", validatedFields = 0, totalFields = 0, validationContext = context, validationTime = time)

// @function Create a successful validation result
export newValidationSuccess(string context = "") =>
    ValidationResult.new(isValid = true, errors = array.new<string>(), warnings = array.new<string>(), corrections = array.new<string>(), suggestions = array.new<string>(), validationScore = 100.0, validationMode = "STRICT", validatedFields = 0, totalFields = 0, validationContext = context, validationTime = time)

// @function Create a failed validation result with errors
export newValidationFailure(string[] errors, string context = "") =>
    ValidationResult.new(isValid = false, errors = errors, warnings = array.new<string>(), corrections = array.new<string>(), suggestions = array.new<string>(), validationScore = 0.0, validationMode = "STRICT", validatedFields = 0, totalFields = array.size(errors), validationContext = context, validationTime = time)

// @function Add an error to validation result
export addValidationError(ValidationResult result, string field, string error) =>
    array.push(result.errors, field + ": " + error)
    result.isValid := false
    result.validationScore := math.max(0, result.validationScore - 10)

// @function Add a warning to validation result
export addValidationWarning(ValidationResult result, string field, string warning) =>
    array.push(result.warnings, field + ": " + warning)
    result.validationScore := math.max(0, result.validationScore - 2)

// @function Add a correction to validation result
export addValidationCorrection(ValidationResult result, string correction) =>
    array.push(result.corrections, correction)

// @function Set validation mode
export setValidationMode(ValidationResult result, string mode) =>
    if mode == "STRICT" or mode == "LENIENT" or mode == "AUTO_CORRECT"
        result.validationMode := mode
    result

// @function Get validation mode
export getValidationMode(ValidationResult result) =>
    result.validationMode

// @function Increment validated fields counter
export incrementValidatedFields(ValidationResult result) =>
    result.validatedFields := result.validatedFields + 1
    result

// @function Set total fields for validation
export setValidationTotalFields(ValidationResult result, int total) =>
    result.totalFields := total
    result

// @function Calculate and update validation score based on errors/warnings
export calculateValidationScore(ValidationResult result) =>
    if result.totalFields == 0
        result.validationScore := result.isValid ? 100.0 : 0.0
    else
        errorPenalty = array.size(result.errors) * 20.0
        warningPenalty = array.size(result.warnings) * 5.0
        completionBonus = result.totalFields > 0 ? (result.validatedFields / result.totalFields * 50.0) : 50.0

        result.validationScore := math.max(0.0, math.min(100.0, 100.0 - errorPenalty - warningPenalty + completionBonus - 50.0))

    result

// ============================================================================
// PERFORMANCE PROFILING TYPES - Monitoring & Optimization
// ============================================================================

// @type Simplified performance profiling for Pine Script limitations
export type PerformanceProfile
    // Basic Execution Metrics (MACHBAR)
    float executionTimeMs
    float averageExecutionMs
    int executionCount
    int errorCount
    // Simple Caching (MACHBAR)
    int cacheHits
    int cacheMisses
    float cacheHitRatio
    // Estimated Memory Usage (ROUGH)
    int estimatedArrayElements
    // Simple Performance Analysis (BASIC)
    bool hasHeavyCalculation        // Simple flag instead of array
    string lastOptimizationHint     // Single hint instead of array
    string performanceGrade         // "A+", "A", "B", "C", "D", "F"
    float performanceScore          // 0-100
    // Context (MACHBAR)
    string functionName
    int profileStartTime

// @function Create a new performance profile
export newPerformanceProfile(string functionName) =>
    PerformanceProfile.new(executionTimeMs = 0.0, averageExecutionMs = 0.0, executionCount = 0, errorCount = 0, cacheHits = 0, cacheMisses = 0, cacheHitRatio = 0.0, estimatedArrayElements = 0, hasHeavyCalculation = false, lastOptimizationHint = "", performanceGrade = "A+", performanceScore = 100.0, functionName = functionName, profileStartTime = time)

// @function Update performance profile with execution data
updatePerformanceProfile(PerformanceProfile profile, float executionTime, bool hadError = false) =>
    profile.executionCount += 1
    profile.executionTimeMs := executionTime
    profile.averageExecutionMs := (profile.averageExecutionMs * (profile.executionCount - 1) + executionTime) / profile.executionCount
    if hadError
        profile.errorCount += 1

    // Detect heavy calculations (simple heuristic)
    if executionTime > 100
        profile.hasHeavyCalculation := true
        profile.lastOptimizationHint := "Execution time > 100ms - consider optimization"

    // Calculate performance score
    errorRate = profile.executionCount > 0 ? profile.errorCount / profile.executionCount * 100 : 0
    avgTimeScore = executionTime <= 10 ? 100 : executionTime <= 50 ? 80 : executionTime <= 100 ? 60 : 40
    cacheScore = profile.cacheHitRatio * 100
    profile.performanceScore := (avgTimeScore * 0.4 + cacheScore * 0.3 + (100 - errorRate) * 0.3)

    // Assign performance grade
    profile.performanceGrade := profile.performanceScore >= 95 ? "A+" : profile.performanceScore >= 85 ? "A" : profile.performanceScore >= 75 ? "B" : profile.performanceScore >= 65 ? "C" : profile.performanceScore >= 55 ? "D" : "F"

// @function Add cache hit to performance profile
recordCacheHit(PerformanceProfile profile) =>
    profile.cacheHits += 1
    profile.cacheHitRatio := profile.cacheHits / (profile.cacheHits + profile.cacheMisses)

// @function Add cache miss to performance profile
recordCacheMiss(PerformanceProfile profile) =>
    profile.cacheMisses += 1
    profile.cacheHitRatio := profile.cacheHits / (profile.cacheHits + profile.cacheMisses)

// @function Start timing a performance profile (simple)
export startTiming(PerformanceProfile profile) =>
    profile.profileStartTime := timenow
    profile

// @function End timing and update performance profile
export endTiming(PerformanceProfile profile, bool hadError = false) =>
    executionTime = timenow - profile.profileStartTime
    updatePerformanceProfile(profile, executionTime, hadError)

// @function Set estimated memory usage (array elements)
export updateMemoryEstimate(PerformanceProfile profile, int arrayElements) =>
    profile.estimatedArrayElements := arrayElements
    // Simple heuristic: >10000 elements = potential memory issue
    if arrayElements > 10000
        profile.lastOptimizationHint := "Large array detected (" + str.tostring(arrayElements) + " elements) - consider reduction"
    profile

// ============================================================================
// HEALTH CHECK TYPES - System Status & Diagnostics
// ============================================================================

// @type Simplified health status for Pine Script limitations
export type HealthStatus
    bool isHealthy
    float healthScore          // 0-100 overall health score
    string healthGrade         // "EXCELLENT", "GOOD", "WARNING", "CRITICAL"
    string[] issues            // Keep arrays - they work fine
    string[] warnings
    string[] recommendations
    // Simple Component Flags (instead of complex maps)
    bool dataValidationOK
    bool calculationsOK
    bool memoryUsageOK
    // Simple Error Tracking (manual)
    int errorCountSession      // Errors since indicator start
    int warningCountSession    // Warnings since indicator start
    // Timestamps (MACHBAR)
    int lastHealthCheck
    string healthCheckVersion

// @function Create a new healthy status
export newHealthyStatus() =>
    HealthStatus.new(isHealthy = true, healthScore = 100.0, healthGrade = "EXCELLENT", issues = array.new<string>(), warnings = array.new<string>(), recommendations = array.new<string>(), dataValidationOK = true, calculationsOK = true, memoryUsageOK = true, errorCountSession = 0, warningCountSession = 0, lastHealthCheck = time, healthCheckVersion = "1.0.0")

// @function Add a health issue
addHealthIssue(HealthStatus status, string issue, string severity = "WARNING") =>
    array.push(status.issues, issue)
    if severity == "CRITICAL"
        status.isHealthy := false
        status.healthScore := math.max(0, status.healthScore - 25)
        status.errorCountSession += 1
    else if severity == "WARNING"
        status.healthScore := math.max(0, status.healthScore - 10)
        status.warningCountSession += 1
    else
        status.healthScore := math.max(0, status.healthScore - 5)

    // Update health grade
    status.healthGrade := status.healthScore >= 90 ? "EXCELLENT" : status.healthScore >= 75 ? "GOOD" : status.healthScore >= 50 ? "WARNING" : "CRITICAL"

// @function Set component health status
export setComponentHealth(HealthStatus status, string component, bool isOK, string message = "") =>
    if component == "data_validation"
        status.dataValidationOK := isOK
    else if component == "calculations"
        status.calculationsOK := isOK
    else if component == "memory_usage"
        status.memoryUsageOK := isOK

    if not isOK and message != ""
        addHealthIssue(status, component + ": " + message, "WARNING")

    status

// @function Quick health check - are all components OK?
export isHealthyOverall(HealthStatus status) =>
    status.dataValidationOK and status.calculationsOK and status.memoryUsageOK and status.isHealthy

// @function Get simple health summary
export getHealthSummary(HealthStatus status) =>
    "Health: " + status.healthGrade + " (" + str.tostring(status.healthScore, "#") + ") " + "Errors: " + str.tostring(status.errorCountSession) + " Warnings: " + str.tostring(status.warningCountSession)

// ============================================================================
// UTILITY FUNCTIONS - Common Operations
// ============================================================================

// @function Check if Result contains a valid float value
export hasValidFloat(Result result) =>
    result.isSuccess and not na(result.floatValue)

// @function Check if Result contains a valid string value
export hasValidString(Result result) =>
    result.isSuccess and result.stringValue != ""

// @function Get float value from Result with fallback
export getFloat(Result result, float fallback = 0.0) =>
    if hasValidFloat(result)
        result.floatValue
    else
        na(result.floatFallback) ? fallback : result.floatFallback

// @function Get string value from Result with fallback
export getString(Result result, string fallback = "") =>
    if hasValidString(result)
        result.stringValue
    else
        result.stringFallback == "" ? fallback : result.stringFallback

// @function Get boolean value from Result with fallback
export getBool(Result result, bool fallback = false) =>
    if result.isSuccess
        result.boolValue
    else
        // Use Result's fallback if set, otherwise use parameter fallback
        fallback or result.boolFallback
// @function Check if Result has specific tag
export hasResultTag(Result result, string tag) =>
    array.includes(result.tags, tag)

// @function Get all tags from Result
export getResultTags(Result result) =>
    result.tags

// @function Set operation context for Result
export setResultContext(Result result, string context) =>
    result.operationContext := context
    result

// @function Create a formatted error message from Result
formatErrorMessage(Result result) =>
    if result.isSuccess
        "SUCCESS"
    else
        "[" + result.errorCode + "] " + result.errorMessage + (result.operationContext != "" ? " (Context: " + result.operationContext + ")" : "")

// @function Calculate validation completion percentage
getValidationCompleteness(ValidationResult validation) =>
    if validation.totalFields == 0
        100.0
    else
        validation.validatedFields / validation.totalFields * 100.0

// @function Check if performance profile indicates good performance
isPerformanceGood(PerformanceProfile profile) =>
    profile.performanceScore >= 75 and profile.performanceGrade != "F"

// @function Get performance summary string
getPerformanceSummary(PerformanceProfile profile) =>
    "Grade: " + profile.performanceGrade + " | Score: " + str.tostring(profile.performanceScore, "#.0") + " | Avg Time: " + str.tostring(profile.averageExecutionMs, "#.0") + "ms" + " | Cache Hit: " + str.tostring(profile.cacheHitRatio * 100, "#.0") + "%"

// @function Filter Results by tag (utility for arrays of Results)
export filterResultsByTag(Result[] results, string tag) =>
    filteredResults = array.new<Result>()
    for i = 0 to array.size(results) - 1
        result = array.get(results, i)
        if hasResultTag(result, tag)
            array.push(filteredResults, result)
    filteredResults

// @function Get all unique tags from array of Results
export getAllResultTags(Result[] results) =>
    allTags = array.new<string>()
    for i = 0 to array.size(results) - 1
        result = array.get(results, i)
        resultTags = getResultTags(result)
        for j = 0 to array.size(resultTags) - 1
            tag = array.get(resultTags, j)
            if not array.includes(allTags, tag)
                array.push(allTags, tag)
    allTags


