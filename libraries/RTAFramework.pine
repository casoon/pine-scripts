// Configuration Module - Analysis and timeframe configuration for RedefiningTechnicalAnalysis Core Library

// ============================================================================
// ANALYSIS CONFIGURATION - Core Analysis Settings
// ============================================================================

// @type Comprehensive analysis configuration with factor weights, thresholds, and extensible options
export type AnalysisConfig
    // Core Factor Configuration
    string[] activeFactors          // ["flow", "momentum", "trend", "volatility", "structure", "divergence"]
    map<string, float> factorWeights  // Individual factor weights (must sum to 1.0)
    map<string, float> thresholds     // Signal generation thresholds per factor
    map<string, bool> features        // Feature toggles (enable/disable specific features)
    // Trading Mode & Strategy
    string tradingMode               // "INTRADAY", "SWING", "TREND", "SCALP"
    string consensusMode             // "STRICT", "MAJORITY", "FLEXIBLE", "WEIGHTED"
    string riskProfile              // "CONSERVATIVE", "MODERATE", "AGGRESSIVE"
    // Signal Configuration
    float minConfidence             // Minimum confidence threshold (0-100)
    float signalStrength            // Required signal strength (0-100)
    bool requireConsensus           // Require multi-timeframe consensus
    int minConsensusCount          // Minimum timeframes that must agree
    // Extensible Parameters
    map<string, float> parameters   // Custom numeric parameters
    map<string, string> options     // Custom string options
    map<string, bool> flags         // Custom boolean flags
    // Metadata
    string configName              // Configuration preset name
    string version                 // Configuration version
    string description             // Configuration description
    int createdTime               // Creation timestamp
    int lastModified              // Last modification timestamp
    ValidationResult validation    // Configuration validation status

// @function Create default analysis configuration
export newDefaultAnalysisConfig() =>
    // Default factor weights (balanced approach)
    defaultWeights = map.new<string, float>()
    map.put(defaultWeights, "flow", 0.20)
    map.put(defaultWeights, "momentum", 0.18)
    map.put(defaultWeights, "trend", 0.22)
    map.put(defaultWeights, "volatility", 0.15)
    map.put(defaultWeights, "structure", 0.15)
    map.put(defaultWeights, "divergence", 0.10)

    // Default thresholds
    defaultThresholds = map.new<string, float>()
    map.put(defaultThresholds, "buy_threshold", 70.0)
    map.put(defaultThresholds, "sell_threshold", -70.0)
    map.put(defaultThresholds, "neutral_range", 30.0)
    map.put(defaultThresholds, "strong_signal", 85.0)

    // Default features
    defaultFeatures = map.new<string, bool>()
    map.put(defaultFeatures, "enable_divergence", true)
    map.put(defaultFeatures, "enable_reversal_zones", true)
    map.put(defaultFeatures, "enable_gradient_analysis", true)
    map.put(defaultFeatures, "enable_volume_confirmation", true)

    defaultFactors = array.from<string>("flow", "momentum", "trend", "volatility", "structure", "divergence")
    defaultParams = map.new<string, float>()
    defaultOptions = map.new<string, string>()
    defaultFlags = map.new<string, bool>()
    validation = newValidationSuccess("default_config")

    AnalysisConfig.new(defaultFactors, defaultWeights, defaultThresholds, defaultFeatures, "SWING", "MAJORITY", "MODERATE", 60.0, 70.0, true, 2, defaultParams, defaultOptions, defaultFlags, "Default Balanced", "1.0.0", "Balanced analysis configuration for swing trading", time, time, validation)

// @function Create aggressive trading configuration
export newAggressiveAnalysisConfig() =>
    config = newDefaultAnalysisConfig()
    // Adjust for aggressive trading
    map.put(config.factorWeights, "momentum", 0.25)
    map.put(config.factorWeights, "flow", 0.25)
    map.put(config.factorWeights, "trend", 0.20)
    map.put(config.factorWeights, "divergence", 0.15)
    map.put(config.factorWeights, "volatility", 0.10)
    map.put(config.factorWeights, "structure", 0.05)

    map.put(config.thresholds, "buy_threshold", 60.0)
    map.put(config.thresholds, "sell_threshold", -60.0)
    map.put(config.thresholds, "strong_signal", 80.0)

    config.riskProfile := "AGGRESSIVE"
    config.minConfidence := 50.0
    config.signalStrength := 60.0
    config.minConsensusCount := 1
    config.configName := "Aggressive Momentum"
    config.description := "High-frequency aggressive trading configuration"
    config

// @function Create conservative trading configuration
export newConservativeAnalysisConfig() =>
    config = newDefaultAnalysisConfig()
    // Adjust for conservative trading
    map.put(config.factorWeights, "trend", 0.30)
    map.put(config.factorWeights, "structure", 0.25)
    map.put(config.factorWeights, "flow", 0.20)
    map.put(config.factorWeights, "volatility", 0.15)
    map.put(config.factorWeights, "momentum", 0.08)
    map.put(config.factorWeights, "divergence", 0.02)

    map.put(config.thresholds, "buy_threshold", 80.0)
    map.put(config.thresholds, "sell_threshold", -80.0)
    map.put(config.thresholds, "strong_signal", 90.0)

    config.riskProfile := "CONSERVATIVE"
    config.minConfidence := 80.0
    config.signalStrength := 85.0
    config.minConsensusCount := 3
    config.configName := "Conservative Trend"
    config.description := "Low-risk conservative trading configuration"
    config

// ============================================================================
// TIMEFRAME CONFIGURATION - Multi-Timeframe Analysis Settings
// ============================================================================

// @type Multi-timeframe configuration with weights and adjustments
export type TimeframeConfig
    // Timeframe Selection
    string[] timeframes             // ["15", "60", "240", "D"] - timeframes to analyze
    float[] weights                // [0.15, 0.25, 0.35, 0.25] - relative weights
    bool autoDetectChartTF         // Automatically include chart timeframe
    bool includeHigherTFs          // Include higher timeframes automatically
    // Timeframe-Specific Adjustments
    map<string, float> tfAdjustments  // TF-specific score adjustments
    map<string, float> tfSensitivity  // TF-specific sensitivity multipliers
    map<string, bool> tfFeatures      // TF-specific feature toggles
    // Consensus Requirements
    int minTimeframes              // Minimum number of TFs for valid analysis
    float consensusThreshold       // Required agreement percentage (0-1)
    string consensusMethod         // "SIMPLE", "WEIGHTED", "DYNAMIC"
    // Advanced Settings
    bool normalizeWeights          // Auto-normalize weights to sum=1.0
    bool adaptiveBias             // Adapt bias based on market conditions
    float higherTFBias            // Bias towards higher timeframes (0-2)
    // Metadata
    string tfConfigName           // Timeframe configuration name
    int configTimestamp           // Configuration creation time
    ValidationResult validation   // Timeframe validation status

// @function Create default timeframe configuration
export newDefaultTimeframeConfig() =>
    defaultTFs = array.from<string>("15", "60", "240", "D")
    defaultWeights = array.from<float>(0.15, 0.25, 0.35, 0.25)

    // Default adjustments
    tfAdjustments = map.new<string, float>()
    map.put(tfAdjustments, "15", 0.95)   // Slightly reduce weight of lower TF
    map.put(tfAdjustments, "60", 1.00)   // Neutral
    map.put(tfAdjustments, "240", 1.05)  // Slight bias towards 4H
    map.put(tfAdjustments, "D", 1.10)    // Higher bias for daily

    tfSensitivity = map.new<string, float>()
    tfFeatures = map.new<string, bool>()
    tfValidation = newValidationSuccess("timeframe_config")

    TimeframeConfig.new(defaultTFs, defaultWeights, true, false, tfAdjustments, tfSensitivity, tfFeatures, 3, 0.6, "WEIGHTED", true, true, 1.2, "Default Multi-TF", time, tfValidation)

// @function Create intraday timeframe configuration
export newIntradayTimeframeConfig() =>
    intradayTFs = array.from<string>("1", "5", "15", "60")
    intradayWeights = array.from<float>(0.20, 0.30, 0.30, 0.20)

    config = newDefaultTimeframeConfig()
    config.timeframes := intradayTFs
    config.weights := intradayWeights
    config.minTimeframes := 3
    config.higherTFBias := 1.1
    config.tfConfigName := "Intraday Focus"
    config

// @function Create swing trading timeframe configuration
export newSwingTimeframeConfig() =>
    swingTFs = array.from<string>("60", "240", "D", "3D")
    swingWeights = array.from<float>(0.15, 0.30, 0.35, 0.20)

    config = newDefaultTimeframeConfig()
    config.timeframes := swingTFs
    config.weights := swingWeights
    config.minTimeframes := 2
    config.higherTFBias := 1.3
    config.tfConfigName := "Swing Trading"
    config

// ============================================================================
// CONFIGURATION UTILITIES
// ============================================================================

// @function Get configuration summary string
export getConfigSummary(AnalysisConfig config) =>
    "Mode: " + config.tradingMode + " | Risk: " + config.riskProfile + " | Consensus: " + config.consensusMode + " | MinConf: " + str.tostring(config.minConfidence) + " | Factors: " + str.tostring(array.size(config.activeFactors))

// @function Clone analysis configuration
export cloneAnalysisConfig(AnalysisConfig source) =>
    // Create deep copy of configuration
    newConfig = newDefaultAnalysisConfig()
    newConfig.activeFactors := array.copy(source.activeFactors)
    newConfig.factorWeights := map.copy(source.factorWeights)
    newConfig.thresholds := map.copy(source.thresholds)
    newConfig.features := map.copy(source.features)
    newConfig.tradingMode := source.tradingMode
    newConfig.consensusMode := source.consensusMode
    newConfig.riskProfile := source.riskProfile
    newConfig.minConfidence := source.minConfidence
    newConfig.signalStrength := source.signalStrength
    newConfig.requireConsensus := source.requireConsensus
    newConfig.minConsensusCount := source.minConsensusCount
    newConfig.parameters := map.copy(source.parameters)
    newConfig.options := map.copy(source.options)
    newConfig.flags := map.copy(source.flags)
    newConfig.configName := source.configName + " (Copy)"
    newConfig.version := source.version
    newConfig.description := source.description
    newConfig.lastModified := time
    newConfig


