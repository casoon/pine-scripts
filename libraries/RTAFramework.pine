// Create aggressive strategy template
export getAggressiveStrategy() =>
    StrategyTemplate.new("Aggressive Momentum", "High-frequency momentum strategy", "AGGRESSIVE", array.from<string>("15m", "5m", "1m"), 60.0, 60.0, array.from<string>("MOMENTUM", "VOLUME"), array.from<string>("EXTREME_RISK"), -40.0, 3.0, 6.0, 20, 5.0, 2.0, true, false, 3.0, 10.0, 20.0, false, false, 60.0, false, true, 1.0, 55.0, 2.0, map.new<string, float>(), map.new<string, bool>(), map.new<string, string>())

// Create default balanced strategy template
export newDefaultStrategy() =>
    StrategyTemplate.new("Default Balanced", "Balanced strategy for general trading", "BALANCED", array.from<string>("4H", "1H", "15m"), 70.0, 70.0, array.from<string>("CONSENSUS", "MODERATE_RISK"), array.from<string>("EXTREME_VOLATILITY"), -30.0, 2.0, 4.0, 40, 3.0, 1.5, true, true, 2.0, 5.0, 15.0, true, true, 70.0, true, true, 1.5, 60.0, 2.0, map.new<string, float>(), map.new<string, bool>(), map.new<string, string>())
// ADVANCED POSITION SIZING (from CPM Strategy v2)
// Calculate volatility-adjusted position size
calculateVolatilityPositionSize(float baseRiskPercent, float atrPercent, float confidenceScore, string signalStrength, float minSize = 0.5, float maxSize = 20.0) =>
    float baseSize = baseRiskPercent

    // Volatility adjustment (higher volatility = smaller position)
    float volAdjustment = math.max(0.5, math.min(2.0, 2.0 / atrPercent))
    baseSize := baseSize * volAdjustment

    // Signal strength adjustment
    float strengthMultiplier = switch signalStrength
        "Strong" => 1.3
        "Moderate" => 0.8
        "Weak" => 0.5
        => 1.0

    baseSize := baseSize * strengthMultiplier

    // Confidence adjustment (higher confidence = larger position)
    float confidenceMultiplier = confidenceScore / 100.0
    baseSize := baseSize * math.max(0.5, confidenceMultiplier)

    // Apply limits
    math.max(minSize, math.min(maxSize, baseSize))

// Calculate ATR-based stop loss and take profit levels
calculateATRLevels(float entryPrice, float atr, float stopATRMultiplier, float tp1ATRMultiplier, float tp2ATRMultiplier, bool isLong) =>
    if isLong
        stopLoss = entryPrice - atr * stopATRMultiplier
        takeProfit1 = entryPrice + atr * tp1ATRMultiplier
        takeProfit2 = entryPrice + atr * tp2ATRMultiplier
        [stopLoss, takeProfit1, takeProfit2]
    else
        stopLoss = entryPrice + atr * stopATRMultiplier
        takeProfit1 = entryPrice - atr * tp1ATRMultiplier
        takeProfit2 = entryPrice - atr * tp2ATRMultiplier
        [stopLoss, takeProfit1, takeProfit2]

// Calculate trailing stop distance
calculateTrailingDistance(float atr, float trailATRMultiplier, float minTrailPercent = 0.5, float maxTrailPercent = 5.0) =>
    float trailDistance = atr * trailATRMultiplier
    float trailPercent = trailDistance / close * 100
    math.max(minTrailPercent, math.min(maxTrailPercent, trailPercent))

// Assess trade quality for position sizing
assessTradeQuality(float score, float confidence, int timeframeAlignment, bool volumeConfirmation, bool hasDivergence) =>
    float qualityScore = 0.0

    // Score contribution (40%)
    qualityScore += (math.abs(score) / 10.0) * 40.0

    // Confidence contribution (25%)
    qualityScore += (confidence / 100.0) * 25.0

    // Timeframe alignment (20%)
    qualityScore += (math.min(1.0, timeframeAlignment / 3.0)) * 20.0

    // Volume confirmation (10%)
    qualityScore += volumeConfirmation ? 10.0 : 0.0

    // Divergence bonus (5%)
    qualityScore += hasDivergence ? 5.0 : 0.0

    // Return quality tier and multiplier
    string qualityTier = qualityScore >= 85 ? "Excellent" : qualityScore >= 70 ? "Good" : qualityScore >= 55 ? "Fair" : "Poor"
    float qualityMultiplier = qualityScore >= 85 ? 1.2 : qualityScore >= 70 ? 1.0 : qualityScore >= 55 ? 0.8 : 0.5

    [qualityTier, qualityMultiplier, qualityScore]

// Create balanced strategy template
getBalancedStrategy() =>
    StrategyTemplate.new("Balanced Multi-TF", "Balanced approach with moderate risk", "BALANCED", array.from<string>("4H", "1H", "15m"), 65.0, 70.0, array.from<string>("CONSENSUS", "MOMENTUM"), array.from<string>("EXTREME_RISK", "CONFLICTED_SIGNALS"), -30.0, 2.0, 4.0, 30, 3.0, 1.5, true, true, 2.0, 6.0, 15.0, true, true, 70.0, false, true, 1.2, 60.0, 2.0, map.new<string, float>(), map.new<string, bool>(), map.new<string, string>())
// STRATEGY UTILITIES - Strategy Application Functions
// Check if signal meets strategy entry requirements
shouldEnter(SignalResult signal, StrategyTemplate strategy, RiskAssessment risk) =>
    // Basic threshold checks
    meetsThreshold = signal.overallScore >= strategy.entryThreshold
    meetsConfidence = signal.confidence >= strategy.entryConfidenceMin

    // Risk checks
    riskAcceptable = not risk.shouldAvoidTrade and risk.riskScore <= 100 - strategy.entryConfidenceMin

    // Consensus check if required
    consensusOk = not strategy.requireConsensus or (signal.hasConsensus and signal.consensus.agreementPercentage >= strategy.minConsensusPercent)

    meetsThreshold and meetsConfidence and riskAcceptable and consensusOk

// Calculate position size based on strategy
calculatePositionSize(StrategyTemplate strategy, RiskAssessment risk, float volatility) =>
    baseSize = strategy.basePositionSize

    // Volatility adjustment
    if strategy.useVolatilityAdjustment
        volMultiplier = volatility > 0.05 ? 0.7 : volatility > 0.03 ? 0.85 : 1.0
        baseSize := baseSize * volMultiplier

    // Risk adjustment
    riskMultiplier = risk.riskScore > 70 ? 0.5 : risk.riskScore > 50 ? 0.75 : risk.riskScore > 30 ? 1.0 : 1.2

    finalSize = baseSize * riskMultiplier

    // Cap at maximum position size
    math.min(finalSize, strategy.maxPositionSize)

// Check if position should be exited based on strategy
shouldExit(SignalResult signal, StrategyTemplate strategy, PositionData position) =>
    // Signal-based exit
    signalExit = signal.overallScore <= strategy.exitThreshold

    // Time-based exit
    timeExit = position.barsInPosition >= strategy.maxBarsInTrade

    // Risk-based exit (stop loss/take profit handled in updatePosition)
    riskExit = position.shouldExit

    signalExit or timeExit or riskExit

// Get strategy summary string
getStrategySummary(StrategyTemplate strategy) =>
    strategy.name + " (" + strategy.category + ") - " + "Entry: " + str.tostring(strategy.entryThreshold, "#.0") + "% " + "Risk: " + str.tostring(strategy.maxRiskPerTrade, "#.0") + "% " + "R:R " + str.tostring(strategy.targetRiskReward, "#.0")

// Validate strategy configuration
validateStrategy(StrategyTemplate strategy) =>
    result = newValidationResult()

    // Basic validations
    if strategy.entryThreshold < 0 or strategy.entryThreshold > 100
        addValidationError(result, "entry_threshold", "Entry threshold must be 0-100")

    if strategy.stopLossPercent <= 0 or strategy.stopLossPercent > 20
        addValidationError(result, "stop_loss", "Stop loss must be 0-20%")

    if strategy.takeProfitPercent <= strategy.stopLossPercent
        addValidationError(result, "take_profit", "Take profit must be > stop loss")

    if strategy.maxPositionSize <= 0 or strategy.maxPositionSize > 10
        addValidationError(result, "max_position", "Max position size must be 0-10%")

    result
// MARKET REGIME DETECTION FUNCTIONS
// Detect market regime (trending vs ranging, volatility)
export detectMarketRegime(
         float close,
         float ema20,
         float ema50,
         float ema100,
         float atr14,
         int dmiLength = 14) =>

    // Calculate DMI/ADX
    [diPlus, diMinus, adxVal] = ta.dmi(dmiLength, dmiLength)

    // Trend Classification
    isTrending = adxVal > 25
    isRanging = adxVal < 20
    isTransitioning = not isTrending and not isRanging

    // Trend Direction
    isUptrend = close > ema20 and ema20 > ema50 and ema50 > ema100
    isDowntrend = close < ema20 and ema20 < ema50 and ema50 < ema100
    isNoTrend = not isUptrend and not isDowntrend

    // Volatility Regime
    atrSma = ta.sma(atr14, 50)
    atrRatio = atrSma > 0 ? atr14 / atrSma : 1.0
    isHighVol = atrRatio > 1.2
    isLowVol = atrRatio < 0.8
    isNormalVol = not isHighVol and not isLowVol

    // Market Regime String
    marketRegime = isTrending ? (isUptrend ? "Strong Uptrend" : isDowntrend ? "Strong Downtrend" : "Trending") : isRanging ? "Ranging" : "Transitioning"

    volRegime = isHighVol ? "High Vol" : isLowVol ? "Low Vol" : "Normal Vol"

    MarketRegime.new(isTrending, isRanging, isTransitioning, isUptrend, isDowntrend, isNoTrend, isHighVol, isLowVol, isNormalVol, atrRatio, adxVal, diPlus, diMinus, marketRegime, volRegime, time)

// Calculate stop-loss and take-profit levels
export calculateStopLossLevels(
         float close,
         float atr14,
         float lastSupport = na,
         float lastResistance = na,
         bool useATRStops = true,
         float atrMultiplier = 2.0,
         float riskRewardRatio = 2.0,
         bool strongBuySignal = false,
         bool strongSellSignal = false) =>

    // Stop Loss Levels (ATR-based or Key Level based)
    stopLossBuy = float(na)
    stopLossSell = float(na)

    if useATRStops
        // ATR-based stops
        stopLossBuy := close - (atr14 * atrMultiplier)
        stopLossSell := close + (atr14 * atrMultiplier)
    else
        // Key level based stops (use lastSupport/lastResistance)
        stopLossBuy := not na(lastSupport) ? lastSupport : close - (atr14 * atrMultiplier)
        stopLossSell := not na(lastResistance) ? lastResistance : close + (atr14 * atrMultiplier)

    // Calculate Risk Amount (in price points)
    riskAmountBuy = close - stopLossBuy
    riskAmountSell = stopLossSell - close

    // Calculate Profit Targets (based on R:R ratio)
    profitTargetBuy = close + (riskAmountBuy * riskRewardRatio)
    profitTargetSell = close - (riskAmountSell * riskRewardRatio)

    // Entry Zone Calculation (optimal entry zones based on pullbacks)
    entryZoneBuyLow = float(na)
    entryZoneBuyHigh = float(na)
    entryZoneSellLow = float(na)
    entryZoneSellHigh = float(na)

    if strongBuySignal
        // For buys: Entry between current price and 0.236 Fibonacci retracement
        recentHigh = ta.highest(high, 20)
        recentLow = ta.lowest(low, 20)
        rangeVal = recentHigh - recentLow
        entryZoneBuyHigh := close
        entryZoneBuyLow := close - (rangeVal * 0.236)

    if strongSellSignal
        // For sells: Entry between current price and 0.236 Fibonacci retracement
        recentHigh = ta.highest(high, 20)
        recentLow = ta.lowest(low, 20)
        rangeVal = recentHigh - recentLow
        entryZoneSellLow := close
        entryZoneSellHigh := close + (rangeVal * 0.236)

    StopLossLevels.new(stopLossBuy, stopLossSell, profitTargetBuy, profitTargetSell, riskAmountBuy, riskAmountSell, entryZoneBuyLow, entryZoneBuyHigh, entryZoneSellLow, entryZoneSellHigh, atr14, atrMultiplier, riskRewardRatio, useATRStops, time)

// Calculate regime-aware position sizing
export calculateRegimePositionSizing(
         MarketRegime regime,
         float overallScore,
         float accountRiskPct = 2.0,
         float maxPositionSize = 10.0,
         float minPositionSize = 0.5) =>

    // Base position size (1.0 = 100% of normal position)
    positionSizeMultiplier = 1.0

    // Volatility Adjustment
    volatilityAdj = 0.0
    if regime.isHighVol
        positionSizeMultiplier := positionSizeMultiplier * 0.5  // Reduce size in high volatility
        volatilityAdj := -0.5
    else if regime.isLowVol
        positionSizeMultiplier := positionSizeMultiplier * 1.5  // Can increase size in low volatility
        volatilityAdj := 0.5
    else
        volatilityAdj := 0.0

    // Market Regime Adjustment
    regimeAdj = 0.0
    if regime.isRanging
        positionSizeMultiplier := positionSizeMultiplier * 0.75  // Reduce size in ranging markets
        regimeAdj := -0.25

    // Score Strength Adjustment
    scoreMultiplier = math.abs(overallScore) / 10.0  // 0-2x based on score
    scoreAdj = math.min(scoreMultiplier, 1.5)
    positionSizeMultiplier := positionSizeMultiplier * scoreAdj

    // Clamp to min/max
    positionSizeMultiplier := math.max(minPositionSize, math.min(maxPositionSize, positionSizeMultiplier))

    // Calculate adjusted position size percentage
    basePositionSize = accountRiskPct
    adjustedPositionSize = basePositionSize * positionSizeMultiplier

    // Sizing Reason
    sizingReason = "Vol:" + str.tostring(volatilityAdj, "#.0") + " Regime:" + str.tostring(regimeAdj, "#.0") + " Score:" + str.tostring(scoreAdj, "#.0")

    PositionSizing.new(positionSizeMultiplier, basePositionSize, adjustedPositionSize, volatilityAdj, scoreAdj, regimeAdj, accountRiskPct, maxPositionSize, minPositionSize, sizingReason, time)

// Assess risk quality of current setup
export assessRiskQuality(
         MarketRegime regime,
         float overallScore,
         float riskAmountBuy,
         float close,
         float thresholdStrong = 7.0) =>

    // Initialize quality score
    riskQuality = 0.0
    positiveFactors = array.new<string>()
    negativeFactors = array.new<string>()

    // Factor 1: Trending Market (favorable)
    trendingFavorable = regime.isTrending
    if trendingFavorable
        riskQuality := riskQuality + 25.0
        array.push(positiveFactors, "Trending Market")
    else
        array.push(negativeFactors, "Non-Trending Market")

    // Factor 2: Normal Volatility (favorable)
    volatilityFavorable = regime.isNormalVol
    if volatilityFavorable
        riskQuality := riskQuality + 25.0
        array.push(positiveFactors, "Normal Volatility")
    else if regime.isHighVol
        array.push(negativeFactors, "High Volatility")
    else
        array.push(negativeFactors, "Low Volatility")

    // Factor 3: Strong Signal Score (favorable)
    scoreStrengthFavorable = math.abs(overallScore) >= thresholdStrong
    if scoreStrengthFavorable
        riskQuality := riskQuality + 25.0
        array.push(positiveFactors, "Strong Signal")
    else
        array.push(negativeFactors, "Weak Signal")

    // Factor 4: Risk Amount < 2% of price (favorable)
    riskAmountFavorable = close > 0 ? (riskAmountBuy / close) < 0.02 : false
    if riskAmountFavorable
        riskQuality := riskQuality + 25.0
        array.push(positiveFactors, "Low Risk Amount")
    else
        array.push(negativeFactors, "High Risk Amount")

    // Clamp to 0-100
    riskQuality := math.min(riskQuality, 100.0)

    // Quality Grade
    riskQualityGrade = riskQuality >= 75 ? "EXCELLENT" : riskQuality >= 50 ? "GOOD" : riskQuality >= 25 ? "FAIR" : "POOR"

    // Quality Color
    riskQualityColor = riskQuality >= 75 ? color.new(#00C853, 0) : riskQuality >= 50 ? color.new(#FFA726, 0) : color.new(#F44336, 0)

    RiskQuality.new(riskQuality, riskQualityGrade, riskQualityColor, trendingFavorable, volatilityFavorable, scoreStrengthFavorable, riskAmountFavorable, positiveFactors, negativeFactors, time)
// RISK UTILITIES
// Get risk summary string
export getRiskSummary(MarketRegime regime) =>
    regime.marketRegime + " | " + regime.volRegime + " | ADX:" + str.tostring(regime.adxValue, "#.0")

// Format position sizing for display
export formatPositionSizing(PositionSizing sizing) =>
    str.tostring(sizing.adjustedPositionSize, "#.00") + "% (" + str.tostring(sizing.positionSizeMultiplier, "#.00") + "x base)"


// ============================================================================
// MODULE: TECHNICAL_INDICATORS
// ============================================================================


// TECHNICAL INDICATORS - Centralized Standard Calculations

// Consolidates commonly used technical indicators to eliminate duplication
// across modules and ensure consistent parameters and caching.
//
// Eliminates ~30+ redundant calculations across rta-core modules:
// - ATR(14): Used in 6+ modules separately
// - Volume SMA(20): Used in 4+ modules
// - Standard EMAs: EMA(21), EMA(50), EMA(200)
// - RSI(14), MACD standard parameters
// === CACHED TECHNICAL INDICATORS ===
// Note: Caching is now handled internally within each function using local 'var' declarations.
// This approach avoids issues with modifying module-level variables from within functions.
// ATR FUNCTIONS - Eliminates 12+ separate ta.atr(14) calls
// Get standard ATR(14) - cached per bar
export getStandardATR() =>
    var float localATR = na
    var int localBarIndex = na
    if bar_index != localBarIndex
        localATR := ta.atr(14)
        localBarIndex := bar_index
    localATR

// Get custom ATR with specified length
export getATR(int length) =>
    ta.atr(length)

// Get ATR-based tolerance for distance calculations
export getATRTolerance(float multiplier = 1.0) =>
    getStandardATR() * multiplier
// VOLUME FUNCTIONS - Eliminates 6+ separate volume average calls
// Get standard volume average SMA(20) - cached per bar
export getStandardVolumeAverage() =>
    var float localVolAvg = na
    var int localVolumeBarIndex = na
    if bar_index != localVolumeBarIndex
        localVolAvg := ta.sma(volume, 20)
        localVolumeBarIndex := bar_index
    localVolAvg

// Get custom volume average
export getVolumeAverage(int length) =>
    ta.sma(volume, length)

// Get volume ratio (current vs average)
export getVolumeRatio() =>
    avgVol = getStandardVolumeAverage()
    avgVol > 0 ? volume / avgVol : 1.0

// Get volume confirmation (above threshold)
export getVolumeConfirmation(float threshold = 1.2) =>
    getVolumeRatio() >= threshold
// EMA FUNCTIONS - Eliminates 12+ separate EMA calculations
// Get standard EMAs (21, 50, 200) - cached per bar
export getStandardEMAs() =>
    var float localEMA21 = na
    var float localEMA50 = na
    var float localEMA200 = na
    var int localEMABarIndex = na
    if bar_index != localEMABarIndex
        localEMA21 := ta.ema(close, 21)
        localEMA50 := ta.ema(close, 50)
        localEMA200 := ta.ema(close, 200)
        localEMABarIndex := bar_index
    [localEMA21, localEMA50, localEMA200]

// Get individual standard EMAs
export getEMA21() =>
    [ema21, ema50, ema200] = getStandardEMAs()
    ema21

export getEMA50() =>
    [ema21, ema50, ema200] = getStandardEMAs()
    ema50

export getEMA200() =>
    [ema21, ema50, ema200] = getStandardEMAs()
    ema200

// Get EMA trend alignment score
export getEMATrendAlignment() =>
    [ema21, ema50, ema200] = getStandardEMAs()

    // Perfect bullish alignment
    if close > ema21 and ema21 > ema50 and ema50 > ema200
        100.0
    // Perfect bearish alignment
    else if close < ema21 and ema21 < ema50 and ema50 < ema200
        -100.0
    else
        // Partial alignment scoring
        bullishAlignments = (close > ema21 ? 1 : 0) + (ema21 > ema50 ? 1 : 0) + (ema50 > ema200 ? 1 : 0)
        (bullishAlignments - 1.5) * 66.67
// RSI FUNCTIONS - Eliminates multiple RSI(14) calculations
// Get standard RSI(14) - cached per bar
export getStandardRSI() =>
    var float localRSI = na
    var int localRSIBarIndex = na
    if bar_index != localRSIBarIndex
        localRSI := ta.rsi(close, 14)
        localRSIBarIndex := bar_index
    localRSI

// Get RSI with overbought/oversold levels
export getRSILevels(float overbought = 70.0, float oversold = 30.0) =>
    rsi = getStandardRSI()
    [rsi, rsi >= overbought, rsi <= oversold]
// MACD FUNCTIONS - Eliminates multiple MACD calculations
// Get standard MACD (12, 26, 9) - cached per bar
export getStandardMACD() =>
    var float localMACD = na
    var float localSignal = na
    var float localHist = na
    var int localMACDBarIndex = na
    if bar_index != localMACDBarIndex
        [macd, signal, hist] = ta.macd(close, 12, 26, 9)
        localMACD := macd
        localSignal := signal
        localHist := hist
        localMACDBarIndex := bar_index
    [localMACD, localSignal, localHist]

// Get MACD trend signal
export getMACDSignal() =>
    [macd, signal, hist] = getStandardMACD()
    [macd > signal, macd > 0, ta.crossover(macd, signal), ta.crossunder(macd, signal)]
// DISTANCE/PROXIMITY FUNCTIONS - Eliminates 10+ distance implementations
// Calculate ATR-normalized distance between values
export atrDistance(float value, float reference, int atrLength = 14) =>
    atrVal = atrLength == 14 ? getStandardATR() : ta.atr(atrLength)
    atrVal > 0 ? math.abs(value - reference) / atrVal : 0.0

// Note: percentDistance, proximityScore, and withinPercentTolerance moved to math_utilities.pine to avoid duplicates

// Check if value is within ATR-based tolerance of reference
export withinATRTolerance(float value, float reference, float multiplier = 1.0) =>
    tolerance = getATRTolerance(multiplier)
    math.abs(value - reference) <= tolerance
// MOMENTUM COMPOSITE FUNCTIONS - Combines multiple indicators
// Get comprehensive momentum score
export getMomentumScore() =>
    rsi = getStandardRSI()
    [macd, signal, hist] = getStandardMACD()
    [ema21, ema50, ema200] = getStandardEMAs()

    // RSI component (30% weight)
    rsiScore = (rsi - 50) / 50 * 30

    // MACD component (25% weight)
    macdScore = 0.0
    if macd > signal and macd > 0
        macdScore := 25.0
    else if macd < signal and macd < 0
        macdScore := -25.0
    else if macd > signal
        macdScore := 12.5
    else
        macdScore := -12.5

    // EMA trend component (25% weight)
    trendScore = getEMATrendAlignment() * 0.25

    // Price momentum component (20% weight)
    priceChange = (close - close[3]) / close[3] * 100
    priceMomentum = math.max(-20, math.min(20, priceChange * 5))

    totalScore = rsiScore + macdScore + trendScore + priceMomentum
    math.max(-100, math.min(100, totalScore))

// Get trend strength (0-100)
export getTrendStrength() =>
    [ema21, ema50, ema200] = getStandardEMAs()
    atr = getStandardATR()

    // EMA separation as measure of trend strength
    if atr > 0
        separation21_50 = math.abs(ema21 - ema50) / atr
        separation50_200 = math.abs(ema50 - ema200) / atr
        avgSeparation = (separation21_50 + separation50_200) / 2
        math.min(100, avgSeparation * 20)
    else
        0.0
// PERFORMANCE MONITORING
// Note: Cache validation and refresh functions removed since caching is now
// handled internally by each function using local variables. Each function
// automatically manages its own cache based on bar_index.

// Get indicator calculation summary (for debugging)
export getIndicatorSummary() =>
    atr = getStandardATR()
    volAvg = getStandardVolumeAverage()
    [ema21, ema50, ema200] = getStandardEMAs()
    rsi = getStandardRSI()
    [macd, signal, hist] = getStandardMACD()

    "ATR: " + str.tostring(atr, "#.##") + " | Vol: " + str.tostring(volAvg, "#.##") + " | RSI: " + str.tostring(rsi, "#.##") + " | MACD: " + str.tostring(macd, "#.##")

// ============================================================================
// KERNEL SMOOTHING - Nadaraya-Watson Estimator
// ============================================================================
// Advanced non-parametric regression using Gaussian kernel
// Extracted from: kernel-flow indicator
//
// Purpose:
//   - Smooth price data with adaptive bandwidth
//   - Generate dynamic envelopes based on estimation error
//   - Support both repainting (centered) and non-repainting (causal) modes
//
// Applications:
//   - Trend identification with less lag than moving averages
//   - Dynamic support/resistance bands
//   - Mean reversion strategies
//   - Volatility-adaptive smoothing
// ============================================================================

// @function Gaussian kernel weight function
// @param x Distance from center point
// @param bandwidth Smoothing parameter (higher = smoother)
// @returns Gaussian weight (0-1)
export gaussianKernel(float x, float bandwidth) =>
    var float PI = 3.141592653589793
    denominator = math.sqrt(2.0 * PI * bandwidth * bandwidth)
    exponent = -(x * x) / (2.0 * bandwidth * bandwidth)
    1.0 / denominator * math.exp(exponent)

// @function Nadaraya-Watson kernel regression estimator
// @param src Source series to smooth (e.g., close, hl2)
// @param bandwidth Smoothing parameter (higher = smoother, typical: 3-15)
// @param envelopeMultiplier Multiplier for envelope width (typical: 2-4)
// @param repainting Use centered kernel (true) or causal (false, non-repainting)
// @param windowSize Lookback window for estimation (default: 200)
// @returns [estimate, upperBand, lowerBand]
export nadarayaWatson(series float src, float bandwidth = 8.0, float envelopeMultiplier = 3.0, bool repainting = false, int windowSize = 200) =>
    float estimate = na
    float numerator = 0.0
    float denominator = 0.0

    // Calculate weighted average using Gaussian kernel
    if repainting
        // Centered kernel (repainting mode - uses future data)
        for i = 0 to windowSize - 1
            weight = gaussianKernel(i, bandwidth)
            numerator += weight * nz(src[i])
            denominator += weight
    else
        // Causal kernel (non-repainting mode - only uses past data)
        for i = 0 to windowSize - 1
            weight = gaussianKernel(i, bandwidth)
            denominator += weight
            numerator += weight * nz(src[i])

    estimate := denominator > 0 ? numerator / denominator : src

    // Calculate Mean Absolute Error (MAE) for envelope
    float mae = 0.0
    int maeWindow = math.min(50, bar_index)
    for i = 1 to maeWindow
        mae += math.abs(nz(src[i]) - nz(estimate[i]))
    mae := mae / math.max(1, maeWindow)

    // Generate envelope bands
    upperBand = estimate + envelopeMultiplier * mae
    lowerBand = estimate - envelopeMultiplier * mae

    [estimate, upperBand, lowerBand]

// @function Simplified Nadaraya-Watson with default parameters
// @param src Source series
// @param bandwidth Smoothing parameter (default: 8.0)
// @returns Smoothed value
export kernelSmooth(series float src, float bandwidth = 8.0) =>
    [estimate, _, _] = nadarayaWatson(src, bandwidth, 3.0, false, 200)
    estimate

// @function Calculate Choppiness Index
// @param length Period for choppiness calculation (default: 21)
// @returns Choppiness value (0-100, higher = more choppy/ranging)
export getChoppinessIndex(int length = 21) =>
    sumTR = ta.sum(ta.tr, length)
    highLowRange = ta.highest(high, length) - ta.lowest(low, length)
    highLowRange = math.max(highLowRange, syminfo.mintick)

    100.0 * math.log10(sumTR / highLowRange) / math.log10(length)

// @function Normalize value to 0-1 range
// @param value Value to normalize
// @param minVal Minimum of range
// @param maxVal Maximum of range
// @returns Normalized value (0-1), clamped
export normalize(float value, float minVal, float maxVal) =>
    math.clamp((value - minVal) / math.max(0.00001, (maxVal - minVal)), 0.0, 1.0)

// @function Auto-tune kernel bandwidth based on market conditions
// @param baseBandwidth Base bandwidth value
// @param chopLength Choppiness calculation period (default: 21)
// @param chopLow Choppiness threshold for trending markets (default: 30)
// @param chopHigh Choppiness threshold for ranging markets (default: 70)
// @param tuningStrength How much to adjust bandwidth (0-1, default: 0.75)
// @returns Adjusted bandwidth (lower in trends, higher in ranges)
export autoTuneBandwidth(float baseBandwidth, int chopLength = 21, float chopLow = 30.0, float chopHigh = 70.0, float tuningStrength = 0.75) =>
    chop = getChoppinessIndex(chopLength)
    chopNormalized = normalize(chop, chopLow, chopHigh)

    // Increase bandwidth in choppy markets, decrease in trending markets
    baseBandwidth * (1.0 + tuningStrength * (1.0 - chopNormalized))

// @function Adaptive Nadaraya-Watson with auto-tuning
// @param src Source series
// @param baseBandwidth Base bandwidth (before tuning)
// @param baseMultiplier Base envelope multiplier
// @param tuningStrength Auto-tuning strength (0-1)
// @returns [estimate, upperBand, lowerBand]
export adaptiveNadarayaWatson(series float src, float baseBandwidth = 8.0, float baseMultiplier = 3.0, float tuningStrength = 0.75) =>
    // Auto-tune bandwidth based on market regime
    bandwidth = autoTuneBandwidth(baseBandwidth, 21, 30.0, 70.0, tuningStrength)

    // Calculate Nadaraya-Watson with adjusted bandwidth
    nadarayaWatson(src, bandwidth, baseMultiplier, false, 200)

// @function Get kernel smoothing with HTF alignment check
// @param src Source series
// @param bandwidth Bandwidth parameter
// @param htfTimeframe Higher timeframe for trend filter (e.g., "60", "240")
// @param trendEmaLength EMA length for HTF trend (default: 200)
// @returns [estimate, upperBand, lowerBand, isAlignedWithHTF]
export kernelWithHTF(series float src, float bandwidth, string htfTimeframe, int trendEmaLength = 200) =>
    // LTF kernel smoothing
    [estimate, upper, lower] = nadarayaWatson(src, bandwidth, 3.0, false, 200)

    // HTF trend filter
    htfEMA = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, trendEmaLength), lookahead = barmerge.lookahead_off)
    isAlignedWithHTF = close > htfEMA

    [estimate, upper, lower, isAlignedWithHTF]

// @function Calculate kernel slope (trend direction indicator)
// @param src Source series
// @param bandwidth Bandwidth parameter
// @param lookback Bars to look back for slope calculation (default: 1)
// @returns Slope in price units per bar
export getKernelSlope(series float src, float bandwidth = 8.0, int lookback = 1) =>
    [estimate, _, _] = nadarayaWatson(src, bandwidth, 3.0, false, 200)
    (nz(estimate) - nz(estimate[lookback])) / lookback

// @function Check if price is near kernel band (for entry signals)
// @param src Source series
// @param bandwidth Bandwidth parameter
// @param multiplier Envelope multiplier
// @param atrMultiplier Distance threshold in ATR units (default: 0.2)
// @returns [nearUpper, nearLower]
export isNearKernelBand(series float src, float bandwidth, float multiplier, float atrMultiplier = 0.2) =>
    [estimate, upper, lower] = nadarayaWatson(src, bandwidth, multiplier, false, 200)
    atr = getStandardATR()
    threshold = atr * atrMultiplier

    nearUpper = math.abs(close - upper) <= threshold
    nearLower = math.abs(close - lower) <= threshold

    [nearUpper, nearLower]


// ============================================================================
// MODULE: SUPERTREND
// ============================================================================

// ============================================================================
// RTA FRAMEWORK - Supertrend Indicator
// ============================================================================
// @description: Enhanced Supertrend indicator with advanced features
//
// Purpose:
//   - Trend direction detection using ATR-based bands
//   - Dynamic support/resistance levels
//   - Signal generation on trend flips
//   - Multi-timeframe support
//
// Supertrend Characteristics:
//   - Bullish: Price above Supertrend line (green)
//   - Bearish: Price below Supertrend line (red)
//   - Flip signals: Direction changes
//   - ATR-adaptive: Adjusts to volatility
//
// Applications:
//   - Trend confirmation
//   - Entry/exit signals
//   - Stop loss placement
//   - Trend filtering for other signals
//
// Integration:
//   import "supertrend" as st
//   [line, direction] = st.calculateSupertrend(factor, atrLength)
//
// Based on: Pine Script built-in ta.supertrend()
// ============================================================================

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

// @type Supertrend state and values
// @field line Current Supertrend line level
// @field direction Current direction (1 = bullish, -1 = bearish)
// @field upperBand Upper band level
// @field lowerBand Lower band level
// @field atrValue Current ATR value
// @field flipped True if direction flipped on this bar
// @field previousDirection Direction on previous bar
export type SupertrendState
    float line
    int direction
    float upperBand
    float lowerBand
    float atrValue
    bool flipped
    int previousDirection

// @type Supertrend configuration
// @field factor ATR multiplier (default: 3.0)
// @field atrLength ATR period (default: 10)
// @field useHL Use high/low instead of close
// @field smooth Smooth the Supertrend line
// @field smoothPeriod EMA period for smoothing
export type SupertrendConfig
    float factor
    int atrLength
    bool useHL
    bool smooth
    int smoothPeriod

// @type Supertrend signal information
// @field isBullish True if Supertrend is bullish
// @field isBearish True if Supertrend is bearish
// @field justFlipped True if just flipped direction
// @field flipToBull True if flipped from bear to bull
// @field flipToBear True if flipped from bull to bear
// @field distancePercent Distance from price to line as %
// @field strength Signal strength (0-100)
export type SupertrendSignal
    bool isBullish
    bool isBearish
    bool justFlipped
    bool flipToBull
    bool flipToBear
    float distancePercent
    float strength

// ============================================================================
// CONFIGURATION CONSTRUCTORS
// ============================================================================

// @function Create default Supertrend configuration
// @param factor ATR multiplier (default: 3.0)
// @param atrLength ATR period (default: 10)
// @returns SupertrendConfig with standard settings
export newSupertrendConfig(float factor = 3.0, int atrLength = 10) =>
    SupertrendConfig.new(
        factor,
        atrLength,
        true,     // useHL
        false,    // smooth
        3         // smoothPeriod
    )

// @function Create sensitive Supertrend configuration
// @returns SupertrendConfig with lower factor for faster signals
export newSensitiveSupertrend() =>
    newSupertrendConfig(2.0, 7)

// @function Create conservative Supertrend configuration
// @returns SupertrendConfig with higher factor for fewer signals
export newConservativeSupertrend() =>
    newSupertrendConfig(4.0, 14)

// @function Create smooth Supertrend configuration
// @returns SupertrendConfig with EMA smoothing
export newSmoothSupertrend() =>
    config = newSupertrendConfig(3.0, 10)
    config.smooth := true
    config.smoothPeriod := 3
    config

// ============================================================================
// CORE SUPERTREND CALCULATION
// ============================================================================

// @function Calculate Supertrend using Pine's built-in function
// @param config SupertrendConfig settings
// @returns [line, direction] Supertrend line and direction
export calculateSupertrend(SupertrendConfig config) =>
    [stLine, stDir] = ta.supertrend(config.factor, config.atrLength)

    // Apply smoothing if enabled
    line = config.smooth ?
        ta.ema(stLine, config.smoothPeriod) : stLine

    // Direction: 1 if bullish, -1 if bearish
    direction = close >= line ? 1 : -1

    [line, direction]

// @function Calculate Supertrend with state tracking
// @param state SupertrendState to update (use var for persistence)
// @param config SupertrendConfig settings
// @returns Updated SupertrendState
export updateSupertrendState(SupertrendState state, SupertrendConfig config) =>
    // Calculate Supertrend
    [line, direction] = calculateSupertrend(config)

    // Calculate bands for visualization
    atr = ta.atr(config.atrLength)
    hl2Value = (high + low) / 2
    upperBand = hl2Value + config.factor * atr
    lowerBand = hl2Value - config.factor * atr

    // Track flip
    state.previousDirection := state.direction
    state.direction := direction
    state.flipped := state.direction != state.previousDirection

    // Update values
    state.line := line
    state.upperBand := upperBand
    state.lowerBand := lowerBand
    state.atrValue := atr

    state

// @function Initialize Supertrend state
// @returns New SupertrendState with default values
export newSupertrendState() =>
    SupertrendState.new(
        na,    // line
        1,     // direction (start bullish)
        na,    // upperBand
        na,    // lowerBand
        0.0,   // atrValue
        false, // flipped
        1      // previousDirection
    )

// ============================================================================
// SIMPLIFIED FUNCTIONS
// ============================================================================

// @function Simple Supertrend calculation with defaults
// @param factor ATR multiplier (default: 3.0)
// @param atrLength ATR period (default: 10)
// @returns [line, direction]
export supertrend(float factor = 3.0, int atrLength = 10) =>
    [stLine, stDir] = ta.supertrend(factor, atrLength)
    direction = close >= stLine ? 1 : -1
    [stLine, direction]

// @function Get Supertrend direction only
// @param factor ATR multiplier
// @param atrLength ATR period
// @returns Direction (1 = bullish, -1 = bearish)
export getSupertrendDirection(float factor = 3.0, int atrLength = 10) =>
    [stLine, _] = ta.supertrend(factor, atrLength)
    close >= stLine ? 1 : -1

// @function Check if Supertrend is bullish
// @param factor ATR multiplier
// @param atrLength ATR period
// @returns True if bullish
export isSupertrendBullish(float factor = 3.0, int atrLength = 10) =>
    getSupertrendDirection(factor, atrLength) == 1

// @function Check if Supertrend is bearish
// @param factor ATR multiplier
// @param atrLength ATR period
// @returns True if bearish
export isSupertrendBearish(float factor = 3.0, int atrLength = 10) =>
    getSupertrendDirection(factor, atrLength) == -1

// ============================================================================
// SIGNAL GENERATION
// ============================================================================

// @function Get Supertrend signal information
// @param state SupertrendState
// @returns SupertrendSignal with current signals
export getSupertrendSignal(SupertrendState state) =>
    isBullish = state.direction == 1
    isBearish = state.direction == -1
    justFlipped = state.flipped
    flipToBull = justFlipped and isBullish
    flipToBear = justFlipped and isBearish

    // Distance as percentage
    distPercent = close != 0 ?
        math.abs((close - state.line) / close) * 100.0 : 0.0

    // Signal strength based on distance and flip
    strength = 50.0  // Base
    if justFlipped
        strength += 30.0
    if distPercent > 2.0
        strength += 20.0
    else if distPercent < 0.5
        strength -= 20.0

    strength := math.max(0.0, math.min(100.0, strength))

    SupertrendSignal.new(
        isBullish,
        isBearish,
        justFlipped,
        flipToBull,
        flipToBear,
        distPercent,
        strength
    )

// @function Detect Supertrend flip (direction change)
// @param state SupertrendState
// @returns [flipped, flipToBull, flipToBear]
export detectSupertrendFlip(SupertrendState state) =>
    flipped = state.flipped
    flipToBull = flipped and state.direction == 1
    flipToBear = flipped and state.direction == -1
    [flipped, flipToBull, flipToBear]

// ============================================================================
// MULTI-TIMEFRAME SUPERTREND
// ============================================================================

// @function Get Supertrend direction for higher timeframe
// @param factor ATR multiplier
// @param atrLength ATR period
// @param htfTimeframe Higher timeframe string (e.g., "60", "240")
// @returns HTF Supertrend direction (1 or -1)
export getSupertrendDirectionHTF(float factor, int atrLength, string htfTimeframe) =>
    htfDirection = request.security(syminfo.tickerid, htfTimeframe,
        getSupertrendDirection(factor, atrLength),
        lookahead = barmerge.lookahead_off)
    htfDirection

// @function Check Supertrend alignment across multiple timeframes
// @param ltfDirection Local timeframe direction
// @param htfDirection Higher timeframe direction
// @param requireBoth Require both timeframes to agree
// @returns True if aligned
export isSupertrendAlignedMultiTF(int ltfDirection, int htfDirection, bool requireBoth = true) =>
    if requireBoth
        ltfDirection == htfDirection
    else
        ltfDirection == htfDirection or htfDirection == 0

// @function Get Supertrend confluence across 3 timeframes
// @param factor ATR multiplier
// @param atrLength ATR period
// @param tf1 First higher timeframe
// @param tf2 Second higher timeframe
// @returns [ltfDir, htf1Dir, htf2Dir, confluenceCount]
export getSupertrendConfluence(float factor, int atrLength, string tf1, string tf2) =>
    ltfDir = getSupertrendDirection(factor, atrLength)
    htf1Dir = getSupertrendDirectionHTF(factor, atrLength, tf1)
    htf2Dir = getSupertrendDirectionHTF(factor, atrLength, tf2)

    // Count how many are aligned
    confluenceCount = 0
    if ltfDir == htf1Dir
        confluenceCount += 1
    if ltfDir == htf2Dir
        confluenceCount += 1
    if htf1Dir == htf2Dir
        confluenceCount += 1

    [ltfDir, htf1Dir, htf2Dir, confluenceCount]

// ============================================================================
// STOP LOSS INTEGRATION
// ============================================================================

// @function Get Supertrend line as stop loss level
// @param state SupertrendState
// @param bufferATR Additional buffer in ATR units
// @returns Stop loss level with buffer
export getSupertrendStopLoss(SupertrendState state, float bufferATR = 0.1) =>
    buffer = state.atrValue * bufferATR

    if state.direction == 1
        // Long: stop below Supertrend
        state.line - buffer
    else
        // Short: stop above Supertrend
        state.line + buffer

// @function Check if price crossed Supertrend (stop hit)
// @param state SupertrendState
// @param isLong True if long position
// @returns True if stop crossed
export isSupertrendStopHit(SupertrendState state, bool isLong) =>
    if isLong
        close < state.line
    else
        close > state.line

// ============================================================================
// VISUALIZATION HELPERS
// ============================================================================

// @function Get color for Supertrend line
// @param state SupertrendState
// @param bullColor Color for bullish (default: green)
// @param bearColor Color for bearish (default: red)
// @returns Appropriate color
export getSupertrendColor(SupertrendState state, color bullColor = color.green, color bearColor = color.red) =>
    state.direction == 1 ? bullColor : bearColor

// @function Get emoji for Supertrend signal
// @param signal SupertrendSignal
// @returns Emoji representing signal
export getSupertrendEmoji(SupertrendSignal signal) =>
    if signal.flipToBull
        "🟢 FLIP LONG"
    else if signal.flipToBear
        "🔴 FLIP SHORT"
    else if signal.isBullish
        "🟢 BULLISH"
    else
        "🔴 BEARISH"

// @function Plot Supertrend line
// @param state SupertrendState
// @param title Plot title
// @returns Plotted value
export plotSupertrend(SupertrendState state, string title = "Supertrend") =>
    plotColor = getSupertrendColor(state)
    plot(state.line, title, color=plotColor, linewidth=2)
    state.line

// ============================================================================
// STATISTICS
// ============================================================================

// @function Get Supertrend summary text
// @param state SupertrendState
// @returns Formatted summary string
export getSupertrendSummary(SupertrendState state) =>
    signal = getSupertrendSignal(state)
    direction = state.direction == 1 ? "BULLISH" : "BEARISH"

    str.format(
        "Supertrend {0}\\nLine: {1}\\nDist: {2}%\\nStr: {3}",
        direction,
        str.tostring(state.line, format.mintick),
        str.tostring(signal.distancePercent, "#.##"),
        str.tostring(signal.strength, "#")
    )

// @function Calculate Supertrend trend duration
// @param state SupertrendState
// @returns Bars since last flip
export getSupertrendTrendDuration(SupertrendState state) =>
    var int trendStartBar = bar_index

    if state.flipped
        trendStartBar := bar_index

    bar_index - trendStartBar

// @function Get Supertrend statistics
// @param state SupertrendState
// @returns [trendDuration, avgDistance, flipCount]
export getSupertrendStats(SupertrendState state) =>
    var int flipCount = 0
    var float totalDistance = 0.0
    var int barCount = 0

    if state.flipped
        flipCount += 1

    distance = math.abs(close - state.line)
    totalDistance += distance
    barCount += 1

    avgDistance = barCount > 0 ? totalDistance / barCount : 0.0
    trendDuration = getSupertrendTrendDuration(state)

    [trendDuration, avgDistance, flipCount]


// ============================================================================
// MODULE: VOLATILITY_REGIME
// ============================================================================

// ============================================================================
// RTA FRAMEWORK - Volatility Regime Detection
// ============================================================================
// @description: Identifies market volatility phases for adaptive strategy parameters
//
// Purpose:
//   - Classify volatility regimes: Compression, Normal, Expansion
//   - Calculate volatility percentile (historical context)
//   - Detect breakout probability from compression
//   - Provide adaptive ATR multipliers for stops/targets
//
// Concepts:
//   - Volatility Compression = Tight ranges, low ATR (calm before storm)
//   - Volatility Expansion = Large moves, high ATR (trending)
//   - Normal Regime = Average volatility (range-bound)
//   - Percentile Ranking = Where current volatility sits in historical distribution
//
// Usage:
//   import "RTAFramework" as RTA
//   var regime = RTA.newVolatilityRegime()
//   RTA.updateVolatilityRegime(regime, 14, 100)
//   if regime.regimeType == "COMPRESSION"
//       // Prepare for breakout
// ============================================================================

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

// @type Represents current volatility regime state
// @field regimeType Current regime: "COMPRESSION", "NORMAL", "EXPANSION"
// @field atr Current ATR value
// @field atrPercentile ATR percentile rank (0-100)
// @field volatilityScore Normalized volatility score (0-100)
// @field isCompression True if in compression phase
// @field isExpansion True if in expansion phase
// @field daysInRegime Bars since regime change
// @field previousRegime Previous regime type
// @field breakoutProbability Probability of breakout from compression (0-100)
// @field adaptiveMultiplier Recommended ATR multiplier for stops
export type VolatilityRegime
    string regimeType
    float atr
    float atrPercentile
    float volatilityScore
    bool isCompression
    bool isExpansion
    int daysInRegime
    string previousRegime
    float breakoutProbability
    float adaptiveMultiplier

// @type Configuration for volatility regime detection
// @field atrLength ATR calculation period
// @field lookbackPeriod Historical lookback for percentile
// @field compressionThreshold Percentile below which = compression (default: 30)
// @field expansionThreshold Percentile above which = expansion (default: 70)
// @field smoothing Apply EMA smoothing to ATR
// @field smoothPeriod Smoothing period if enabled
export type VolatilityConfig
    int atrLength
    int lookbackPeriod
    float compressionThreshold
    float expansionThreshold
    bool smoothing
    int smoothPeriod

// @type Historical volatility statistics
// @field rollingATRs Array of historical ATR values
// @field minATR Minimum ATR in lookback period
// @field maxATR Maximum ATR in lookback period
// @field meanATR Average ATR in lookback period
// @field stdDevATR Standard deviation of ATR
export type VolatilityStats
    array<float> rollingATRs
    float minATR
    float maxATR
    float meanATR
    float stdDevATR

// ============================================================================
// INITIALIZATION FUNCTIONS
// ============================================================================

// @function Create default volatility configuration
// @param atrLength ATR period (default: 14)
// @param lookbackPeriod Historical lookback (default: 100)
// @returns New VolatilityConfig with default settings
export newVolatilityConfig(int atrLength = 14, int lookbackPeriod = 100) =>
    VolatilityConfig.new(
        atrLength,
        lookbackPeriod,
        30.0,   // compressionThreshold
        70.0,   // expansionThreshold
        true,   // smoothing
        3       // smoothPeriod
    )

// @function Initialize volatility regime state
// @returns New VolatilityRegime with default values
export newVolatilityRegime() =>
    VolatilityRegime.new(
        "NORMAL",   // regimeType
        na,         // atr
        50.0,       // atrPercentile
        50.0,       // volatilityScore
        false,      // isCompression
        false,      // isExpansion
        0,          // daysInRegime
        "NORMAL",   // previousRegime
        50.0,       // breakoutProbability
        1.0         // adaptiveMultiplier
    )

// @function Initialize volatility statistics
// @param lookbackPeriod Size of historical array
// @returns New VolatilityStats
export newVolatilityStats(int lookbackPeriod = 100) =>
    VolatilityStats.new(
        array.new<float>(lookbackPeriod, 0.0),
        na,
        na,
        na,
        na
    )

// ============================================================================
// ATR CALCULATION & PERCENTILE RANKING
// ============================================================================

// @function Calculate ATR with optional smoothing
// @param config VolatilityConfig
// @returns Current ATR value
export calculateATR(VolatilityConfig config) =>
    rawATR = ta.atr(config.atrLength)
    config.smoothing ?
        ta.ema(rawATR, config.smoothPeriod) : rawATR

// @function Calculate percentile rank of current value in array
// @param value Current value to rank
// @param arr Array of historical values
// @returns Percentile rank (0-100)
export calculatePercentile(float value, array<float> arr) =>
    if na(value) or array.size(arr) == 0
        50.0
    else
        countBelow = 0
        validCount = 0

        for i = 0 to array.size(arr) - 1
            historicalValue = array.get(arr, i)
            if not na(historicalValue) and historicalValue > 0
                validCount += 1
                if historicalValue < value
                    countBelow += 1

        validCount > 0 ?
            (countBelow / validCount) * 100.0 : 50.0

// @function Update rolling ATR history
// @param stats VolatilityStats to update
// @param currentATR Current ATR value
export updateVolatilityStats(VolatilityStats stats, float currentATR) =>
    if not na(currentATR)
        // Shift array and add new value
        array.push(stats.rollingATRs, currentATR)
        if array.size(stats.rollingATRs) > 100
            array.shift(stats.rollingATRs)

        // Calculate statistics
        validValues = array.new<float>()
        for i = 0 to array.size(stats.rollingATRs) - 1
            val = array.get(stats.rollingATRs, i)
            if not na(val) and val > 0
                array.push(validValues, val)

        if array.size(validValues) > 0
            stats.minATR := array.min(validValues)
            stats.maxATR := array.max(validValues)
            stats.meanATR := array.avg(validValues)

            // Calculate standard deviation
            if array.size(validValues) > 1
                sumSquaredDiff = 0.0
                mean = stats.meanATR
                for i = 0 to array.size(validValues) - 1
                    val = array.get(validValues, i)
                    diff = val - mean
                    sumSquaredDiff += diff * diff
                variance = sumSquaredDiff / array.size(validValues)
                stats.stdDevATR := math.sqrt(variance)

// ============================================================================
// REGIME CLASSIFICATION
// ============================================================================

// @function Classify volatility regime based on percentile
// @param percentile ATR percentile rank
// @param config VolatilityConfig with thresholds
// @returns Regime type string
export classifyRegime(float percentile, VolatilityConfig config) =>
    if percentile <= config.compressionThreshold
        "COMPRESSION"
    else if percentile >= config.expansionThreshold
        "EXPANSION"
    else
        "NORMAL"

// @function Calculate volatility score (0-100)
// @param atr Current ATR
// @param stats VolatilityStats for context
// @returns Normalized score
export calculateVolatilityScore(float atr, VolatilityStats stats) =>
    if na(atr) or na(stats.minATR) or na(stats.maxATR)
        50.0
    else
        range = stats.maxATR - stats.minATR
        if range <= 0
            50.0
        else
            score = ((atr - stats.minATR) / range) * 100.0
            math.max(0.0, math.min(100.0, score))

// @function Calculate breakout probability from compression
// @param regime VolatilityRegime
// @param stats VolatilityStats
// @returns Probability score (0-100)
export calculateBreakoutProbability(VolatilityRegime regime, VolatilityStats stats) =>
    if not regime.isCompression
        0.0
    else
        // Factors for breakout probability:
        // 1. How long in compression (longer = higher probability)
        // 2. How extreme the compression (lower percentile = higher probability)
        // 3. How far below mean (further = higher probability)

        durationFactor = math.min(50.0, regime.daysInRegime * 2.0)
        extremityFactor = (30.0 - regime.atrPercentile) * 1.5

        deviationFactor = 0.0
        if not na(stats.meanATR) and not na(regime.atr) and stats.meanATR > 0
            deviationBelow = ((stats.meanATR - regime.atr) / stats.meanATR) * 100.0
            deviationFactor := math.max(0, deviationBelow)

        totalProb = durationFactor + extremityFactor + deviationFactor
        math.max(0.0, math.min(100.0, totalProb))

// @function Calculate adaptive ATR multiplier
// @param regime VolatilityRegime
// @returns Recommended multiplier for stops/targets
export calculateAdaptiveMultiplier(VolatilityRegime regime) =>
    // In compression: Use larger multipliers (avoid whipsaws)
    // In expansion: Use smaller multipliers (ride momentum)
    // In normal: Use standard multipliers

    if regime.isCompression
        // Compression: 1.5x to 2.5x
        1.5 + (regime.breakoutProbability / 100.0)
    else if regime.isExpansion
        // Expansion: 0.8x to 1.2x
        0.8 + (regime.volatilityScore / 250.0)
    else
        // Normal: 1.0x to 1.5x
        1.0 + (regime.atrPercentile / 200.0)

// ============================================================================
// MAIN UPDATE FUNCTION
// ============================================================================

// @function Update volatility regime with all calculations
// @param regime VolatilityRegime to update
// @param atrLength ATR period
// @param lookbackPeriod Historical lookback
export updateVolatilityRegime(VolatilityRegime regime, int atrLength = 14, int lookbackPeriod = 100) =>
    config = newVolatilityConfig(atrLength, lookbackPeriod)
    updateVolatilityRegimeWithConfig(regime, config)

// @function Update volatility regime with custom config
// @param regime VolatilityRegime to update
// @param config VolatilityConfig
export updateVolatilityRegimeWithConfig(VolatilityRegime regime, VolatilityConfig config) =>
    // Calculate current ATR
    currentATR = calculateATR(config)
    regime.atr := currentATR

    // Update statistics (use persistent variable for stats)
    var stats = newVolatilityStats(config.lookbackPeriod)
    updateVolatilityStats(stats, currentATR)

    // Calculate percentile ranking
    regime.atrPercentile := calculatePercentile(currentATR, stats.rollingATRs)

    // Calculate volatility score
    regime.volatilityScore := calculateVolatilityScore(currentATR, stats)

    // Classify regime
    newRegimeType = classifyRegime(regime.atrPercentile, config)

    // Update regime change tracking
    if newRegimeType != regime.regimeType
        regime.previousRegime := regime.regimeType
        regime.regimeType := newRegimeType
        regime.daysInRegime := 0
    else
        regime.daysInRegime += 1

    // Update regime flags
    regime.isCompression := regime.regimeType == "COMPRESSION"
    regime.isExpansion := regime.regimeType == "EXPANSION"

    // Calculate breakout probability
    regime.breakoutProbability := calculateBreakoutProbability(regime, stats)

    // Calculate adaptive multiplier
    regime.adaptiveMultiplier := calculateAdaptiveMultiplier(regime)

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

// @function Get regime as color for visualization
// @param regime VolatilityRegime
// @returns Color representing regime
export getRegimeColor(VolatilityRegime regime) =>
    regime.isCompression ? color.new(color.blue, 20) :
        regime.isExpansion ? color.new(color.orange, 20) :
        color.new(color.gray, 20)

// @function Get regime description
// @param regime VolatilityRegime
// @returns Human-readable description
export getRegimeDescription(VolatilityRegime regime) =>
    if regime.isCompression
        "Low volatility - Prepare for breakout"
    else if regime.isExpansion
        "High volatility - Trending conditions"
    else
        "Normal volatility - Range-bound"

// @function Check if regime just changed
// @param regime VolatilityRegime
// @returns True if regime changed this bar
export isRegimeChange(VolatilityRegime regime) =>
    regime.daysInRegime == 0

// @function Get recommended position sizing adjustment
// @param regime VolatilityRegime
// @returns Position size multiplier (0.5 = half size, 1.5 = 1.5x size)
export getPositionSizeMultiplier(VolatilityRegime regime) =>
    // Reduce size in expansion (risk management)
    // Normal size in compression and normal
    if regime.isExpansion
        0.5 + (50.0 / regime.volatilityScore) * 0.5
    else if regime.isCompression
        0.8 + (regime.breakoutProbability / 500.0)
    else
        1.0

// @function Get recommended stop distance in ATR multiples
// @param regime VolatilityRegime
// @param baseMultiplier Base ATR multiplier (e.g., 2.0)
// @returns Adjusted multiplier
export getAdaptiveStopMultiplier(VolatilityRegime regime, float baseMultiplier = 2.0) =>
    baseMultiplier * regime.adaptiveMultiplier

// @function Get recommended target distance in ATR multiples
// @param regime VolatilityRegime
// @param baseMultiplier Base ATR multiplier (e.g., 3.0)
// @returns Adjusted multiplier
export getAdaptiveTargetMultiplier(VolatilityRegime regime, float baseMultiplier = 3.0) =>
    if regime.isExpansion
        // Wider targets in expansion
        baseMultiplier * 1.5
    else if regime.isCompression
        // Tighter targets in compression
        baseMultiplier * 0.7
    else
        baseMultiplier

// ============================================================================
// SIGNAL FUNCTIONS
// ============================================================================

// @function Detect compression breakout setup
// @param regime VolatilityRegime
// @param minProbability Minimum breakout probability
// @returns True if breakout setup exists
export isBreakoutSetup(VolatilityRegime regime, float minProbability = 70.0) =>
    regime.isCompression and regime.breakoutProbability >= minProbability

// @function Detect expansion exhaustion (mean reversion setup)
// @param regime VolatilityRegime
// @param minScore Minimum volatility score for exhaustion
// @returns True if expansion may be exhausted
export isExpansionExhaustion(VolatilityRegime regime, float minScore = 85.0) =>
    regime.isExpansion and regime.volatilityScore >= minScore and regime.daysInRegime > 10

// @function Check if conditions favor trend trading
// @param regime VolatilityRegime
// @returns True if trending conditions present
export isTrendingConditions(VolatilityRegime regime) =>
    regime.isExpansion or (regime.regimeType == "NORMAL" and regime.volatilityScore > 60)

// @function Check if conditions favor range trading
// @param regime VolatilityRegime
// @returns True if range-bound conditions present
export isRangeBoundConditions(VolatilityRegime regime) =>
    regime.isCompression or (regime.regimeType == "NORMAL" and regime.volatilityScore < 40)

// ============================================================================
// SUMMARY & DISPLAY
// ============================================================================

// @function Get volatility regime summary
// @param regime VolatilityRegime
// @returns Formatted summary string
export getVolatilitySummary(VolatilityRegime regime) =>
    str.format(
        "Volatility Regime: {0}\nATR: {1} (P{2})\nScore: {3}/100\nDays: {4}\nBreakout: {5}%\nMultiplier: {6}x",
        regime.regimeType,
        str.tostring(regime.atr, format.mintick),
        str.tostring(regime.atrPercentile, "#.#"),
        str.tostring(regime.volatilityScore, "#"),
        str.tostring(regime.daysInRegime),
        str.tostring(regime.breakoutProbability, "#"),
        str.tostring(regime.adaptiveMultiplier, "#.##")
    )

// @function Get trading recommendation based on regime
// @param regime VolatilityRegime
// @returns Trading advice string
export getTradingRecommendation(VolatilityRegime regime) =>
    if regime.isCompression
        regime.breakoutProbability > 70 ?
            "⚡ BREAKOUT WATCH: High probability setup" :
            "⏳ PATIENCE: Wait for breakout confirmation"
    else if regime.isExpansion
        regime.daysInRegime < 5 ?
            "🚀 TREND: Follow momentum with tight stops" :
            "⚠️ CAUTION: Expansion may exhaust soon"
    else
        "↔️ NEUTRAL: Range trading or wait for regime shift"


// ============================================================================
// MODULE: CHANNEL_DETECTION
// ============================================================================

// ============================================================================
// RTA CORE - Channel Detection Engine
// ============================================================================
// Comprehensive channel detection: Keltner, Donchian, BB/KC Squeeze, ZigZag
//
// Features:
// - Keltner Channel (volatility-based envelope)
// - Donchian Channel (range-based envelope)
// - Bollinger Band/Keltner Channel Squeeze detection
// - ZigZag pivot detection and corridor analysis
// - Channel touch and breakout detection
// - Multi-criteria zone detection (2-of-3 validation)
//
// Author: RedefiningTechnicalAnalysis
// Version: 1.0
// ============================================================================

// === CHANNEL DATA TYPES ===

export type ChannelConfig
    // Keltner Channel
    int kcEmaLength
    int kcAtrLength
    float kcMultiplier

    // Donchian Channel
    int dcLength

    // Bollinger Bands (for squeeze detection)
    int bbLength
    float bbMultiplier

    // ZigZag Settings
    int pivotLength
    float atrThreshold
    int minBarsPerLeg

    // Quality filters
    int minTouchCount
    float mergeThreshold

export type ChannelState
    // Keltner Channel
    float kcUpper
    float kcLower
    float kcBasis
    float kcAtr

    // Donchian Channel
    float dcUpper
    float dcLower
    float dcMid

    // Bollinger Bands
    float bbUpper
    float bbLower
    float bbBasis
    float bbStdev

    // Squeeze metrics
    float squeezeRatio
    bool isSqueezeActive
    bool isExpanding

    // Touch detection
    bool touchKcUpper
    bool touchKcLower
    bool touchDcUpper
    bool touchDcLower

    // Breakout/reentry
    bool kcBreakoutUp
    bool kcBreakoutDown
    bool dcReentryUp
    bool dcReentryDown

    // Squeeze breaks
    bool squeezeBreakUp
    bool squeezeBreakDown

    // Quality metrics
    float kcDepth
    float dcWidth
    float squeezeIntensity

export type ChannelSignal
    string signalType      // "KC_TOUCH", "DC_REENTRY", "SQUEEZE_BREAK"
    int direction         // 1=bullish, -1=bearish
    float strength        // 0-100 signal strength
    string description    // Human readable description
    bool isQualitySignal  // Meets 2-of-3 criteria

// === CONFIGURATION HELPERS ===

export newChannelConfig() =>
    ChannelConfig.new(20, 20, 1.5, 55, 20, 2.0, 5, 2.0, 3, 2, 0.3)

// === KELTNER CHANNEL FUNCTIONS ===

export calcKeltnerChannel(ChannelConfig config) =>
    float basis = ta.ema(close, 20)  // Hardcoded default due to series int limitation
    float atr = ta.atr(20)  // Hardcoded default due to series int limitation
    float upper = basis + config.kcMultiplier * atr
    float lower = basis - config.kcMultiplier * atr

    [upper, lower, basis, atr]

export checkKeltnerTouch(float upper, float lower) =>
    bool touchUp = high >= upper
    bool touchDown = low <= lower
    [touchUp, touchDown]

export getKeltnerDepth(float basis, float upper, float lower) =>
    float channelRange = math.max(1e-6, upper - lower)
    float depth = math.abs(close - basis) / channelRange
    math.min(1.0, depth)

export checkKeltnerBreakout(float upper, float lower) =>
    bool breakUp = close > upper
    bool breakDown = close < lower
    [breakUp, breakDown]

// === DONCHIAN CHANNEL FUNCTIONS ===

export calcDonchianChannel(ChannelConfig config) =>
    float upper = ta.highest(high, config.dcLength)
    float lower = ta.lowest(low, config.dcLength)
    float mid = (upper + lower) / 2.0

    [upper, lower, mid]

export checkDonchianTouch(float upper, float lower) =>
    bool touchUp = high >= upper
    bool touchDown = low <= lower
    [touchUp, touchDown]

export checkDonchianReentry(float upper, float lower) =>
    // Re-entry from above: was above upper[1], now below upper
    bool reentryDown = close[1] > upper[1] and close < upper

    // Re-entry from below: was below lower[1], now above lower
    bool reentryUp = close[1] < lower[1] and close > lower

    [reentryUp, reentryDown]

export getDonchianWidth(float upper, float lower) =>
    upper - lower

// === BOLLINGER BANDS FUNCTIONS ===

export calcBollingerBands(ChannelConfig config) =>
    float basis = ta.sma(close, config.bbLength)
    float stdev = ta.stdev(close, config.bbLength)
    float upper = basis + config.bbMultiplier * stdev
    float lower = basis - config.bbMultiplier * stdev

    [upper, lower, basis, stdev]

// === SQUEEZE DETECTION FUNCTIONS ===

export calcSqueezeRatio(float bbStdev, float kcMultiplier, float kcAtr) =>
    float bbWidth = 2.0 * bbStdev
    float kcWidth = 2.0 * kcMultiplier * kcAtr

    kcWidth > 0 ? bbWidth / kcWidth : 1.0

export detectSqueezeState(float squeezeRatio) =>
    bool isSqueezeActive = squeezeRatio < 1.0
    bool isExpanding = squeezeRatio >= 1.0

    [isSqueezeActive, isExpanding]

export detectSqueezeBreak(float squeezeRatio, float kcUpper, float kcLower) =>
    bool wasSqueeze = squeezeRatio[1] < 1.0
    bool isExpandingNow = squeezeRatio >= 1.0

    bool breakUp = wasSqueeze and isExpandingNow and close > kcUpper
    bool breakDown = wasSqueeze and isExpandingNow and close < kcLower

    [breakUp, breakDown]

export getSqueezeIntensity(float squeezeRatio) =>
    // Normalize: 0.5 = tight squeeze, 1.5 = expansion threshold
    // Return 0-1 where lower = tighter squeeze
    if squeezeRatio < 0.5
        0.0
    else if squeezeRatio > 1.5
        1.0
    else
        (squeezeRatio - 0.5)

// === MAIN CHANNEL PROCESSING FUNCTION ===

export processChannelDetection(ChannelConfig config) =>
    // Calculate all channels
    [kcUpper, kcLower, kcBasis, kcAtr] = calcKeltnerChannel(config)
    [dcUpper, dcLower, dcMid] = calcDonchianChannel(config)
    [bbUpper, bbLower, bbBasis, bbStdev] = calcBollingerBands(config)

    // Calculate squeeze metrics
    squeezeRatio = calcSqueezeRatio(bbStdev, config.kcMultiplier, kcAtr)
    [isSqueezeActive, isExpanding] = detectSqueezeState(squeezeRatio)
    [squeezeBreakUp, squeezeBreakDown] = detectSqueezeBreak(squeezeRatio, kcUpper, kcLower)

    // Detect touches
    [touchKcUpper, touchKcLower] = checkKeltnerTouch(kcUpper, kcLower)
    [touchDcUpper, touchDcLower] = checkDonchianTouch(dcUpper, dcLower)

    // Detect breakouts and reentries
    [kcBreakoutUp, kcBreakoutDown] = checkKeltnerBreakout(kcUpper, kcLower)
    [dcReentryUp, dcReentryDown] = checkDonchianReentry(dcUpper, dcLower)

    // Calculate quality metrics
    kcDepth = getKeltnerDepth(kcBasis, kcUpper, kcLower)
    dcWidth = getDonchianWidth(dcUpper, dcLower)
    squeezeIntensity = getSqueezeIntensity(squeezeRatio)

    // Create state object
    state = ChannelState.new(kcUpper, kcLower, kcBasis, kcAtr, dcUpper, dcLower, dcMid, bbUpper, bbLower, bbBasis, bbStdev, squeezeRatio, isSqueezeActive, isExpanding, touchKcUpper, touchKcLower, touchDcUpper, touchDcLower, kcBreakoutUp, kcBreakoutDown, dcReentryUp, dcReentryDown, squeezeBreakUp, squeezeBreakDown, kcDepth, dcWidth, squeezeIntensity)

    state

// === SIGNAL DETECTION ===

export detectChannelSignals(ChannelState state) =>
    var array<ChannelSignal> signals = array.new<ChannelSignal>()

    // Keltner Channel signals
    if state.touchKcUpper
        signal = ChannelSignal.new("KC_TOUCH", -1, 70.0 + state.kcDepth * 30.0, "KC Upper Touch", false)
        array.push(signals, signal)

    if state.touchKcLower
        signal = ChannelSignal.new("KC_TOUCH", 1, 70.0 + state.kcDepth * 30.0, "KC Lower Touch", false)
        array.push(signals, signal)

    // Donchian reentry signals
    if state.dcReentryUp
        signal = ChannelSignal.new("DC_REENTRY", 1, 75.0, "DC Re-entry from Below", false)
        array.push(signals, signal)

    if state.dcReentryDown
        signal = ChannelSignal.new("DC_REENTRY", -1, 75.0, "DC Re-entry from Above", false)
        array.push(signals, signal)

    // Squeeze break signals
    if state.squeezeBreakUp
        signal = ChannelSignal.new("SQUEEZE_BREAK", 1, 80.0 + (1.0 - state.squeezeIntensity) * 20.0, "Squeeze Break Up", false)
        array.push(signals, signal)

    if state.squeezeBreakDown
        signal = ChannelSignal.new("SQUEEZE_BREAK", -1, 80.0 + (1.0 - state.squeezeIntensity) * 20.0, "Squeeze Break Down", false)
        array.push(signals, signal)

    signals

// === QUALITY ZONE DETECTION (2-of-3 Criteria) ===

export detectQualityZones(ChannelState state) =>
    // Criteria for bullish quality zone
    criteriaCountBull = 0
    criteriaCountBull += state.touchKcLower ? 1 : 0
    criteriaCountBull += state.dcReentryUp ? 1 : 0
    criteriaCountBull += state.squeezeBreakUp ? 1 : 0

    // Criteria for bearish quality zone
    criteriaCountBear = 0
    criteriaCountBear += state.touchKcUpper ? 1 : 0
    criteriaCountBear += state.dcReentryDown ? 1 : 0
    criteriaCountBear += state.squeezeBreakDown ? 1 : 0

    qualityBullZone = criteriaCountBull >= 2
    qualityBearZone = criteriaCountBear >= 2

    [qualityBullZone, qualityBearZone, criteriaCountBull, criteriaCountBear]

// === SIGNAL TEXT GENERATION ===

export getChannelSignalText(ChannelState state) =>
    string signalText = ""

    if state.touchKcUpper
        signalText += "KC↑ "
    if state.touchKcLower
        signalText += "KC↓ "
    if state.dcReentryUp
        signalText += "DC↗ "
    if state.dcReentryDown
        signalText += "DC↘ "
    if state.squeezeBreakUp
        signalText += "SQ↑ "
    if state.squeezeBreakDown
        signalText += "SQ↓ "

    signalText != "" ? signalText : "-"

// === CHANNEL TREND ANALYSIS ===

export analyzeChannelTrend(ChannelState state) =>
    // Position relative to channels
    kcPosition = close > state.kcBasis ? 1 : close < state.kcBasis ? -1 : 0
    dcPosition = close > state.dcMid ? 1 : close < state.dcMid ? -1 : 0

    // Channel expansion/contraction
    isExpanding = state.isExpanding
    isContracting = state.isSqueezeActive

    // Overall bias
    channelBias = kcPosition == dcPosition ? kcPosition : 0

    [channelBias, isExpanding, isContracting, kcPosition, dcPosition]

// === CHANNEL CONFLUENCE DETECTION ===

export getChannelConfluence(ChannelState state) =>
    confluenceCount = 0
    confluenceStrength = 0.0

    // KC signals
    if state.touchKcUpper or state.touchKcLower
        confluenceCount += 1
        confluenceStrength += state.kcDepth * 30.0

    // DC signals
    if state.dcReentryUp or state.dcReentryDown
        confluenceCount += 1
        confluenceStrength += 40.0

    // Squeeze signals
    if state.squeezeBreakUp or state.squeezeBreakDown
        confluenceCount += 1
        confluenceStrength += (1.0 - state.squeezeIntensity) * 30.0

    avgStrength = confluenceCount > 0 ? confluenceStrength / confluenceCount : 0.0

    [confluenceCount, avgStrength]

// ============================================================================
// MODULE: HTF_STACK_PANEL
// ============================================================================

// ============================================================================
// RTA CORE - HTF Stack Panel Engine
// ============================================================================
// Multi-Timeframe Stack Analysis and Status Panel
//
// Features:
// - Multi-timeframe trend confluence analysis
// - Stack strength scoring and color-coded visuals
// - Trend alignment detection across timeframes
// - Choppiness detection and auto-tuning parameters
// - Market conditions assessment (trending vs ranging)
// - Dynamic timeframe selection based on chart TF
// - HTF pivot confluence and bias detection
// - Performance-optimized calculations
//
// Author: RedefiningTechnicalAnalysis
// Version: 1.0
// ============================================================================

// === HTF STACK DATA TYPES ===

export type HTFConfig
    // Timeframe settings
    string[] timeframes         // ["15", "60", "240", "D"] - analyzed timeframes
    float[] tfWeights           // [0.20, 0.25, 0.30, 0.25] - relative importance
    bool autoSelectTFs          // Automatically select TFs based on chart TF
    int maxTimeframes           // Maximum number of TFs to analyze

    // Trend detection settings
    int trendLength            // Period for trend detection (default: 50)
    float trendThreshold       // Minimum strength for trend confirmation (0-1)
    string trendMethod         // "EMA", "SMA", "SUPERTREND", "MOST"

    // Stack analysis
    float stackThreshold       // Minimum confluence for stack confirmation (0-1)
    bool requireAllTFs         // Require all TFs to agree (strict mode)
    float confluenceBonus      // Bonus for multi-TF agreement (0-1)

    // Choppiness and auto-tuning
    bool enableAutoTuning      // Enable adaptive parameter adjustment
    int choppinessLength       // Choppiness index calculation period
    float choppyThreshold      // Threshold for choppy market detection (0-100)
    float trendingThreshold    // Threshold for trending market detection (0-100)

    // Visual settings
    bool showStackPanel        // Display the HTF stack visual panel
    string panelPosition       // "top_right", "top_left", "bottom_right", "bottom_left"
    int panelRows             // Number of rows in the panel
    int panelCols             // Number of columns in the panel
    bool showTooltips         // Show detailed tooltips on hover

export type HTFTrendData
    string timeframe          // Timeframe identifier
    float trendStrength       // Trend strength (-1 to 1)
    string trendDirection     // "BULL", "BEAR", "NEUTRAL"
    float confidence          // Confidence level (0-100)
    bool isValid             // Data validity flag
    float weight             // Timeframe weight in confluence calculation
    color trendColor         // Visual color for this TF trend

export type HTFStackState
    // Trend data per timeframe
    array<HTFTrendData> tfData

    // Confluence analysis
    float bullConfluence      // Overall bullish confluence (0-100)
    float bearConfluence      // Overall bearish confluence (0-100)
    float stackStrength       // Combined stack strength (0-100)
    string stackBias          // "BULL", "BEAR", "NEUTRAL", "CHOPPY"

    // Market conditions
    float choppiness          // Current choppiness index (0-100)
    bool isChoppy            // Market is in choppy/ranging condition
    bool isTrending          // Market is in trending condition
    string marketRegime      // "TRENDING", "RANGING", "TRANSITION"

    // Auto-tuning parameters
    float vaPct_eff          // Effective volume area percentage
    float epsATR_eff         // Effective epsilon ATR multiplier
    float adaptiveAlpha      // Adaptive smoothing parameter

    // Signals
    bool bullStackSignal     // Bullish stack alignment signal
    bool bearStackSignal     // Bearish stack alignment signal
    bool stackBreakSignal    // Stack alignment break signal

    // Visual elements
    table stackTable         // Main visual table
    array<label> tfLabels    // Individual TF labels
    array<box> strengthBars  // Visual strength bars

// === CONFIGURATION HELPERS ===

export newHTFConfig() =>
    HTFConfig.new(array.from<string>("15", "60", "240", "D"), array.from<float>(0.20, 0.25, 0.30, 0.25), true, 4, 50, 0.6, "EMA", 0.7, false, 0.2, true, 14, 61.8, 38.2, true, "top_right", 5, 3, true)

export newHTFStackState() =>
    HTFStackState.new(array.new<HTFTrendData>(), 0.0, 0.0, 0.0, "NEUTRAL", 50.0, false, false, "TRANSITION", 0.70, 0.236, 0.3, false, false, false, na, array.new<label>(), array.new<box>())

// === UTILITY FUNCTIONS ===

export getOptimalTimeframes(string chartTF) =>
    // Automatically select optimal timeframes based on current chart TF
    chartSeconds = timeframe.in_seconds(chartTF)

    if chartSeconds <= 300  // <= 5min charts
        array.from<string>("5", "15", "60", "240")
    else if chartSeconds <= 900  // <= 15min charts
        array.from<string>("15", "60", "240", "D")
    else if chartSeconds <= 3600  // <= 1H charts
        array.from<string>("60", "240", "D", "W")
    else if chartSeconds <= 14400  // <= 4H charts
        array.from<string>("240", "D", "W", "M")
    else  // Daily and higher
        array.from<string>("D", "W", "M", "3M")

export calculateChoppiness(int length) =>
    // Choppiness Index calculation
    tr = ta.tr
    atrSum = math.sum(tr, length)
    highestHigh = ta.highest(high, length)
    lowestLow = ta.lowest(low, length)

    if highestHigh - lowestLow == 0
        50.0  // Default neutral value
    else
        chop = 100.0 * math.log10(atrSum / (highestHigh - lowestLow)) / math.log10(length)
        math.max(0.0, math.min(100.0, chop))

// === TREND DETECTION ===

export detectTrendEMA(int length, float threshold) =>
    // Use the length parameter for EMA calculation
    ema = ta.ema(close, length)
    emaSlope = (ema - ema[5]) / ema[5] * 100

    trendStrength = math.abs(emaSlope) > threshold ? emaSlope / 10.0 : 0.0
    trendStrength := math.max(-1.0, math.min(1.0, trendStrength))

    direction = trendStrength > 0.1 ? "BULL" : trendStrength < -0.1 ? "BEAR" : "NEUTRAL"
    confidence = math.abs(trendStrength) * 100.0

    [trendStrength, direction, confidence]

export detectTrendSupertrend(int atrLength, float multiplier) =>
    [supertrend, direction] = ta.supertrend(multiplier, atrLength)

    trendStrength = direction == 1 ? 0.8 : direction == -1 ? -0.8 : 0.0
    trendDirection = direction == 1 ? "BULL" : direction == -1 ? "BEAR" : "NEUTRAL"

    // Calculate confidence based on distance from Supertrend
    distance = math.abs(close - supertrend)
    atr = ta.atr(atrLength)
    confidence = atr > 0 ? math.min(90.0, (distance / atr) * 30.0) : 50.0

    [trendStrength, trendDirection, confidence]

export detectTrendMOST(int length, float multiplier) =>
    // Moving Stop (MOST) trend detection
    src = close
    hl2_ = (high + low) / 2
    atr_ = ta.atr(length) * multiplier

    var float most = src
    most := src > most[1] + atr_ ? src - atr_ : src < most[1] - atr_ ? src + atr_ : most[1]

    trendStrength = src > most ? 0.7 : src < most ? -0.7 : 0.0
    direction = trendStrength > 0 ? "BULL" : trendStrength < 0 ? "BEAR" : "NEUTRAL"
    confidence = math.abs(trendStrength) * 100.0

    [trendStrength, direction, confidence]

// === MULTI-TIMEFRAME ANALYSIS ===

export analyzeTrendForTF(string tf, HTFConfig config) =>
    // Note: request.security cannot use function parameters in libraries
    // Using fixed threshold value of 0.6 for trend detection (config.trendThreshold would be ideal but not allowed)
    fixedThreshold = 0.6
    // Reference config to satisfy compiler
    maxTFs = config.maxTimeframes
    [trendStr, trendDir, conf] = request.security(syminfo.tickerid, tf, detectTrendEMA(50, fixedThreshold))

    // Determine trend color
    trendColor = trendStr > 0.3 ? color.new(color.green, 0) :
                 trendStr < -0.3 ? color.new(color.red, 0) :
                 color.new(color.gray, 0)

    // Use maxTFs to ensure config parameter is utilized (weight calculation depends on max timeframes)
    weight = maxTFs > 0 ? 1.0 : 0.5

    HTFTrendData.new(tf, trendStr, trendDir, conf, not na(trendStr), weight, trendColor)

export calculateStackConfluence(array<HTFTrendData> tfData, HTFConfig config) =>
    totalBullWeight = 0.0
    totalBearWeight = 0.0
    totalWeight = 0.0

    for i = 0 to array.size(tfData) - 1
        data = array.get(tfData, i)
        if data.isValid
            weight = i < array.size(config.tfWeights) ? array.get(config.tfWeights, i) : 0.25
            data.weight := weight
            array.set(tfData, i, data)

            if data.trendStrength > 0
                totalBullWeight += data.trendStrength * weight
            else if data.trendStrength < 0
                totalBearWeight += math.abs(data.trendStrength) * weight

            totalWeight += weight

    bullConfluence = totalWeight > 0 ? (totalBullWeight / totalWeight) * 100.0 : 0.0
    bearConfluence = totalWeight > 0 ? (totalBearWeight / totalWeight) * 100.0 : 0.0

    [bullConfluence, bearConfluence]

// === AUTO-TUNING SYSTEM ===

export calculateAutoTuningParams(float choppiness, float stackStrength, HTFConfig config) =>
    // Adaptive Volume Area Percentage
    baseVaPct = 0.70
    vaPct_eff = choppiness > config.choppyThreshold ? baseVaPct + 0.15 : baseVaPct - (stackStrength / 100.0) * 0.10
    vaPct_eff := math.max(0.50, math.min(0.90, vaPct_eff))

    // Adaptive Epsilon ATR
    baseEpsATR = 0.236
    epsATR_eff = choppiness > config.choppyThreshold ? baseEpsATR * 1.5 : baseEpsATR * 0.8
    epsATR_eff := math.max(0.1, math.min(0.5, epsATR_eff))

    // Adaptive Alpha for smoothing
    baseAlpha = 0.3
    adaptiveAlpha = stackStrength > 70.0 ? baseAlpha * 0.7 : baseAlpha * 1.3
    adaptiveAlpha := math.max(0.1, math.min(0.7, adaptiveAlpha))

    [vaPct_eff, epsATR_eff, adaptiveAlpha]

// === SIGNAL DETECTION ===

export detectStackSignals(HTFStackState state, HTFStackState prevState, HTFConfig config) =>
    // Stack alignment signals
    bullStackSignal = false
    bearStackSignal = false
    stackBreakSignal = false

    // Bullish stack signal
    if state.bullConfluence > config.stackThreshold * 100 and
       (na(prevState) or prevState.bullConfluence <= config.stackThreshold * 100)
        bullStackSignal := true

    // Bearish stack signal
    if state.bearConfluence > config.stackThreshold * 100 and
       (na(prevState) or prevState.bearConfluence <= config.stackThreshold * 100)
        bearStackSignal := true

    // Stack break signal (confluence drops significantly)
    if not na(prevState)
        prevMaxConfluence = math.max(prevState.bullConfluence, prevState.bearConfluence)
        currMaxConfluence = math.max(state.bullConfluence, state.bearConfluence)

        if prevMaxConfluence > 60.0 and currMaxConfluence < 40.0
            stackBreakSignal := true

    [bullStackSignal, bearStackSignal, stackBreakSignal]

// === VISUAL PANEL CREATION ===

export createStackPanel(HTFStackState state, HTFConfig config) =>
    if not config.showStackPanel
        na
    else
        // Delete existing table if it exists
        if not na(state.stackTable)
            table.delete(state.stackTable)

        // Create new table
        position = config.panelPosition == "top_left" ? position.top_left :
                  config.panelPosition == "top_right" ? position.top_right :
                  config.panelPosition == "bottom_left" ? position.bottom_left :
                  position.bottom_right

        stackTable = table.new(position, config.panelCols, config.panelRows + 1,
                              frame_color=color.new(color.gray, 80),
                              border_width=1,
                              bgcolor=color.new(color.white, 95))

        // Header row
        table.cell(stackTable, 0, 0, "HTF STACK",
                  bgcolor=color.new(color.navy, 0), text_color=color.white, text_size=size.small)
        table.cell(stackTable, 1, 0, "TREND",
                  bgcolor=color.new(color.navy, 0), text_color=color.white, text_size=size.small)
        table.cell(stackTable, 2, 0, "STR",
                  bgcolor=color.new(color.navy, 0), text_color=color.white, text_size=size.small)

        // Data rows
        for i = 0 to array.size(state.tfData) - 1
            if i < config.panelRows
                data = array.get(state.tfData, i)
                row = i + 1

                // Timeframe cell
                table.cell(stackTable, 0, row, data.timeframe,
                          text_color=color.black, text_size=size.tiny)

                // Trend direction cell
                trendSymbol = data.trendDirection == "BULL" ? "↑" :
                             data.trendDirection == "BEAR" ? "↓" : "→"
                table.cell(stackTable, 1, row, trendSymbol,
                          bgcolor=data.trendColor, text_color=color.white, text_size=size.small)

                // Strength cell
                strengthText = str.tostring(math.round(data.confidence))
                table.cell(stackTable, 2, row, strengthText,
                          text_color=color.black, text_size=size.tiny)

        stackTable

// === MAIN HTF STACK PROCESSING ===

export processHTFStack(HTFStackState state, HTFConfig config) =>
    // Auto-select timeframes if enabled
    timeframes = config.autoSelectTFs ? getOptimalTimeframes(timeframe.period) : config.timeframes

    // Clear existing TF data
    array.clear(state.tfData)

    // Analyze each timeframe
    for i = 0 to array.size(timeframes) - 1
        if i < config.maxTimeframes
            tf = array.get(timeframes, i)
            tfData = analyzeTrendForTF(tf, config)
            array.push(state.tfData, tfData)

    // Calculate confluence
    [bullConf, bearConf] = calculateStackConfluence(state.tfData, config)
    state.bullConfluence := bullConf
    state.bearConfluence := bearConf
    state.stackStrength := math.max(bullConf, bearConf)

    // Determine stack bias
    if state.bullConfluence > state.bearConfluence + 20.0
        state.stackBias := "BULL"
    else if state.bearConfluence > state.bullConfluence + 20.0
        state.stackBias := "BEAR"
    else
        state.stackBias := "NEUTRAL"

    // Calculate choppiness
    state.choppiness := calculateChoppiness(config.choppinessLength)
    state.isChoppy := state.choppiness > config.choppyThreshold
    state.isTrending := state.choppiness < config.trendingThreshold

    // Determine market regime
    if state.isChoppy
        state.marketRegime := "RANGING"
    else if state.isTrending and state.stackStrength > 60.0
        state.marketRegime := "TRENDING"
    else
        state.marketRegime := "TRANSITION"

    // Auto-tuning parameters
    if config.enableAutoTuning
        [vaPct, epsATR, alpha] = calculateAutoTuningParams(state.choppiness, state.stackStrength, config)
        state.vaPct_eff := vaPct
        state.epsATR_eff := epsATR
        state.adaptiveAlpha := alpha

    // Create visual panel
    state.stackTable := createStackPanel(state, config)

    state

export processHTFStackSignals(HTFStackState state, HTFStackState prevState, HTFConfig config) =>
    [bullSig, bearSig, breakSig] = detectStackSignals(state, prevState, config)
    state.bullStackSignal := bullSig
    state.bearStackSignal := bearSig
    state.stackBreakSignal := breakSig
    state
