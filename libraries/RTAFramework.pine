// ============================================================================
// GENERIC ANALYSIS BASE - Foundation for All Analysis Types
// ============================================================================

// @type Generic analysis result that all specific analysis types extend
export type GenericAnalysis
    // Core Analysis Results
    float totalScore                      // Overall analysis score (-100 to +100)
    float confidence                     // Confidence in analysis (0-100)
    string action                        // "BUY", "SELL", "NEUTRAL", "WAIT"
    string strength                      // "STRONG", "MODERATE", "WEAK"
    string riskLevel                     // "LOW", "MEDIUM", "HIGH", "EXTREME"
    // Factor Breakdown (Extensible)
    map<string, float> factorScores      // Individual factor scores
    map<string, float> factorWeights     // Applied factor weights
    map<string, bool> factorSignals      // Factor signal states
    map<string, string> factorReasons    // Reasoning for each factor
    // Analysis Metadata
    string analysisType                  // "CPM", "WAVE", "FLOW", etc.
    string timeframeAnalyzed            // Primary timeframe analyzed
    int analysisTimestamp               // When analysis was performed
    string marketCondition              // "TRENDING", "RANGING", "VOLATILE"
    // Quality & Performance
    float dataQuality                   // Input data quality score (0-100)
    PerformanceProfile performance      // Analysis performance metrics
    ValidationResult validation         // Analysis validation results
    // Extensible Metadata
    map<string, float> numericData      // Custom numeric data points
    map<string, string> textData        // Custom text data
    map<string, bool> flags             // Custom boolean flags

// @function Create a new generic analysis result
export newGenericAnalysis(string analysisType, string timeframe) =>
    GenericAnalysis.new(totalScore = 0.0, confidence = 0.0, action = "NEUTRAL", strength = "WEAK", riskLevel = "MEDIUM", factorScores = map.new<string, float>(), factorWeights = map.new<string, float>(), factorSignals = map.new<string, bool>(), factorReasons = map.new<string, string>(), analysisType = analysisType, timeframeAnalyzed = timeframe, analysisTimestamp = time, marketCondition = "RANGING", dataQuality = 100.0, performance = newPerformanceProfile(analysisType + "_analysis"), validation = newValidationSuccess(analysisType + "_analysis"), numericData = map.new<string, float>(), textData = map.new<string, string>(), flags = map.new<string, bool>())

// ============================================================================
// CONSENSUS ANALYSIS - Multi-Timeframe Consensus
// ============================================================================

// @type Multi-timeframe consensus analysis data
export type ConsensusData
    // Agreement Metrics
    int agreementCount                // Number of timeframes in agreement
    int totalTimeframes              // Total timeframes analyzed
    float agreementPercentage        // Percentage agreement (0-100)
    bool hasStrongConsensus         // Strong consensus achieved (>80% agreement)
    bool hasMajorityConsensus       // Majority consensus achieved (>60% agreement)
    // Timeframe Breakdown
    string[] agreeingTimeframes     // Timeframes that agree with primary signal
    string[] disagreeingTimeframes  // Timeframes that disagree
    map<string, float> tfScores     // Individual timeframe scores
    map<string, string> tfActions   // Individual timeframe actions
    // Consensus Analysis
    string consensusMode            // Mode used for consensus calculation
    float consensusScore           // Overall consensus score (-100 to +100)
    string consensusAction         // Consensus action recommendation
    string consensusStrength       // "UNANIMOUS", "STRONG", "MODERATE", "WEAK", "CONFLICTED"
    // Weighting Information
    map<string, float> tfWeights   // Timeframe weights used
    bool weightedConsensus         // Whether consensus was weighted
    float weightedScore           // Weighted consensus score
    // Consensus Quality
    float consensusQuality        // Quality of consensus (0-100)
    string consensusReliability   // "HIGH", "MEDIUM", "LOW"
    string[] consensusWarnings    // Consensus warnings or conflicts

// @function Create empty consensus data
export newConsensusData() =>
    ConsensusData.new(agreementCount = 0, totalTimeframes = 0, agreementPercentage = 0.0, hasStrongConsensus = false, hasMajorityConsensus = false, agreeingTimeframes = array.new<string>(), disagreeingTimeframes = array.new<string>(), tfScores = map.new<string, float>(), tfActions = map.new<string, string>(), consensusMode = "SIMPLE", consensusScore = 0.0, consensusAction = "NEUTRAL", consensusStrength = "NONE", tfWeights = map.new<string, float>(), weightedConsensus = false, weightedScore = 0.0, consensusQuality = 0.0, consensusReliability = "LOW", consensusWarnings = array.new<string>())

// ============================================================================
// SIGNAL GENERATION - Trading Signal Results
// ============================================================================

// @type Comprehensive trading signal result
export type SignalResult
    // Basic Signal Classification
    bool strongBuy                      // Strong buy signal detected
    bool buy                           // Buy signal detected
    bool neutral                       // Neutral/hold signal
    bool sell                          // Sell signal detected
    bool strongSell                    // Strong sell signal detected
    // Signal Metrics
    float overallScore                 // Combined signal score (-100 to +100)
    float confidence                   // Signal confidence (0-100)
    string primaryAction               // "STRONG_BUY", "BUY", "NEUTRAL", "SELL", "STRONG_SELL"
    string signalStrength              // "VERY_STRONG", "STRONG", "MODERATE", "WEAK"
    // Signal Genesis
    string signalReason               // Primary reason for signal
    string[] contributingFactors      // Factors that contributed to signal
    map<string, float> factorContributions // Factor contribution weights
    string triggerCondition           // Condition that triggered signal
    // Consensus Information
    ConsensusData consensus           // Multi-timeframe consensus data
    string consensusLevel            // "STRONG", "MODERATE", "WEAK", "NONE"
    bool hasConsensus               // Consensus achieved
    // Risk Assessment
    string riskLevel                 // "LOW", "MEDIUM", "HIGH", "EXTREME"
    float riskRewardRatio           // Estimated risk/reward ratio
    float successProbability        // Estimated success probability (0-100)
    // Timing Information
    int signalTimestamp             // When signal was generated
    string urgency                  // "IMMEDIATE", "SOON", "MODERATE", "LOW"
    int validityPeriod              // How long signal remains valid (bars)
    // Additional Context
    string marketPhase              // "TRENDING", "RANGING", "BREAKOUT", "REVERSAL"
    string[] warningFlags           // Any warning flags
    map<string, string> metadata    // Additional signal metadata

// @function Create a neutral signal result
export newNeutralSignal(string reason = "No clear direction") =>
    SignalResult.new(strongBuy = false, buy = false, neutral = true, sell = false, strongSell = false, overallScore = 0.0, confidence = 50.0, primaryAction = "NEUTRAL", signalStrength = "WEAK", signalReason = reason, contributingFactors = array.new<string>(), factorContributions = map.new<string, float>(), triggerCondition = "NONE", consensus = newConsensusData(), consensusLevel = "NONE", hasConsensus = false, riskLevel = "MEDIUM", riskRewardRatio = 1.0, successProbability = 50.0, signalTimestamp = time, urgency = "LOW", validityPeriod = 10, marketPhase = "RANGING", warningFlags = array.new<string>(), metadata = map.new<string, string>())

// @function Create a buy signal result
export newBuySignal(float score, float confidence, string reason) =>
    signal = newNeutralSignal(reason)
    signal.buy := score >= 50
    signal.strongBuy := score >= 80
    signal.neutral := false
    signal.overallScore := score
    signal.confidence := confidence
    signal.primaryAction := score >= 80 ? "STRONG_BUY" : "BUY"
    signal.signalStrength := score >= 90 ? "VERY_STRONG" :
                             score >= 75 ? "STRONG" :
                             score >= 60 ? "MODERATE" : "WEAK"
    signal.urgency := score >= 85 ? "IMMEDIATE" : score >= 70 ? "SOON" : "MODERATE"
    signal

// @function Create a sell signal result
export newSellSignal(float score, float confidence, string reason) =>
    signal = newNeutralSignal(reason)
    signal.sell := score <= -50
    signal.strongSell := score <= -80
    signal.neutral := false
    signal.overallScore := score
    signal.confidence := confidence
    signal.primaryAction := score <= -80 ? "STRONG_SELL" : "SELL"
    signal.signalStrength := score <= -90 ? "VERY_STRONG" :
                             score <= -75 ? "STRONG" :
                             score <= -60 ? "MODERATE" : "WEAK"
    signal.urgency := score <= -85 ? "IMMEDIATE" : score <= -70 ? "SOON" : "MODERATE"
    signal

// ============================================================================
// MULTI-TIMEFRAME RESULT - Complete Analysis Container
// ============================================================================

// @type Multi-timeframe analysis result container
export type MultiTimeframeResult
    // Core Results
    GenericAnalysis primaryAnalysis      // Primary timeframe analysis
    map<string, GenericAnalysis> tfResults  // Individual timeframe results
    ConsensusData consensus             // Consensus calculation results
    // Aggregated Scores
    float aggregatedScore                  // Weighted aggregated score
    float confidenceScore                  // Overall confidence score
    string dominantAction                  // Dominant action across timeframes
    string consensusStrength               // Consensus strength assessment
    // Analysis Metadata
    string[] analyzedTimeframes           // Successfully analyzed timeframes
    string[] failedTimeframes            // Timeframes that failed analysis
    map<string, string> failureReasons   // Failure reasons by timeframe
    // Performance & Quality
    PerformanceProfile performance       // Overall analysis performance
    ValidationResult validation          // Multi-TF validation results
    float dataQualityScore               // Combined data quality score
    // Configuration Used
    AnalysisConfig config                // Analysis configuration used
    TimeframeConfig tfConfig             // Timeframe configuration used
    int analysisTimestamp                // When analysis was performed

// @function Create new multi-timeframe result
export newMultiTimeframeResult(AnalysisConfig config, TimeframeConfig tfConfig) =>
    MultiTimeframeResult.new(primaryAnalysis = newGenericAnalysis("MULTI_TF", timeframe.period), tfResults = map.new<string, GenericAnalysis>(), consensus = newConsensusData(), aggregatedScore = 0.0, confidenceScore = 0.0, dominantAction = "NEUTRAL", consensusStrength = "NONE", analyzedTimeframes = array.new<string>(), failedTimeframes = array.new<string>(), failureReasons = map.new<string, string>(), performance = newPerformanceProfile("multi_timeframe_analysis"), validation = newValidationSuccess("multi_tf_analysis"), dataQualityScore = 100.0, config = config, tfConfig = tfConfig, analysisTimestamp = time)

// ============================================================================
// UTILITY FUNCTIONS - Analysis Management
// ============================================================================

// @function Get analysis action string
export getAnalysisAction(GenericAnalysis analysis) =>
    if analysis.totalScore >= 70
        "STRONG_BUY"
    else if analysis.totalScore >= 30
        "BUY"
    else if analysis.totalScore >= -30
        "NEUTRAL"
    else if analysis.totalScore >= -70
        "SELL"
    else
        "STRONG_SELL"

// @function Check if analysis is bullish
export isBullish(GenericAnalysis analysis) =>
    analysis.totalScore > 0 and analysis.confidence >= 60

// @function Check if analysis is bearish
export isBearish(GenericAnalysis analysis) =>
    analysis.totalScore < 0 and analysis.confidence >= 60

// @function Get signal summary string
export getSignalSummary(SignalResult signal) =>
    signal.primaryAction + " (" + str.tostring(signal.overallScore, "#.0") + "/" + str.tostring(signal.confidence, "#.0") + "%) - " + signal.signalReason

// @function Check if consensus is strong
export hasStrongConsensus(ConsensusData consensus) =>
    consensus.agreementPercentage >= 80 and consensus.agreementCount >= 3

// @function Get consensus summary
export getConsensusSummary(ConsensusData consensus) =>
    str.tostring(consensus.agreementCount) + "/" + str.tostring(consensus.totalTimeframes) + " TFs (" + str.tostring(consensus.agreementPercentage, "#.0") + "%) - " + consensus.consensusStrength

// @function Check if signal is actionable
export isActionableSignal(SignalResult signal) =>
    signal.primaryAction != "NEUTRAL" and signal.signalStrength != "WEAK" and signal.confidence >= 60 and array.size(signal.warningFlags) <= 1

// @function Get signal color for UI display
export getSignalColor(SignalResult signal) =>
    switch signal.primaryAction
        "STRONG_BUY" => color.new(color.green, 0)
        "BUY" => color.new(color.green, 30)
        "NEUTRAL" => color.new(color.gray, 0)
        "SELL" => color.new(color.red, 30)
        "STRONG_SELL" => color.new(color.red, 0)
        => color.new(color.yellow, 0)


// ============================================================================
// MODULE: DATA_VALIDATION
// ============================================================================

// Data Validation Module - Input validation and sanitization

// ============================================================================
// VALIDATION FUNCTIONS
// ============================================================================

// @function Validate analysis configuration
export validateAnalysisConfig(AnalysisConfig config) =>
    result = newValidationResult()

    // Validate confidence threshold
    if config.minConfidence < 0 or config.minConfidence > 100
        addValidationError(result, "minConfidence", "Must be between 0 and 100")

    if config.signalStrength < 0 or config.signalStrength > 100
        addValidationError(result, "signalStrength", "Must be between 0 and 100")

    // Validate factor weights sum to approximately 1.0
    totalWeight = 0.0
    for i = 0 to array.size(config.activeFactors) - 1
        factor = array.get(config.activeFactors, i)
        if map.contains(config.factorWeights, factor)
            totalWeight := totalWeight + map.get(config.factorWeights, factor)

    if totalWeight < 0.8 or totalWeight > 1.2
        addValidationWarning(result, "factorWeights", "Factor weights should sum to approximately 1.0")

    result

// @function Validate timeframe configuration
export validateTimeframeConfig(TimeframeConfig config) =>
    result = newValidationResult()

    if array.size(config.timeframes) == 0
        addValidationError(result, "timeframes", "At least one timeframe must be specified")

    // Check timeframe weights sum to reasonable values
    totalWeight = 0.0
    for i = 0 to array.size(config.weights) - 1
        weight = array.get(config.weights, i)
        totalWeight := totalWeight + weight

    if totalWeight < 0.8 or totalWeight > 1.2
        addValidationWarning(result, "weights", "Timeframe weights should sum to approximately 1.0")

    result

// @function Validate price data array
export validatePriceData(array<float> prices) =>
    result = newValidationResult()

    if na(prices) or array.size(prices) == 0
        addValidationError(result, "prices", "Price data is empty")
        result
    else
        size = array.size(prices)
        if size < 10
            addValidationWarning(result, "prices", "Price data has fewer than 10 points")

        // Check for invalid values
        invalidCount = 0
        for i = 0 to size - 1
            price = array.get(prices, i)
            if na(price) or price <= 0
                invalidCount += 1

        if invalidCount > 0
            addValidationError(result, "prices", str.tostring(invalidCount) + " invalid price values found")

        result

// @function Sanitize numeric input
export sanitizeFloat(float value, float minVal, float maxVal, float defaultVal) =>
    if na(value) or value < minVal or value > maxVal
        defaultVal
    else
        value

// @function Sanitize integer input
export sanitizeInt(int value, int minVal, int maxVal, int defaultVal) =>
    if na(value) or value < minVal or value > maxVal
        defaultVal
    else
        value

// @function Sanitize array by removing invalid values
export sanitizeFloatArray(array<float> arr) =>
    if na(arr)
        array.new<float>()
    else
        cleaned = array.new<float>()
        for i = 0 to array.size(arr) - 1
            value = array.get(arr, i)
            if not na(value) and value > 0
                array.push(cleaned, value)
        cleaned


// ============================================================================
// MODULE: ERROR_HANDLING
// ============================================================================

// Error Handling Module - Robust error handling with circuit breakers

// ============================================================================
// ERROR HANDLING FUNCTIONS
// ============================================================================

// @function Log error message
export logError(string message) =>
    // In Pine Script, we'll use runtime.error for critical errors
    // For non-critical errors, we could store them in an array
    log_text = "ERROR: " + message + " (Bar: " + str.tostring(bar_index) + ")"
    // Store error for later retrieval instead of throwing
    log_text

// @function Log warning message
export logWarning(string message) =>
    "WARNING: " + message + " (Bar: " + str.tostring(bar_index) + ")"

// @function Safe execute wrapper
export safeExecute(string operationName, bool condition = true) =>
    if condition
        newBoolResult(true, operationName + " completed successfully")
    else
        newBoolResult(false, operationName + " failed")

// @function Circuit breaker pattern
export shouldAllowOperation(int errorCount, int maxErrors = 5) =>
    errorCount < maxErrors

// @function Retry mechanism
export retryOperation(int maxRetries = 3) =>
    // Simple retry counter - in practice would wrap actual operations
    maxRetries > 0


// ============================================================================
// MODULE: MATH_UTILITIES
// ============================================================================

// Math Utilities Module - Enhanced mathematical functions and calculations
// ADVANCED STATISTICAL FUNCTIONS
// Calculate percentile of a value within an array
percentile(array<float> values, float targetValue) =>
    if array.size(values) == 0
        0.0
    else
        count = 0
        total = array.size(values)
        for i = 0 to total - 1
            if array.get(values, i) <= targetValue
                count += 1
        count / total * 100

// Calculate z-score (standard score)
zScore(float value, float mean, float stdDev) =>
    if stdDev == 0
        0.0
    else
        (value - mean) / stdDev

// Calculate standard deviation of an array
standardDeviation(array<float> values) =>
    size = array.size(values)
    if size <= 1
        0.0
    else
        mean = array.avg(values)
        sumSquaredDiff = 0.0
        for i = 0 to size - 1
            diff = array.get(values, i) - mean
            sumSquaredDiff := sumSquaredDiff + (diff * diff)
        math.sqrt(sumSquaredDiff / (size - 1))

// Calculate skewness (measure of asymmetry)
skewness(array<float> values) =>
    size = array.size(values)
    if size < 3
        0.0
    else
        mean = array.avg(values)
        stdDev = standardDeviation(values)
        if stdDev == 0
            0.0
        else
            sumCubedZ = 0.0
            for i = 0 to size - 1
                z = (array.get(values, i) - mean) / stdDev
                sumCubedZ := sumCubedZ + (z * z * z)
            sumCubedZ / size

// Calculate kurtosis (measure of tail heaviness)
kurtosis(array<float> values) =>
    size = array.size(values)
    if size < 4
        0.0
    else
        mean = array.avg(values)
        stdDev = standardDeviation(values)
        if stdDev == 0
            0.0
        else
            sumQuadZ = 0.0
            for i = 0 to size - 1
                z = (array.get(values, i) - mean) / stdDev
                sumQuadZ := sumQuadZ + (z * z * z * z)
            (sumQuadZ / size) - 3.0  // Excess kurtosis

// Calculate correlation coefficient between two arrays
correlation(array<float> x, array<float> y) =>
    sizeX = array.size(x)
    sizeY = array.size(y)
    if sizeX != sizeY or sizeX < 2
        0.0
    else
        meanX = array.avg(x)
        meanY = array.avg(y)
        numerator = 0.0
        sumXX = 0.0
        sumYY = 0.0
        for i = 0 to sizeX - 1
            diffX = array.get(x, i) - meanX
            diffY = array.get(y, i) - meanY
            numerator := numerator + (diffX * diffY)
            sumXX := sumXX + (diffX * diffX)
            sumYY := sumYY + (diffY * diffY)
        denominator = math.sqrt(sumXX * sumYY)
        denominator == 0 ? 0.0 : numerator / denominator
// FINANCIAL MATHEMATICS
// Calculate compound annual growth rate (CAGR)
cagr(float startValue, float endValue, int periods) =>
    if startValue <= 0 or endValue <= 0 or periods <= 0
        0.0
    else
        math.pow(endValue / startValue, 1.0 / periods) - 1.0

// Calculate Sharpe ratio
sharpeRatio(array<float> returns, float riskFreeRate = 0.02) =>
    if array.size(returns) < 2
        0.0
    else
        avgReturn = array.avg(returns)
        stdDev = standardDeviation(returns)
        stdDev == 0 ? 0.0 : (avgReturn - riskFreeRate) / stdDev

// Calculate maximum drawdown
maxDrawdown(array<float> values) =>
    size = array.size(values)
    if size == 0
        0.0
    else
        peak = array.get(values, 0)
        maxDD = 0.0
        for i = 0 to size - 1
            value = array.get(values, i)
            if value > peak
                peak := value
            drawdown = (peak - value) / peak * 100
            if drawdown > maxDD
                maxDD := drawdown
        maxDD

// Calculate Value at Risk (VaR) at given confidence level
valueAtRisk(array<float> returns, float confidenceLevel = 0.95) =>
    size = array.size(returns)
    if size == 0
        0.0
    else
        sortedReturns = array.copy(returns)
        array.sort(sortedReturns, order.ascending)
        index = math.floor((1 - confidenceLevel) * size)
        if index >= size
            array.get(sortedReturns, size - 1)
        else
            array.get(sortedReturns, index)

// Calculate Kelly Criterion for optimal position sizing
kellyCriterion(float winRate, float avgWin, float avgLoss) =>
    if avgLoss == 0 or winRate <= 0 or winRate >= 1
        0.0
    else
        lossRate = 1 - winRate
        (winRate / avgLoss) - (lossRate / avgWin)
// SMOOTHING AND FILTERING
// Exponential moving average with custom alpha
emaCustom(float value, float prevEma, float alpha) =>
    alpha * value + (1 - alpha) * prevEma

// Double exponential smoothing (Holt's method)
doubleExpSmoothing(array<float> values, float alpha = 0.3, float beta = 0.3) =>
    size = array.size(values)
    if size < 2
        array.copy(values)
    else
        smoothed = array.new<float>()
        // Initialize
        s1 = array.get(values, 0)
        b1 = array.get(values, 1) - array.get(values, 0)
        array.push(smoothed, s1)
        for i = 1 to size - 1
            value = array.get(values, i)
            s0 = s1
            b0 = b1
            s1 := alpha * value + (1 - alpha) * (s0 + b0)
            b1 := beta * (s1 - s0) + (1 - beta) * b0
            array.push(smoothed, s1)
        smoothed

// Adaptive smoothing based on volatility
adaptiveSmoothing(array<float> values, int period = 14) =>
    size = array.size(values)
    if size < period
        array.copy(values)
    else
        smoothed = array.new<float>()
        for i = 0 to size - 1
            if i < period - 1
                array.push(smoothed, array.get(values, i))
            else
                // Calculate volatility for adaptive alpha
                subset = array.slice(values, i - period + 1, i + 1)
                volatility = standardDeviation(subset)
                maxVol = array.max(subset) - array.min(subset)
                alpha = maxVol == 0 ? 0.1 : math.min(0.9, volatility / maxVol * 2)

                // Apply adaptive EMA
                if i == period - 1
                    array.push(smoothed, array.avg(subset))
                else
                    prevSmoothed = array.get(smoothed, i - 1)
                    newSmoothed = emaCustom(array.get(values, i), prevSmoothed, alpha)
                    array.push(smoothed, newSmoothed)
        smoothed
// SIGNAL PROCESSING
// Normalize values to 0-1 range
normalize(array<float> values) =>
    if array.size(values) == 0
        values
    else
        minVal = array.min(values)
        maxVal = array.max(values)
        valueRange = maxVal - minVal
        if valueRange == 0
            values
        else
            normalized = array.new<float>()
            for i = 0 to array.size(values) - 1
                normalizedVal = (array.get(values, i) - minVal) / valueRange
                array.push(normalized, normalizedVal)
            normalized

// Z-score normalization (standardization)
standardize(array<float> values) =>
    if array.size(values) < 2
        values
    else
        mean = array.avg(values)
        stdDev = standardDeviation(values)
        if stdDev == 0
            values
        else
            standardized = array.new<float>()
            for i = 0 to array.size(values) - 1
                zScore = (array.get(values, i) - mean) / stdDev
                array.push(standardized, zScore)
            standardized

// Simple linear regression
// Returns [slope, intercept, r_squared]
linearRegression(array<float> x, array<float> y) =>
    sizeX = array.size(x)
    sizeY = array.size(y)
    if sizeX != sizeY or sizeX < 2
        [0.0, 0.0, 0.0]
    else
        meanX = array.avg(x)
        meanY = array.avg(y)
        numerator = 0.0
        denominator = 0.0
        totalSumSquares = 0.0

        for i = 0 to sizeX - 1
            diffX = array.get(x, i) - meanX
            diffY = array.get(y, i) - meanY
            numerator := numerator + (diffX * diffY)
            denominator := denominator + (diffX * diffX)
            totalSumSquares := totalSumSquares + (diffY * diffY)

        slope = denominator == 0 ? 0.0 : numerator / denominator
        intercept = meanY - (slope * meanX)

        // Calculate R-squared
        residualSumSquares = 0.0
        for i = 0 to sizeX - 1
            predicted = slope * array.get(x, i) + intercept
            actual = array.get(y, i)
            residual = actual - predicted
            residualSumSquares := residualSumSquares + (residual * residual)

        rSquared = totalSumSquares == 0 ? 0.0 : 1.0 - (residualSumSquares / totalSumSquares)

        [slope, intercept, rSquared]
// UTILITY FUNCTIONS
// Safe division with default value
safeDivide(float numerator, float denominator, float defaultValue = 0.0) =>
    denominator == 0 ? defaultValue : numerator / denominator

// Clamp value between min and max
clamp(float value, float minVal, float maxVal) =>
    math.max(minVal, math.min(maxVal, value))

// Linear interpolation between two values
lerp(float a, float b, float t) =>
    a + (b - a) * clamp(t, 0.0, 1.0)

// Check if value is within tolerance of target
isNear(float value, float target, float tolerance = 1e-6) =>
    math.abs(value - target) <= tolerance

// Round to specified decimal places
roundTo(float value, int decimalPlaces) =>
    multiplier = math.pow(10, decimalPlaces)
    math.round(value * multiplier) / multiplier

// Calculate percentage change
percentChange(float oldValue, float newValue) =>
    if oldValue == 0
        0.0
    else
        (newValue - oldValue) / math.abs(oldValue) * 100

// Calculate log return
logReturn(float currentPrice, float previousPrice) =>
    if previousPrice <= 0 or currentPrice <= 0
        0.0
    else
        math.log(currentPrice / previousPrice)

// Convert array to string representation
arrayToString(array<float> arr, string separator = ", ", int precision = 2) =>
    size = array.size(arr)
    if size == 0
        "[]"
    else
        result = "["
        for i = 0 to size - 1
            value = array.get(arr, i)
            valueStr = str.tostring(value, "#." + str.repeat("0", precision))
            result := result + (i > 0 ? separator : "") + valueStr
        result + "]"

// Find index of maximum value in array
argMax(array<float> values) =>
    size = array.size(values)
    if size == 0
        -1
    else
        maxIndex = 0
        maxValue = array.get(values, 0)
        for i = 1 to size - 1
            if array.get(values, i) > maxValue
                maxValue := array.get(values, i)
                maxIndex := i
        maxIndex

// Find index of minimum value in array
argMin(array<float> values) =>
    size = array.size(values)
    if size == 0
        -1
    else
        minIndex = 0
        minValue = array.get(values, 0)
        for i = 1 to size - 1
            if array.get(values, i) < minValue
                minValue := array.get(values, i)
                minIndex := i
        minIndex

// Calculate weighted average
weightedAverage(array<float> values, array<float> weights) =>
    sizeValues = array.size(values)
    sizeWeights = array.size(weights)
    if sizeValues != sizeWeights or sizeValues == 0
        0.0
    else
        numerator = 0.0
        denominator = 0.0
        for i = 0 to sizeValues - 1
            value = array.get(values, i)
            weight = array.get(weights, i)
            numerator := numerator + (value * weight)
            denominator := denominator + weight
        denominator == 0 ? 0.0 : numerator / denominator
// DISTANCE AND PROXIMITY FUNCTIONS (Consolidated from duplicated implementations)
// Calculate ATR-normalized distance between two values
export atrDistance(float value1, float value2, float atr) =>
    atr > 0 ? math.abs(value1 - value2) / atr : 0.0

// Calculate percentage-based distance between two values
export percentDistance(float value1, float value2) =>
    if value2 == 0
        0.0
    else
        math.abs(value1 - value2) / math.abs(value2) * 100.0

// Check if value is within ATR-based tolerance of reference
export withinATRTolerance(float value, float reference, float atr, float multiplier = 1.0) =>
    if atr <= 0
        false
    else
        tolerance = atr * multiplier
        math.abs(value - reference) <= tolerance

// Check if value is within percentage tolerance of reference
export withinPercentTolerance(float value, float reference, float percentTolerance) =>
    if reference == 0 or percentTolerance <= 0
        false
    else
        tolerance = math.abs(reference) * (percentTolerance / 100.0)
        math.abs(value - reference) <= tolerance

// Get proximity score (0-1, where 1 = very close)
export proximityScore(float value, float reference, float maxDistance) =>
    if maxDistance <= 0
        0.0
    else
        distance = math.abs(value - reference)
        math.max(0.0, 1.0 - (distance / maxDistance))
// ARRAY UTILITIES (Consolidated implementations)
// Efficient array sorting using Pine Script native sort
// Note: Replaces inefficient bubble sort implementations found in modules
export sortArrayByValue(array<float> values, string sortOrder = "ascending") =>
    if array.size(values) <= 1
        values
    else
        sortedArray = array.copy(values)
        if sortOrder == "ascending"
            array.sort(sortedArray, order.ascending)
        else
            array.sort(sortedArray, order.descending)
        sortedArray

// Safe array average with null handling
export safeArrayAverage(array<float> values) =>
    size = array.size(values)
    if size == 0
        0.0
    else
        total = 0.0
        validCount = 0
        for i = 0 to size - 1
            val = array.get(values, i)
            if not na(val)
                total += val
                validCount += 1
        validCount > 0 ? total / validCount : 0.0


// ============================================================================
// MODULE: FORMAT_HELPERS
// ============================================================================

// Format Helpers Module - Display formatting and string utilities
// NUMBER FORMATTING
// Format number as percentage with specified precision
formatPercent(float value, int precision = 1) =>
    str.tostring(value, "#." + str.repeat("0", precision)) + "%"

// Format number as currency
formatCurrency(float value, string symbol = "$", int precision = 2) =>
    formatted = str.tostring(math.abs(value), "#." + str.repeat("0", precision))
    sign = value < 0 ? "-" : ""
    sign + symbol + formatted

// Format large numbers with K, M, B suffixes
formatLargeNumber(float value, int precision = 1) =>
    absValue = math.abs(value)
    sign = value < 0 ? "-" : ""

    if absValue >= 1e9
        sign + str.tostring(value / 1e9, "#." + str.repeat("0", precision)) + "B"
    else if absValue >= 1e6
        sign + str.tostring(value / 1e6, "#." + str.repeat("0", precision)) + "M"
    else if absValue >= 1e3
        sign + str.tostring(value / 1e3, "#." + str.repeat("0", precision)) + "K"
    else
        str.tostring(value, "#." + str.repeat("0", precision))

// Format number with thousand separators
formatWithSeparators(float value, string separator = ",") =>
    valueStr = str.tostring(math.abs(value), "#")
    length = str.length(valueStr)
    result = ""

    for i = 0 to length - 1
        pos = length - 1 - i
        char = str.substring(valueStr, pos, pos + 1)
        if i > 0 and i % 3 == 0
            result := separator + result
        result := char + result

    (value < 0 ? "-" : "") + result

// Format risk/reward ratio
formatRiskReward(float ratio, int precision = 1) =>
    "1:" + str.tostring(ratio, "#." + str.repeat("0", precision))

// Format time duration in human readable format
formatDuration(int bars, string timeframe = "1") =>
    // Convert based on timeframe
    minutes = switch timeframe
        "1" => bars
        "5" => bars * 5
        "15" => bars * 15
        "30" => bars * 30
        "60" => bars * 60
        "1H" => bars * 60
        "240" => bars * 240
        "4H" => bars * 240
        "1D" => bars * 1440
        => bars

    if minutes < 60
        str.tostring(minutes) + "m"
    else if minutes < 1440
        hours = minutes / 60
        str.tostring(hours, "#.0") + "h"
    else
        days = minutes / 1440
        str.tostring(days, "#.0") + "d"
// SIGNAL FORMATTING
// Format signal strength as text
formatSignalStrength(string strength) =>
    switch strength
        "VERY_STRONG" => "🔴 Very Strong"
        "STRONG" => "🟠 Strong"
        "MODERATE" => "🟡 Moderate"
        "WEAK" => "⚪ Weak"
        => "❓ Unknown"

// Format signal action with emoji
formatSignalAction(string action) =>
    switch action
        "STRONG_BUY" => "🟢 STRONG BUY"
        "BUY" => "🔵 BUY"
        "NEUTRAL" => "⚪ NEUTRAL"
        "SELL" => "🟠 SELL"
        "STRONG_SELL" => "🔴 STRONG SELL"
        => "❓ " + action

// Format risk level with color coding
formatRiskLevel(string riskLevel) =>
    switch riskLevel
        "VERY_LOW" => "🟢 Very Low"
        "LOW" => "🔵 Low"
        "MEDIUM" => "🟡 Medium"
        "HIGH" => "🟠 High"
        "EXTREME" => "🔴 Extreme"
        => "❓ " + riskLevel

// Format confidence score with visual indicator
formatConfidence(float confidence) =>
    bars = math.floor(confidence / 10)
    indicator = str.repeat("█", bars) + str.repeat("░", 10 - bars)
    str.tostring(confidence, "#.0") + "% " + indicator

// Format consensus agreement
formatConsensus(float agreementPercent, int agreeingTF, int totalTF) =>
    emoji = agreementPercent >= 80 ? "🟢" : agreementPercent >= 60 ? "🟡" : agreementPercent >= 40 ? "🟠" : "🔴"
    emoji + " " + str.tostring(agreeingTF) + "/" + str.tostring(totalTF) + " TFs (" + formatPercent(agreementPercent) + ")"
// TABLE FORMATTING
// Create formatted header for display tables
export formatTableHeader(string title, int width = 40) =>
    titleLength = str.length(title)
    // Ensure width is at least large enough for the title, but not too large
    actualWidth = math.max(10, math.min(100, math.max(width, titleLength + 4)))
    padding = math.max(0, actualWidth - titleLength - 2)
    leftPad = math.max(0, math.min(50, padding / 2))
    rightPad = math.max(0, math.min(50, padding - leftPad))
    "┌" + str.repeat("─", actualWidth) + "┐\n" + "│ " + str.repeat(" ", leftPad) + title + str.repeat(" ", rightPad) + "│\n" + "├" + str.repeat("─", actualWidth) + "┤"

// Format table row with key-value pair
export formatTableRow(string key, string value, int width = 40) =>
    keyLength = str.length(key)
    valueLength = str.length(value)
    totalContent = keyLength + valueLength + 3  // 3 for " : "
    // Ensure width is reasonable
    safeWidth = math.max(10, math.min(100, width))

    if totalContent <= safeWidth - 2
        padding = math.max(0, math.min(50, safeWidth - 2 - totalContent))
        "│ " + key + " : " + value + str.repeat(" ", padding) + "│"
    else
        // Truncate if too long
        available = math.max(3, safeWidth - keyLength - 5)  // 5 for "│ ", " : ", "│", min 3 chars
        truncatedValue = str.substring(value, 0, math.max(0, available))
        "│ " + key + " : " + truncatedValue + "│"

// Close table formatting
export formatTableFooter(int width = 40) =>
    safeWidth = math.max(10, math.min(100, width))
    "└" + str.repeat("─", safeWidth) + "┘"
