// MARKET REGIME DETECTION TYPES

export type MarketRegime
    // Trend Classification
    bool isTrending           // Market is trending (ADX > 25)
    bool isRanging           // Market is ranging (ADX < 20)
    bool isTransitioning     // Market is transitioning
    bool isUptrend           // Strong uptrend detected
    bool isDowntrend         // Strong downtrend detected
    bool isNoTrend           // No clear trend
    // Volatility Classification
    bool isHighVol           // High volatility regime
    bool isLowVol            // Low volatility regime
    bool isNormalVol         // Normal volatility
    float volatilityRatio    // ATR ratio vs SMA
    // ADX Values
    float adxValue           // Current ADX value
    float diPlus             // DI+ value
    float diMinus            // DI- value
    // Regime Strings
    string marketRegime      // "Strong Uptrend", "Ranging", etc.
    string volRegime         // "High Vol", "Low Vol", "Normal Vol"
    // Metadata
    int timestamp            // When regime was calculated
export type StopLossLevels
    // Stop Loss Levels
    float stopLossBuy        // Stop loss for long positions
    float stopLossSell       // Stop loss for short positions
    // Take Profit Levels
    float profitTargetBuy    // Take profit for long positions
    float profitTargetSell   // Take profit for short positions
    // Risk Amounts
    float riskAmountBuy      // Risk amount for longs (price distance)
    float riskAmountSell     // Risk amount for shorts (price distance)
    // Entry Zones
    float entryZoneBuyLow    // Entry zone low (pullback entry)
    float entryZoneBuyHigh   // Entry zone high
    float entryZoneSellLow   // Entry zone low for shorts
    float entryZoneSellHigh  // Entry zone high for shorts
    // Parameters Used
    float atrValue           // ATR value used
    float atrMultiplier      // ATR multiplier used
    float riskRewardRatio    // Risk:Reward ratio
    bool useATRStops         // Whether ATR-based stops were used
    // Metadata
    int timestamp            // When levels were calculated
export type PositionSizing
    float positionSizeMultiplier    // Position size multiplier (0.5-2.0)
    float basePositionSize          // Base position size %
    float adjustedPositionSize      // Final adjusted position size %
    // Adjustment Factors
    float volatilityAdjustment      // Adjustment based on volatility
    float scoreAdjustment           // Adjustment based on signal score
    float regimeAdjustment          // Adjustment based on market regime
    // Risk Parameters
    float accountRiskPct            // Account risk percentage
    float maxPositionSize           // Maximum position size allowed
    float minPositionSize           // Minimum position size allowed
    // Context
    string sizingReason             // Reason for sizing decision
    int timestamp                   // When sizing was calculated
export type RiskQuality
    float riskQualityScore          // Risk quality score (0-100)
    string riskQualityGrade         // "EXCELLENT", "GOOD", "FAIR", "POOR"
    color riskQualityColor          // Color for visualization
    // Quality Factors
    bool trendingFavorable          // Trending market (favorable)
    bool volatilityFavorable        // Normal volatility (favorable)
    bool scoreStrengthFavorable     // Strong signal score
    bool riskAmountFavorable        // Risk amount < 2% of price
    // Metadata
    string[] positiveFactors        // Positive risk factors
    string[] negativeFactors        // Negative risk factors
