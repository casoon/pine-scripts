// COLOR FORMATTING
// Get color based on performance value
getPerformanceColor(float value, float neutral = 0.0) =>
    if value > neutral + 20
        color.new(color.green, 0)
    else if value > neutral + 5
        color.new(color.green, 30)
    else if value > neutral - 5
        color.new(color.gray, 0)
    else if value > neutral - 20
        color.new(color.red, 30)
    else
        color.new(color.red, 0)

// Get color based on risk level
getRiskColor(string riskLevel) =>
    switch riskLevel
        "VERY_LOW" => color.new(color.green, 0)
        "LOW" => color.new(color.blue, 0)
        "MEDIUM" => color.new(color.yellow, 0)
        "HIGH" => color.new(color.orange, 0)
        "EXTREME" => color.new(color.red, 0)
        => color.new(color.gray, 0)

// Get color gradient for confidence
getConfidenceColor(float confidence) =>
    if confidence >= 80
        color.new(color.green, 0)
    else if confidence >= 60
        color.new(color.blue, 0)
    else if confidence >= 40
        color.new(color.yellow, 0)
    else
        color.new(color.red, 30)
// TEXT UTILITIES
// Truncate text to specified length
export truncateText(string txt, int maxLength, string suffix = "...") =>
    if str.length(txt) <= maxLength
        txt
    else
        str.substring(txt, 0, maxLength - str.length(suffix)) + suffix

// Pad text to specified width
export padText(string txt, int width, string padChar = " ", string align = "left") =>
    txtLength = str.length(txt)
    if txtLength >= width
        txt
    else
        paddingLength = math.max(0, width - txtLength)
        padding = str.repeat(padChar, paddingLength)
        switch align
            "center" =>
                leftPadLength = math.max(0, (width - txtLength) / 2)
                leftPad = str.repeat(padChar, leftPadLength)
                rightPadLength = math.max(0, width - txtLength - str.length(leftPad))
                rightPad = str.repeat(padChar, rightPadLength)
                leftPad + txt + rightPad
            "right" => padding + txt
            => txt + padding  // left align (default)

// Convert text to title case
export titleCase(string txt) =>
    // Simple title case - capitalize first letter
    if str.length(txt) == 0
        txt
    else
        first = str.upper(str.substring(txt, 0, 1))
        rest = str.lower(str.substring(txt, 1))
        first + rest

// Join array of strings with separator
export joinStrings(array<string> strings, string separator = ", ") =>
    size = array.size(strings)
    if size == 0
        ""
    else if size == 1
        array.get(strings, 0)
    else
        result = array.get(strings, 0)
        for i = 1 to size - 1
            result := result + separator + array.get(strings, i)
        result

